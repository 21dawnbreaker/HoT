// DIAMOND
@compiletime function genDiamond1Item()
    new ItemDefinition(DIAMOND_1_ITEM_ID, ORIGIN_ITEM_ID)
        ..setName("|cffc0c0c0Мутный алмаз|r")
        ..setTooltipBasic("|cffcef8ffМутный алмаз|r")
        ..setTooltipExtended("+3% сопротивления всем видам урона.")
        ..setDescription("+3% сопротивления всем видам урона. |n|n[|cff00ffffСамоцвет|r]")
        ..setLevel(rune)
        ..setLevelUnclassified(rune)
        ..setIncludeAsRandomChoice(true)
        ..setTintingColor1Red(100)
        ..setTintingColor2Green(100)
        ..setTintingColor3Blue(100)
        ..setInterfaceIcon("ReplaceableTextures\\CommandButtons\\BTNDiamonChipped.blp")
        ..setModelUsed("Models\\Item_Gem_Diamond.mdx")
        ..setScalingValue(0.5)
        ..setCanBeDropped(true)
        ..setCanBeSoldByMerchants(true)
        ..setCanBeSoldToMerchants(true)
        ..setAbilities(ALL_RESISTANCE_3_SPELL_ID.toRawCode())
        ..setActivelyUsed(false)
        ..setCooldownGroup(ORIGIN_ITEM_ID.toRawCode())
        ..setClassification(other)
        ..setGoldCost(50)

