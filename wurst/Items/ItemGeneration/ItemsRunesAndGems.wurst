import GemAbilities

public class GemData
    int itemId
    int abilityId
    int upgradedItem
    int powerLvl
    static constant gemDropSound = new SoundDefinition("Sounds/gem.wav", false, true)
    static constant skullDropSound = new SoundDefinition("diablo2skull.wav", false, true)

    construct(int itemId, int abilityId, int powerLvl, int upgradedItem)
        this.itemId = itemId
        this.abilityId = abilityId
        this.upgradedItem = upgradedItem
        this.powerLvl = powerLvl

    static function getRandomGemObjByPowerLvl(LinkedList<GemData> gems, int powerLvl) returns GemData
        var count = 0
        for gem in gems
            if gem.powerLvl == powerLvl
                count++
        let rnd = GetRandomInt(1, count)
        count = 0
        for gem in gems
            if gem.powerLvl == powerLvl
                count++
                if count == rnd
                    return gem
        return null
public constant GEMS = new LinkedList<GemData>
