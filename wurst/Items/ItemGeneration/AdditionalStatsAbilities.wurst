// Создание дамми-способностей
// В самом низу обязательно нужно внести способность в соответствующий dict
// через function fill_dicts() 
// В ином случае способность не будет "зарегистрирована" и выдана предмету


// ALL resistance --------------------------------------------------------------------
public constant ALL_RESISTANCE_3_SPELL_ID = compiletime(ABIL_ID_GEN.next())
public constant ALL_RESISTANCE_5_SPELL_ID = compiletime(ABIL_ID_GEN.next())
