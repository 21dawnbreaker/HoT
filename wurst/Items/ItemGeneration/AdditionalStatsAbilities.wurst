// !
function fill_dicts()
    all_resistance_dict.put(ALL_RESISTANCE_3_SPELL_ID, 3)
    all_resistance_dict.put(ALL_RESISTANCE_5_SPELL_ID, 5)
    all_resistance_dict.put(ALL_RESISTANCE_6_SPELL_ID, 6)
    all_resistance_dict.put(ALL_RESISTANCE_9_SPELL_ID, 9)
    all_resistance_dict.put(ALL_RESISTANCE_10_SPELL_ID, 10)
    all_resistance_dict.put(ALL_RESISTANCE_12_SPELL_ID, 12)
    all_resistance_dict.put(ALL_RESISTANCE_15_SPELL_ID, 15)
    all_resistance_dict.put(ALL_RESISTANCE_20_SPELL_ID, 20)

    magic_resistance_dict.put(MAGIC_RESISTANCE_5_SPELL_ID, 5)
    magic_resistance_dict.put(MAGIC_RESISTANCE_15_SPELL_ID, 15)
    magic_resistance_dict.put(MAGIC_RESISTANCE_20_SPELL_ID, 20)

    physical_resistance_dict.put(PHYSICAL_RESISTANCE_5_SPELL_ID, 5)

    all_amp_dict.put(ALL_AMP_5_SPELL_ID, 5)
    all_amp_dict.put(ALL_AMP_15_SPELL_ID, 15)

    magic_amp_dict.put(MAGIC_AMP_5_SPELL_ID, 5)

    physical_amp_dict.put(PHYSICAL_AMP_5_SPELL_ID, 5)

    vs_elite_amp_dict.put(VS_ELITES_AMP_5_SPELL_ID, 5)
    vs_elite_amp_dict.put(VS_ELITES_AMP_8_SPELL_ID, 8)
    vs_elite_amp_dict.put(VS_ELITES_AMP_15_SPELL_ID, 15)
    vs_elite_amp_dict.put(VS_ELITES_AMP_16_SPELL_ID, 16)
    vs_elite_amp_dict.put(VS_ELITES_AMP_24_SPELL_ID, 24)
    vs_elite_amp_dict.put(VS_ELITES_AMP_32_SPELL_ID, 32)

    vs_undead_amp_dict.put(VS_UNDEAD_AMP_5_SPELL_ID, 5)
    vs_undead_amp_dict.put(VS_UNDEAD_AMP_8_SPELL_ID, 8)
    vs_undead_amp_dict.put(VS_UNDEAD_AMP_12_SPELL_ID, 12)
    vs_undead_amp_dict.put(VS_UNDEAD_AMP_16_SPELL_ID, 16)
    vs_undead_amp_dict.put(VS_UNDEAD_AMP_24_SPELL_ID, 24)
    vs_undead_amp_dict.put(VS_UNDEAD_AMP_32_SPELL_ID, 32)
    vs_undead_amp_dict.put(VS_UNDEAD_AMP_50_SPELL_ID, 50)

    minion_amp_dict.put(MINIONS_AMP_5_SPELL_ID, 5)
    minion_amp_dict.put(MINIONS_AMP_10_SPELL_ID, 10)
    minion_amp_dict.put(MINIONS_AMP_20_SPELL_ID, 20)
    minion_amp_dict.put(MINIONS_AMP_30_SPELL_ID, 30)
    minion_amp_dict.put(MINIONS_AMP_40_SPELL_ID, 40)

    death_disobedience_dict.put(DEATH_DISOBEDIENCE_1_SPELL_ID, 1)

init
    fill_dicts()