@compiletime function genObjAllResistance3()
    new AbilityDefinitionCriticalStrikeItem(ALL_RESISTANCE_3_SPELL_ID)
        ..setChancetoCriticalStrike(1, 0)
        ..setDamageMultiplier(1, 0)

