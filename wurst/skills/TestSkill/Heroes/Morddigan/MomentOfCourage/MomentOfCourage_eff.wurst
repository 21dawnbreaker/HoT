package MomentOfCourage_eff

import ClosureEvents
import ClosureTimers


init
    EventListener.onCast('A02G') (unit caster) ->
        flashEffect("Models/[Wind]Decimate_Q2.mdx", caster.getPos3Real(), 0.75)
        caster.setAnimation("attack")
        doAfter(0.5) -> 
            PauseUnit(caster, false)
            caster.setAnimation("ready")
