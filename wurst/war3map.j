function InitTrig_MomentOfCourage takes nothing returns nothing
    set gg_trg_MomentOfCourage=CreateTrigger()
    call TriggerRegisterUnitEvent(gg_trg_MomentOfCourage, gg_unit_E001_0061, EVENT_UNIT_DAMAGED)
    call TriggerAddCondition(gg_trg_MomentOfCourage, Condition(function Trig_MomentOfCourage_Conditions))
    call TriggerAddAction(gg_trg_MomentOfCourage, function Trig_MomentOfCourage_Actions)
