function Trig_LifeDrain_Func002A takes nothing returns nothing
    if ( Trig_LifeDrain_Func002Func001C() ) then
        if ( Trig_LifeDrain_Func002Func001Func001C() ) then
            call GroupAddUnitSimple(GetEnumUnit(), udg_LifeDrainUG)
            call CreateNUnitsAtLoc(1, 'h00U', GetOwningPlayer(GetTriggerUnit()), udg_LifeDrainLoc, bj_UNIT_FACING)
            call SetUnitPathing(GetLastCreatedUnit(), false)
            call SetUnitPositionLoc(GetLastCreatedUnit(), udg_LifeDrainLoc)
            call UnitAddAbilityBJ('Amrf', GetLastCreatedUnit())
            call SetUnitFlyHeightBJ(GetLastCreatedUnit(), 0.00, 999999.00)
            call IssueTargetOrderBJ(GetLastCreatedUnit(), "drain", GetEnumUnit())
            call UnitApplyTimedLifeBJ(3.00, 'BTLF', GetLastCreatedUnit())
            call GroupAddUnitSimple(GetLastCreatedUnit(), udg_LifeDrainUG_Copy)
            call SetUnitLifeBJ(GetLastCreatedUnit(), 1.00)
        else
        endif
