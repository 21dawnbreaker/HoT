function Trig_ShiadalEnd_Actions takes nothing returns nothing
    call DisableTrigger(gg_trg_InexorableAssaultPeriodic)
    call DisableTrigger(gg_trg_ShiadalPeriodic)
    call GroupRemoveUnitSimple(gg_unit_E002_0526, udg_BossUG)
    call GroupClear(udg_HeroesBossfightUG)
    set udg_Boss[1]=null
    set udg_BossfightShiadal=- 1
