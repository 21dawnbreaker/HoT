//===========================================================================
// Trigger: GUI Init
//
// You can add multiple code version support using the different codex :
// 	→ One codex = One version support = One trigger to load the code properly
// > Turn Enabled and Initially On
//===========================================================================
function Trig_GUI_Init_Actions takes nothing returns nothing
    // Don't edit the top of the file
    call InitHashtableBJ()
    set udg_NSL_GUIHashtable=GetLastCreatedHashtableBJ()
    // -------------------------------------------------
    set udg_NSL_TriggerCheckLoad=gg_trg_GUI_AllowPlayerLoad
    set udg_NSL_TriggerCheckSave=gg_trg_GUI_AllowPlayerSave
    set udg_NSL_TriggerExecutorSave=gg_trg_GUI_Save
    // -------------------------------------------------
    // ↓↓↓ Edit starting from here ↓↓↓
    // -------------------------------------------------
    // Register codex
    set udg_NSL_CodexVersion=1
    set udg_NSL_CodexTrigger=gg_trg_GUI_Load
    call TriggerExecute(gg_trg_GUI_Register_Codex)
    // Register codex
    set udg_NSL_CodexVersion=2
    set udg_NSL_CodexTrigger=gg_trg_GUI_Load
    call TriggerExecute(gg_trg_GUI_Register_Codex)
endfunction

