function InitTrig_Alliance takes nothing returns nothing
    set gg_trg_Alliance=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Alliance, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_Alliance, Condition(function Trig_Alliance_Conditions))
    call TriggerAddAction(gg_trg_Alliance, function Trig_Alliance_Actions)
