function Trig_CharityPeriodic_Func001Func001Func001Func004C takes nothing returns boolean
    if ( ( GetUnitAbilityLevelSwapped('A07Y', GetEnumUnit()) > 1 ) ) then
        return true
    endif
    if ( ( GetUnitAbilityLevelSwapped('A07Z', GetEnumUnit()) > 1 ) ) then
        return true
    endif
    if ( ( GetUnitRace(GetEnumUnit()) == RACE_DEMON ) ) then
        return true
    endif
    return false
endfunction

function Trig_CharityPeriodic_Func001Func001Func001C takes nothing returns boolean
    if ( not Trig_CharityPeriodic_Func001Func001Func001Func004C() ) then
        return false
    endif
    return true
endfunction

