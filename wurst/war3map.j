function Trig_TomeOfAlignment_Actions takes nothing returns nothing
    if ( Trig_TomeOfAlignment_Func001C() ) then
        if ( Trig_TomeOfAlignment_Func001Func001C() ) then
            set bj_forLoopAIndex=1
            set bj_forLoopAIndexEnd=udg_HeroNumber
            loop
                exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
                if ( Trig_TomeOfAlignment_Func001Func001Func001Func001C() ) then
                    set udg_Karma[GetForLoopIndexA()]=( udg_Karma[GetForLoopIndexA()] + 1 )
                    set udg_KarmaU=GetTriggerUnit()
                    call TriggerExecute(gg_trg_KarmaSystem)
                    set udg_KarmaU=null
                else
                endif
                set bj_forLoopAIndex=bj_forLoopAIndex + 1
            endloop
        else
        endif
    else
    endif
    if ( Trig_TomeOfAlignment_Func002C() ) then
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=udg_HeroNumber
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            set udg_tempLoc=GetUnitLoc(udg_Hero[GetForLoopIndexA()])
            set udg_Karma[GetForLoopIndexA()]=( udg_Karma[GetForLoopIndexA()] + 1 )
            set udg_KarmaU=udg_Hero[GetForLoopIndexA()]
            call TriggerExecute(gg_trg_KarmaSystem)
            set udg_KarmaU=null
            call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\Human\\HolyBolt\\HolyBoltSpecialArt.mdl")
            call DestroyEffectBJ(GetLastCreatedEffectBJ())
            call RemoveLocation(udg_tempLoc)
            set bj_forLoopAIndex=bj_forLoopAIndex + 1
        endloop
    else
    endif
    if ( Trig_TomeOfAlignment_Func003C() ) then
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=udg_HeroNumber
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            if ( Trig_TomeOfAlignment_Func003Func001Func001C() ) then
                set udg_Karma[GetForLoopIndexA()]=( udg_Karma[GetForLoopIndexA()] - 1 )
                set udg_KarmaU=GetTriggerUnit()
                call TriggerExecute(gg_trg_KarmaSystem)
                set udg_KarmaU=null
            else
            endif
            set bj_forLoopAIndex=bj_forLoopAIndex + 1
        endloop
    else
    endif
endfunction

