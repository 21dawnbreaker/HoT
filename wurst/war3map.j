//===========================================================================
function Trig_Judgement_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A02N' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Judgement_Func003A takes nothing returns nothing
    call UnitRemoveAbilityBJ('A024', GetEnumUnit())
    call UnitRemoveAbilityBJ('A025', GetEnumUnit())
    call UnitRemoveAbilityBJ('A026', GetEnumUnit())
    call UnitRemoveAbilityBJ('A027', GetEnumUnit())
    call UnitRemoveAbilityBJ('A028', GetEnumUnit())
endfunction

function Trig_Judgement_Func010Func001C takes nothing returns boolean
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(GetTriggerUnit())) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Judgement_Func010A takes nothing returns nothing
    if ( Trig_Judgement_Func010Func001C() ) then
        call UnitDamageTargetBJ(GetTriggerUnit(), GetEnumUnit(), ( ( 2.00 * I2R(GetUnitAbilityLevelSwapped('A02N', GetTriggerUnit())) ) * ( I2R(GetHeroStatBJ(bj_HEROSTAT_STR, GetTriggerUnit(), true)) + I2R(GetHeroStatBJ(bj_HEROSTAT_INT, GetTriggerUnit(), true)) ) ), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_MAGIC)
    else
    endif
endfunction

function Trig_Judgement_Func016A takes nothing returns nothing
    call UnitRemoveAbilityBJ('A024', GetEnumUnit())
    call UnitRemoveAbilityBJ('A025', GetEnumUnit())
    call UnitRemoveAbilityBJ('A026', GetEnumUnit())
    call UnitRemoveAbilityBJ('A027', GetEnumUnit())
    call UnitRemoveAbilityBJ('A028', GetEnumUnit())
endfunction

function Trig_Judgement_Actions takes nothing returns nothing
    call DestroyEffectBJ(udg_SacredGroundEff)
    call BlzUnitHideAbility(GetTriggerUnit(), 'A023', true)
    call ForGroupBJ(udg_SacredGroundGroup, function Trig_Judgement_Func003A)
    call GroupRemoveGroup(udg_SacredGroundGroup, udg_SacredGroundGroup)
    call RemoveLocation(udg_SacredGround)
    set udg_SacredGround=GetSpellTargetLoc()
    call AddSpecialEffectLocBJ(udg_SacredGround, "Judgement NoHive.mdx")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call TriggerSleepAction(0.80)
    call ForGroupBJ(GetUnitsInRangeOfLocAll(300.00, udg_SacredGround), function Trig_Judgement_Func010A)
    call PlaySoundAtPointBJ(gg_snd_ResurrectTarget, 100, udg_SacredGround, 0)
    call AddSpecialEffectLocBJ(udg_SacredGround, "BlessedField.mdx")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call EnableTrigger(gg_trg_SacredGroundPeriodic)
    call TriggerSleepAction(5.00)
    call ForGroupBJ(udg_SacredGroundGroup, function Trig_Judgement_Func016A)
    call GroupRemoveGroup(udg_SacredGroundGroup, udg_SacredGroundGroup)
    call DisableTrigger(gg_trg_SacredGroundPeriodic)
    call DestroyEffectBJ(udg_SacredGroundEff)
    call RemoveLocation(udg_SacredGround)
    call BlzUnitHideAbility(GetTriggerUnit(), 'A023', false)
endfunction

