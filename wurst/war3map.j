//===========================================================================
// Trigger: Castling
//===========================================================================
function Trig_Castling_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A05K' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Castling_Func005C takes nothing returns boolean
    if ( not ( UnitHasBuffBJ(udg_CastlingT1, 'B011') == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Castling_Actions takes nothing returns nothing
    set udg_CastlingT1=GetSpellTargetUnit()
    call BlzUnitHideAbility(GetTriggerUnit(), 'A05K', true)
    call UnitAddAbilityBJ('A05L', GetTriggerUnit())
    call TriggerSleepAction(9.00)
    if ( Trig_Castling_Func005C() ) then
        set udg_CastlingT1=null
        call UnitRemoveAbilityBJ('A05L', GetTriggerUnit())
        call BlzUnitHideAbility(GetTriggerUnit(), 'A05K', false)
    else
    endif
endfunction

//===========================================================================
function InitTrig_Castling takes nothing returns nothing
    set gg_trg_Castling=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Castling, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_Castling, Condition(function Trig_Castling_Conditions))
    call TriggerAddAction(gg_trg_Castling, function Trig_Castling_Actions)
endfunction

//===========================================================================
// Trigger: Castling2
//===========================================================================
function Trig_Castling2_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A05L' ) ) then
        return false
    endif
    if ( not ( UnitHasBuffBJ(udg_CastlingT1, 'B011') == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Castling2_Func016C takes nothing returns boolean
    if ( not ( IsUnitAlly(udg_CastlingT1, GetOwningPlayer(GetTriggerUnit())) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Castling2_Func017C takes nothing returns boolean
    if ( not ( IsUnitAlly(udg_CastlingT2, GetOwningPlayer(GetTriggerUnit())) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Castling2_Actions takes nothing returns nothing
    set udg_CastlingT2=GetSpellTargetUnit()
    set udg_tempLoc=GetUnitLoc(udg_CastlingT2)
    set udg_tempLoc2=GetUnitLoc(udg_CastlingT1)
    call SetUnitPathing(udg_CastlingT1, false)
    call SetUnitPathing(udg_CastlingT2, false)
    call SetUnitPositionLoc(udg_CastlingT1, udg_tempLoc)
    call AddSpecialEffectLocBJ(udg_tempLoc, "Flamestrike Starfire I.mdx")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 0.50)
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call SetUnitPositionLoc(udg_CastlingT2, udg_tempLoc2)
    call AddSpecialEffectLocBJ(udg_tempLoc2, "Flamestrike Starfire I.mdx")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 0.50)
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call RemoveLocation(udg_tempLoc)
    call RemoveLocation(udg_tempLoc2)
    if ( Trig_Castling2_Func016C() ) then
        set udg_tempLoc=GetUnitLoc(udg_CastlingT1)
        call CreateNUnitsAtLoc(1, 'h00L', GetOwningPlayer(gg_unit_H00D_0059), udg_tempLoc, bj_UNIT_FACING)
        call IssueTargetOrderBJ(GetLastCreatedUnit(), "faeriefire", udg_CastlingT1)
        call UnitApplyTimedLifeBJ(2.00, 'BTLF', GetLastCreatedUnit())
        call RemoveLocation(udg_tempLoc)
    else
    endif
    if ( Trig_Castling2_Func017C() ) then
        set udg_tempLoc2=GetUnitLoc(udg_CastlingT2)
        call CreateNUnitsAtLoc(1, 'h00L', GetOwningPlayer(gg_unit_H00D_0059), udg_tempLoc2, bj_UNIT_FACING)
        call IssueTargetOrderBJ(GetLastCreatedUnit(), "faeriefire", udg_CastlingT2)
        call UnitApplyTimedLifeBJ(2.00, 'BTLF', GetLastCreatedUnit())
        call RemoveLocation(udg_tempLoc2)
    else
    endif
    call SetUnitPathing(udg_CastlingT1, true)
    call SetUnitPathing(GetSpellTargetUnit(), true)
    call UnitRemoveBuffBJ('B011', udg_CastlingT1)
    call UnitRemoveBuffBJ('B011', GetSpellTargetUnit())
    set udg_CastlingT1=null
    call UnitRemoveAbilityBJ('A05L', GetTriggerUnit())
    call BlzUnitHideAbility(GetTriggerUnit(), 'A05K', false)
endfunction

//===========================================================================
function InitTrig_Castling2 takes nothing returns nothing
    set gg_trg_Castling2=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Castling2, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_Castling2, Condition(function Trig_Castling2_Conditions))
    call TriggerAddAction(gg_trg_Castling2, function Trig_Castling2_Actions)
endfunction

