    if ( not ( GetOwningPlayer(GetBuyingUnit()) == GetOwningPlayer(GetEnumUnit()) ) ) then
        return false
    endif
    if ( not ( GetRandomInt(1, 4) == 1 ) ) then
        return false
    endif
    return true
endfunction

