        call AddSpecialEffectTargetUnitBJ("chest", GetEnumUnit(), "Objects\\Spawnmodels\\Orc\\Orcblood\\BattrollBlood.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
    else
    endif
endfunction

function Trig_RandomImpalesPeriodicDifficulty_Actions takes nothing returns nothing
    set udg_RandomImpalesInt=( udg_RandomImpalesInt + 1 )
    if ( Trig_RandomImpalesPeriodicDifficulty_Func003C() ) then
        set udg_RandomImpalesInt=1
    else
    endif
    set udg_RandomImpaleLoc[udg_RandomImpalesInt]=PolarProjectionBJ(GetUnitLoc(GroupPickRandomUnit(GetUnitsInRectMatching(gg_rct_MainBossLoc, Condition(function Trig_RandomImpalesPeriodicDifficulty_Func004002001001001002)))), GetRandomReal(0, 500.00), GetRandomDirectionDeg())
    call AddSpecialEffectLocBJ(udg_RandomImpaleLoc[udg_RandomImpalesInt], "Skill_Indicator_Circle.mdx")
    set udg_RandomImpaleEff1[udg_RandomImpalesInt]=GetLastCreatedEffectBJ()
    call TriggerSleepAction(1.40)
    call DestroyEffectBJ(udg_RandomImpaleEff1[udg_RandomImpalesInt])
    call AddSpecialEffectLocBJ(udg_RandomImpaleLoc[udg_RandomImpalesInt], "Abilities\\Spells\\Undead\\Impale\\ImpaleHitTarget.mdl")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 2.00)
    call BlzSetSpecialEffectYaw(GetLastCreatedEffectBJ(), Deg2Rad(GetRandomDirectionDeg()))
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call ForGroupBJ(GetUnitsInRangeOfLocAll(100.00, udg_RandomImpaleLoc[udg_RandomImpalesInt]), function Trig_RandomImpalesPeriodicDifficulty_Func014A)
    call RemoveLocation(udg_RandomImpaleLoc[udg_RandomImpalesInt])
endfunction

