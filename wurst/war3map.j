//===========================================================================
// Trigger: GetMainSelectedUnit
//===========================================================================
//===========================================================================
// Trigger: UI
//
// 36481‬
//===========================================================================

//===========================================================================
// Trigger: Save Profiles
//
// > Can be deleted → Enable for testing purposes
// > To trigger a manual save or manual load use :
// 	> Set two variable : ManualPlayer and ManualSaveName
// 	> Run the trigger
// > Can be deleted if you use `NSL_UseSimpleSaveLoad = true`
//===========================================================================
function Trig_Save_Profiles_Func002A takes nothing returns nothing
    set udg_NSL_ManualPlayer=GetEnumPlayer()
    set udg_NSL_ManualSaveName=GetPlayerName(GetEnumPlayer())
    set udg_tempInt=( udg_tempInt + 1 )
    call MultiboardSetItemValueBJ(udg_Multiboard1, 4, udg_tempInt, I2S(udg_player_rooms_normal[GetConvertedPlayerId(GetEnumPlayer())]))
    call MultiboardSetItemValueBJ(udg_Multiboard1, 5, udg_tempInt, I2S(udg_player_rooms_nightmare[GetConvertedPlayerId(GetEnumPlayer())]))
    call TriggerExecute(gg_trg_GUI_Manual_Save)
endfunction

function Trig_Save_Profiles_Actions takes nothing returns nothing
    set udg_tempInt=1
    call ForForce(udg_PlayerGroup, function Trig_Save_Profiles_Func002A)
    set udg_tempInt=0
endfunction

//===========================================================================
function InitTrig_Save_Profiles takes nothing returns nothing
    set gg_trg_Save_Profiles=CreateTrigger()
    call TriggerAddAction(gg_trg_Save_Profiles, function Trig_Save_Profiles_Actions)
endfunction

