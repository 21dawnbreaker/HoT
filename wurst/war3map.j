    if ( Trig_RuneOfMightyWind_Func002C() ) then
        call SetUnitManaBJ(GetSpellTargetUnit(), ( ( GetUnitStateSwap(UNIT_STATE_MANA, GetSpellTargetUnit()) + 20.00 ) + ( 10.00 * I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) ) ))
    else
    endif
