function Trig_DefenseStaff_Actions takes nothing returns nothing
    call SetUnitLifePercentBJ(GetTriggerUnit(), ( GetUnitLifePercent(GetTriggerUnit()) - 25.00 ))
    call GroupClear(udg_DefenseStaffUG)
    set udg_tempInt=0
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=udg_HeroNumber
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        set udg_DefenseStaffReal[GetForLoopIndexA()]=( GetUnitStateSwap(UNIT_STATE_MAX_LIFE, GetTriggerUnit()) * 0.50 )
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    call ForGroupBJ(udg_HeroesGroup, function Trig_DefenseStaff_Func005A)
endfunction

