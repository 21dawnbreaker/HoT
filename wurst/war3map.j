// Trigger: Shrine
//===========================================================================
function Trig_Shrine_Conditions takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetSoldUnit()) == 'o02G' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Shrine_Func007Func006Func001C takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetEnumUnit()) != 'H004' ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( IsUnitAlly(GetEnumUnit(), GetOwningPlayer(GetBuyingUnit())) == true ) ) then
        return false
    endif
    if ( not ( GetOwningPlayer(GetEnumUnit()) != Player(PLAYER_NEUTRAL_PASSIVE) ) ) then
        return false
    endif
    return true
endfunction

function Trig_Shrine_Func007Func006A takes nothing returns nothing
    if ( Trig_Shrine_Func007Func006Func001C() ) then
        call SetUnitLifePercentBJ(GetEnumUnit(), 100)
        call SetUnitManaPercentBJ(GetEnumUnit(), 100)
        call AddSpecialEffectTargetUnitBJ("origin", GetEnumUnit(), "Abilities\\Spells\\Items\\AIma\\AImaTarget.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
    else
    endif
endfunction

