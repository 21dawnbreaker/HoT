//===========================================================================
function Trig_Retribution_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A015' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Retribution_Func010Func001Func001C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()) == 3 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Retribution_Func010Func001C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()) == 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Retribution_Func010C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Retribution_Actions takes nothing returns nothing
    call PlaySoundOnUnitBJ(gg_snd_ResurrectTarget, 100, gg_unit_H00N_0277)
    call EnableTrigger(gg_trg_RetributionCheck)
    set udg_RetributionIsOn=1
    call SetPlayerAbilityAvailableBJ(false, 'A04K', GetOwningPlayer(GetTriggerUnit()))
    call UnitRemoveAbilityBJ('A04L', gg_unit_H00N_0277)
    call UnitAddAbilityBJ('A04O', gg_unit_H00N_0277)
    call SetUnitAbilityLevelSwapped('A04O', gg_unit_H00N_0277, udg_BladeOfJusticeLvl2)
    set udg_BladeOfRetributionLvl=GetUnitAbilityLevelSwapped('A04O', gg_unit_H00N_0277)
    call PlaySoundBJ(gg_snd_ArthasYesAttack5)
    if ( Trig_Retribution_Func010C() ) then
        call UnitAddAbilityBJ('A021', GetTriggerUnit())
    else
        if ( Trig_Retribution_Func010Func001C() ) then
            call UnitAddAbilityBJ('A02C', GetTriggerUnit())
        else
            if ( Trig_Retribution_Func010Func001Func001C() ) then
                call UnitAddAbilityBJ('A04P', GetTriggerUnit())
            else
            endif
        endif
    endif
endfunction

//===========================================================================
function InitTrig_Retribution takes nothing returns nothing
    set gg_trg_Retribution=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Retribution, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_Retribution, Condition(function Trig_Retribution_Conditions))
    call TriggerAddAction(gg_trg_Retribution, function Trig_Retribution_Actions)
endfunction

