        call CreateTextTagUnitBJ(( udg_MutagenText_Named[GetRandomInt(0, 3)] + GetUnitName(udg_MutagenHero) ), udg_MutagenEiramonta, 0, 10, 100, 100, 100, 0)
    else
        call CreateTextTagUnitBJ(( udg_MutagenText[GetRandomInt(0, 9)] + "" ), udg_MutagenEiramonta, 0, 10, 100, 100, 100, 0)
