function Trig_Warstomp_Func003Func002A takes nothing returns nothing
    if ( Trig_Warstomp_Func003Func002Func001C() ) then
        set udg_KBA_Caster=GetTriggerUnit()
        set udg_KBA_TargetUnit=GetEnumUnit()
        set udg_KBA_Level=1
