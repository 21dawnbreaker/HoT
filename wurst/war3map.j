//===========================================================================
// Trigger: CheckPlayerFoodLimitFunc
//
// expects nothing
//===========================================================================
function Trig_CheckPlayerFoodLimitFunc_Func001Func003Func001C takes nothing returns boolean
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_CheckPlayerFoodLimitFunc_Func001Func003A takes nothing returns nothing
    if ( Trig_CheckPlayerFoodLimitFunc_Func001Func003Func001C() ) then
        set udg_food_per_player_int[GetConvertedPlayerId(udg_tempPlayer)]=( udg_food_per_player_int[GetConvertedPlayerId(udg_tempPlayer)] + GetUnitFoodUsed(GetEnumUnit()) )
    else
    endif
endfunction

function Trig_CheckPlayerFoodLimitFunc_Func001Func004001002 takes nothing returns boolean
    return ( GetUnitFoodUsed(GetFilterUnit()) > 0 )
endfunction

function Trig_CheckPlayerFoodLimitFunc_Func001Func004Func001C takes nothing returns boolean
    if ( not ( GetPlayerState(udg_tempPlayer, PLAYER_STATE_RESOURCE_FOOD_CAP) < udg_food_per_player_int[GetConvertedPlayerId(udg_tempPlayer)] ) ) then
        return false
    endif
    return true
endfunction

function Trig_CheckPlayerFoodLimitFunc_Func001Func004A takes nothing returns nothing
    if ( Trig_CheckPlayerFoodLimitFunc_Func001Func004Func001C() ) then
        set udg_food_per_player_int[GetConvertedPlayerId(udg_tempPlayer)]=( udg_food_per_player_int[GetConvertedPlayerId(udg_tempPlayer)] - GetUnitFoodUsed(GetEnumUnit()) )
        set udg_tempLoc=GetUnitLoc(GetEnumUnit())
        call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\Human\\MassTeleport\\MassTeleportTarget.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call RemoveLocation(udg_tempLoc)
        call RemoveUnit(GetEnumUnit())
    else
    endif
endfunction

function Trig_CheckPlayerFoodLimitFunc_Func001A takes nothing returns nothing
    set udg_tempPlayer=GetEnumPlayer()
    set udg_food_per_player_int[GetConvertedPlayerId(udg_tempPlayer)]=0
    call ForGroupBJ(GetUnitsOfPlayerAll(udg_tempPlayer), function Trig_CheckPlayerFoodLimitFunc_Func001Func003A)
    call ForGroupBJ(GetUnitsOfPlayerMatching(udg_tempPlayer, Condition(function Trig_CheckPlayerFoodLimitFunc_Func001Func004001002)), function Trig_CheckPlayerFoodLimitFunc_Func001Func004A)
endfunction

function Trig_CheckPlayerFoodLimitFunc_Actions takes nothing returns nothing
    call ForForce(udg_PlayerGroup, function Trig_CheckPlayerFoodLimitFunc_Func001A)
endfunction

//===========================================================================
function InitTrig_CheckPlayerFoodLimitFunc takes nothing returns nothing
    set gg_trg_CheckPlayerFoodLimitFunc=CreateTrigger()
    call TriggerAddAction(gg_trg_CheckPlayerFoodLimitFunc, function Trig_CheckPlayerFoodLimitFunc_Actions)
endfunction

//===========================================================================
// Trigger: DisobidienceOfDeathResAndRemove
//===========================================================================
function Trig_DisobidienceOfDeathResAndRemove_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A01P' ) ) then
        return false
    endif
    return true
endfunction

function Trig_DisobidienceOfDeathResAndRemove_Func001Func001C takes nothing returns boolean
    if ( not ( GetUnitStateSwap(UNIT_STATE_LIFE, GetEnumUnit()) < 2.00 ) ) then
        return false
    endif
    if ( not ( GetOwningPlayer(GetEnumUnit()) == GetOwningPlayer(GetTriggerUnit()) ) ) then
        return false
    endif
    return true
endfunction

function Trig_DisobidienceOfDeathResAndRemove_Func001A takes nothing returns nothing
    if ( Trig_DisobidienceOfDeathResAndRemove_Func001Func001C() ) then
        call AddSpecialEffectLocBJ(GetUnitLoc(GetTriggerUnit()), "Stormfall.mdx")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call ReviveHeroLoc(GetEnumUnit(), GetUnitLoc(GetEnumUnit()), false)
        call PauseUnitBJ(false, udg_backpack_by_player[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])
        call SetUnitLifePercentBJ(GetEnumUnit(), 100.00)
        call SetUnitManaPercentBJ(GetEnumUnit(), 100.00)
        call GroupRemoveUnitSimple(GetTriggerUnit(), udg_disobidience_of_deathUG[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])
        call RemoveUnit(GetTriggerUnit())
    else
    endif
endfunction

function Trig_DisobidienceOfDeathResAndRemove_Func003C takes nothing returns boolean
    if ( not ( udg_game_over_incoming == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_DisobidienceOfDeathResAndRemove_Actions takes nothing returns nothing
    call ForGroupBJ(udg_HeroesGroup, function Trig_DisobidienceOfDeathResAndRemove_Func001A)
    // -
    if ( Trig_DisobidienceOfDeathResAndRemove_Func003C() ) then
        set udg_game_over_incoming=false
        call CinematicFadeBJ(bj_CINEFADETYPE_FADEIN, 1.00, "ReplaceableTextures\\CameraMasks\\Black_mask.blp", 0, 0, 0, 0)
        call EndThematicMusicBJ()
        call SetMusicVolumeBJ(100.00)
        set udg_musicOn=0
        call EnableTrigger(gg_trg_MusicEnd)
        call EnableTrigger(gg_trg_BossMusicTimer)
        call EnableTrigger(gg_trg_BossMusicHeroes)
        call EnableTrigger(gg_trg_BossMusicHeroesKilling)
        call EnableTrigger(gg_trg_BossMusicBoss)
        call DisableTrigger(gg_trg_GameOverIncoming)
        call DisableTrigger(gg_trg_GameOver)
        // -
        call TriggerExecute(gg_trg_MusicEnd)
        call TriggerExecute(gg_trg_BossMusicTimer)
    else
    endif
endfunction

//===========================================================================
function InitTrig_DisobidienceOfDeathResAndRemove takes nothing returns nothing
    set gg_trg_DisobidienceOfDeathResAndRemove=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_DisobidienceOfDeathResAndRemove, EVENT_PLAYER_UNIT_SPELL_EFFECT)
