//===========================================================================
function Trig_TerrorMove_Func001Func001C takes nothing returns boolean
    if ( not ( UnitHasBuffBJ(GetEnumUnit(), 'B00J') == true ) ) then
        return false
    endif
    if ( not ( GetUnitAbilityLevelSwapped('A082', GetEnumUnit()) < 7 ) ) then
        return false
    endif
    return true
endfunction

function Trig_TerrorMove_Func001A takes nothing returns nothing
    if ( Trig_TerrorMove_Func001Func001C() ) then
        set udg_tempLoc=GetUnitLoc(GetEnumUnit())
        call IssuePointOrderLocBJ(GetEnumUnit(), "move", PolarProjectionBJ(GetUnitLoc(GetEnumUnit()), 256, AngleBetweenPoints(udg_TerrorLoc, udg_tempLoc)))
        call RemoveLocation(udg_tempLoc)
    else
        call UnitRemoveAbilityBJ('Abun', GetEnumUnit())
        call GroupRemoveUnitSimple(GetEnumUnit(), udg_TerrorUG)
    endif
endfunction

function Trig_TerrorMove_Actions takes nothing returns nothing
    call ForGroupBJ(udg_TerrorUG, function Trig_TerrorMove_Func001A)
endfunction

