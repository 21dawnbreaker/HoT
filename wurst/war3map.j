//library NSLSaveLoadExecutor:
    
    function NSLSaveLoadExecutor__LoadSaveSlot takes player p,string charId returns nothing
        local string s
        local integer user= (GetPlayerId((p))) // INLINED!!
        
        if ( not (StringLength((s__File_readEx(s__File_open(((NSL_FolderName + "\\SaveChar_" + ((charId)) + ".pld"))),true))) > 1) ) then // INLINED!!
            call DisplayTimedTextToPlayer(Player((s__User_id[user] )), 0, 0, 5.0, ( "|cffff3333[Load Error]|r Did not find any save data.")) // INLINED!!
            return
        elseif ( NSL_PlayerLoading[s__User_id[user]] ) then
        else
            set NSL_PlayerLoading[s__User_id[user]]=true
            set s=(s__SaveFile_getLines((charId) , 1 , false)) // INLINED!!
            if ( GetLocalPlayer() == p ) then
                call SyncString(s)
            endif
        endif
    endfunction

    function NSLSaveLoadExecutor__OnPlayerCodeGenerated takes integer player_id,string generated_code returns nothing
        local string charId= NSL_PlayerCharId[player_id]
		call s__SaveFile_create(Player(player_id) , charId , charId , generated_code)
        if ( player_id == GetPlayerId(GetLocalPlayer()) ) then
        endif
        
        call FlushChildHashtable(udg_NSL_GUIHashtable, player_id + 1)
    endfunction
    
    function NSLSaveLoadExecutor__CheckSaveCompleted takes nothing returns nothing
        if ( not udg_NSL_AllowPlayerSave ) then
            call DisplayTimedTextToPlayer(Player((GetPlayerId(udg_NSL_AllowCheckPlayer) )), 0, 0, 5.0, ( "|cffff3333[Save Error]|r You are not allowed to save.")) // INLINED!!
            return
        endif
        call NSLImpl_SavePlayer(GetPlayerId(udg_NSL_AllowCheckPlayer) , s__NSL_Code_create_save(GetPlayerId(udg_NSL_AllowCheckPlayer) , (1)))
        
        set udg_NSL_EventCheckSaveCompleted=0.0
    endfunction
    
    function NSLSaveLoadExecutor__CheckLoadCompleted takes nothing returns nothing
        if ( not udg_NSL_AllowPlayerLoad ) then
            call DisplayTimedTextToPlayer(Player((GetPlayerId(udg_NSL_AllowCheckPlayer) )), 0, 0, 5.0, ( "|cffff3333[Load Error]|r You are not allowed to load.")) // INLINED!!
            return
        endif

        call NSLSaveLoadExecutor__LoadSaveSlot(udg_NSL_AllowCheckPlayer , NSL_PlayerCharId[GetPlayerId(udg_NSL_AllowCheckPlayer)])
        
        set udg_NSL_EventCheckLoadCompleted=0.0
    endfunction

    function NSLSaveLoadExecutor_Load takes integer playerId,string loadSlotName returns nothing
        set NSL_PlayerCharId[playerId]=loadSlotName
        set udg_NSL_AllowPlayerLoad=false
        set udg_NSL_AllowCheckPlayer=Player(playerId)
        call TriggerExecute(udg_NSL_TriggerCheckLoad)
    endfunction
    
    function NSLSaveLoadExecutor_Save takes integer playerId,string saveSlotName returns nothing
        set NSL_PlayerCharId[playerId]=saveSlotName
        set udg_NSL_AllowPlayerSave=false
        set udg_NSL_AllowCheckPlayer=Player(playerId)
        call TriggerExecute(udg_NSL_TriggerCheckSave)
    endfunction

    function NSLSaveLoadExecutor__Init takes nothing returns nothing
        local trigger t= CreateTrigger()
        call h__TriggerRegisterVariableEvent(t, "udg_NSL_EventCheckSaveCompleted", EQUAL, 1.0)
        call TriggerAddAction(t, function NSLSaveLoadExecutor__CheckSaveCompleted)
        
        set t=CreateTrigger()
        call h__TriggerRegisterVariableEvent(t, "udg_NSL_EventCheckLoadCompleted", EQUAL, 1.0)
        call TriggerAddAction(t, function NSLSaveLoadExecutor__CheckLoadCompleted)
    endfunction


//library NSLSaveLoadExecutor ends
//library NSLUtils:


    function NSLUtils_OnPlayerSave takes nothing returns nothing
        local player savingPlayer= GetTriggerPlayer()
  local string input= GetEventPlayerChatString()
        local string charId= null

		if ( SubString(input, 0, 5) != "-save" ) then
			return
		endif
        if ( StringLength(input) == 5 ) then
            call DisplayTimedTextToPlayer(Player((GetPlayerId(savingPlayer) )), 0, 0, 5.0, ( "|cffff3333[Save Error]|r Please name your save using '-save <character_name>' !")) // INLINED!!
            return
        endif
        call NSLSaveLoadExecutor_Save(GetPlayerId(savingPlayer) , SubString(input, 6, 999))
    endfunction

    function NSLUtils__OnPlayerCodeLoaded takes integer player_id,boolean is_valid,integer loader returns nothing
        if ( is_valid ) then
            set NSLUtils__format=NSLCodexStore_GetCodexForVersion(s__NSL_Code_code_version[loader])
            if ( NSLUtils__format == null ) then
                call DisplayTimedTextToPlayer(Player((player_id )), 0, 0, 5.0, ( "|cffff3333[Load Error]|r Code version " + I2S(s__NSL_Code_code_version[loader]) + " is unsupported.")) // INLINED!!
                call s__NSL_Code_deallocate(loader)
                return
            endif
            call NSLImpl_LoadPlayer(player_id , loader , NSLUtils__format)
        else
            call DisplayTimedTextToPlayer(Player((player_id )), 0, 0, 5.0, ( "|cffff3333[Load Error]|r Code is invalid.")) // INLINED!!
            call s__NSL_Code_deallocate(loader)
        endif
    endfunction
        
    function NSLUtils__LoadSaveSlot takes player p,string charId returns nothing
        local string s
        local integer user= (GetPlayerId((p))) // INLINED!!
        
        if ( not (StringLength((s__File_readEx(s__File_open(((NSL_FolderName + "\\SaveChar_" + ((charId)) + ".pld"))),true))) > 1) ) then // INLINED!!
            call DisplayTimedTextToPlayer(Player((s__User_id[user] )), 0, 0, 5.0, ( "|cffff3333[Load Error]|r Did not find any save data.")) // INLINED!!
            return
        elseif ( NSL_PlayerLoading[s__User_id[user]] ) then
            call DisplayTimedTextToPlayer(Player((s__User_id[user] )), 0, 0, 5.0, ( "|cffffcc00[Load Info]|r Please wait while your character synchronizes.")) // INLINED!!
        else
            set NSL_PlayerLoading[s__User_id[user]]=true
            set s=(s__SaveFile_getLines((charId) , 1 , false)) // INLINED!!
            if ( GetLocalPlayer() == p ) then
                call SyncString(s)
            endif
            call ClearTextMessages()
            call DisplayTimedTextToPlayer(Player((s__User_id[user] )), 0, 0, 5.0, ( "|cffffcc00[Load Info]|r Synchronizing with other players...")) // INLINED!!
        endif
    endfunction

    function NSLUtils_OnPlayerLoad takes nothing returns nothing
  local string input= GetEventPlayerChatString()
        local player loadingPlayer= GetTriggerPlayer()

		if ( SubString(input, 0, 5) != "-load" ) then
            return
		endif
        if ( StringLength(input) == 5 ) then
            call DisplayTimedTextToPlayer(Player((GetPlayerId(loadingPlayer) )), 0, 0, 5.0, ( "|cffff3333[Load Error]|r Please name your load using '-load <character_name>' !")) // INLINED!!
            return
        endif
        call NSLSaveLoadExecutor_Load(GetPlayerId(loadingPlayer) , SubString(input, 6, 999))
	endfunction
    
    function NSLUtils__LoadSaveSlot_OnLoadCount takes nothing returns nothing
        local player p= GetTriggerPlayer()
        local string data= BlzGetTriggerSyncData()
        local integer user= (GetPlayerId((p))) // INLINED!!
        
        set NSL_PlayerLoadingExpectCount[s__User_id[user]]=S2I(data)
        set NSL_PlayerLoadingCurrentCount[s__User_id[user]]=0
        set NSL_PlayerLoadingCode[s__User_id[user]]=""
    endfunction
    
    function NSLUtils__LoadSaveSlot_OnLoad takes nothing returns nothing
        local player p= GetTriggerPlayer()
        local string data= BlzGetTriggerSyncData()
        local integer user= (GetPlayerId((p))) // INLINED!!
        
        set NSL_PlayerLoadingCurrentCount[s__User_id[user]]=NSL_PlayerLoadingCurrentCount[s__User_id[user]] + 1
        set NSL_PlayerLoadingCode[s__User_id[user]]=NSL_PlayerLoadingCode[s__User_id[user]] + data

        if ( NSL_PlayerLoadingCurrentCount[s__User_id[user]] == NSL_PlayerLoadingExpectCount[s__User_id[user]] ) then
            set NSL_PlayerLoading[s__User_id[user]]=false
            call s__NSL_Code_create_load(s__User_id[user] , NSL_PlayerLoadingCode[s__User_id[user]] , (1))
        endif
    endfunction
    
 function NSLUtils__Init takes nothing returns nothing
  local integer i= 0

call TriggerAddAction(s__SyncHelper__Sync_TriggerCount, (function NSLUtils__LoadSaveSlot_OnLoadCount)) // INLINED!!
call TriggerAddAction(s__SyncHelper__Sync_Trigger, (function NSLUtils__LoadSaveSlot_OnLoad)) // INLINED!!

		loop
            if ( NSL_UseSimpleSaveLoad ) then
                call TriggerRegisterPlayerChatEvent(NSL_OnSave, Player(i), "-save", false)
                call TriggerRegisterPlayerChatEvent(NSL_OnLoad, Player(i), "-load", false)
            endif
            set NSL_PlayerLoading[i]=false
            set NSL_PlayerLoadingExpectCount[i]=0
            set NSL_PlayerLoadingCurrentCount[i]=0
            set NSL_PlayerLoadingCode[i]=""
			set i=i + 1
			exitwhen i == 24
		endloop

		call TriggerAddAction(NSL_OnSave, function NSLUtils_OnPlayerSave)
		call TriggerAddAction(NSL_OnLoad, function NSLUtils_OnPlayerLoad)

	endfunction


