// Trigger: ShiadalDamages
//===========================================================================
function Trig_ShiadalDamages_Conditions takes nothing returns boolean
    if ( not ( udg_DamageEventSource == gg_unit_E002_0526 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ShiadalDamages_Func001C takes nothing returns boolean
    if ( not ( udg_BossPhase >= 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ShiadalDamages_Actions takes nothing returns nothing
    if ( Trig_ShiadalDamages_Func001C() ) then
        call IssueTargetOrderBJ(udg_DamageEventSource, "slow", udg_DamageEventTarget)
    else
    endif
endfunction

//===========================================================================
function InitTrig_ShiadalDamages takes nothing returns nothing
    set gg_trg_ShiadalDamages=CreateTrigger()
    call h__TriggerRegisterVariableEvent(gg_trg_ShiadalDamages, "udg_DamageEvent", EQUAL, 1.00)
    call TriggerAddCondition(gg_trg_ShiadalDamages, Condition(function Trig_ShiadalDamages_Conditions))
    call TriggerAddAction(gg_trg_ShiadalDamages, function Trig_ShiadalDamages_Actions)
