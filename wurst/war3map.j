function Trig_GoldenConsulSelling_Actions takes nothing returns nothing
    set udg_GoldenConsulEffect=GetUnitTypeId(GetSoldUnit())
    call CinematicFadeBJ(bj_CINEFADETYPE_FADEOUT, 3.00, "ReplaceableTextures\\CameraMasks\\Black_mask.blp", 0, 0, 0, 0)
    call CreateTextTagUnitBJ("TRIGSTR_8856", GetTriggerUnit(), 0, 10, 100, 100, 100, 0)
    call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
    call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 3.00)
    call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
    call ForGroupBJ(udg_HeroesGroup, function Trig_GoldenConsulSelling_Func007A)
    call PauseUnitBJ(true, GetTriggerUnit())
    call RemoveUnit(GetSoldUnit())
    call TriggerSleepAction(3.00)
    call CinematicFadeBJ(bj_CINEFADETYPE_FADEIN, 3.00, "ReplaceableTextures\\CameraMasks\\Black_mask.blp", 0, 0, 0, 0)
    call PlaySoundBJ(gg_snd_guitar_camp)
    call TriggerSleepAction(2.00)
    call ForGroupBJ(udg_HeroesGroup, function Trig_GoldenConsulSelling_Func014A)
    call CreateTextTagUnitBJ("TRIGSTR_8857", GetTriggerUnit(), 0, 10, 100, 100, 100, 0)
    call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
    call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 5.00)
    call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
    set udg_tempLoc=GetUnitLoc(GetTriggerUnit())
    call TriggerExecute(gg_trg_GoldenConsulEffect)
endfunction

