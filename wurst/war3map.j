//===========================================================================
function Trig_FireWall_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A00S' ) ) then
        return false
    endif
    return true
endfunction

function Trig_FireWall_Actions takes nothing returns nothing
    set udg_FireWallPos=GetSpellTargetLoc()
    set udg_FireWallPos_Copy=PolarProjectionBJ(udg_FireWallPos, 150.00, ( GetUnitFacing(GetTriggerUnit()) + 90.00 ))
    set udg_FireWallPos_Copy_2=PolarProjectionBJ(udg_FireWallPos, 300.00, ( GetUnitFacing(GetTriggerUnit()) + 90.00 ))
    set udg_FireWallPos_Copy_3=PolarProjectionBJ(udg_FireWallPos, 300.00, ( GetUnitFacing(GetTriggerUnit()) - 90.00 ))
    set udg_FireWallPos_Copy_4=PolarProjectionBJ(udg_FireWallPos, 150.00, ( GetUnitFacing(GetTriggerUnit()) - 90.00 ))
    call PlaySoundAtPointBJ(gg_snd_dragon_fire, 100, GetSpellTargetLoc(), BlzGetLocalUnitZ(GetTriggerUnit()))
    call TriggerSleepAction(0.80)
    call AddSpecialEffectLocBJ(udg_FireWallPos, "Environment\\LargeBuildingFire\\LargeBuildingFire1.mdl")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 1.30)
    set udg_tempLoc=GetUnitLoc(GetTriggerUnit())
    set udg_tempZ=GetLocationZ(udg_tempLoc)
    set udg_tempZ=0.00
    call RemoveLocation(udg_tempLoc)
    set udg_FireWallEff=GetLastCreatedEffectBJ()
    call AddSpecialEffectLocBJ(udg_FireWallPos_Copy, "Environment\\LargeBuildingFire\\LargeBuildingFire1.mdl")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 1.30)
    set udg_FireWallEff_Copy=GetLastCreatedEffectBJ()
    call AddSpecialEffectLocBJ(udg_FireWallPos_Copy_2, "Environment\\LargeBuildingFire\\LargeBuildingFire1.mdl")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 1.30)
    set udg_FireWallEff_Copy_2=GetLastCreatedEffectBJ()
    call AddSpecialEffectLocBJ(udg_FireWallPos_Copy_3, "Environment\\LargeBuildingFire\\LargeBuildingFire1.mdl")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 1.30)
    set udg_FireWallEff_Copy_3=GetLastCreatedEffectBJ()
    call AddSpecialEffectLocBJ(udg_FireWallPos_Copy_4, "Environment\\LargeBuildingFire\\LargeBuildingFire1.mdl")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 1.30)
    set udg_FireWallEff_Copy_4=GetLastCreatedEffectBJ()
    call EnableTrigger(gg_trg_FireWallPeriodic)
    call TriggerSleepAction(0.20)
    call SetUnitAnimation(gg_unit_H00Q_0280, "stand")
    call TriggerSleepAction(0.50)
    call PlaySoundAtPointBJ(gg_snd_MediumBuildingFire1, 100, udg_FireWallPos, 0)
    set udg_FireWallSound=GetLastPlayedSound()
    call TriggerSleepAction(12.00)
    call StopSoundBJ(udg_FireWallSound, false)
    call DisableTrigger(gg_trg_FireWallPeriodic)
    call DestroyEffectBJ(udg_FireWallEff)
    call DestroyEffectBJ(udg_FireWallEff_Copy)
    call DestroyEffectBJ(udg_FireWallEff_Copy_2)
    call DestroyEffectBJ(udg_FireWallEff_Copy_3)
    call DestroyEffectBJ(udg_FireWallEff_Copy_4)
    call RemoveLocation(udg_FireWallPos)
    call RemoveLocation(udg_FireWallPos_Copy)
    call RemoveLocation(udg_FireWallPos_Copy_2)
    call RemoveLocation(udg_FireWallPos_Copy_3)
    call RemoveLocation(udg_FireWallPos_Copy_4)
endfunction

//===========================================================================
function InitTrig_FireWall takes nothing returns nothing
    set gg_trg_FireWall=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_FireWall, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_FireWall, Condition(function Trig_FireWall_Conditions))
    call TriggerAddAction(gg_trg_FireWall, function Trig_FireWall_Actions)
endfunction

