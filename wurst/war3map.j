    call SetUnitAnimation(gg_unit_H012_0027, "alive")
    call TriggerSleepAction(1.50)
    call PauseUnitBJ(false, gg_unit_H012_0027)
    call SetUnitMoveSpeed(gg_unit_H012_0027, 250.00)
    call SetUnitPathing(gg_unit_H012_0027, true)
    call UnitRemoveAbilityBJ('Avul', gg_unit_H012_0027)
