//*
//*  Triggers
//*
//***************************************************************************

//===========================================================================
// Trigger: GlobalPeriodic
//===========================================================================
function Trig_GlobalPeriodic_Func002Func005A takes nothing returns nothing
    call SetUnitX(GetEnumUnit(), ( GetLocationX(udg_tempLoc) ))
    call SetUnitY(GetEnumUnit(), ( GetLocationY(udg_tempLoc) ))
endfunction

function Trig_GlobalPeriodic_Func002Func007Func003C takes nothing returns boolean
    if ( not ( udg_HERO_DAMAGE_DEF_ALL[udg_player_num] > 90 ) ) then
        return false
    endif
    return true
endfunction

function Trig_GlobalPeriodic_Func002Func007Func004C takes nothing returns boolean
    if ( not ( udg_HERO_DAMAGE_DEF_PHYSICAL[udg_player_num] > 90 ) ) then
        return false
    endif
    return true
endfunction

function Trig_GlobalPeriodic_Func002Func007Func005C takes nothing returns boolean
    if ( not ( udg_HERO_DAMAGE_DEF_MAGIC[udg_player_num] > 90 ) ) then
        return false
    endif
    return true
endfunction

function Trig_GlobalPeriodic_Func002Func007C takes nothing returns boolean
    if ( not ( udg_ShowStatsOn[udg_player_num] == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_GlobalPeriodic_Func002A takes nothing returns nothing
    set udg_tempLoc=GetUnitLoc(GetEnumUnit())
    set udg_player_num=GetConvertedPlayerId(GetOwningPlayer(GetEnumUnit()))
    call SetUnitX(udg_backpack_by_player[udg_player_num], ( GetLocationX(udg_tempLoc) ))
    call SetUnitY(udg_backpack_by_player[udg_player_num], ( GetLocationY(udg_tempLoc) ))
    call ForGroupBJ(udg_disobidience_of_deathUG[udg_player_num], function Trig_GlobalPeriodic_Func002Func005A)
    // show stats
    if ( Trig_GlobalPeriodic_Func002Func007C() ) then
        call DestroyTextTagBJ(udg_ShowStatsDef[udg_player_num])
        call DestroyTextTagBJ(udg_ShowStatsDmg[udg_player_num])
        if ( Trig_GlobalPeriodic_Func002Func007Func003C() ) then
            set udg_tempInt=90
        else
            set udg_tempInt=udg_HERO_DAMAGE_DEF_ALL[udg_player_num]
        endif
        if ( Trig_GlobalPeriodic_Func002Func007Func004C() ) then
            set udg_tempInt2=90
        else
            set udg_tempInt2=udg_HERO_DAMAGE_DEF_PHYSICAL[udg_player_num]
        endif
        if ( Trig_GlobalPeriodic_Func002Func007Func005C() ) then
            set udg_tempInt3=90
        else
            set udg_tempInt3=udg_HERO_DAMAGE_DEF_MAGIC[udg_player_num]
        endif
        set udg_tempLoc=GetUnitLoc(udg_hero_by_player[udg_player_num])
        set udg_tempLoc2=PolarProjectionBJ(udg_tempLoc, 50.00, 315.00)
        set udg_tempZ=GetUnitFlyHeight(udg_hero_by_player[udg_player_num])
        call CreateTextTagUnitBJ(( "            |cffe6c800DAMAGE|r:|n" + ( "|cffff0000All|r Damage Bonus:  |cffff0000" + ( I2S(udg_HERO_DAMAGE_BONUS_ALL[udg_player_num]) + ( "|r%|n" + ( "|cffc89664Physical|r Damage Bonus:  |cffff0000" + ( I2S(udg_HERO_DAMAGE_BONUS_PHYSICAL[udg_player_num]) + ( "|r%|n" + ( "|cff8080ffMagic|r Damage Bonus:  |cffff0000" + ( I2S(udg_HERO_DAMAGE_BONUS_MAGIC[udg_player_num]) + ( "|r%|n---------------------------------------------------|n" + ( "Damage Bonus vs |cffc0c0c0Elite|r:  |cffff0000" + ( I2S(udg_HERO_DAMAGE_BONUS_VS_ELITES[udg_player_num]) + ( "|r%|n" + ( "Damage Bonus vs |cffc0c0c0Undead|r:  |cffff0000" + ( I2S(udg_HERO_DAMAGE_BONUS_VS_UNDEAD[udg_player_num]) + ( "|r%|n" + ( "|cffc0c0c0Minion|r Damage Bonus:  |cffff0000" + ( I2S(udg_HERO_DAMAGE_BONUS_MINIONS[udg_player_num]) + "|r%" ) ) ) ) ) ) ) ) ) ) ) ) ) ) ) ) ) ), udg_hero_by_player[udg_player_num], 0, 7.50, 100, 100, 100, 0)
        set udg_ShowStatsDmg[udg_player_num]=GetLastCreatedTextTag()
        call SetTextTagPosBJ(GetLastCreatedTextTag(), udg_tempLoc2, udg_tempZ)
        call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
        call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 0.30)
        call RemoveLocation(udg_tempLoc2)
        set udg_tempLoc2=PolarProjectionBJ(udg_tempLoc, 425.00, 180.00)
        call CreateTextTagUnitBJ(( "            |cffe6c800DEFENSE|r:|n" + ( "|cffff0000All|r Damage Resistance:  |cffff0000" + ( I2S(udg_tempInt) + ( "|r%|n" + ( "|cffc89664Physical|r Damage Resistance:  |cffff0000" + ( I2S(udg_tempInt2) + ( "|r%|n" + ( "|cff8080ffMagic|r Damage Resistance:  |cffff0000" + ( I2S(udg_tempInt3) + ( "|r%|n---------------------------------------------------|n" + ( "|cffc0c0c0Death Disobedience|r (|cffff0000MAX|r):  |cffff0000" + ( I2S(udg_DISOBIDIENCE_OF_DEATH) + "|r" ) ) ) ) ) ) ) ) ) ) ) ), udg_hero_by_player[udg_player_num], 0, 7.50, 100, 100, 100, 0)
        set udg_ShowStatsDef[udg_player_num]=GetLastCreatedTextTag()
        call SetTextTagPosBJ(GetLastCreatedTextTag(), udg_tempLoc2, udg_tempZ)
        call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
        call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 0.30)
        call RemoveLocation(udg_tempLoc)
        call RemoveLocation(udg_tempLoc2)
        set udg_tempZ=0.00
        set udg_tempInt=0
        set udg_tempInt2=0
        set udg_tempInt3=0
    else
    endif
    call RemoveLocation(udg_tempLoc)
endfunction

function Trig_GlobalPeriodic_Func005Func002Func001Func001C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 2) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_GlobalPeriodic_Func005Func002Func001C takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetEnumUnit()) == 'u000' ) ) then
        return false
    endif
    return true
endfunction

function Trig_GlobalPeriodic_Func005Func002A takes nothing returns nothing
    if ( Trig_GlobalPeriodic_Func005Func002Func001C() ) then
        if ( Trig_GlobalPeriodic_Func005Func002Func001Func001C() ) then
            call IssueTargetOrderBJ(GetEnumUnit(), "deathcoil", GroupPickRandomUnit(udg_HeroesGroup))
        else
        endif
        call IssueImmediateOrderBJ(GetEnumUnit(), "berserk")
    else
    endif
endfunction

function Trig_GlobalPeriodic_Func005C takes nothing returns boolean
    if ( not ( CountUnitsInGroup(udg_RoomEnemyUG) > 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_GlobalPeriodic_Func007Func001C takes nothing returns boolean
    if ( not ( UnitHasBuffBJ(GetEnumUnit(), 'Bssd') == false ) ) then
        return false
    endif
    if ( not ( UnitHasBuffBJ(GetEnumUnit(), 'Bspo') == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_GlobalPeriodic_Func007A takes nothing returns nothing
    if ( Trig_GlobalPeriodic_Func007Func001C() ) then
        call SetUnitVertexColorBJ(GetEnumUnit(), 100.00, 100.00, 100.00, 0)
        call GroupRemoveUnitSimple(GetEnumUnit(), udg_poisoned_UG)
    else
    endif
endfunction

function Trig_GlobalPeriodic_Func008Func006C takes nothing returns boolean
    if ( not ( IsUnitInGroup(gg_unit_H00A_0082, udg_toughness_UG) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_GlobalPeriodic_Func008C takes nothing returns boolean
    if ( not ( UnitHasBuffBJ(gg_unit_H00A_0082, 'B01Y') == false ) ) then
        return false
    endif
    if ( not ( GetUnitStateSwap(UNIT_STATE_LIFE, gg_unit_H00A_0082) >= ( GetUnitStateSwap(UNIT_STATE_MAX_LIFE, gg_unit_H00A_0082) * 0.70 ) ) ) then
        return false
    endif
    if ( not ( GetPlayerController(GetOwningPlayer(gg_unit_H00A_0082)) == MAP_CONTROL_USER ) ) then
        return false
    endif
    return true
endfunction

function Trig_GlobalPeriodic_Func010Func001C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped('A08D', GetEnumUnit()) == 1 ) ) then
        return false
    endif
    if ( not ( UnitHasBuffBJ(GetEnumUnit(), 'B022') == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_GlobalPeriodic_Func010A takes nothing returns nothing
    if ( Trig_GlobalPeriodic_Func010Func001C() ) then
        call UnitRemoveAbilityBJ('A08D', GetEnumUnit())
        call GroupRemoveUnitSimple(GetEnumUnit(), udg_AngerUG)
    else
    endif
endfunction

function Trig_GlobalPeriodic_Actions takes nothing returns nothing
    // heroes
    call ForGroupBJ(udg_HeroesGroup, function Trig_GlobalPeriodic_Func002A)
    set udg_player_num=0
    // enemies
    if ( Trig_GlobalPeriodic_Func005C() ) then
        call ForGroupBJ(udg_RoomEnemyUG, function Trig_GlobalPeriodic_Func005Func002A)
    else
    endif
    // poison
    call ForGroupBJ(udg_poisoned_UG, function Trig_GlobalPeriodic_Func007A)
    if ( Trig_GlobalPeriodic_Func008C() ) then
        set udg_tempLoc=GetUnitLoc(gg_unit_H00A_0082)
        call CreateNUnitsAtLoc(1, 'h016', GetOwningPlayer(gg_unit_H00A_0082), udg_tempLoc, bj_UNIT_FACING)
        call RemoveLocation(udg_tempLoc)
        call UnitApplyTimedLifeBJ(2.00, 'BTLF', GetLastCreatedUnit())
        call IssueTargetOrderBJ(GetLastCreatedUnit(), "innerfire", gg_unit_H00A_0082)
        if ( Trig_GlobalPeriodic_Func008Func006C() ) then
            call GroupAddUnitSimple(gg_unit_H00A_0082, udg_toughness_UG)
            set udg_HERO_DAMAGE_DEF_ALL[GetConvertedPlayerId(GetOwningPlayer(gg_unit_H00A_0082))]=( udg_HERO_DAMAGE_DEF_ALL[GetConvertedPlayerId(GetOwningPlayer(gg_unit_H00A_0082))] + 30 )
        else
        endif
    else
    endif
    // anger
    call ForGroupBJ(udg_AngerUG, function Trig_GlobalPeriodic_Func010A)
endfunction

//===========================================================================
function InitTrig_GlobalPeriodic takes nothing returns nothing
    set gg_trg_GlobalPeriodic=CreateTrigger()
    call TriggerRegisterTimerEventPeriodic(gg_trg_GlobalPeriodic, 0.10)
    call TriggerAddAction(gg_trg_GlobalPeriodic, function Trig_GlobalPeriodic_Actions)
endfunction

