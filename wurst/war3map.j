function Trig_ChestBase_Func001Func003C takes nothing returns boolean
    if ( not ( udg_tempInt > 99 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ChestBase_Func001Func005C takes nothing returns boolean
    if ( not ( udg_tempInt <= 99 ) ) then
        return false
    endif
    if ( not ( udg_tempInt > 95 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ChestBase_Func001Func007C takes nothing returns boolean
    if ( not ( udg_tempInt <= 95 ) ) then
        return false
    endif
    if ( not ( udg_tempInt > 80 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ChestBase_Func001Func009C takes nothing returns boolean
    if ( not ( udg_tempInt <= 80 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ChestBase_Actions takes nothing returns nothing
    set bj_forLoopAIndex=GetRandomInt(1, 3)
    set bj_forLoopAIndexEnd=udg_ChestRollNumber
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        set udg_tempInt=GetRandomInt(1, 100)
        // LEGENDARY
        if ( Trig_ChestBase_Func001Func003C() ) then
            set udg_ChestCounter=( udg_ChestCounter + 1 )
            set udg_LootItems[udg_ChestCounter]=ChooseRandomItemBJ(5)
        else
        endif
        // EPIC
        if ( Trig_ChestBase_Func001Func005C() ) then
            set udg_ChestCounter=( udg_ChestCounter + 1 )
            set udg_LootItems[udg_ChestCounter]=ChooseRandomItemBJ(4)
        else
        endif
        // RARE
        if ( Trig_ChestBase_Func001Func007C() ) then
            set udg_ChestCounter=( udg_ChestCounter + 1 )
            set udg_LootItems[udg_ChestCounter]=ChooseRandomItemBJ(3)
        else
        endif
        // COMMON
        if ( Trig_ChestBase_Func001Func009C() ) then
            set udg_ChestCounter=( udg_ChestCounter + 1 )
            set udg_LootItems[udg_ChestCounter]=ChooseRandomItemBJ(GetRandomInt(0, 2))
        else
        endif
        set udg_tempInt=0
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
endfunction

