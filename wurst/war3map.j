function Trig_PathAlliance_Actions takes nothing returns nothing
    set udg_RoomMultiboardCounting=( udg_RoomMultiboardCounting + 1 )
    call MultiboardSetTitleText(udg_Multiboard1, ( ( udg_difficultyString + " - |cffffffffRoom:|r " ) + I2S(R2I(udg_RoomMultiboardCounting)) ))
    set udg_PathTown=0
    set udg_EncounterEndInt=0
    set udg_PathArtifact=0
    set udg_PathGold=0
    set udg_PathObject=0
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=18
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        call ForGroupBJ(GetUnitsInRectAll(udg_RoomReg[GetForLoopIndexA()]), function Trig_PathAlliance_Func008Func001A)
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    call EnumItemsInRectBJ(GetPlayableMapRect(), function Trig_PathAlliance_Func009A)
    call RemoveUnit(GetSoldUnit())
    call RemoveUnit(GetSellingUnit())
    set udg_RoomInt=GetRandomInt(13, 17)
    // CHECKING PREVIOUS ROOM 5 TIMES
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=5
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        if ( Trig_PathAlliance_Func016Func001C() ) then
            set udg_RoomInt=GetRandomInt(13, 17)
        else
        endif
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    set udg_RoomPreviousInt=udg_RoomInt
    if ( Trig_PathAlliance_Func018C() ) then
        set udg_PathArtifact=1
    else
    endif
    if ( Trig_PathAlliance_Func019C() ) then
        set udg_PathGold=1
    else
    endif
    if ( Trig_PathAlliance_Func020C() ) then
        set udg_PathObject=1
    else
    endif
    // IF TOWN
    if ( Trig_PathAlliance_Func022C() ) then
        call ForGroupBJ(udg_HeroesGroup, function Trig_PathAlliance_Func022Func001A)
        call ForGroupBJ(udg_MinionsUG, function Trig_PathAlliance_Func022Func002A)
        set udg_PathTown=1
        // IF BOSS
        if ( Trig_PathAlliance_Func022Func005C() ) then
            call ConditionalTriggerExecute(gg_trg_ToBoss)
        else
            set udg_tempLoc=GetRandomLocInRect(gg_rct_ExitRoom18_Copy)
            call CreateNUnitsAtLoc(1, 'o02I', Player(PLAYER_NEUTRAL_PASSIVE), udg_tempLoc, bj_UNIT_FACING)
            call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\NightElf\\Blink\\BlinkTarget.mdl")
            call DestroyEffectBJ(GetLastCreatedEffectBJ())
            call AddUnitToStockBJ('o02J', GetLastCreatedUnit(), 1, 1)
            call RemoveLocation(udg_tempLoc)
            set udg_tempLoc=GetRandomLocInRect(gg_rct_ExitRoom18)
            call CreateNUnitsAtLoc(1, 'o02I', Player(PLAYER_NEUTRAL_PASSIVE), udg_tempLoc, bj_UNIT_FACING)
            call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\NightElf\\Blink\\BlinkTarget.mdl")
            call DestroyEffectBJ(GetLastCreatedEffectBJ())
            call AddUnitToStockBJ('o02H', GetLastCreatedUnit(), 1, 1)
            call RemoveLocation(udg_tempLoc)
        endif
        // Traders - Alliance
        if ( Trig_PathAlliance_Func022Func007C() ) then
            set udg_tempLoc=GetRectCenter(gg_rct_cheed2)
            call CreateNUnitsAtLoc(1, 'h025', Player(20), udg_tempLoc, 270.00)
            call RemoveLocation(udg_tempLoc)
        else
        endif
        if ( Trig_PathAlliance_Func022Func008C() ) then
            set udg_tempLoc=GetRectCenter(gg_rct_goldenconsul2)
            call CreateNUnitsAtLoc(1, 'h026', Player(20), udg_tempLoc, 230.00)
            call RemoveLocation(udg_tempLoc)
        else
        endif
    else
    endif
    // IF NOT TOWN
    // IF NOT TOWN
    // IF NOT TOWN
    if ( Trig_PathAlliance_Func026C() ) then
        call ForGroupBJ(udg_HeroesGroup, function Trig_PathAlliance_Func026Func002A)
        call ForGroupBJ(udg_MinionsUG, function Trig_PathAlliance_Func026Func003A)
        // MAKING ENEMIES
        set udg_RoomInt=( udg_RoomInt * 5 )
        // regional enemies or not
        if ( Trig_PathAlliance_Func026Func007C() ) then
            set udg_tempInt=GetRandomInt(0, 2)
            // room
            set bj_forLoopBIndex=1
            set bj_forLoopBIndexEnd=5
            loop
                exitwhen bj_forLoopBIndex > bj_forLoopBIndexEnd
                // number of enemies
                set bj_forLoopAIndex=1
                set bj_forLoopAIndexEnd=GetRandomInt(( udg_NUMBER_OF_ENEMIES_PER_SPAWN - 3 ), udg_NUMBER_OF_ENEMIES_PER_SPAWN)
                loop
                    exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
                    set udg_tempLoc=GetRandomLocInRect(udg_EnemyRoomReg[udg_RoomInt])
                    call CreateNUnitsAtLoc(1, udg_EnemyRoomRegionalAlliance[GetRandomInt(( ( udg_tempInt * 20 ) + 1 ), ( 20 + ( udg_tempInt * 20 ) ))], Player(23), udg_tempLoc, GetRandomDirectionDeg())
                    call GroupAddUnitSimple(GetLastCreatedUnit(), udg_RoomEnemyUG)
                    call RemoveLocation(udg_tempLoc)
                    // MAKING REGIONAL HERO
                    if ( Trig_PathAlliance_Func026Func007Func005Func002Func006C() ) then
                        if ( Trig_PathAlliance_Func026Func007Func005Func002Func006Func001C() ) then
                            set udg_tempLoc=GetRandomLocInRect(udg_EnemyRoomReg[udg_RoomInt])
                            call SetUnitPositionLocFacingBJ(udg_EnemyRoomMinibossAlliance[( 20 + ( 20 * udg_tempInt ) )], udg_tempLoc, GetRandomDirectionDeg())
                            call GroupAddUnitSimple(udg_EnemyRoomMinibossAlliance[( 20 + ( 20 * udg_tempInt ) )], udg_RoomEnemyUG)
                            call GroupAddUnitSimple(udg_EnemyRoomMinibossAlliance[( 20 + ( 20 * udg_tempInt ) )], udg_MiniBossUG)
                            call SetHeroLevelBJ(udg_EnemyRoomMinibossAlliance[( 20 + ( 20 * udg_tempInt ) )], GetHeroLevel(GroupPickRandomUnit(udg_HeroesGroup)), false)
                            call RemoveLocation(udg_tempLoc)
                        else
                        endif
                    else
                    endif
                    set bj_forLoopAIndex=bj_forLoopAIndex + 1
                endloop
                set udg_RoomInt=( udg_RoomInt - 1 )
                set bj_forLoopBIndex=bj_forLoopBIndex + 1
            endloop
        else
            // undead or not
            if ( Trig_PathAlliance_Func026Func007Func002C() ) then
                set bj_forLoopBIndex=1
                set bj_forLoopBIndexEnd=5
                loop
                    exitwhen bj_forLoopBIndex > bj_forLoopBIndexEnd
                    // number of enemies
                    set bj_forLoopAIndex=1
                    set bj_forLoopAIndexEnd=GetRandomInt(( udg_NUMBER_OF_ENEMIES_PER_SPAWN - 3 ), udg_NUMBER_OF_ENEMIES_PER_SPAWN)
                    loop
                        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
                        set udg_tempLoc=GetRandomLocInRect(udg_EnemyRoomReg[udg_RoomInt])
                        call CreateNUnitsAtLoc(1, udg_EnemyRoom[GetRandomInt(1, 20)], Player(22), udg_tempLoc, GetRandomDirectionDeg())
                        call GroupAddUnitSimple(GetLastCreatedUnit(), udg_RoomEnemyUG)
                        call RemoveLocation(udg_tempLoc)
                        // MAKING UNDEAD HERO
                        if ( Trig_PathAlliance_Func026Func007Func002Func003Func002Func006C() ) then
                            if ( Trig_PathAlliance_Func026Func007Func002Func003Func002Func006Func001C() ) then
                                set udg_tempLoc=GetRandomLocInRect(udg_EnemyRoomReg[udg_RoomInt])
                                call SetUnitPositionLocFacingBJ(udg_EnemyRoomMiniboss[20], udg_tempLoc, GetRandomDirectionDeg())
                                call GroupAddUnitSimple(udg_EnemyRoomMiniboss[20], udg_RoomEnemyUG)
                                call GroupAddUnitSimple(udg_EnemyRoomMiniboss[20], udg_MiniBossUG)
                                call SetHeroLevelBJ(udg_EnemyRoomMiniboss[20], GetHeroLevel(GroupPickRandomUnit(udg_HeroesGroup)), false)
                                call RemoveLocation(udg_tempLoc)
                            else
                            endif
                        else
                        endif
                        set bj_forLoopAIndex=bj_forLoopAIndex + 1
                    endloop
                    set udg_RoomInt=( udg_RoomInt - 1 )
                    set bj_forLoopBIndex=bj_forLoopBIndex + 1
                endloop
            else
                set udg_tempInt2=GetRandomInt(1, 5)
                set bj_forLoopBIndex=3
                set bj_forLoopBIndexEnd=6
                loop
                    exitwhen bj_forLoopBIndex > bj_forLoopBIndexEnd
                    // number of enemies
                    set bj_forLoopAIndex=1
                    set bj_forLoopAIndexEnd=GetRandomInt(( udg_NUMBER_OF_ENEMIES_PER_SPAWN - 3 ), udg_NUMBER_OF_ENEMIES_PER_SPAWN)
                    loop
                        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
                        set udg_tempLoc=GetRandomLocInRect(udg_EnemyRoomReg[udg_RoomInt])
                        call CreateNUnitsAtLoc(1, udg_EnemyRoom[GetRandomInt(( ( udg_tempInt2 * 20 ) + 1 ), ( 20 + ( udg_tempInt2 * 20 ) ))], Player(23), udg_tempLoc, GetRandomDirectionDeg())
                        call GroupAddUnitSimple(GetLastCreatedUnit(), udg_RoomEnemyUG)
                        call RemoveLocation(udg_tempLoc)
                        // MAKING ALL HERO
                        if ( Trig_PathAlliance_Func026Func007Func002Func002Func002Func006C() ) then
                            if ( Trig_PathAlliance_Func026Func007Func002Func002Func002Func006Func001C() ) then
                                set udg_tempLoc=GetRandomLocInRect(udg_EnemyRoomReg[udg_RoomInt])
                                call SetUnitPositionLocFacingBJ(udg_EnemyRoomMiniboss[( 20 + ( 20 * udg_tempInt2 ) )], udg_tempLoc, GetRandomDirectionDeg())
                                call GroupAddUnitSimple(udg_EnemyRoomMiniboss[( 20 + ( 20 * udg_tempInt2 ) )], udg_RoomEnemyUG)
                                call GroupAddUnitSimple(udg_EnemyRoomMiniboss[( 20 + ( 20 * udg_tempInt2 ) )], udg_MiniBossUG)
                                call SetHeroLevelBJ(udg_EnemyRoomMiniboss[( 20 + ( 20 * udg_tempInt2 ) )], GetHeroLevel(GroupPickRandomUnit(udg_HeroesGroup)), false)
                                call RemoveLocation(udg_tempLoc)
                            else
                            endif
                        else
                        endif
                        set bj_forLoopAIndex=bj_forLoopAIndex + 1
                    endloop
                    set udg_RoomInt=( udg_RoomInt - 1 )
                    set bj_forLoopBIndex=bj_forLoopBIndex + 1
                endloop
            endif
        endif
        set udg_RoomInt=( ( udg_RoomInt + 5 ) / 5 )
        set udg_tempInt=0
        set udg_tempInt2=0
        call ConditionalTriggerExecute(gg_trg_RoomsGeneralCombat)
        call TriggerExecute(gg_trg_AurasForMinibossGiveaway)
    else
    endif
    set udg_PathTown=0
endfunction

//===========================================================================
function InitTrig_PathAlliance takes nothing returns nothing
    set gg_trg_PathAlliance=CreateTrigger()
    call DisableTrigger(gg_trg_PathAlliance)
    call TriggerRegisterAnyUnitEventBJ(gg_trg_PathAlliance, EVENT_PLAYER_UNIT_SELL)
    call TriggerAddCondition(gg_trg_PathAlliance, Condition(function Trig_PathAlliance_Conditions))
    call TriggerAddAction(gg_trg_PathAlliance, function Trig_PathAlliance_Actions)
endfunction

//===========================================================================
// Trigger: ToBoss
//===========================================================================
function Trig_ToBoss_Func004Func001C takes nothing returns boolean
    if ( ( udg_BossfightAtkivus != - 1 ) ) then
        return true
    endif
    if ( ( udg_BossfightNataAra != - 1 ) ) then
        return true
    endif
    if ( ( udg_BossfightShiadal != - 1 ) ) then
        return true
    endif
    return false
endfunction

function Trig_ToBoss_Func004Func002Func002C takes nothing returns boolean
    if ( not ( udg_tempInt == 1 ) ) then
        return false
    endif
    if ( not ( udg_BossfightAtkivus != - 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ToBoss_Func004Func002Func003C takes nothing returns boolean
    if ( not ( udg_tempInt == 2 ) ) then
        return false
    endif
    if ( not ( udg_BossfightNataAra != - 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ToBoss_Func004Func002Func004C takes nothing returns boolean
    if ( not ( udg_tempInt == 3 ) ) then
        return false
    endif
    if ( not ( udg_BossfightShiadal != - 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ToBoss_Func004C takes nothing returns boolean
    if ( not Trig_ToBoss_Func004Func001C() ) then
        return false
    endif
    return true
endfunction

function Trig_ToBoss_Func005C takes nothing returns boolean
    if ( not ( udg_BossNumbers == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ToBoss_Func006C takes nothing returns boolean
    if ( not ( udg_BossNumbers == 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ToBoss_Func007C takes nothing returns boolean
    if ( not ( udg_BossNumbers == 3 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ToBoss_Func010C takes nothing returns boolean
    if ( not ( udg_CurrentLocation == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ToBoss_Func011C takes nothing returns boolean
    if ( not ( udg_CurrentLocation == 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ToBoss_Func012C takes nothing returns boolean
    if ( not ( udg_CurrentLocation == 3 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ToBoss_Actions takes nothing returns nothing
    call PlaySoundBJ(gg_snd_ArrangedTeamInvitation)
    set udg_music_before_boss=true
    // Boss choosing
    if ( Trig_ToBoss_Func004C() ) then
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=200
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            set udg_tempInt=GetRandomInt(1, 3)
            if ( Trig_ToBoss_Func004Func002Func002C() ) then
                set udg_BossNumbers=1
            else
            endif
            if ( Trig_ToBoss_Func004Func002Func003C() ) then
                set udg_BossNumbers=2
            else
            endif
            if ( Trig_ToBoss_Func004Func002Func004C() ) then
                set udg_BossNumbers=3
            else
            endif
            set bj_forLoopAIndex=bj_forLoopAIndex + 1
        endloop
    else
    endif
    if ( Trig_ToBoss_Func005C() ) then
        call DisplayTextToForce(GetPlayersAll(), "TRIGSTR_8927")
    else
    endif
    if ( Trig_ToBoss_Func006C() ) then
        call DisplayTextToForce(GetPlayersAll(), "TRIGSTR_8930")
    else
    endif
    if ( Trig_ToBoss_Func007C() ) then
        call DisplayTextToForce(GetPlayersAll(), "TRIGSTR_8931")
    else
    endif
    set udg_tempInt=0
    // -
    if ( Trig_ToBoss_Func010C() ) then
        set udg_tempLoc=GetRectCenter(gg_rct_portalToBossOrc)
        call CreateNUnitsAtLoc(1, 'o039', Player(PLAYER_NEUTRAL_PASSIVE), udg_tempLoc, bj_UNIT_FACING)
    else
    endif
    if ( Trig_ToBoss_Func011C() ) then
        set udg_tempLoc=GetRectCenter(gg_rct_portalToBossNaluara)
        call CreateNUnitsAtLoc(1, 'o039', Player(PLAYER_NEUTRAL_PASSIVE), udg_tempLoc, bj_UNIT_FACING)
        call SetUnitFacingTimed(GetLastCreatedUnit(), 240.00, 0)
    else
    endif
    if ( Trig_ToBoss_Func012C() ) then
        set udg_tempLoc=GetRectCenter(gg_rct_portalToBossAlliance)
        call CreateNUnitsAtLoc(1, 'o039', Player(PLAYER_NEUTRAL_PASSIVE), udg_tempLoc, bj_UNIT_FACING)
        call SetUnitFacingTimed(GetLastCreatedUnit(), 240.00, 0)
    else
    endif
    call SetUnitAnimation(GetLastCreatedUnit(), "birth")
    call RemoveLocation(udg_tempLoc)
    call AddUnitToStockBJ('o02R', GetLastCreatedUnit(), 1, 1)
endfunction

//===========================================================================
function InitTrig_ToBoss takes nothing returns nothing
    set gg_trg_ToBoss=CreateTrigger()
    call TriggerAddAction(gg_trg_ToBoss, function Trig_ToBoss_Actions)
endfunction

//===========================================================================
// Trigger: PathToBossInit
//===========================================================================
function Trig_PathToBossInit_Conditions takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetSoldUnit()) == 'o02R' ) ) then
        return false
    endif
    return true
endfunction

function Trig_PathToBossInit_Func018C takes nothing returns boolean
    if ( not ( udg_BossNumbers == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_PathToBossInit_Func019C takes nothing returns boolean
    if ( not ( udg_BossNumbers == 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_PathToBossInit_Func020C takes nothing returns boolean
    if ( not ( udg_BossNumbers == 3 ) ) then
        return false
    endif
    return true
endfunction

function Trig_PathToBossInit_Func021Func001Func001Func006C takes nothing returns boolean
    if ( not ( IsUnitInGroup(GetEnumUnit(), udg_HeroesGroup) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_PathToBossInit_Func021Func001Func001C takes nothing returns boolean
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( GetUnitTypeId(GetEnumUnit()) != 'h01W' ) ) then
        return false
    endif
    return true
endfunction

function Trig_PathToBossInit_Func021Func001A takes nothing returns nothing
    if ( Trig_PathToBossInit_Func021Func001Func001C() ) then
        set udg_tempLoc=GetRandomLocInRect(gg_rct_BossfightHeroes)
        call SetUnitPositionLocFacingBJ(GetEnumUnit(), udg_tempLoc, 180.00)
        call PanCameraToTimedLocForPlayer(GetOwningPlayer(GetEnumUnit()), udg_tempLoc, 0.00)
        if ( Trig_PathToBossInit_Func021Func001Func001Func006C() ) then
            call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\Human\\MassTeleport\\MassTeleportTarget.mdl")
            call DestroyEffectBJ(GetLastCreatedEffectBJ())
        else
        endif
        call RemoveLocation(udg_tempLoc)
    else
    endif
endfunction

function Trig_PathToBossInit_Func021A takes nothing returns nothing
    call ForGroupBJ(GetUnitsOfPlayerAll(GetEnumPlayer()), function Trig_PathToBossInit_Func021Func001A)
endfunction

function Trig_PathToBossInit_Func022Func001C takes nothing returns boolean
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( IsUnitInGroup(GetEnumUnit(), udg_HeroesGroup) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_PathToBossInit_Func022A takes nothing returns nothing
    if ( Trig_PathToBossInit_Func022Func001C() ) then
        call GroupAddUnitSimple(GetEnumUnit(), udg_HeroesBossfightUG)
        set udg_tempLoc=GetRectCenter(gg_rct_StartLoc)
        call PanCameraToTimedLocForPlayer(GetOwningPlayer(GetEnumUnit()), udg_tempLoc, 0.00)
        call RemoveLocation(udg_tempLoc)
    else
    endif
endfunction

function Trig_PathToBossInit_Actions takes nothing returns nothing
    call RemoveUnit(GetSoldUnit())
    call RemoveUnit(GetSellingUnit())
    call EndThematicMusicBJ()
    set udg_RoomMultiboardCounting=( udg_RoomMultiboardCounting + 1 )
    call MultiboardSetTitleText(udg_Multiboard1, ( "|cffffffffRoom:|r " + I2S(R2I(udg_RoomMultiboardCounting)) ))
    set udg_RoomSpecialExit=0
    set udg_RoomWayToTown=0
    set udg_EncounterEndInt=0
    set udg_PathTown=0
    set udg_PathArtifact=0
    set udg_PathGold=0
    set udg_PathObject=0
    set udg_music_before_boss=false
    call CinematicFadeBJ(bj_CINEFADETYPE_FADEOUT, 3.00, "ReplaceableTextures\\CameraMasks\\Black_mask.blp", 0, 0, 0, 0)
    set udg_BossfightMainIsOn=1
    call TriggerSleepAction(3.50)
    call CinematicFadeBJ(bj_CINEFADETYPE_FADEIN, 7.00, "ReplaceableTextures\\CameraMasks\\Black_mask.blp", 0, 0, 0, 0)
    if ( Trig_PathToBossInit_Func018C() ) then
        call ConditionalTriggerExecute(gg_trg_AtkivusInit)
    else
    endif
    if ( Trig_PathToBossInit_Func019C() ) then
        call ConditionalTriggerExecute(gg_trg_BossfightNataAraInit)
    else
    endif
    if ( Trig_PathToBossInit_Func020C() ) then
        call ConditionalTriggerExecute(gg_trg_ShiadalInit)
    else
    endif
    call ForForce(udg_PlayerGroup, function Trig_PathToBossInit_Func021A)
    call ForGroupBJ(GetUnitsInRectAll(gg_rct_MainBossLoc), function Trig_PathToBossInit_Func022A)
    call EndThematicMusicBJ()
    set udg_BossTheme=1
    call PlayThematicMusicBJ("xcombbattle3.mp3")
    call SetMusicVolumeBJ(100.00)
endfunction

//===========================================================================
function InitTrig_PathToBossInit takes nothing returns nothing
    set gg_trg_PathToBossInit=CreateTrigger()
    call DisableTrigger(gg_trg_PathToBossInit)
    call TriggerRegisterAnyUnitEventBJ(gg_trg_PathToBossInit, EVENT_PLAYER_UNIT_SELL)
    call TriggerAddCondition(gg_trg_PathToBossInit, Condition(function Trig_PathToBossInit_Conditions))
    call TriggerAddAction(gg_trg_PathToBossInit, function Trig_PathToBossInit_Actions)
endfunction

