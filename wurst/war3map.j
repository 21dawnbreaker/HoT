//===========================================================================
// Trigger: CounterForce
//===========================================================================
function Trig_CounterForce_Func002001003 takes nothing returns boolean
    return ( GetUnitTypeId(GetFilterUnit()) == 'nvdg' )
endfunction

function Trig_CounterForce_Func002Func001Func001C takes nothing returns boolean
    if ( not ( udg_tempInt == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_CounterForce_Func002Func001C takes nothing returns boolean
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(GetTriggerUnit())) == true ) ) then
        return false
    endif
    if ( not ( GetUnitStateSwap(UNIT_STATE_MANA, GetEnumUnit()) >= 50.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_CounterForce_Func002A takes nothing returns nothing
    if ( Trig_CounterForce_Func002Func001C() ) then
        if ( Trig_CounterForce_Func002Func001Func001C() ) then
            set udg_tempLoc2=GetUnitLoc(GetEnumUnit())
            call CreateNUnitsAtLoc(1, 'h01R', Player(PLAYER_NEUTRAL_PASSIVE), udg_tempLoc2, bj_UNIT_FACING)
            call UnitAddAbilityBJ('Amrf', GetLastCreatedUnit())
            call UnitAddAbilityBJ('A0FV', GetLastCreatedUnit())
            call IssueTargetOrderBJ(GetLastCreatedUnit(), "chainlightning", GetTriggerUnit())
            call UnitApplyTimedLifeBJ(2.00, 'BTLF', GetLastCreatedUnit())
            call UnitDamageTargetBJ(GetEnumUnit(), GetTriggerUnit(), ( GetUnitStateSwap(UNIT_STATE_MANA, GetTriggerUnit()) * 0.15 ), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_MAGIC)
            call SetUnitManaBJ(GetEnumUnit(), ( GetUnitStateSwap(UNIT_STATE_MANA, GetEnumUnit()) - 50.00 ))
            call RemoveLocation(udg_tempLoc2)
        else
        endif
        set udg_tempInt=1
    else
    endif
endfunction

function Trig_CounterForce_Actions takes nothing returns nothing
    set udg_tempLoc=GetUnitLoc(GetTriggerUnit())
    call ForGroupBJ(GetUnitsInRangeOfLocMatching(1200.00, udg_tempLoc, Condition(function Trig_CounterForce_Func002001003)), function Trig_CounterForce_Func002A)
    set udg_tempInt=0
    call RemoveLocation(udg_tempLoc)
endfunction

//===========================================================================
function InitTrig_CounterForce takes nothing returns nothing
    set gg_trg_CounterForce=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_CounterForce, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddAction(gg_trg_CounterForce, function Trig_CounterForce_Actions)
endfunction

