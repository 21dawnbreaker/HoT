//===========================================================================
// Trigger: LifeTap
//===========================================================================
function Trig_LifeTap_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A01F' ) ) then
        return false
    endif
    return true
endfunction

function Trig_LifeTap_Func001C takes nothing returns boolean
    if ( not ( ( R2I(GetUnitStateSwap(UNIT_STATE_LIFE, GetTriggerUnit())) * 100 ) <= ( ( R2I(GetUnitStateSwap(UNIT_STATE_MAX_LIFE, GetTriggerUnit())) * 1 ) * 30 ) ) ) then
        return false
    endif
    return true
endfunction

function Trig_LifeTap_Actions takes nothing returns nothing
    if ( Trig_LifeTap_Func001C() ) then
        call IssueImmediateOrderBJ(GetTriggerUnit(), "stop")
        call CreateTextTagUnitBJ("TRIGSTR_1720", GetTriggerUnit(), 0, 10, 100, 100, 100, 0)
        call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
        call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 3.00)
        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
    else
        call SetUnitLifePercentBJ(GetTriggerUnit(), ( GetUnitLifePercent(GetTriggerUnit()) - 30.00 ))
        call SetUnitManaPercentBJ(GetTriggerUnit(), ( GetUnitManaPercent(GetTriggerUnit()) + 35.00 ))
        call AddSpecialEffectLocBJ(PolarProjectionBJ(GetUnitLoc(GetTriggerUnit()), 30.00, 225.00), "MagicCircle_Demon.mdx")
        set udg_LifeTapSE=GetLastCreatedEffectBJ()
        call TriggerSleepAction(3.00)
        call DestroyEffectBJ(udg_LifeTapSE)
    endif
endfunction

