    if ( not ( GetSpellAbilityId() == 'A016' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Drop_Func001Func001C takes nothing returns boolean
    if ( not ( GetItemTypeId(UnitItemInSlotBJ(GetTriggerUnit(), GetForLoopIndexA())) != 'I08S' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Drop_Actions takes nothing returns nothing
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=6
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        if ( Trig_Drop_Func001Func001C() ) then
            call UnitRemoveItemFromSlotSwapped(GetForLoopIndexA(), GetTriggerUnit())
        else
        endif
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
endfunction

