    set gg_trg_GUI_AllowPlayerLoad=CreateTrigger()
    call DisableTrigger(gg_trg_GUI_AllowPlayerLoad)
    call TriggerAddAction(gg_trg_GUI_AllowPlayerLoad, function Trig_GUI_AllowPlayerLoad_Actions)
endfunction

