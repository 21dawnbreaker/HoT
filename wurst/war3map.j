    set gg_trg_Recklessness=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Recklessness, EVENT_PLAYER_UNIT_ATTACKED)
    call TriggerAddCondition(gg_trg_Recklessness, Condition(function Trig_Recklessness_Conditions))
    call TriggerAddAction(gg_trg_Recklessness, function Trig_Recklessness_Actions)
