    if ( not Trig_Despair_Func001Func002C() ) then
        return false
    endif
    return true
endfunction

function Trig_Despair_Actions takes nothing returns nothing
    if ( Trig_Despair_Func001C() ) then
        call SetUnitLifeBJ(GetSpellTargetUnit(), ( GetUnitStateSwap(UNIT_STATE_LIFE, GetSpellTargetUnit()) + ( GetUnitStateSwap(UNIT_STATE_MAX_LIFE, GetSpellTargetUnit()) * 0.50 ) ))
    else
        call SetUnitLifePercentBJ(GetSpellTargetUnit(), 100)
    endif
    set udg_tempLoc=GetUnitLoc(GetTriggerUnit())
    call CreateNUnitsAtLoc(1, 'h00W', Player(11), udg_tempLoc, bj_UNIT_FACING)
    call IssueTargetOrderBJ(GetLastCreatedUnit(), "thunderbolt", GetTriggerUnit())
    call UnitApplyTimedLifeBJ(2.00, 'BTLF', GetLastCreatedUnit())
    call RemoveLocation(udg_tempLoc)
endfunction

