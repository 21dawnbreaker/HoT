function InitTrig_ImpalesTimerExpire takes nothing returns nothing
    set gg_trg_ImpalesTimerExpire=CreateTrigger()
    call TriggerRegisterTimerExpireEventBJ(gg_trg_ImpalesTimerExpire, udg_RandomImpalesTimer)
    call TriggerAddAction(gg_trg_ImpalesTimerExpire, function Trig_ImpalesTimerExpire_Actions)
endfunction

