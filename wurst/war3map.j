        set udg_DifficultyVote[1]=( udg_DifficultyVote[1] + 1 )
        call DisplayTextToForce(GetPlayersAll(), ( GetPlayerName(GetTriggerPlayer()) + ( " - |cffdcdc00I'm too young to die" ) ))
    else
    endif
    if ( Trig_DifficultyVote_Func002C() ) then
        set udg_DifficultyVote[2]=( udg_DifficultyVote[2] + 1 )
        call DisplayTextToForce(GetPlayersAll(), ( GetPlayerName(GetTriggerPlayer()) + ( " - |cffdcdc00Ultra-violence|r" ) ))
    else
    endif
    if ( Trig_DifficultyVote_Func003C() ) then
        set udg_DifficultyVote[3]=( udg_DifficultyVote[3] + 1 )
        call DisplayTextToForce(GetPlayersAll(), ( GetPlayerName(GetTriggerPlayer()) + ( " - |cffff0000NIGHTMARE|r" ) ))
    else
    endif
    if ( Trig_DifficultyVote_Func004C() ) then
        call DisplayTextToForce(GetPlayersAll(), ( GetPlayerName(GetTriggerPlayer()) + ( " - |cffc0c0c0I don't care|r" ) ))
    else
    endif
endfunction

