// Trigger: ThrowAxes
//===========================================================================
function Trig_ThrowAxes_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A06Q' ) ) then
        return false
    endif
    return true
endfunction

function Trig_ThrowAxes_Actions takes nothing returns nothing
    call PlaySoundOnUnitBJ(gg_snd_Whirling_Axes__Ranged__mp3, 100, gg_unit_U005_0113)
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=5
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        set udg_ThrowAxesInt[GetForLoopIndexA()]=GetForLoopIndexA()
        set udg_ThrowAxesReal[GetForLoopIndexA()]=( ( GetUnitFacing(GetTriggerUnit()) - 60.00 ) + ( 20.00 * I2R(GetForLoopIndexA()) ) )
        set udg_ThrowAxesLoc[GetForLoopIndexA()]=PolarProjectionBJ(GetUnitLoc(GetTriggerUnit()), 50.00, udg_ThrowAxesReal[GetForLoopIndexA()])
        call CreateNUnitsAtLoc(1, 'h015', GetOwningPlayer(gg_unit_U006_0283), udg_ThrowAxesLoc[GetForLoopIndexA()], udg_ThrowAxesReal[GetForLoopIndexA()])
        call RemoveLocation(udg_ThrowAxesLoc[GetForLoopIndexA()])
        call UnitAddAbilityBJ('Amrf', GetLastCreatedUnit())
        call SetUnitFlyHeightBJ(GetLastCreatedUnit(), 100.00, 999.00)
        call SetUnitPathing(GetLastCreatedUnit(), false)
        set udg_ThrowAxesU[GetForLoopIndexA()]=GetLastCreatedUnit()
        call UnitApplyTimedLifeBJ(3.00, 'BTLF', GetLastCreatedUnit())
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    call EnableTrigger(gg_trg_ThrowAxesPeriodic)
    call TriggerSleepAction(4.00)
    call GroupRemoveGroup(udg_ThrowAxesUG, udg_ThrowAxesUG)
    call DisableTrigger(gg_trg_ThrowAxesPeriodic)
endfunction

