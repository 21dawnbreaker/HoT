//===========================================================================
function Trig_IngotsMagic_Conditions takes nothing returns boolean
    if ( not ( GetItemTypeId(GetSoldItem()) == 'I01K' ) ) then
        return false
    endif
    if ( not ( GetUnitTypeId(GetSellingUnit()) != 'h01D' ) ) then
        return false
    endif
    if ( not ( GetUnitTypeId(GetSellingUnit()) != 'h01E' ) ) then
        return false
    endif
    if ( not ( GetUnitTypeId(GetSellingUnit()) != 'h01F' ) ) then
        return false
    endif
    if ( not ( GetUnitTypeId(GetSellingUnit()) != 'h025' ) ) then
        return false
    endif
    return true
endfunction

function Trig_IngotsMagic_Func001C takes nothing returns boolean
    if ( not ( GetPlayerState(GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD) < 25 ) ) then
        return false
    endif
    return true
endfunction

function Trig_IngotsMagic_Actions takes nothing returns nothing
    if ( Trig_IngotsMagic_Func001C() ) then
        set udg_IngotFareU=GetBuyingUnit()
        call TriggerSleepAction(0.01)
        call SetPlayerStateBJ(GetOwningPlayer(udg_IngotFareU), PLAYER_STATE_RESOURCE_GOLD, ( GetPlayerState(GetOwningPlayer(udg_IngotFareU), PLAYER_STATE_RESOURCE_GOLD) + 50 ))
        call SetItemCharges(GetItemOfTypeFromUnitBJ(udg_IngotFareU, 'I01K'), ( GetItemCharges(GetItemOfTypeFromUnitBJ(udg_IngotFareU, 'I01K')) - 2 ))
        call CreateTextTagUnitBJ("TRIGSTR_7498", udg_IngotFareU, 0, 10, 100, 100, 100, 0)
        call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
        call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 3.00)
        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 90.00)
        call TriggerSleepAction(0.50)
        set udg_IngotFareU=null
    else
        call SetPlayerStateBJ(GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD, ( GetPlayerState(GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD) - 25 ))
        call CreateTextTagUnitBJ(( "Import product: |cffffff00-25" ), GetBuyingUnit(), 0, 10, 100, 100, 100, 0)
        call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
        call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 3.00)
        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 90.00)
    endif
endfunction

