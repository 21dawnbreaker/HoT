function Trig_HopesEndTimer_Actions takes nothing returns nothing
    call StopSoundBJ(udg_hopes_end_sound, false)
    call SetUnitManaPercentBJ(udg_Boss[1], 0.00)
    call DisableTrigger(gg_trg_HopesEndMovePeriodic)
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=4
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        call DestroyLightningBJ(udg_hopes_end_lightning[GetForLoopIndexA()])
        call RemoveLocation(udg_hopes_end_pos[GetForLoopIndexA()])
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
endfunction

//===========================================================================
function InitTrig_HopesEndTimer takes nothing returns nothing
    set gg_trg_HopesEndTimer=CreateTrigger()
    call TriggerRegisterTimerExpireEventBJ(gg_trg_HopesEndTimer, udg_hopes_end_timer)
    call TriggerAddAction(gg_trg_HopesEndTimer, function Trig_HopesEndTimer_Actions)
endfunction

//===========================================================================
// Trigger: EmilismaDies
//===========================================================================
function Trig_EmilismaDies_Func011A takes nothing returns nothing
    call SetCameraFieldForPlayer(GetEnumPlayer(), CAMERA_FIELD_TARGET_DISTANCE, 1650.00, 1.20)
endfunction

function Trig_EmilismaDies_Actions takes nothing returns nothing
    call GroupRemoveUnitSimple(gg_unit_H013_0011, udg_BossUG)
    set udg_MusicEmilisma=false
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=8
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        call DestroyEffectBJ(udg_harvest_eff[GetForLoopIndexA()])
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    call DisableTrigger(gg_trg_EmilismaPeriodic)
    call DisableTrigger(gg_trg_MagicStormPeriodic)
    call DisableTrigger(gg_trg_HarvestPeriodic)
    call DisableTrigger(gg_trg_HarvestMovePeriodic)
    call DisableTrigger(gg_trg_HopesEndPeriodic)
    call TriggerExecute(gg_trg_HopesEndTimer)
    call TriggerExecute(gg_trg_AtkivusEnd)
    call ForForce(udg_PlayerGroup, function Trig_EmilismaDies_Func011A)
endfunction

//===========================================================================
function InitTrig_EmilismaDies takes nothing returns nothing
    set gg_trg_EmilismaDies=CreateTrigger()
    call TriggerRegisterUnitEvent(gg_trg_EmilismaDies, gg_unit_H013_0011, EVENT_UNIT_DEATH)
    call TriggerAddAction(gg_trg_EmilismaDies, function Trig_EmilismaDies_Actions)
endfunction

//===========================================================================
// Trigger: AtkivusEscape
//===========================================================================
function Trig_AtkivusEscape_Actions takes nothing returns nothing
    call SetUnitAnimation(gg_unit_U007_0220, "stand")
    call CreateTextTagUnitBJ("TRIGSTR_9075", udg_Boss[1], 0, 10, 100, 100, 100, 0)
    call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
    call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 2.00)
    call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
    call TriggerSleepAction(2)
    call CreateTextTagUnitBJ("TRIGSTR_9076", udg_Boss[1], 0, 10, 100, 100, 100, 0)
    call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
    call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 3.00)
    call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
    call TriggerSleepAction(2.00)
    call RemoveUnit(gg_unit_H012_0027)
    call AddSpecialEffectLocBJ(GetUnitLoc(gg_unit_H012_0027), "Abilities\\Spells\\Human\\MassTeleport\\MassTeleportTarget.mdl")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call RemoveUnit(udg_ricardessa)
    call AddSpecialEffectLocBJ(GetUnitLoc(udg_ricardessa), "Abilities\\Spells\\Items\\RitualDagger\\RitualDaggerTarget.mdl")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 2.00)
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call TriggerSleepAction(1.00)
    call TriggerExecute(gg_trg_AtkivusEnd)
endfunction

//===========================================================================
function InitTrig_AtkivusEscape takes nothing returns nothing
    set gg_trg_AtkivusEscape=CreateTrigger()
    call TriggerAddAction(gg_trg_AtkivusEscape, function Trig_AtkivusEscape_Actions)
endfunction

//===========================================================================
// Trigger: AtkivusEnd
//===========================================================================
function Trig_AtkivusEnd_Actions takes nothing returns nothing
    call TriggerExecute(gg_trg_RicardessaDying)
    call TriggerExecute(gg_trg_BallLightningDestroy)
    call DisableTrigger(gg_trg_AtkivusPeriodic)
    call DisableTrigger(gg_trg_GiornosAidPeriodic)
    call DisableTrigger(gg_trg_ShadowdancePeriodic)
    call GroupRemoveUnitSimple(gg_unit_H012_0027, udg_BossUG)
    call GroupClear(udg_HeroesBossfightUG)
    set udg_Boss[1]=null
    set udg_BossfightAtkivus=- 1
    set udg_BossPhase=0
    call EndThematicMusicBJ()
    set udg_BossTheme=1
    set udg_BossfightMainIsOn=0
    set udg_musicOn=0
    call TriggerSleepAction(2.00)
    set udg_tempUnit=GetTriggerUnit()
    call TriggerExecute(gg_trg_BossDiesGeneralFunc)
    call QuestSetCompletedBJ(udg_Quests[5], true)
endfunction

//===========================================================================
function InitTrig_AtkivusEnd takes nothing returns nothing
    set gg_trg_AtkivusEnd=CreateTrigger()
    call TriggerRegisterUnitEvent(gg_trg_AtkivusEnd, gg_unit_H012_0027, EVENT_UNIT_DEATH)
    call TriggerAddAction(gg_trg_AtkivusEnd, function Trig_AtkivusEnd_Actions)
endfunction

