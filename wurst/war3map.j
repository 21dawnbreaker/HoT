//===========================================================================
// Trigger: Terror
//===========================================================================
function Trig_Terror_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A08N' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Terror_Func007Func001C takes nothing returns boolean
    if ( not ( IsUnitAlly(GetEnumUnit(), GetOwningPlayer(udg_TerrorC)) == true ) ) then
        return false
    endif
    if ( not ( UnitHasBuffBJ(GetEnumUnit(), 'B00J') == true ) ) then
        return false
    endif
    if ( not ( udg_TerrorC != GetEnumUnit() ) ) then
        return false
    endif
    return true
endfunction

function Trig_Terror_Func007A takes nothing returns nothing
    if ( Trig_Terror_Func007Func001C() ) then
        call GroupAddUnitSimple(GetEnumUnit(), udg_TerrorUG)
        call UnitAddAbilityBJ('Abun', GetEnumUnit())
    else
    endif
endfunction

function Trig_Terror_Func012A takes nothing returns nothing
    call UnitRemoveAbilityBJ('Abun', GetEnumUnit())
endfunction

function Trig_Terror_Actions takes nothing returns nothing
    call TriggerSleepAction(0.50)
    call UnitRemoveBuffBJ('B00J', udg_TerrorC)
    set udg_TerrorLoc=GetUnitLoc(GetTriggerUnit())
    call PlaySoundOnUnitBJ(gg_snd_InfernalJuggernautFire1, 100, udg_TerrorC)
    call ForGroupBJ(GetUnitsInRangeOfLocAll(300.00, GetUnitLoc(GetTriggerUnit())), function Trig_Terror_Func007A)
    call EnableTrigger(gg_trg_TerrorMove)
    call DisableTrigger(GetTriggeringTrigger())
    call TriggerSleepAction(4.50)
    set udg_TerrorC=null
    call ForGroupBJ(udg_TerrorUG, function Trig_Terror_Func012A)
    call GroupClear(udg_TerrorUG)
    call RemoveLocation(udg_TerrorLoc)
    call DisableTrigger(gg_trg_TerrorMove)
    call EnableTrigger(GetTriggeringTrigger())
    set udg_terror_is_avaible=true
endfunction

//===========================================================================
function InitTrig_Terror takes nothing returns nothing
    set gg_trg_Terror=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Terror, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_Terror, Condition(function Trig_Terror_Conditions))
    call TriggerAddAction(gg_trg_Terror, function Trig_Terror_Actions)
endfunction

