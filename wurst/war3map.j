//===========================================================================
// Trigger: TalentsInit
//===========================================================================
function Trig_TalentsInit_Actions takes nothing returns nothing
    call InitHashtableBJ()
    set udg_LastGraspHT=GetLastCreatedHashtableBJ()
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=24
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        set udg_TalentsPoolString[GetForLoopIndexA()]="| "
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    set udg_TalentUnitType[1]='o00W'
    set udg_TalentUnitType[2]='o00Z'
    set udg_TalentUnitType[3]='o010'
    set udg_TalentUnitType[4]='o011'
    set udg_TalentUnitType[5]='o012'
    set udg_TalentUnitType[6]='o013'
    set udg_TalentUnitType[7]='o015'
    set udg_TalentUnitType[8]='o016'
    set udg_TalentUnitType[9]='o017'
    set udg_TalentUnitType[10]='o018'
    set udg_TalentUnitType[11]='o019'
    set udg_TalentUnitType[12]='o01A'
    set udg_TalentUnitType[13]='o01B'
    set udg_TalentUnitType[14]='o01D'
    set udg_TalentUnitType[15]='o01C'
    set udg_TalentUnitType[16]='o00U'
    set udg_TalentUnitType[17]='o00Y'
    set udg_TalentUnitType[18]='o014'
    set udg_TalentUnitType[19]='o01E'
    set udg_TalentUnitType[20]='o01F'
    set udg_TalentUnitType[21]='o01G'
    set udg_TalentUnitType[22]='o01H'
    set udg_TalentUnitType[23]='o01I'
    set udg_TalentUnitType[24]='o01J'
    set udg_TalentUnitType[25]='o01K'
