function Trig_RecklessnessEternalFight_Actions takes nothing returns nothing
    if ( Trig_RecklessnessEternalFight_Func001C() ) then
        call UnitRemoveBuffBJ('B003', GetTriggerUnit())
        call SetUnitLifePercentBJ(GetTriggerUnit(), ( GetUnitLifePercent(GetTriggerUnit()) + 10.00 ))
        call SetUnitManaPercentBJ(GetTriggerUnit(), 50.00)
        call UnitAddAbilityBJ('A00C', GetTriggerUnit())
        call UnitAddAbilityBJ('A00Z', GetTriggerUnit())
        call CreateNUnitsAtLoc(1, 'h00F', GetOwningPlayer(GetTriggerUnit()), GetUnitLoc(GetTriggerUnit()), bj_UNIT_FACING)
        call UnitApplyTimedLifeBJ(1.00, 'BTLF', GetLastCreatedUnit())
        call IssueTargetOrderBJ(GetLastCreatedUnit(), "acidbomb", GetTriggerUnit())
        call CreateNUnitsAtLoc(1, 'h00F', GetOwningPlayer(GetTriggerUnit()), GetUnitLoc(GetTriggerUnit()), bj_UNIT_FACING)
        call UnitApplyTimedLifeBJ(1.00, 'BTLF', GetLastCreatedUnit())
        call TriggerSleepAction(13.00)
        if ( Trig_RecklessnessEternalFight_Func001Func012C() ) then
            call UnitRemoveAbilityBJ('A00C', GetTriggerUnit())
            call UnitRemoveAbilityBJ('A00Z', GetTriggerUnit())
