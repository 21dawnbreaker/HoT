    call StartTimerBJ(udg_InexorableTimer, false, 4.00)
    set udg_InexorableT=GetSpellTargetUnit()
    call DisableTrigger(gg_trg_ShiadalDamaged)
endfunction

//===========================================================================
function InitTrig_InexorableAssault takes nothing returns nothing
    set gg_trg_InexorableAssault=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_InexorableAssault, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_InexorableAssault, Condition(function Trig_InexorableAssault_Conditions))
    call TriggerAddAction(gg_trg_InexorableAssault, function Trig_InexorableAssault_Actions)
endfunction

//===========================================================================
// Trigger: InexorableAssaultTimer
//===========================================================================
function Trig_InexorableAssaultTimer_Actions takes nothing returns nothing
    call PauseUnitBJ(true, udg_Boss[1])
    call SetUnitAnimation(GetTriggerUnit(), "ready")
    call TriggerSleepAction(0.30)
    set udg_tempLoc=PolarProjectionBJ(GetUnitLoc(udg_InexorableT), 90.00, GetRandomDirectionDeg())
    set udg_tempLoc2=GetUnitLoc(udg_Boss[1])
    call SetUnitPositionLocFacingBJ(udg_Boss[1], udg_tempLoc, GetRandomDirectionDeg())
    call AddSpecialEffectLocBJ(udg_tempLoc2, "Winter Blast HD.mdx")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 0.50)
    call BlzSetSpecialEffectZ(GetLastCreatedEffectBJ(), BlzGetLocalUnitZ(udg_Boss[1]))
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call CreateNUnitsAtLocFacingLocBJ(1, 'E00B', Player(22), udg_tempLoc2, udg_tempLoc)
    call UnitApplyTimedLifeBJ(60, 'BTLF', GetLastCreatedUnit())
    call AddSpecialEffectLocBJ(udg_tempLoc, "Winter Blast HD.mdx")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 0.50)
    call BlzSetSpecialEffectZ(GetLastCreatedEffectBJ(), BlzGetLocalUnitZ(udg_Boss[1]))
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call UnitDamageTargetBJ(udg_Boss[1], udg_InexorableT, ( GetUnitStateSwap(UNIT_STATE_MAX_LIFE, udg_InexorableT) * 1.00 ), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_MAGIC)
    call AddSpecialEffectTargetUnitBJ("origin", udg_InexorableT, "Abilities\\Spells\\Undead\\FrostNova\\FrostNovaTarget.mdl")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call DestroyGroup(GetLastCreatedGroup())
    call RemoveLocation(udg_tempLoc)
    call RemoveLocation(udg_tempLoc2)
    set udg_InexorableT=null
    call TriggerSleepAction(0.50)
    call EnableTrigger(gg_trg_ShiadalDamaged)
    call PauseUnitBJ(false, udg_Boss[1])
endfunction

//===========================================================================
function InitTrig_InexorableAssaultTimer takes nothing returns nothing
    set gg_trg_InexorableAssaultTimer=CreateTrigger()
    call TriggerRegisterTimerExpireEventBJ(gg_trg_InexorableAssaultTimer, udg_InexorableTimer)
    call TriggerAddAction(gg_trg_InexorableAssaultTimer, function Trig_InexorableAssaultTimer_Actions)
endfunction

//===========================================================================
// Trigger: FrostCage
//===========================================================================
function Trig_FrostCage_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A0IF' ) ) then
        return false
    endif
    return true
endfunction

function Trig_FrostCage_Func003Func001C takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetEnumUnit()) != 'H004' ) ) then
        return false
    endif
    return true
endfunction

function Trig_FrostCage_Func003A takes nothing returns nothing
    if ( Trig_FrostCage_Func003Func001C() ) then
        call PauseUnitBJ(true, GetEnumUnit())
    else
    endif
endfunction

function Trig_FrostCage_Func019Func001C takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetEnumUnit()) == 'E00B' ) ) then
        return false
    endif
    return true
endfunction

function Trig_FrostCage_Func019A takes nothing returns nothing
    if ( Trig_FrostCage_Func019Func001C() ) then
        set udg_tempLoc=GetRandomLocInRect(gg_rct_ShiadalLoc2)
        set udg_tempLoc2=GetUnitLoc(GetEnumUnit())
        call SetUnitPositionLocFacingBJ(GetEnumUnit(), udg_tempLoc, 0.00)
        call AddSpecialEffectLocBJ(udg_tempLoc2, "Winter Blast HD.mdx")
        call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 0.50)
        call BlzSetSpecialEffectZ(GetLastCreatedEffectBJ(), ( BlzGetLocalUnitZ(udg_Boss[1]) - 50.00 ))
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call AddSpecialEffectLocBJ(udg_tempLoc, "Winter Blast HD.mdx")
        call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 0.50)
        call BlzSetSpecialEffectZ(GetLastCreatedEffectBJ(), ( BlzGetLocalUnitZ(udg_Boss[1]) - 50.00 ))
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call RemoveLocation(udg_tempLoc)
        call RemoveLocation(udg_tempLoc2)
    else
    endif
endfunction

function Trig_FrostCage_Func022Func001C takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetEnumUnit()) != 'H004' ) ) then
        return false
    endif
    if ( not ( GetUnitTypeId(GetEnumUnit()) != 'e008' ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(GetTriggerUnit())) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_FrostCage_Func022A takes nothing returns nothing
    if ( Trig_FrostCage_Func022Func001C() ) then
        set udg_tempLoc=GetRandomLocInRect(gg_rct_ShiadalLoc)
        set udg_tempLoc2=GetUnitLoc(GetEnumUnit())
        call SetUnitPositionLocFacingBJ(GetEnumUnit(), udg_tempLoc, 180.00)
        call PanCameraToTimedLocForPlayer(GetOwningPlayer(GetEnumUnit()), udg_tempLoc, 0.50)
        call SetUnitAnimation(GetEnumUnit(), "ready")
        call AddSpecialEffectLocBJ(udg_tempLoc2, "Winter Blast HD.mdx")
        call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 0.50)
        call BlzSetSpecialEffectZ(GetLastCreatedEffectBJ(), ( BlzGetLocalUnitZ(udg_Boss[1]) - 50.00 ))
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call RemoveLocation(udg_tempLoc)
        call RemoveLocation(udg_tempLoc2)
    else
    endif
endfunction

function Trig_FrostCage_Actions takes nothing returns nothing
    call PlaySoundOnUnitBJ(gg_snd_ShandrisPissed2, 100, GetTriggerUnit())
    call StartTimerBJ(udg_FrostCageTimer, false, 2.00)
    call ForGroupBJ(GetUnitsInRectAll(gg_rct_MainBossLoc), function Trig_FrostCage_Func003A)
    // -
    set udg_tempLoc=GetRectCenter(gg_rct_BossfightBossLoc)
    set udg_tempLoc2=GetUnitLoc(udg_Boss[1])
    call SetUnitPositionLocFacingBJ(udg_Boss[1], udg_tempLoc, 0.00)
    call AddSpecialEffectLocBJ(udg_tempLoc2, "Winter Blast HD.mdx")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 0.50)
    call BlzSetSpecialEffectZ(GetLastCreatedEffectBJ(), ( BlzGetLocalUnitZ(udg_Boss[1]) - 50.00 ))
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call AddSpecialEffectLocBJ(udg_tempLoc, "Winter Blast HD.mdx")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 0.50)
    call BlzSetSpecialEffectZ(GetLastCreatedEffectBJ(), ( BlzGetLocalUnitZ(udg_Boss[1]) - 50.00 ))
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call RemoveLocation(udg_tempLoc)
    call RemoveLocation(udg_tempLoc2)
    // -
    call ForGroupBJ(GetUnitsInRectAll(gg_rct_MainBossLoc), function Trig_FrostCage_Func019A)
    call DestroyGroup(GetLastCreatedGroup())
    // -
    call ForGroupBJ(GetUnitsInRectAll(gg_rct_MainBossLoc), function Trig_FrostCage_Func022A)
    call DestroyGroup(GetLastCreatedGroup())
    set udg_tempLoc=GetRectCenter(gg_rct_ShiadalLoc)
    call AddSpecialEffectLocBJ(udg_tempLoc, "Winter Blast HD.mdx")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 3.50)
    call BlzSetSpecialEffectZ(GetLastCreatedEffectBJ(), ( BlzGetLocalUnitZ(udg_Boss[1]) - 50.00 ))
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call RemoveLocation(udg_tempLoc)
    call PauseUnitBJ(true, GetTriggerUnit())
endfunction

//===========================================================================
function InitTrig_FrostCage takes nothing returns nothing
    set gg_trg_FrostCage=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_FrostCage, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_FrostCage, Condition(function Trig_FrostCage_Conditions))
    call TriggerAddAction(gg_trg_FrostCage, function Trig_FrostCage_Actions)
endfunction

//===========================================================================
// Trigger: FrostCageTimer
//===========================================================================
function Trig_FrostCageTimer_Func006Func001C takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetEnumUnit()) != 'H004' ) ) then
        return false
    endif
    return true
endfunction

function Trig_FrostCageTimer_Func006A takes nothing returns nothing
    if ( Trig_FrostCageTimer_Func006Func001C() ) then
        call PauseUnitBJ(false, GetEnumUnit())
    else
    endif
endfunction

function Trig_FrostCageTimer_Actions takes nothing returns nothing
    set udg_tempReal=30.00
    set udg_tempLoc2=GetRectCenter(gg_rct_ShiadalLoc)
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=6
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        set udg_tempLoc=PolarProjectionBJ(GetRectCenter(gg_rct_ShiadalLoc), 600.00, udg_tempReal)
        call CreateNUnitsAtLocFacingLocBJ(1, 'E00B', Player(22), udg_tempLoc, udg_tempLoc2)
        call UnitApplyTimedLifeBJ(GetRandomReal(59.00, 61.00), 'BTLF', GetLastCreatedUnit())
        call AddSpecialEffectLocBJ(udg_tempLoc, "Winter Blast HD.mdx")
        call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 0.50)
        call BlzSetSpecialEffectZ(GetLastCreatedEffectBJ(), BlzGetLocalUnitZ(udg_Boss[1]))
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call RemoveLocation(udg_tempLoc)
        set udg_tempReal=( udg_tempReal + 60.00 )
        call PauseUnitBJ(true, GetLastCreatedUnit())
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    call RemoveLocation(udg_tempLoc2)
    call TriggerSleepAction(3.00)
    call ForGroupBJ(GetUnitsInRectAll(gg_rct_MainBossLoc), function Trig_FrostCageTimer_Func006A)
    call DestroyGroup(GetLastCreatedGroup())
    call PauseUnitBJ(false, udg_Boss[1])
endfunction

//===========================================================================
function InitTrig_FrostCageTimer takes nothing returns nothing
    set gg_trg_FrostCageTimer=CreateTrigger()
    call TriggerRegisterTimerExpireEventBJ(gg_trg_FrostCageTimer, udg_FrostCageTimer)
    call TriggerAddAction(gg_trg_FrostCageTimer, function Trig_FrostCageTimer_Actions)
endfunction

