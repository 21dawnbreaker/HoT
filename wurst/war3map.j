    call TriggerRegisterUnitEvent(gg_trg_Phase_1_NataAra, gg_unit_U006_0283, EVENT_UNIT_ATTACKED)
    call TriggerRegisterUnitEvent(gg_trg_Phase_1_NataAra, gg_unit_U005_0113, EVENT_UNIT_ATTACKED)
    call TriggerAddAction(gg_trg_Phase_1_NataAra, function Trig_Phase_1_NataAra_Actions)
endfunction

