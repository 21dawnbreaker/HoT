    if ( Trig_Warlocks_Func002Func001C() ) then
        call BlzSetUnitMaxMana(GetEnumUnit(), ( BlzGetUnitMaxMana(GetEnumUnit()) + 2 ))
        call SetUnitManaPercentBJ(GetEnumUnit(), ( GetUnitManaPercent(GetEnumUnit()) + 1.00 ))
    else
    endif
endfunction

