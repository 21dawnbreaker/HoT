//===========================================================================
function Trig_FeralSpider_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A0GZ' ) ) then
        return false
    endif
    return true
endfunction

function Trig_FeralSpider_Actions takes nothing returns nothing
    call PlaySoundOnUnitBJ(gg_snd_SpiderYesAttack1, 100, GetTriggerUnit())
    set udg_tempInt=( udg_RoomInt * 5 )
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=GetRandomInt(1, 5)
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        set udg_tempLoc=GetRandomLocInRect(udg_EnemyRoomReg[udg_tempInt])
        call CreateNUnitsAtLoc(1, 'o02O', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc, GetRandomDirectionDeg())
        call UnitApplyTimedLifeBJ(12.00, 'BTLF', GetLastCreatedUnit())
        call AddSpecialEffectLocBJ(udg_tempLoc, "Doodads\\Dungeon\\Terrain\\EggSack\\EggSack0.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call RemoveLocation(udg_tempLoc)
        set udg_tempInt=( udg_tempInt - 1 )
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    set udg_tempInt=0
endfunction

