function Trig_Riptide_Actions takes nothing returns nothing
    set udg_tempLoc=GetUnitLoc(GetSpellTargetUnit())
    call AddSpecialEffectLocBJ(udg_tempLoc, "Tidal Burst.mdx")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call RemoveLocation(udg_tempLoc)
    if ( Trig_Riptide_Func005C() ) then
        call SetUnitLifePercentBJ(GetSpellTargetUnit(), ( GetUnitLifePercent(GetSpellTargetUnit()) + 7.00 ))
    else
        if ( Trig_Riptide_Func005Func001C() ) then
            call SetUnitLifePercentBJ(GetSpellTargetUnit(), ( GetUnitLifePercent(GetSpellTargetUnit()) + 9.00 ))
        else
            if ( Trig_Riptide_Func005Func001Func001C() ) then
                call SetUnitLifePercentBJ(GetSpellTargetUnit(), ( GetUnitLifePercent(GetSpellTargetUnit()) + 11.00 ))
            else
                if ( Trig_Riptide_Func005Func001Func001Func001C() ) then
                    call SetUnitLifePercentBJ(GetSpellTargetUnit(), ( GetUnitLifePercent(GetSpellTargetUnit()) + 13.00 ))
                else
                    if ( Trig_Riptide_Func005Func001Func001Func001Func001C() ) then
                        call SetUnitLifePercentBJ(GetSpellTargetUnit(), ( GetUnitLifePercent(GetSpellTargetUnit()) + 15.00 ))
                    else
                    endif
                endif
            endif
        endif
    endif
endfunction

