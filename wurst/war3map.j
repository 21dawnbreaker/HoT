    call SaveIntegerBJ(udg_player_mutagens[udg_NSL_PlayerId], 1, udg_NSL_PlayerId, udg_NSL_GUIHashtable)
    call SaveIntegerBJ(udg_player_rooms_normal[udg_NSL_PlayerId], 2, udg_NSL_PlayerId, udg_NSL_GUIHashtable)
    call SaveIntegerBJ(udg_player_rooms_nightmare[udg_NSL_PlayerId], 3, udg_NSL_PlayerId, udg_NSL_GUIHashtable)
    // When finished saving, set `NSL_EventExecutorSaveCompleted` to 1.0
    set udg_NSL_EventExecutorSaveCompleted=1.00
endfunction

