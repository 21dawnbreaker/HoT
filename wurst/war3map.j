function Trig_UnstableAffliction_Func002A takes nothing returns nothing
    if ( Trig_UnstableAffliction_Func002Func001C() ) then
    else
        set udg_UnstableAfllInt=( udg_UnstableAfllInt + 1 )
    endif
    if ( Trig_UnstableAffliction_Func002Func002C() ) then
    else
        set udg_UnstableAfllInt=( udg_UnstableAfllInt + 1 )
    endif
    if ( Trig_UnstableAffliction_Func002Func003C() ) then
    else
        set udg_UnstableAfllInt=( udg_UnstableAfllInt + 1 )
    endif
    call UnitDamageTargetBJ(GetTriggerUnit(), GetEnumUnit(), ( ( I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) * ( 40.00 * I2R(udg_UnstableAfllInt) ) ) + ( I2R(GetHeroStatBJ(bj_HEROSTAT_INT, GetTriggerUnit(), true)) * ( ( 0.25 * I2R(udg_UnstableAfllInt) ) * I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) ) ) ), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_MAGIC)
    call AddSpecialEffectTargetUnitBJ("origin", GetEnumUnit(), "Soul Discharge.mdx")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    set udg_UnstableAfllInt=0
    call UnitRemoveBuffBJ('B01M', GetEnumUnit())
    call UnitRemoveBuffBJ('B01L', GetEnumUnit())
    call UnitRemoveBuffBJ('B01K', GetEnumUnit())
    call GroupRemoveUnitSimple(GetEnumUnit(), udg_DamnationUG)
