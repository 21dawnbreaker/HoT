//===========================================================================
// Trigger: GoldRewardingGeneral
//===========================================================================
function Trig_GoldRewardingGeneral_Conditions takes nothing returns boolean
    if ( not ( IsUnitInGroup(GetTriggerUnit(), udg_RoomEnemyUG) == true ) ) then
        return false
    endif
    if ( not ( udg_PathGold == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_GoldRewardingGeneral_Func002Func011Func001C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 4) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_GoldRewardingGeneral_Func002C takes nothing returns boolean
    if ( not ( RectContainsUnit(udg_RoomReg[udg_RoomInt], GetTriggerUnit()) == true ) ) then
        return false
    endif
    if ( not ( CountUnitsInGroup(udg_RoomEnemyUG) == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_GoldRewardingGeneral_Actions takes nothing returns nothing
    call GroupRemoveUnitSimple(GetTriggerUnit(), udg_RoomEnemyUG)
    if ( Trig_GoldRewardingGeneral_Func002C() ) then
        call TriggerExecute(gg_trg_RewardingGeneral)
        call ConditionalTriggerExecute(gg_trg_HeroResFunc)
        set udg_EncounterEndInt=1
        call ConditionalTriggerExecute(gg_trg_RewardingChestsRollFunc)
        set udg_tempLoc=GetRandomLocInRect(udg_RewardRoom[udg_RoomInt])
        set udg_tempZ=GetLocationZ(udg_tempLoc)
        call PlaySoundAtPointBJ(gg_snd_GoldSoundEff1, 100, udg_tempLoc, udg_tempZ)
        set udg_tempZ=0.00
        call RemoveLocation(udg_tempLoc)
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=CountPlayersInForceBJ(udg_PlayerGroup)
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            set udg_tempLoc=GetRandomLocInRect(udg_RewardRoom[udg_RoomInt])
            call CreateItemLoc('I03U', udg_tempLoc)
            call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\NightElf\\Blink\\BlinkTarget.mdl")
            call DestroyEffectBJ(GetLastCreatedEffectBJ())
            call RemoveLocation(udg_tempLoc)
            set bj_forLoopAIndex=bj_forLoopAIndex + 1
        endloop
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=( CountPlayersInForceBJ(udg_PlayerGroup) + 3 )
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            if ( Trig_GoldRewardingGeneral_Func002Func011Func001C() ) then
                set udg_tempLoc=GetRandomLocInRect(udg_RewardRoom[udg_RoomInt])
                call CreateItemLoc('I03T', udg_tempLoc)
                call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\NightElf\\Blink\\BlinkTarget.mdl")
                call DestroyEffectBJ(GetLastCreatedEffectBJ())
                call RemoveLocation(udg_tempLoc)
            else
            endif
            set bj_forLoopAIndex=bj_forLoopAIndex + 1
        endloop
    else
    endif
endfunction

//===========================================================================
