function InitTrig_tL33_Copy takes nothing returns nothing
    set gg_trg_tL33_Copy=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_tL33_Copy, EVENT_PLAYER_UNIT_DEATH)
    call TriggerAddCondition(gg_trg_tL33_Copy, Condition(function Trig_tL33_Copy_Conditions))
    call TriggerAddAction(gg_trg_tL33_Copy, function Trig_tL33_Copy_Actions)
