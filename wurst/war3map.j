            else
            endif
            // -
            // minimal 10%
            if ( Trig_GlobalDamageEvent_Func011Func007Func014C() ) then
                set udg_DamageEventAmount=( udg_temp_damage * 0.10 )
            else
            endif
        else
        endif
        // -
        set udg_temp_damage=0.00
        set udg_damage_to_be_added=0.00
    else
