        call PlaySoundOnUnitBJ(gg_snd_Spell_HU_Kill_Command_Cast_0301, 100, GetEnumUnit())
        call GroupAddUnitSimple(GetEnumUnit(), udg_HeadhunterUG)
        call ForceAddPlayerSimple(GetOwningPlayer(GetTriggerUnit()), udg_HeadhunterPG)
        call IncUnitAbilityLevelSwapped('A0AA', GetEnumUnit())
        call UnitAddAbilityBJ('A0AA', GetEnumUnit())
        if ( Trig_tL33_Func001Func001Func006C() ) then
            call DisplayTextToForce(GetPlayersAll(), ( GetHeroProperName(GetEnumUnit()) + " становится охотником за головами!" ))
