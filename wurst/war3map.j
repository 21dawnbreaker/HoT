//===========================================================================
// Trigger: RaiseDeadUp
//===========================================================================
function Trig_RaiseDeadUp_Actions takes nothing returns nothing
    set udg_RaiseDeadInt=( udg_RaiseDeadInt + 1 )
endfunction

//===========================================================================
function InitTrig_RaiseDeadUp takes nothing returns nothing
    set gg_trg_RaiseDeadUp=CreateTrigger()
    call DisableTrigger(gg_trg_RaiseDeadUp)
    call TriggerRegisterTimerEventPeriodic(gg_trg_RaiseDeadUp, 540.00)
    call TriggerAddAction(gg_trg_RaiseDeadUp, function Trig_RaiseDeadUp_Actions)
