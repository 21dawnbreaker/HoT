//===========================================================================
// Trigger: TornadoMove
//===========================================================================
function Trig_TornadoMove_Func001Func001Func001C takes nothing returns boolean
    if ( not ( IsUnitType(GetEnumUnit(), UNIT_TYPE_HERO) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_TornadoMove_Func001Func001C takes nothing returns boolean
    if ( not ( DistanceBetweenPoints(GetUnitLoc(GetEnumUnit()), udg_TornadoLoc) >= 100.00 ) ) then
        return false
    endif
    if ( not ( IsUnitType(GetEnumUnit(), UNIT_TYPE_STRUCTURE) == false ) ) then
        return false
    endif
    if ( not ( BlzIsUnitInvulnerable(GetEnumUnit()) == false ) ) then
        return false
    endif
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(gg_unit_H00M_0276)) == true ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( IsUnitInGroup(GetEnumUnit(), udg_not_knockbackable_UG) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_TornadoMove_Func001A takes nothing returns nothing
    if ( Trig_TornadoMove_Func001Func001C() ) then
        if ( Trig_TornadoMove_Func001Func001Func001C() ) then
            set udg_tempLoc2=GetUnitLoc(GetEnumUnit())
            set udg_tempLoc=PolarProjectionBJ(udg_tempLoc2, 3.00, AngleBetweenPoints(GetUnitLoc(GetEnumUnit()), udg_TornadoLoc))
            call SetUnitX(GetEnumUnit(), ( GetLocationX(udg_tempLoc) ))
            call SetUnitY(GetEnumUnit(), ( GetLocationY(udg_tempLoc) ))
            call RemoveLocation(udg_tempLoc)
            call RemoveLocation(udg_tempLoc2)
        else
            set udg_tempLoc2=GetUnitLoc(GetEnumUnit())
            set udg_tempLoc=PolarProjectionBJ(udg_tempLoc2, 1.00, AngleBetweenPoints(GetUnitLoc(GetEnumUnit()), udg_TornadoLoc))
            call SetUnitX(GetEnumUnit(), ( GetLocationX(udg_tempLoc) ))
            call SetUnitY(GetEnumUnit(), ( GetLocationY(udg_tempLoc) ))
            call RemoveLocation(udg_tempLoc)
            call RemoveLocation(udg_tempLoc2)
        endif
    else
    endif
endfunction

function Trig_TornadoMove_Actions takes nothing returns nothing
    call ForGroupBJ(GetUnitsInRangeOfLocAll(( 300.00 + ( 200.00 * I2R(GetUnitAbilityLevelSwapped('A0G1', gg_unit_H00M_0276)) ) ), udg_TornadoLoc), function Trig_TornadoMove_Func001A)
endfunction

