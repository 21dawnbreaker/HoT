//===========================================================================
// Trigger: SoulShatter
//===========================================================================
function Trig_SoulShatter_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A0H1' ) ) then
        return false
    endif
    return true
endfunction

function Trig_SoulShatter_Func002Func001C takes nothing returns boolean
    if ( not ( IsUnitAliveBJ(udg_Hero[GetForLoopIndexA()]) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_SoulShatter_Actions takes nothing returns nothing
    call PlaySoundOnUnitBJ(gg_snd_FacelessDeath1, 100, GetTriggerUnit())
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=udg_HeroNumber
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        if ( Trig_SoulShatter_Func002Func001C() ) then
            set udg_tempLoc=PolarProjectionBJ(GetUnitLoc(udg_Hero[GetForLoopIndexA()]), 400.00, GetRandomDirectionDeg())
            set udg_tempLoc2=GetUnitLoc(udg_Hero[GetForLoopIndexA()])
            call CreateNUnitsAtLocFacingLocBJ(1, GetUnitTypeId(udg_Hero[GetForLoopIndexA()]), GetOwningPlayer(GetTriggerUnit()), udg_tempLoc, udg_tempLoc2)
            call GroupAddUnitSimple(GetLastCreatedUnit(), udg_SoulShatterUG)
            set udg_SoulShatterDummy[GetForLoopIndexA()]=GetLastCreatedUnit()
            call UnitApplyTimedLifeBJ(15.00, 'BTLF', GetLastCreatedUnit())
            set bj_forLoopBIndex=1
            set bj_forLoopBIndexEnd=6
            loop
                exitwhen bj_forLoopBIndex > bj_forLoopBIndexEnd
                call RemoveItem(UnitItemInSlotBJ(GetLastCreatedUnit(), GetForLoopIndexB()))
                set bj_forLoopBIndex=bj_forLoopBIndex + 1
            endloop
            call BlzSetUnitMaxMana(GetLastCreatedUnit(), 0)
            call SetUnitPathing(GetLastCreatedUnit(), false)
            call UnitAddAbilityBJ('Abun', GetLastCreatedUnit())
            call SetUnitMoveSpeed(GetLastCreatedUnit(), 125.00)
            call SetUnitVertexColorBJ(GetLastCreatedUnit(), 75.00, 25.00, 75.00, 50.00)
            call AddSpecialEffectLocBJ(udg_tempLoc, "Stormfall Red.mdx")
            call DestroyEffectBJ(GetLastCreatedEffectBJ())
            call UnitAddAbilityBJ('Avul', GetLastCreatedUnit())
            call UnitAddAbilityBJ('Aloc', GetLastCreatedUnit())
            call RemoveLocation(udg_tempLoc)
            call RemoveLocation(udg_tempLoc2)
        else
        endif
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    call EnableTrigger(gg_trg_SoulShatterPeriodic)
endfunction

//===========================================================================
function InitTrig_SoulShatter takes nothing returns nothing
    set gg_trg_SoulShatter=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_SoulShatter, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_SoulShatter, Condition(function Trig_SoulShatter_Conditions))
    call TriggerAddAction(gg_trg_SoulShatter, function Trig_SoulShatter_Actions)
endfunction

