// Trigger: ShockRay
//===========================================================================
function Trig_ShockRay_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A068' ) ) then
        return false
    endif
    return true
endfunction

function Trig_ShockRay_Actions takes nothing returns nothing
    set udg_tempLoc=GetUnitLoc(gg_unit_H00M_0276)
    set udg_tempZ=GetLocationZ(udg_tempLoc)
    call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Weapons\\FireBallMissile\\FireBallMissile.mdl")
    set udg_ShockRayEff=GetLastCreatedEffectBJ()
    call BlzSetSpecialEffectHeight(GetLastCreatedEffectBJ(), ( udg_tempZ + 300.00 ))
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 5.00)
    set udg_ShockRayReal=AngleBetweenPoints(udg_tempLoc, GetSpellTargetLoc())
    call CreateNUnitsAtLoc(1, 'h010', GetOwningPlayer(GetTriggerUnit()), PolarProjectionBJ(udg_tempLoc, 100.00, udg_ShockRayReal), bj_UNIT_FACING)
    call UnitAddAbilityBJ('Amrf', GetLastCreatedUnit())
    call SetUnitFlyHeightBJ(GetLastCreatedUnit(), 0.00, 9999999.00)
    call SetUnitPathing(GetLastCreatedUnit(), false)
    call UnitApplyTimedLifeBJ(3.00, 'BTLF', GetLastCreatedUnit())
    set udg_ShockRayU=GetLastCreatedUnit()
    call CreateNUnitsAtLoc(1, 'h00Z', GetOwningPlayer(GetTriggerUnit()), PolarProjectionBJ(udg_tempLoc, - 150.00, udg_ShockRayReal), bj_UNIT_FACING)
    set udg_ShockRayU_Copy=GetLastCreatedUnit()
    call IssueTargetOrderBJ(GetLastCreatedUnit(), "attack", udg_ShockRayU)
    call UnitApplyTimedLifeBJ(3.00, 'BTLF', GetLastCreatedUnit())
    call RemoveLocation(udg_tempLoc)
    set udg_tempZ=0.00
    call EnableTrigger(gg_trg_ShockRayMove)
    call TriggerSleepAction(2.50)
    call RemoveUnit(udg_ShockRayU)
    call RemoveUnit(udg_ShockRayU_Copy)
    call DestroyEffectBJ(udg_ShockRayEff)
    call DisableTrigger(gg_trg_ShockRayMove)
endfunction

