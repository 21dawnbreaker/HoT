    set gg_trg_ElementalSummoning=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_ElementalSummoning, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_ElementalSummoning, Condition(function Trig_ElementalSummoning_Conditions))
    call TriggerAddAction(gg_trg_ElementalSummoning, function Trig_ElementalSummoning_Actions)
