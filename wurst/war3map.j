    set gg_trg_EmilismaSpawn=CreateTrigger()
    call TriggerRegisterPlayerChatEvent(gg_trg_EmilismaSpawn, Player(0), "-elisma", true)
    call TriggerAddAction(gg_trg_EmilismaSpawn, function Trig_EmilismaSpawn_Actions)
endfunction

