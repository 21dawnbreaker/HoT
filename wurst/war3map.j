// Trigger: BossDiesGeneralFunc
//
// func expects tempUnit
//===========================================================================
function Trig_BossDiesGeneralFunc_Func003Func001C takes nothing returns boolean
    if ( ( udg_tempUnit == gg_unit_H012_0027 ) ) then
        return true
    endif
    if ( ( udg_tempUnit == gg_unit_H013_0011 ) ) then
        return true
    endif
    return false
endfunction

function Trig_BossDiesGeneralFunc_Func003Func002C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 2) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_BossDiesGeneralFunc_Func003C takes nothing returns boolean
    if ( not Trig_BossDiesGeneralFunc_Func003Func001C() ) then
        return false
    endif
    return true
endfunction

function Trig_BossDiesGeneralFunc_Func004C takes nothing returns boolean
    if ( not ( udg_tempUnit == gg_unit_U005_0113 ) ) then
        return false
    endif
    return true
endfunction

