//===========================================================================
function Trig_NightHunter_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A06T' ) ) then
        return false
    endif
    return true
endfunction

function Trig_NightHunter_Actions takes nothing returns nothing
    call PlaySoundOnUnitBJ(gg_snd_DevourMagic, 100, gg_unit_U006_0283)
    call PlaySoundOnUnitBJ(gg_snd_VarimathrasYesAttack2, 100, GetTriggerUnit())
    call SetUnitColor(GetTriggerUnit(), ConvertPlayerColor(24))
    call SetUnitPathing(GetTriggerUnit(), false)
    call UnitAddAbilityBJ('A06R', GetTriggerUnit())
    call UnitAddAbilityBJ('A06U', GetTriggerUnit())
    call UnitAddAbilityBJ('A06S', GetTriggerUnit())
    call SetUnitAbilityLevelSwapped('A06S', GetTriggerUnit(), ( udg_DIFFICULTY * 1 ))
    call AddSpecialEffectTargetUnitBJ("chest", GetTriggerUnit(), "Abilities\\Weapons\\AvengerMissile\\AvengerMissile.mdl")
    set udg_NightHunterEff[1]=GetLastCreatedEffectBJ()
    call AddSpecialEffectTargetUnitBJ("left hand", GetTriggerUnit(), "Abilities\\Weapons\\AvengerMissile\\AvengerMissile.mdl")
    set udg_NightHunterEff[2]=GetLastCreatedEffectBJ()
    call AddSpecialEffectTargetUnitBJ("right hand", GetTriggerUnit(), "Abilities\\Weapons\\AvengerMissile\\AvengerMissile.mdl")
    set udg_NightHunterEff[3]=GetLastCreatedEffectBJ()
    call StartTimerBJ(udg_NightHunterTimer, false, 12.00)
endfunction

//===========================================================================
