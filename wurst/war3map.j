//===========================================================================
// Trigger: Obliterate
//===========================================================================
function Trig_Obliterate_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A0IG' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Obliterate_Func003Func001C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped('A0IG', GetTriggerUnit()) < 10 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Obliterate_Func003C takes nothing returns boolean
    if ( not ( UnitHasBuffBJ(GetSpellTargetUnit(), 'B03T') == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Obliterate_Func006Func001C takes nothing returns boolean
    if ( ( IsUnitType(GetSpellTargetUnit(), UNIT_TYPE_HERO) == true ) ) then
        return true
    endif
    if ( ( GetUnitTypeId(GetSpellTargetUnit()) == 'n00B' ) ) then
        return true
    endif
    return false
endfunction

function Trig_Obliterate_Func006C takes nothing returns boolean
    if ( not Trig_Obliterate_Func006Func001C() ) then
        return false
    endif
    return true
endfunction

function Trig_Obliterate_Actions takes nothing returns nothing
    call PlaySoundOnUnitBJ(gg_snd_MetalHeavySliceFlesh2, 100, GetTriggerUnit())
    call PlaySoundOnUnitBJ(gg_snd_Obliterate_Revamp_Cast01, 100, GetTriggerUnit())
    if ( Trig_Obliterate_Func003C() ) then
        if ( Trig_Obliterate_Func003Func001C() ) then
            call IncUnitAbilityLevelSwapped('A0IG', GetTriggerUnit())
        else
        endif
    else
        call SetUnitAbilityLevelSwapped('A0IG', GetTriggerUnit(), ( GetUnitAbilityLevelSwapped('A0IG', GetTriggerUnit()) - 2 ))
    endif
    call AddSpecialEffectTargetUnitBJ("weapon", GetTriggerUnit(), "Abilities\\Weapons\\ZigguratFrostMissile\\ZigguratFrostMissile.mdl")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    if ( Trig_Obliterate_Func006C() ) then
        call UnitDamageTargetBJ(GetTriggerUnit(), GetSpellTargetUnit(), ( I2R(BlzGetUnitBaseDamage(GetTriggerUnit(), 0)) * ( 3.00 * I2R(GetUnitAbilityLevelSwapped('A0IG', GetTriggerUnit())) ) ), ATTACK_TYPE_MELEE, DAMAGE_TYPE_NORMAL)
    else
        set udg_tempUnit=GetSpellTargetUnit()
        call TriggerExecute(gg_trg_FreezeFunc)
        call UnitDamageTargetBJ(GetTriggerUnit(), GetSpellTargetUnit(), 10.00, ATTACK_TYPE_MELEE, DAMAGE_TYPE_NORMAL)
        set udg_tempUnit=null
    endif
    call AddSpecialEffectTargetUnitBJ("chest", GetSpellTargetUnit(), "Ephemeral Cut Midnight.mdx")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 1.50)
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
endfunction

//===========================================================================
function InitTrig_Obliterate takes nothing returns nothing
    set gg_trg_Obliterate=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Obliterate, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_Obliterate, Condition(function Trig_Obliterate_Conditions))
    call TriggerAddAction(gg_trg_Obliterate, function Trig_Obliterate_Actions)
endfunction

