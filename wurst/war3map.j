//===========================================================================
function Trig_ThrowAxesPeriodic_Func001Func001C takes nothing returns boolean
    if ( not ( RectContainsUnit(gg_rct_MainBossLoc, udg_ThrowAxesU[GetForLoopIndexA()]) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_ThrowAxesPeriodic_Func001Func002Func003Func001Func001C takes nothing returns boolean
    if ( not ( IsUnitInGroup(GetEnumUnit(), udg_MinionsUG) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_ThrowAxesPeriodic_Func001Func002Func003Func001C takes nothing returns boolean
    if ( not ( IsUnitEnemy(GetEnumUnit(), Player(19)) == true ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( IsUnitInGroup(GetEnumUnit(), udg_ThrowAxesUG) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_ThrowAxesPeriodic_Func001Func002Func003A takes nothing returns nothing
    if ( Trig_ThrowAxesPeriodic_Func001Func002Func003Func001C() ) then
        if ( Trig_ThrowAxesPeriodic_Func001Func002Func003Func001Func001C() ) then
            call UnitDamageTargetBJ(gg_unit_U005_0113, GetEnumUnit(), ( I2R(BlzGetUnitBaseDamage(gg_unit_U005_0113, 0)) * 3.00 ), ATTACK_TYPE_MELEE, DAMAGE_TYPE_NORMAL)
        else
            call UnitDamageTargetBJ(gg_unit_U005_0113, GetEnumUnit(), ( 0.10 * ( I2R(BlzGetUnitBaseDamage(gg_unit_U005_0113, 0)) * 3.00 ) ), ATTACK_TYPE_MELEE, DAMAGE_TYPE_NORMAL)
        endif
        call GroupAddUnitSimple(GetEnumUnit(), udg_ThrowAxesUG)
        call AddSpecialEffectTargetUnitBJ("chest", GetEnumUnit(), "Objects\\Spawnmodels\\Human\\HumanBlood\\HumanBloodPeasant.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call PlaySoundOnUnitBJ(gg_snd_AxeMissile1, 100, GetEnumUnit())
    else
    endif
endfunction

function Trig_ThrowAxesPeriodic_Func001Func002C takes nothing returns boolean
    if ( not ( IsUnitAliveBJ(udg_ThrowAxesU[GetForLoopIndexA()]) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_ThrowAxesPeriodic_Actions takes nothing returns nothing
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=5
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        if ( Trig_ThrowAxesPeriodic_Func001Func001C() ) then
            call KillUnit(udg_ThrowAxesU[GetForLoopIndexA()])
        else
        endif
        if ( Trig_ThrowAxesPeriodic_Func001Func002C() ) then
            set udg_ThrowAxesLoc[GetForLoopIndexA()]=PolarProjectionBJ(GetUnitLoc(udg_ThrowAxesU[GetForLoopIndexA()]), 18.00, udg_ThrowAxesReal[GetForLoopIndexA()])
            call SetUnitPositionLoc(udg_ThrowAxesU[GetForLoopIndexA()], udg_ThrowAxesLoc[GetForLoopIndexA()])
            call ForGroupBJ(GetUnitsInRangeOfLocAll(60.00, udg_ThrowAxesLoc[GetForLoopIndexA()]), function Trig_ThrowAxesPeriodic_Func001Func002Func003A)
        else
        endif
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    call RemoveLocation(udg_ThrowAxesLoc[GetForLoopIndexA()])
endfunction

