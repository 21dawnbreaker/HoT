function Trig_ArrowsSpending_Actions takes nothing returns nothing
    if ( Trig_ArrowsSpending_Func001C() ) then
        if ( Trig_ArrowsSpending_Func001Func001C() ) then
            call RemoveItem(GetItemOfTypeFromUnitBJ(udg_DamageEventSource, 'I0A6'))
        else
            call SetItemCharges(GetItemOfTypeFromUnitBJ(udg_DamageEventSource, 'I0A6'), ( GetItemCharges(GetItemOfTypeFromUnitBJ(udg_DamageEventSource, 'I0A6')) - 1 ))
        endif
    else
    endif
    if ( Trig_ArrowsSpending_Func002C() ) then
        if ( Trig_ArrowsSpending_Func002Func001C() ) then
            call RemoveItem(GetItemOfTypeFromUnitBJ(udg_DamageEventSource, 'I09D'))
        else
            call SetItemCharges(GetItemOfTypeFromUnitBJ(udg_DamageEventSource, 'I09D'), ( GetItemCharges(GetItemOfTypeFromUnitBJ(udg_DamageEventSource, 'I09D')) - 1 ))
        endif
    else
    endif
    if ( Trig_ArrowsSpending_Func003C() ) then
        if ( Trig_ArrowsSpending_Func003Func001C() ) then
            call RemoveItem(GetItemOfTypeFromUnitBJ(udg_DamageEventSource, 'I00G'))
        else
            call SetItemCharges(GetItemOfTypeFromUnitBJ(udg_DamageEventSource, 'I00G'), ( GetItemCharges(GetItemOfTypeFromUnitBJ(udg_DamageEventSource, 'I00G')) - 1 ))
        endif
    else
    endif
    if ( Trig_ArrowsSpending_Func004C() ) then
        if ( Trig_ArrowsSpending_Func004Func001C() ) then
            call RemoveItem(GetItemOfTypeFromUnitBJ(udg_DamageEventSource, 'I00H'))
        else
            call SetItemCharges(GetItemOfTypeFromUnitBJ(udg_DamageEventSource, 'I00H'), ( GetItemCharges(GetItemOfTypeFromUnitBJ(udg_DamageEventSource, 'I00H')) - 1 ))
        endif
    else
    endif
    call DisableTrigger(GetTriggeringTrigger())
    call TriggerSleepAction(0.01)
    call EnableTrigger(GetTriggeringTrigger())
endfunction

