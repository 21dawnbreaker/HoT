//===========================================================================
// Trigger: ShieldOfVengeanceCheck
//===========================================================================
function Trig_ShieldOfVengeanceCheck_Conditions takes nothing returns boolean
    if ( not ( UnitHasBuffBJ(udg_ShieldOfVengeanceT, 'B00W') == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_ShieldOfVengeanceCheck_Func004Func001C takes nothing returns boolean
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(gg_unit_H00N_0277)) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_ShieldOfVengeanceCheck_Func004A takes nothing returns nothing
    if ( Trig_ShieldOfVengeanceCheck_Func004Func001C() ) then
        call AddSpecialEffectTargetUnitBJ("chest", GetEnumUnit(), "Abilities\\Weapons\\LordofFlameMissile\\LordofFlameMissile.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call UnitDamageTargetBJ(gg_unit_H00N_0277, GetEnumUnit(), I2R(udg_ShieldOfVengeanceDMG), ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL)
    else
    endif
endfunction

function Trig_ShieldOfVengeanceCheck_Actions takes nothing returns nothing
    call AddSpecialEffectTargetUnitBJ("origin", udg_ShieldOfVengeanceT, "Singularity I Orange.mdx")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call DisableTrigger(gg_trg_ShieldOfVengeanceHP)
    call ForGroupBJ(GetUnitsInRangeOfLocAll(250.00, GetUnitLoc(udg_ShieldOfVengeanceT)), function Trig_ShieldOfVengeanceCheck_Func004A)
    set udg_ShieldOfVengeanceHP=0
    set udg_ShieldOfVengeanceDMG=0
    set udg_ShieldOfVengeanceT=null
    call DisableTrigger(GetTriggeringTrigger())
endfunction

//===========================================================================
function InitTrig_ShieldOfVengeanceCheck takes nothing returns nothing
    set gg_trg_ShieldOfVengeanceCheck=CreateTrigger()
    call DisableTrigger(gg_trg_ShieldOfVengeanceCheck)
    call TriggerRegisterTimerEventPeriodic(gg_trg_ShieldOfVengeanceCheck, 1.00)
    call TriggerAddCondition(gg_trg_ShieldOfVengeanceCheck, Condition(function Trig_ShieldOfVengeanceCheck_Conditions))
    call TriggerAddAction(gg_trg_ShieldOfVengeanceCheck, function Trig_ShieldOfVengeanceCheck_Actions)
endfunction

//===========================================================================
// Trigger: ShieldOfVengeanceHP
//===========================================================================
function Trig_ShieldOfVengeanceHP_Conditions takes nothing returns boolean
    if ( not ( udg_DamageEventTarget == udg_ShieldOfVengeanceT ) ) then
        return false
    endif
    return true
endfunction

function Trig_ShieldOfVengeanceHP_Func006Func005Func001C takes nothing returns boolean
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(udg_ShieldOfVengeanceT)) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_ShieldOfVengeanceHP_Func006Func005A takes nothing returns nothing
    if ( Trig_ShieldOfVengeanceHP_Func006Func005Func001C() ) then
        call AddSpecialEffectTargetUnitBJ("chest", GetEnumUnit(), "Abilities\\Weapons\\LordofFlameMissile\\LordofFlameMissile.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call UnitDamageTargetBJ(udg_DamageEventTarget, GetEnumUnit(), I2R(udg_ShieldOfVengeanceDMG), ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL)
    else
    endif
endfunction

function Trig_ShieldOfVengeanceHP_Func006C takes nothing returns boolean
    if ( not ( udg_ShieldOfVengeanceHP <= 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ShieldOfVengeanceHP_Func007C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 100) >= 90 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ShieldOfVengeanceHP_Actions takes nothing returns nothing
    set udg_ShieldOfVengeanceDMG=( udg_ShieldOfVengeanceDMG + R2I(udg_DamageEventAmount) )
    set udg_ShieldOfVengeanceHP=( udg_ShieldOfVengeanceHP - R2I(udg_DamageEventAmount) )
    set udg_DamageEventAmount=0.00
    call AddSpecialEffectTargetUnitBJ("origin", udg_DamageEventTarget, "Abilities\\Spells\\Human\\DivineShield\\DivineShieldTarget.mdl")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    if ( Trig_ShieldOfVengeanceHP_Func006C() ) then
        call UnitRemoveBuffBJ('B00W', udg_DamageEventTarget)
        call DisableTrigger(gg_trg_ShieldOfVengeanceCheck)
        call AddSpecialEffectTargetUnitBJ("origin", udg_ShieldOfVengeanceT, "Singularity I Orange.mdx")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call ForGroupBJ(GetUnitsInRangeOfLocAll(250.00, GetUnitLoc(udg_ShieldOfVengeanceT)), function Trig_ShieldOfVengeanceHP_Func006Func005A)
        set udg_ShieldOfVengeanceHP=0
        set udg_ShieldOfVengeanceDMG=0
        call DisableTrigger(GetTriggeringTrigger())
    else
    endif
    if ( Trig_ShieldOfVengeanceHP_Func007C() ) then
        call TriggerExecute(gg_trg_ShieldOfVengeanceReset)
    else
    endif
endfunction

//===========================================================================
function InitTrig_ShieldOfVengeanceHP takes nothing returns nothing
    set gg_trg_ShieldOfVengeanceHP=CreateTrigger()
    call DisableTrigger(gg_trg_ShieldOfVengeanceHP)
    call h__TriggerRegisterVariableEvent(gg_trg_ShieldOfVengeanceHP, "udg_DamageEvent", EQUAL, 1.00)
    call TriggerAddCondition(gg_trg_ShieldOfVengeanceHP, Condition(function Trig_ShieldOfVengeanceHP_Conditions))
    call TriggerAddAction(gg_trg_ShieldOfVengeanceHP, function Trig_ShieldOfVengeanceHP_Actions)
endfunction

//===========================================================================
// Trigger: ShieldOfVengeanceReset
//===========================================================================
function Trig_ShieldOfVengeanceReset_Func001Func005C takes nothing returns boolean
    if ( not ( udg_RetributionIsOn == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ShieldOfVengeanceReset_Func001Func010C takes nothing returns boolean
    if ( ( GetUnitAbilityLevelSwapped('A04K', gg_unit_H00N_0277) > 0 ) ) then
        return true
    endif
    if ( ( GetUnitAbilityLevelSwapped('A04O', gg_unit_H00N_0277) > 0 ) ) then
        return true
    endif
    return false
endfunction

function Trig_ShieldOfVengeanceReset_Func001C takes nothing returns boolean
    if ( not Trig_ShieldOfVengeanceReset_Func001Func010C() ) then
        return false
    endif
    return true
endfunction

function Trig_ShieldOfVengeanceReset_Actions takes nothing returns nothing
    if ( Trig_ShieldOfVengeanceReset_Func001C() ) then
        set udg_BladeOfJusticeLvl=GetUnitAbilityLevelSwapped('A04K', gg_unit_H00N_0277)
        set udg_BladeOfJusticeLvl=( udg_BladeOfJusticeLvl + GetUnitAbilityLevelSwapped('A04O', gg_unit_H00N_0277) )
        call AddSpecialEffectTargetUnitBJ("overhead", gg_unit_H00N_0277, "Abilities\\Spells\\Human\\InnerFire\\InnerFireTarget.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        if ( Trig_ShieldOfVengeanceReset_Func001Func005C() ) then
            call BlzEndUnitAbilityCooldown(gg_unit_H00N_0277, 'A04K')
        else
            call BlzEndUnitAbilityCooldown(gg_unit_H00N_0277, 'A04O')
        endif
        call SetUnitManaBJ(gg_unit_H00N_0277, ( GetUnitStateSwap(UNIT_STATE_MANA, gg_unit_H00N_0277) + 50.00 ))
        call DisableTrigger(GetTriggeringTrigger())
        call TriggerSleepAction(2)
        call EnableTrigger(GetTriggeringTrigger())
    else
    endif
endfunction

//===========================================================================
function InitTrig_ShieldOfVengeanceReset takes nothing returns nothing
    set gg_trg_ShieldOfVengeanceReset=CreateTrigger()
    call TriggerAddAction(gg_trg_ShieldOfVengeanceReset, function Trig_ShieldOfVengeanceReset_Actions)
endfunction

