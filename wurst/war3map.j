//===========================================================================
// Trigger: BallLightningBullethell
//===========================================================================
function Trig_BallLightningBullethell_Conditions takes nothing returns boolean
    if ( not ( udg_DamageEventSource == gg_unit_H012_0027 ) ) then
        return false
    endif
    if ( not ( udg_IsDamageAttack == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_BallLightningBullethell_Func001Func001C takes nothing returns boolean
    if ( not ( udg_ball_lightning_count == udg_BALLS_ATKIVUS ) ) then
        return false
    endif
    return true
endfunction

function Trig_BallLightningBullethell_Func002C takes nothing returns boolean
    if ( not ( RectContainsLoc(gg_rct_inactiveBallsAtkivus, udg_ball_lightning_pos_current[udg_ball_lightning_count]) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_BallLightningBullethell_Actions takes nothing returns nothing
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=GetRandomInt(1, 1)
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        if ( Trig_BallLightningBullethell_Func001Func001C() ) then
            set udg_ball_lightning_count=1
        else
            set udg_ball_lightning_count=( udg_ball_lightning_count + 1 )
        endif
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    if ( Trig_BallLightningBullethell_Func002C() ) then
        set udg_tempLoc2=GetUnitLoc(udg_DamageEventSource)
        set udg_tempLoc3=GetUnitLoc(udg_DamageEventTarget)
        set udg_tempLoc=PolarProjectionBJ(GetUnitLoc(udg_DamageEventTarget), 110.00, AngleBetweenPoints(udg_tempLoc2, udg_tempLoc3))
        // CLEANUP
        call DestroyEffectBJ(udg_ball_lightning_eff[udg_ball_lightning_count])
        call RemoveLocation(udg_ball_lightning_pos_final[udg_ball_lightning_count])
        call RemoveLocation(udg_ball_lightning_pos_current[udg_ball_lightning_count])
        // CLEANUP
        call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Weapons\\FarseerMissile\\FarseerMissile.mdl")
        call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 2.00)
        call BlzSetSpecialEffectHeight(GetLastCreatedEffectBJ(), ( BlzGetLocalUnitZ(udg_DamageEventTarget) + 65.00 ))
        set udg_ball_lightning_eff[udg_ball_lightning_count]=GetLastCreatedEffectBJ()
        set udg_ball_lightning_pos_current[udg_ball_lightning_count]=udg_tempLoc
        set udg_tempReal=GetRandomReal(- 40.00, 40.00)
        set udg_ball_lightning_pos_final[udg_ball_lightning_count]=PolarProjectionBJ(udg_tempLoc, 10000.00, ( GetUnitFacing(udg_DamageEventSource) + udg_tempReal ))
        set udg_tempReal=0.00
        call RemoveLocation(udg_tempLoc2)
        call RemoveLocation(udg_tempLoc3)
    else
    endif
endfunction

//===========================================================================
function InitTrig_BallLightningBullethell takes nothing returns nothing
    set gg_trg_BallLightningBullethell=CreateTrigger()
    call h__TriggerRegisterVariableEvent(gg_trg_BallLightningBullethell, "udg_DamageEvent", EQUAL, 1.00)
    call TriggerAddCondition(gg_trg_BallLightningBullethell, Condition(function Trig_BallLightningBullethell_Conditions))
    call TriggerAddAction(gg_trg_BallLightningBullethell, function Trig_BallLightningBullethell_Actions)
endfunction

//===========================================================================
// Trigger: BallLightningPeriodic
//===========================================================================
function Trig_BallLightningPeriodic_Func001Func001Func011Func001Func003C takes nothing returns boolean
    if ( not ( IsUnitIdType(GetUnitTypeId(GetEnumUnit()), UNIT_TYPE_HERO) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_BallLightningPeriodic_Func001Func001Func011Func001C takes nothing returns boolean
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( BlzIsUnitInvulnerable(GetEnumUnit()) == false ) ) then
        return false
    endif
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(gg_unit_H012_0027)) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_BallLightningPeriodic_Func001Func001Func011A takes nothing returns nothing
    if ( Trig_BallLightningPeriodic_Func001Func001Func011Func001C() ) then
        call AddSpecialEffectTargetUnitBJ("chest", GetEnumUnit(), "Abilities\\Spells\\Orc\\LightningBolt\\LightningBoltMissile.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        if ( Trig_BallLightningPeriodic_Func001Func001Func011Func001Func003C() ) then
            call DestroyEffectBJ(udg_ball_lightning_eff[GetForLoopIndexA()])
            call RemoveLocation(udg_ball_lightning_pos_final[GetForLoopIndexA()])
            call RemoveLocation(udg_ball_lightning_pos_current[GetForLoopIndexA()])
            set udg_ball_lightning_pos_current[GetForLoopIndexA()]=GetRectCenter(gg_rct_inactiveBallsAtkivus)
            set udg_ball_lightning_pos_final[GetForLoopIndexA()]=GetRectCenter(GetPlayableMapRect())
            call UnitDamageTargetBJ(udg_Boss[1], GetEnumUnit(), ( GetUnitStateSwap(UNIT_STATE_MAX_LIFE, GetEnumUnit()) * 0.80 ), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_MAGIC)
        else
            call SetUnitLifePercentBJ(GetEnumUnit(), ( GetUnitLifePercent(GetEnumUnit()) - 0.80 ))
        endif
    else
    endif
endfunction

function Trig_BallLightningPeriodic_Func001Func001Func012Func002Func002C takes nothing returns boolean
    if ( ( GetLocationX(udg_tempLoc) > GetRectMaxX(gg_rct_BossfightInnerLoc) ) ) then
        return true
    endif
    if ( ( GetLocationX(udg_tempLoc) < GetRectMinX(gg_rct_BossfightInnerLoc) ) ) then
        return true
    endif
    return false
endfunction

function Trig_BallLightningPeriodic_Func001Func001Func012Func002C takes nothing returns boolean
    if ( not Trig_BallLightningPeriodic_Func001Func001Func012Func002Func002C() ) then
        return false
    endif
    return true
endfunction

function Trig_BallLightningPeriodic_Func001Func001Func012C takes nothing returns boolean
    if ( not ( RectContainsLoc(gg_rct_BossfightInnerLoc, udg_ball_lightning_pos_current[GetForLoopIndexA()]) == false ) ) then
        return false
    endif
    if ( not ( RectContainsLoc(gg_rct_MainBossLoc, udg_ball_lightning_pos_current[GetForLoopIndexA()]) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_BallLightningPeriodic_Func001Func001C takes nothing returns boolean
    if ( not ( RectContainsLoc(gg_rct_MainBossLoc, udg_ball_lightning_pos_current[GetForLoopIndexA()]) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_BallLightningPeriodic_Actions takes nothing returns nothing
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=udg_BALLS_ATKIVUS
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        if ( Trig_BallLightningPeriodic_Func001Func001C() ) then
            set udg_tempReal=AngleBetweenPoints(udg_ball_lightning_pos_current[GetForLoopIndexA()], udg_ball_lightning_pos_final[GetForLoopIndexA()])
            set udg_tempReal=( udg_tempReal + GetRandomReal(- 10.00, 10.00) )
            set udg_tempLoc=PolarProjectionBJ(udg_ball_lightning_pos_current[GetForLoopIndexA()], 10.00, udg_tempReal)
            call RemoveLocation(udg_ball_lightning_pos_current[GetForLoopIndexA()])
            call BlzSetSpecialEffectPositionLoc(udg_ball_lightning_eff[GetForLoopIndexA()], udg_tempLoc)
            call BlzSetSpecialEffectHeight(udg_ball_lightning_eff[GetForLoopIndexA()], ( BlzGetLocalUnitZ(udg_Boss[1]) + 65.00 ))
            set udg_ball_lightning_pos_current[GetForLoopIndexA()]=udg_tempLoc
            set udg_tempReal=0.00
            call ForGroupBJ(GetUnitsInRangeOfLocAll(90.00, udg_ball_lightning_pos_current[GetForLoopIndexA()]), function Trig_BallLightningPeriodic_Func001Func001Func011A)
            if ( Trig_BallLightningPeriodic_Func001Func001Func012C() ) then
                if ( Trig_BallLightningPeriodic_Func001Func001Func012Func002C() ) then
                    set udg_tempReal=( 180.00 - AngleBetweenPoints(udg_ball_lightning_pos_current[GetForLoopIndexA()], udg_ball_lightning_pos_final[GetForLoopIndexA()]) )
                else
                    set udg_tempReal=( 360.00 - AngleBetweenPoints(udg_ball_lightning_pos_current[GetForLoopIndexA()], udg_ball_lightning_pos_final[GetForLoopIndexA()]) )
                endif
                call RemoveLocation(udg_ball_lightning_pos_final[GetForLoopIndexA()])
                set udg_ball_lightning_pos_final[GetForLoopIndexA()]=PolarProjectionBJ(udg_tempLoc, 10000.00, udg_tempReal)
                set udg_tempReal=0.00
            else
            endif
            set udg_tempInt=0
        else
        endif
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
endfunction

//===========================================================================
function InitTrig_BallLightningPeriodic takes nothing returns nothing
    set gg_trg_BallLightningPeriodic=CreateTrigger()
    call DisableTrigger(gg_trg_BallLightningPeriodic)
    call TriggerRegisterTimerEventPeriodic(gg_trg_BallLightningPeriodic, 0.04)
    call TriggerAddAction(gg_trg_BallLightningPeriodic, function Trig_BallLightningPeriodic_Actions)
endfunction

