//===========================================================================
// Trigger: Recklessness
//===========================================================================
function Trig_Recklessness_Conditions takes nothing returns boolean
    if ( not ( IsUnitInGroup(GetTriggerUnit(), udg_WarriorsGroup) == true ) ) then
        return false
    endif
    if ( not ( UnitHasItemOfTypeBJ(GetTriggerUnit(), 'I078') == false ) ) then
        return false
    endif
    if ( not ( GetUnitStateSwap(UNIT_STATE_MANA, GetTriggerUnit()) >= ( GetUnitStateSwap(UNIT_STATE_MAX_MANA, GetTriggerUnit()) * 0.95 ) ) ) then
        return false
    endif
    if ( not ( UnitHasBuffBJ(GetTriggerUnit(), 'B003') == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_Recklessness_Func001C takes nothing returns boolean
    if ( not ( GetTriggerUnit() != gg_unit_H00A_0082 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Recklessness_Actions takes nothing returns nothing
    if ( Trig_Recklessness_Func001C() ) then
        call SetUnitLifePercentBJ(GetTriggerUnit(), ( GetUnitLifePercent(GetTriggerUnit()) + 10.00 ))
        call UnitAddAbilityBJ('A00C', GetTriggerUnit())
        call UnitAddAbilityBJ('A00Z', GetTriggerUnit())
        call CreateNUnitsAtLoc(1, 'h00F', GetOwningPlayer(GetTriggerUnit()), GetUnitLoc(GetTriggerUnit()), bj_UNIT_FACING)
        call UnitApplyTimedLifeBJ(1.00, 'BTLF', GetLastCreatedUnit())
        call IssueTargetOrderBJ(GetLastCreatedUnit(), "acidbomb", GetTriggerUnit())
        call CreateNUnitsAtLoc(1, 'h00F', GetOwningPlayer(GetTriggerUnit()), GetUnitLoc(GetTriggerUnit()), bj_UNIT_FACING)
        call UnitApplyTimedLifeBJ(1.00, 'BTLF', GetLastCreatedUnit())
        call IssueTargetOrderBJ(GetLastCreatedUnit(), "drunkenhaze", GetTriggerUnit())
        call TriggerSleepAction(12.00)
        call UnitRemoveAbilityBJ('A00C', GetTriggerUnit())
        call UnitRemoveAbilityBJ('A00Z', GetTriggerUnit())
    else
    endif
endfunction

//===========================================================================
