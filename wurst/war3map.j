    if ( not ( udg_DIFFICULTY >= 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_RicardessaPreparePeriodic_Actions takes nothing returns nothing
    call DisableTrigger(gg_trg_RicardessaAnimationPeriodic)
    set udg_tempLoc2=GetUnitLoc(GroupPickRandomUnit(udg_HeroesGroup))
    set udg_tempInt=GetRandomInt(1, 4)
    if ( Trig_RicardessaPreparePeriodic_Func004C() ) then
        set udg_tempLoc=GetRandomLocInRect(gg_rct_BossfightBorderUp)
        call SetUnitPositionLocFacingLocBJ(udg_ricardessa, udg_tempLoc, udg_tempLoc2)
    else
    endif
    if ( Trig_RicardessaPreparePeriodic_Func005C() ) then
        set udg_tempLoc=GetRandomLocInRect(gg_rct_BossfightBorderRight)
        call SetUnitPositionLocFacingLocBJ(udg_ricardessa, udg_tempLoc, udg_tempLoc2)
    else
    endif
    if ( Trig_RicardessaPreparePeriodic_Func006C() ) then
        set udg_tempLoc=GetRandomLocInRect(gg_rct_BossfightBorderLeft)
        call SetUnitPositionLocFacingLocBJ(udg_ricardessa, udg_tempLoc, udg_tempLoc2)
    else
    endif
    if ( Trig_RicardessaPreparePeriodic_Func007C() ) then
        set udg_tempLoc=GetRandomLocInRect(gg_rct_BossfightBorderDown)
        call SetUnitPositionLocFacingLocBJ(udg_ricardessa, udg_tempLoc, udg_tempLoc2)
    else
    endif
    call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\Items\\RitualDagger\\RitualDaggerTarget.mdl")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 2.00)
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    set udg_tempReal=50.00
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=20
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        call AddSpecialEffectLocBJ(PolarProjectionBJ(udg_tempLoc, udg_tempReal, AngleBetweenPoints(udg_tempLoc, udg_tempLoc2)), "Skill_Indicator_Straight.mdx")
        call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 1.25)
        call BlzSetSpecialEffectZ(GetLastCreatedEffectBJ(), GetUnitFlyHeight(udg_ricardessa))
        call BlzSetSpecialEffectYaw(GetLastCreatedEffectBJ(), Deg2Rad(AngleBetweenPoints(udg_tempLoc, udg_tempLoc2)))
        set udg_tempReal=( udg_tempReal + 200.00 )
        set udg_ricardessa_line[GetForLoopIndexA()]=GetLastCreatedEffectBJ()
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    set udg_tempReal=0.00
    set udg_tempInt=0
    call RemoveLocation(udg_tempLoc)
    call RemoveLocation(udg_tempLoc2)
    set udg_tempInt=GetRandomInt(1, 3)
    if ( Trig_RicardessaPreparePeriodic_Func018C() ) then
        call PlaySoundBJ(gg_snd_ricardessa_attack1)
    else
    endif
    if ( Trig_RicardessaPreparePeriodic_Func019C() ) then
        call PlaySoundBJ(gg_snd_ricardessa_attack2)
    else
    endif
    if ( Trig_RicardessaPreparePeriodic_Func020C() ) then
        call PlaySoundBJ(gg_snd_ricardessa_attack3)
    else
    endif
    set udg_tempInt=0
    if ( Trig_RicardessaPreparePeriodic_Func022C() ) then
        call TriggerSleepAction(0.50)
    else
        call SetUnitAnimation(udg_ricardessa, "ready")
        call TriggerSleepAction(1.50)
    endif
    call SetUnitAnimation(udg_ricardessa, "move")
    call EnableTrigger(gg_trg_RicardessaMovePeriodic)
    call EnableTrigger(gg_trg_RicardessaAnimationPeriodic)
    call DisableTrigger(GetTriggeringTrigger())
endfunction

