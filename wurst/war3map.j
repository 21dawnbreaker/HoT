    if ( not ( GetRandomInt(1, 2) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_OrcishMight_Actions takes nothing returns nothing
    if ( Trig_OrcishMight_Func001C() ) then
        call SetUnitAbilityLevelSwapped('A06K', GetTriggerUnit(), ( GetUnitAbilityLevelSwapped('A06K', GetTriggerUnit()) + 1 ))
    else
        call SetUnitAbilityLevelSwapped('A06K', GetTriggerUnit(), 1)
    endif
    call UnitDamageTargetBJ(GetTriggerUnit(), GetSpellTargetUnit(), I2R(BlzGetUnitBaseDamage(GetTriggerUnit(), 0)), ATTACK_TYPE_MELEE, DAMAGE_TYPE_NORMAL)
    if ( Trig_OrcishMight_Func003C() ) then
        call PlaySoundOnUnitBJ(gg_snd_GromYesAttack3, 100, GetTriggerUnit())
    else
    endif
    call PlaySoundOnUnitBJ(gg_snd_SPELL_WR_ColossusSmash_Impact_04, 100, GetTriggerUnit())
    set udg_KBA_Caster=GetTriggerUnit()
    set udg_KBA_TargetUnit=GetSpellTargetUnit()
    set udg_KBA_Level=1
    set udg_KBA_StartingPosition=GetUnitLoc(GetTriggerUnit())
    set udg_KBA_Speed=5.00
    set udg_KBA_DistancePerLevel=250.00
    set udg_KBA_SpecialEffects[1]="Abilities\\Spells\\Human\\FlakCannons\\FlakTarget.mdl"
    set udg_KBA_SpecialEffects[2]="Abilities\\Weapons\\AncientProtectorMissile\\AncientProtectorMissile.mdl"
    set udg_KBA_DestroyTrees=false
    call ConditionalTriggerExecute(gg_trg_Cast_A_Knockback)
endfunction

