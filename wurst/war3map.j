    if ( not ( udg_LifeDrainProc == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_LifeDrain_Actions takes nothing returns nothing
    set udg_LifeDrainLoc=PolarProjectionBJ(GetUnitLoc(GetTriggerUnit()), 0.00, 0.00)
    call ForGroupBJ(GetUnitsInRangeOfLocAll(500.00, udg_LifeDrainLoc), function Trig_LifeDrain_Func002A)
    call EnableTrigger(gg_trg_LifeDrainPeridoic)
    call EnableTrigger(gg_trg_LifeDrainDying)
    call TriggerSleepAction(3.00)
    call GroupRemoveGroup(udg_LifeDrainUG, udg_LifeDrainUG)
    call GroupRemoveGroup(udg_LifeDrainUG_Copy, udg_LifeDrainUG_Copy)
    call DisableTrigger(gg_trg_LifeDrainPeridoic)
    call DisableTrigger(gg_trg_LifeDrainDying)
    call RemoveLocation(udg_LifeDrainLoc)
    if ( Trig_LifeDrain_Func011C() ) then
        set udg_LifeDrainProc=GetRandomInt(1, 100)
        if ( Trig_LifeDrain_Func011Func002C() ) then
            call AddSpecialEffectTargetUnitBJ("origin", GetTriggerUnit(), "Abilities\\Spells\\Undead\\AnimateDead\\AnimateDeadTarget.mdl")
            call DestroyEffectBJ(GetLastCreatedEffectBJ())
            set udg_LifeDrainProc=GetUnitAbilityLevelSwapped('A05Y', gg_unit_O001_0069)
            call UnitRemoveAbilityBJ('A05Y', gg_unit_O001_0069)
            call UnitAddAbilityBJ('A05Y', gg_unit_O001_0069)
            call SetUnitAbilityLevelSwapped('A05Y', gg_unit_O001_0069, udg_LifeDrainProc)
            set udg_LifeDrainProc=0
        else
        endif
    else
    endif
endfunction

