    if ( not ( udg_BossfightDialogueInt == 0 ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(gg_unit_U006_0283) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_ImpalesRandomPeriodic_Actions takes nothing returns nothing
    set udg_RandomImpalesInt=1
    call DestroyEffectBJ(udg_RandomImpaleEff1[udg_RandomImpalesInt])
    set udg_tempLoc=GetUnitLoc(GroupPickRandomUnit(udg_HeroesGroup))
    set udg_RandomImpaleLoc[udg_RandomImpalesInt]=PolarProjectionBJ(udg_tempLoc, GetRandomReal(0, 500.00), GetRandomDirectionDeg())
    call RemoveLocation(udg_tempLoc)
    call AddSpecialEffectLocBJ(udg_RandomImpaleLoc[udg_RandomImpalesInt], "Skill_Indicator_Circle.mdx")
    set udg_RandomImpaleEff1[udg_RandomImpalesInt]=GetLastCreatedEffectBJ()
    call StartTimerBJ(udg_RandomImpalesTimer, false, 1.40)
endfunction

