//===========================================================================
// Trigger: DuelTimer
//===========================================================================
function Trig_DuelTimer_Conditions takes nothing returns boolean
    if ( not ( IsUnitAliveBJ(gg_unit_E001_0061) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_DuelTimer_Func004C takes nothing returns boolean
    if ( not ( DistanceBetweenPoints(GetUnitLoc(udg_DuelC), GetUnitLoc(udg_DuelT)) > 101.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_DuelTimer_Func005Func013C takes nothing returns boolean
    if ( not ( IsUnitAliveBJ(udg_DuelT) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_DuelTimer_Func005Func019C takes nothing returns boolean
    if ( ( UnitHasBuffBJ(udg_DuelC, 'B00O') == false ) ) then
        return true
    endif
    if ( ( UnitHasBuffBJ(udg_DuelT, 'B00O') == false ) ) then
        return true
    endif
    if ( ( BlzIsUnitInvulnerable(udg_DuelT) == true ) ) then
        return true
    endif
    return false
endfunction

function Trig_DuelTimer_Func005C takes nothing returns boolean
    if ( not Trig_DuelTimer_Func005Func019C() ) then
        return false
    endif
    return true
endfunction

function Trig_DuelTimer_Actions takes nothing returns nothing
    call IssueTargetOrderBJ(udg_DuelT, "smart", udg_DuelC)
    call IssueTargetOrderBJ(udg_DuelC, "smart", udg_DuelT)
    if ( Trig_DuelTimer_Func004C() ) then
        call UnitRemoveBuffBJ('B02J', udg_DuelT)
        call UnitRemoveBuffBJ('B02J', udg_DuelC)
    else
    endif
    if ( Trig_DuelTimer_Func005C() ) then
        call UnitRemoveBuffBJ('B00O', udg_DuelC)
        call UnitRemoveBuffBJ('B00O', udg_DuelT)
        call DestroyEffectBJ(udg_DuelEff)
        call DestroyEffectBJ(udg_DuelEff1)
        call DestroyEffectBJ(udg_DuelEff1_Copy)
        call DestroyEffectBJ(udg_DuelEff1_Copy_2)
        call DestroyEffectBJ(udg_DuelEff1_Copy_3)
        call DestroyEffectBJ(udg_DuelEff1_Copy_4)
        call DestroyEffectBJ(udg_DuelEff1_Copy_5)
        call DestroyEffectBJ(udg_DuelEff1_Copy_6)
        call DestroyEffectBJ(udg_DuelEff1_Copy_7)
        call SetTextTagLifespanBJ(udg_DuelText, 0.10)
        if ( Trig_DuelTimer_Func005Func013C() ) then
            call PlaySoundOnUnitBJ(gg_snd_Legcom_duelfailure_01_rump3, 100, gg_unit_E001_0061)
        else
        endif
        set udg_DuelC=null
        set udg_DuelT=null
        call DisableTrigger(gg_trg_DuelC)
        call DisableTrigger(gg_trg_DuelT)
        call DisableTrigger(GetTriggeringTrigger())
    else
    endif
endfunction

//===========================================================================
function InitTrig_DuelTimer takes nothing returns nothing
    set gg_trg_DuelTimer=CreateTrigger()
    call DisableTrigger(gg_trg_DuelTimer)
    call TriggerRegisterTimerEventPeriodic(gg_trg_DuelTimer, 0.50)
    call TriggerAddCondition(gg_trg_DuelTimer, Condition(function Trig_DuelTimer_Conditions))
    call TriggerAddAction(gg_trg_DuelTimer, function Trig_DuelTimer_Actions)
endfunction

