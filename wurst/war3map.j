    call h__TriggerRegisterVariableEvent(gg_trg_Phase3_Shiadal, "udg_DamageEvent", EQUAL, 1.00)
    call TriggerAddCondition(gg_trg_Phase3_Shiadal, Condition(function Trig_Phase3_Shiadal_Conditions))
    call TriggerAddAction(gg_trg_Phase3_Shiadal, function Trig_Phase3_Shiadal_Actions)
endfunction

//===========================================================================
// Trigger: MurderousEfficency
//===========================================================================
function Trig_MurderousEfficency_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A0IB' ) ) then
        return false
    endif
    return true
endfunction

function Trig_MurderousEfficency_Actions takes nothing returns nothing
    call PauseUnitBJ(true, GetTriggerUnit())
    call SetUnitAnimation(GetTriggerUnit(), "channel")
    call PlaySoundOnUnitBJ(gg_snd_ShandrisYesAttack3, 100, GetTriggerUnit())
    call TriggerSleepAction(2.60)
    set udg_MurderousLoc=GetUnitLoc(GetTriggerUnit())
    call AddSpecialEffectLocBJ(udg_MurderousLoc, "Winter Blast HD.mdx")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 0.50)
    call BlzSetSpecialEffectZ(GetLastCreatedEffectBJ(), BlzGetLocalUnitZ(udg_Boss[1]))
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call SetUnitInvulnerable(GetTriggerUnit(), true)
    call EnableTrigger(gg_trg_MurderousEfficencyPeriodic)
endfunction

//===========================================================================
function InitTrig_MurderousEfficency takes nothing returns nothing
    set gg_trg_MurderousEfficency=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_MurderousEfficency, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_MurderousEfficency, Condition(function Trig_MurderousEfficency_Conditions))
    call TriggerAddAction(gg_trg_MurderousEfficency, function Trig_MurderousEfficency_Actions)
endfunction

//===========================================================================
// Trigger: MurderousEfficencyPeriodic
//===========================================================================
function Trig_MurderousEfficencyPeriodic_Func001C takes nothing returns boolean
    if ( not ( udg_MurderousInt < udg_HeroNumber ) ) then
        return false
    endif
    return true
endfunction

function Trig_MurderousEfficencyPeriodic_Actions takes nothing returns nothing
    if ( Trig_MurderousEfficencyPeriodic_Func001C() ) then
        set udg_MurderousInt=( udg_MurderousInt + 1 )
        set udg_tempLoc=PolarProjectionBJ(GetUnitLoc(udg_Hero[udg_MurderousInt]), 90.00, GetRandomDirectionDeg())
        set udg_tempLoc2=GetUnitLoc(udg_Hero[udg_MurderousInt])
        call SetUnitPositionLoc(udg_Boss[1], udg_tempLoc)
        call SetUnitFacingToFaceLocTimed(udg_Boss[1], udg_tempLoc2, 0)
        call SetUnitAnimation(udg_Boss[1], "attack")
        call AddSpecialEffectLocBJ(udg_tempLoc, "Winter Blast HD.mdx")
        call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 0.50)
        call BlzSetSpecialEffectZ(GetLastCreatedEffectBJ(), BlzGetLocalUnitZ(udg_Boss[1]))
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call AddSpecialEffectTargetUnitBJ("chest", udg_Hero[udg_MurderousInt], "Ephemeral Cut Midnight.mdx")
        call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 1.50)
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call RemoveLocation(udg_tempLoc)
        call RemoveLocation(udg_tempLoc2)
    else
        call DisableTrigger(GetTriggeringTrigger())
        call ConditionalTriggerExecute(gg_trg_MurderousEfficencyEnd)
    endif
endfunction

//===========================================================================
function InitTrig_MurderousEfficencyPeriodic takes nothing returns nothing
    set gg_trg_MurderousEfficencyPeriodic=CreateTrigger()
    call DisableTrigger(gg_trg_MurderousEfficencyPeriodic)
    call TriggerRegisterTimerEventPeriodic(gg_trg_MurderousEfficencyPeriodic, 0.30)
    call TriggerAddAction(gg_trg_MurderousEfficencyPeriodic, function Trig_MurderousEfficencyPeriodic_Actions)
endfunction

//===========================================================================
// Trigger: MurderousEfficencyEnd
//===========================================================================
function Trig_MurderousEfficencyEnd_Func013Func001C takes nothing returns boolean
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_MurderousEfficencyEnd_Func013A takes nothing returns nothing
    if ( Trig_MurderousEfficencyEnd_Func013Func001C() ) then
        call UnitDamageTargetBJ(udg_Boss[1], GetEnumUnit(), ( GetUnitStateSwap(UNIT_STATE_MAX_LIFE, GetEnumUnit()) * 1.00 ), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_MAGIC)
        call AddSpecialEffectTargetUnitBJ("origin", GetEnumUnit(), "Abilities\\Spells\\Undead\\FrostNova\\FrostNovaTarget.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
    else
    endif
endfunction

function Trig_MurderousEfficencyEnd_Actions takes nothing returns nothing
    set udg_MurderousInt=0
    call SetUnitPositionLoc(udg_Boss[1], udg_MurderousLoc)
    call SetUnitInvulnerable(udg_Boss[1], false)
    call AddSpecialEffectLocBJ(udg_MurderousLoc, "Winter Blast HD.mdx")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 0.50)
    call BlzSetSpecialEffectZ(GetLastCreatedEffectBJ(), BlzGetLocalUnitZ(udg_Boss[1]))
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call RemoveLocation(udg_MurderousLoc)
    call SetUnitAnimation(udg_Boss[1], "stand")
    call TriggerSleepAction(2)
    set udg_MurderousInt=1
    call SetUnitAnimation(udg_Boss[1], "spell")
    call ForGroupBJ(udg_HeroesGroup, function Trig_MurderousEfficencyEnd_Func013A)
    call TriggerSleepAction(1.30)
    call PauseUnitBJ(false, udg_Boss[1])
    call SetUnitAnimation(udg_Boss[1], "ready")
    set udg_MurderousInt=0
endfunction

//===========================================================================
function InitTrig_MurderousEfficencyEnd takes nothing returns nothing
    set gg_trg_MurderousEfficencyEnd=CreateTrigger()
    call TriggerAddAction(gg_trg_MurderousEfficencyEnd, function Trig_MurderousEfficencyEnd_Actions)
endfunction

