        call MultiboardSetItemWidthBJ(GetLastCreatedMultiboard(), 2, GetForLoopIndexA(), 9.00)
        call MultiboardSetItemWidthBJ(GetLastCreatedMultiboard(), 3, GetForLoopIndexA(), 9.00)
        call MultiboardSetItemWidthBJ(GetLastCreatedMultiboard(), 4, GetForLoopIndexA(), 9.00)
        call MultiboardSetItemWidthBJ(GetLastCreatedMultiboard(), 5, GetForLoopIndexA(), 9.00)
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    call MultiboardSetItemStyleBJ(GetLastCreatedMultiboard(), 1, 1, true, true)
    call MultiboardSetItemStyleBJ(GetLastCreatedMultiboard(), 2, 1, true, true)
    call MultiboardSetItemStyleBJ(GetLastCreatedMultiboard(), 3, 1, true, true)
    call MultiboardSetItemStyleBJ(GetLastCreatedMultiboard(), 4, 1, true, true)
    call MultiboardSetItemStyleBJ(GetLastCreatedMultiboard(), 5, 1, true, true)
