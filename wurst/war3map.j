//===========================================================================
// Trigger: Starfall
//===========================================================================
function Trig_Starfall_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A05H' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Starfall_Func002Func001C takes nothing returns boolean
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(GetTriggerUnit())) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Starfall_Func002A takes nothing returns nothing
    if ( Trig_Starfall_Func002Func001C() ) then
        call AddSpecialEffectTargetUnitBJ("origin", GetEnumUnit(), "Abilities\\Spells\\NightElf\\Starfall\\StarfallTarget.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call GroupAddUnitSimple(GetEnumUnit(), udg_StarfallUG)
    else
    endif
endfunction

function Trig_Starfall_Func005A takes nothing returns nothing
    call SetUnitManaBJ(GetTriggerUnit(), ( ( 5.00 + ( 1 * I2R(GetUnitAbilityLevelSwapped('A05H', GetTriggerUnit())) ) ) + GetUnitStateSwap(UNIT_STATE_MANA, GetTriggerUnit()) ))
    call UnitDamageTargetBJ(GetTriggerUnit(), GetEnumUnit(), ( ( 40.00 * I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) ) + ( I2R(GetHeroStatBJ(bj_HEROSTAT_AGI, GetTriggerUnit(), true)) * ( I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) * 0.50 ) ) ), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_MAGIC)
endfunction

function Trig_Starfall_Actions takes nothing returns nothing
    set udg_tempLoc=GetSpellTargetLoc()
    call ForGroupBJ(GetUnitsInRangeOfLocAll(500.00, udg_tempLoc), function Trig_Starfall_Func002A)
    call RemoveLocation(udg_tempLoc)
    call TriggerSleepAction(1.00)
    call ForGroupBJ(udg_StarfallUG, function Trig_Starfall_Func005A)
    call GroupRemoveGroup(udg_StarfallUG, udg_StarfallUG)
endfunction

//===========================================================================
function InitTrig_Starfall takes nothing returns nothing
    set gg_trg_Starfall=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Starfall, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_Starfall, Condition(function Trig_Starfall_Conditions))
    call TriggerAddAction(gg_trg_Starfall, function Trig_Starfall_Actions)
endfunction

