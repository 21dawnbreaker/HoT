    call CreateNUnitsAtLoc(1, 'h028', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc, bj_UNIT_FACING)
    call UnitApplyTimedLifeBJ(1.00, 'BTLF', GetLastCreatedUnit())
    call UnitAddAbilityBJ('AInv', GetLastCreatedUnit())
    if ( Trig_TomeOfWonders_Func006C() ) then
        call UnitAddItemByIdSwapped('I01D', GetLastCreatedUnit())
    else
    endif
    if ( Trig_TomeOfWonders_Func007C() ) then
