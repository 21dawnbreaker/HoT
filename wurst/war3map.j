    set gg_trg_InfernoNotEnoughHP=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_InfernoNotEnoughHP, EVENT_PLAYER_UNIT_SPELL_CAST)
    call TriggerAddCondition(gg_trg_InfernoNotEnoughHP, Condition(function Trig_InfernoNotEnoughHP_Conditions))
