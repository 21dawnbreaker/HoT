function Trig_ThePursuitDifficulty_Actions takes nothing returns nothing
    call TriggerSleepAction(0.25)
    set udg_RandomU=null
    set udg_RandomU=GroupPickRandomUnit(GetUnitsInRectMatching(gg_rct_MainBossLoc, Condition(function Trig_ThePursuitDifficulty_Func003002001002)))
    if ( Trig_ThePursuitDifficulty_Func004C() ) then
        set udg_tempLoc=GetUnitLoc(udg_RandomU)
        call SetUnitPositionLocFacingLocBJ(gg_unit_U005_0113, PolarProjectionBJ(udg_tempLoc, 150.00, GetRandomDirectionDeg()), udg_tempLoc)
        call PauseUnitBJ(true, GetTriggerUnit())
        call SetUnitAnimation(GetTriggerUnit(), "birth")
        call TriggerSleepAction(2.00)
        call PauseUnitBJ(false, GetTriggerUnit())
        call SetUnitAnimation(GetTriggerUnit(), "alive")
        call RemoveLocation(udg_tempLoc)
    else
        set udg_RandomU=null
        set udg_RandomU=GroupPickRandomUnit(GetUnitsInRectMatching(gg_rct_MainBossLoc, Condition(function Trig_ThePursuitDifficulty_Func004Func002002001002)))
        if ( Trig_ThePursuitDifficulty_Func004Func003C() ) then
            set udg_tempLoc=GetUnitLoc(udg_RandomU)
            call SetUnitPositionLocFacingLocBJ(gg_unit_U005_0113, PolarProjectionBJ(udg_tempLoc, 150.00, GetRandomDirectionDeg()), udg_tempLoc)
            call PauseUnitBJ(true, GetTriggerUnit())
            call SetUnitAnimation(GetTriggerUnit(), "birth")
            call TriggerSleepAction(2.00)
            call PauseUnitBJ(false, GetTriggerUnit())
            call SetUnitAnimation(GetTriggerUnit(), "alive")
            call RemoveLocation(udg_tempLoc)
        else
            set udg_RandomU=null
            set udg_RandomU=GroupPickRandomUnit(GetUnitsInRectMatching(gg_rct_MainBossLoc, Condition(function Trig_ThePursuitDifficulty_Func004Func003Func002002001002)))
            if ( Trig_ThePursuitDifficulty_Func004Func003Func003C() ) then
                set udg_tempLoc=GetUnitLoc(udg_RandomU)
                call SetUnitPositionLocFacingLocBJ(gg_unit_U005_0113, PolarProjectionBJ(udg_tempLoc, 150.00, GetRandomDirectionDeg()), udg_tempLoc)
                call PauseUnitBJ(true, GetTriggerUnit())
                call SetUnitAnimation(GetTriggerUnit(), "birth")
                call TriggerSleepAction(2.00)
                call PauseUnitBJ(false, GetTriggerUnit())
                call SetUnitAnimation(GetTriggerUnit(), "alive")
                call RemoveLocation(udg_tempLoc)
            else
                set udg_RandomU=null
                set udg_RandomU=GroupPickRandomUnit(GetUnitsInRectMatching(gg_rct_MainBossLoc, Condition(function Trig_ThePursuitDifficulty_Func004Func003Func003Func002002001002)))
                if ( Trig_ThePursuitDifficulty_Func004Func003Func003Func003C() ) then
                    set udg_tempLoc=GetUnitLoc(udg_RandomU)
                    call SetUnitPositionLocFacingLocBJ(gg_unit_U005_0113, PolarProjectionBJ(udg_tempLoc, 150.00, GetRandomDirectionDeg()), udg_tempLoc)
                    call PauseUnitBJ(true, GetTriggerUnit())
                    call SetUnitAnimation(GetTriggerUnit(), "birth")
                    call TriggerSleepAction(2.00)
                    call PauseUnitBJ(false, GetTriggerUnit())
                    call SetUnitAnimation(GetTriggerUnit(), "alive")
                    call RemoveLocation(udg_tempLoc)
                else
                    set udg_RandomU=null
                    set udg_RandomU=GroupPickRandomUnit(GetUnitsInRectMatching(gg_rct_MainBossLoc, Condition(function Trig_ThePursuitDifficulty_Func004Func003Func003Func003Func002002001002)))
                    if ( Trig_ThePursuitDifficulty_Func004Func003Func003Func003Func003C() ) then
                        set udg_tempLoc=GetUnitLoc(udg_RandomU)
                        call SetUnitPositionLocFacingLocBJ(gg_unit_U005_0113, PolarProjectionBJ(udg_tempLoc, 150.00, GetRandomDirectionDeg()), udg_tempLoc)
                        call PauseUnitBJ(true, GetTriggerUnit())
                        call SetUnitAnimation(GetTriggerUnit(), "birth")
                        call TriggerSleepAction(2.00)
                        call PauseUnitBJ(false, GetTriggerUnit())
                        call SetUnitAnimation(GetTriggerUnit(), "alive")
                        call RemoveLocation(udg_tempLoc)
                    else
                        call RemoveLocation(udg_tempLoc)
                    endif
                    call RemoveLocation(udg_tempLoc)
                endif
                call RemoveLocation(udg_tempLoc)
            endif
            call RemoveLocation(udg_tempLoc)
        endif
        call RemoveLocation(udg_tempLoc)
    endif
endfunction

