    call DialogDisplayBJ(true, udg_dialogDifficulty, GetEnumPlayer())
endfunction

function Trig_TimeElapsedInit_Func105Func001A takes nothing returns nothing
    call SetUnitInvulnerable(GetEnumUnit(), true)
endfunction

function Trig_TimeElapsedInit_Func105A takes nothing returns nothing
    call ForGroupBJ(GetUnitsOfPlayerAll(GetEnumPlayer()), function Trig_TimeElapsedInit_Func105Func001A)
endfunction

function Trig_TimeElapsedInit_Actions takes nothing returns nothing
    call PlayThematicMusicBJ("IntroMusic.mp3")
    call SetPlayerName(Player(19), "TRIGSTR_9088")
    call SetPlayerAllianceStateBJ(Player(19), Player(22), bj_ALLIANCE_ALLIED_VISION)
    call SetPlayerAllianceStateBJ(Player(19), Player(23), bj_ALLIANCE_ALLIED_VISION)
    call SetPlayerAllianceStateBJ(Player(22), Player(19), bj_ALLIANCE_ALLIED_VISION)
    call SetPlayerAllianceStateBJ(Player(23), Player(19), bj_ALLIANCE_ALLIED_VISION)
    call BlzSetHeroProperName(gg_unit_U007_0220, "Ricardessa")
    call ForForce(GetPlayersAll(), function Trig_TimeElapsedInit_Func008A)
    call EnableTrigger(gg_trg_GameInit)


    call MeleeStartingVisibility()
    call MeleeStartingHeroLimit()
    // ----
    call GroupAddUnitSimple(gg_unit_H013_0011, udg_not_knockbackable_UG)
    call GroupAddUnitSimple(gg_unit_U007_0220, udg_not_knockbackable_UG)
    call GroupAddUnitSimple(gg_unit_U00I_0341, udg_not_knockbackable_UG)
    call GroupAddUnitSimple(gg_unit_O02P_0444, udg_not_knockbackable_UG)
    call GroupAddUnitSimple(gg_unit_N01N_0235, udg_not_knockbackable_UG)
    call GroupAddUnitSimple(gg_unit_U00K_0485, udg_not_knockbackable_UG)
    call GroupAddUnitSimple(gg_unit_O01W_0221, udg_not_knockbackable_UG)
    call GroupAddUnitSimple(gg_unit_E00C_0088, udg_not_knockbackable_UG)
    // ----
    call GroupAddUnitSimple(gg_unit_O002_0064, udg_WarriorsGroup)
    call GroupAddUnitSimple(gg_unit_H00A_0082, udg_WarriorsGroup)
    call GroupAddUnitSimple(gg_unit_O00C_0065, udg_WarriorsGroup)
    call GroupAddUnitSimple(gg_unit_H00O_0278, udg_WarriorsGroup)
    call GroupAddUnitSimple(gg_unit_E001_0061, udg_WarriorsGroup)
    call GroupAddUnitSimple(gg_unit_O024_0311, udg_WarriorsGroup)
    call GroupAddUnitSimple(gg_unit_E00C_0088, udg_WarriorsGroup)
    call GroupAddUnitSimple(gg_unit_H00B_0036, udg_WarlockGroup)
    call GroupAddUnitSimple(gg_unit_O001_0069, udg_WarlockGroup)
    // ----
    call GroupAddUnitSimple(gg_unit_O002_0064, udg_Orcs)
    call GroupAddUnitSimple(gg_unit_O000_0013, udg_Orcs)
    call GroupAddUnitSimple(gg_unit_H001_0116, udg_Orcs)
    call GroupAddUnitSimple(gg_unit_O001_0069, udg_Orcs)
    call GroupAddUnitSimple(gg_unit_E001_0061, udg_Orcs)
    // ----
    call GroupAddUnitSimple(gg_unit_O00C_0065, udg_Alliance)
    call GroupAddUnitSimple(gg_unit_H009_0081, udg_Alliance)
    call GroupAddUnitSimple(gg_unit_H00A_0082, udg_Alliance)
    call GroupAddUnitSimple(gg_unit_H008_0079, udg_Alliance)
    call GroupAddUnitSimple(gg_unit_H00B_0036, udg_Alliance)
    call GroupAddUnitSimple(gg_unit_H00Q_0280, udg_Alliance)
    call GroupAddUnitSimple(gg_unit_H00C_0066, udg_Alliance)
    call GroupAddUnitSimple(gg_unit_H00D_0059, udg_Alliance)
    call GroupAddUnitSimple(gg_unit_H00P_0279, udg_Alliance)
    // ----
    call GroupAddUnitSimple(gg_unit_H00E_0060, udg_NotAlliance)
    call GroupAddUnitSimple(gg_unit_H00O_0278, udg_NotAlliance)
    call GroupAddUnitSimple(gg_unit_H00N_0277, udg_NotAlliance)
    call GroupAddUnitSimple(gg_unit_H00M_0276, udg_NotAlliance)
    call GroupAddUnitSimple(gg_unit_O024_0311, udg_NotAlliance)
    // ----
    call ForGroupBJ(GetUnitsInRectAll(gg_rct_PlayableMapAreaLoc), function Trig_TimeElapsedInit_Func056A)
    call DestroyGroup(GetLastCreatedGroup())
    // ----
    call ForForce(GetPlayersAll(), function Trig_TimeElapsedInit_Func059A)
    call ForForce(GetPlayersAll(), function Trig_TimeElapsedInit_Func060A)
    call SetPlayerAllianceStateBJ(Player(22), Player(11), bj_ALLIANCE_ALLIED)
    call SetPlayerAllianceStateBJ(Player(23), Player(11), bj_ALLIANCE_ALLIED)
    call SetPlayerAllianceStateBJ(Player(11), Player(22), bj_ALLIANCE_ALLIED)
    call SetPlayerAllianceStateBJ(Player(11), Player(23), bj_ALLIANCE_ALLIED)
    set udg_KoshaiaAnim=gg_unit_H001_0116
