function Trig_NightHunterEnd_Actions takes nothing returns nothing
    call PlaySoundOnUnitBJ(gg_snd_DevourMagic, 100, gg_unit_U006_0283)
    call SetUnitColor(gg_unit_U006_0283, PLAYER_COLOR_MAROON)
    call SetUnitPathing(gg_unit_U006_0283, true)
    call UnitRemoveAbilityBJ('A06R', gg_unit_U006_0283)
    call UnitRemoveAbilityBJ('A06S', gg_unit_U006_0283)
    call UnitRemoveAbilityBJ('A06U', gg_unit_U006_0283)
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=3
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        call DestroyEffectBJ(udg_NightHunterEff[GetForLoopIndexA()])
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
