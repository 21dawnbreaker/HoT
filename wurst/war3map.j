//===========================================================================
// Trigger: TemplarsVerdictCast
//===========================================================================
function Trig_TemplarsVerdictCast_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A04N' ) ) then
        return false
    endif
    return true
endfunction

function Trig_TemplarsVerdictCast_Func005C takes nothing returns boolean
    if ( not ( udg_RetributionIsOn == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_TemplarsVerdictCast_Actions takes nothing returns nothing
    call SetUnitManaPercentBJ(GetTriggerUnit(), ( GetUnitManaPercent(GetTriggerUnit()) + ( 4.00 * I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) ) ))
    set udg_BladeOfJusticeLvl2=( GetUnitAbilityLevelSwapped('A04K', GetTriggerUnit()) + GetUnitAbilityLevelSwapped('A04O', GetTriggerUnit()) )
    set udg_BladeOfJusticeLvl2=( udg_BladeOfJusticeLvl2 + GetUnitAbilityLevelSwapped('A04L', GetTriggerUnit()) )
    call SetUnitLifePercentBJ(GetTriggerUnit(), ( GetUnitLifePercent(GetTriggerUnit()) + ( I2R(GetUnitAbilityLevelSwapped('A04L', gg_unit_H00N_0277)) * 3.00 ) ))
    if ( Trig_TemplarsVerdictCast_Func005C() ) then
        call UnitAddAbilityBJ('A04L', gg_unit_H00N_0277)
        call SetUnitAbilityLevelSwapped('A04L', gg_unit_H00N_0277, udg_BladeOfJusticeLvl2)
        call SetPlayerAbilityAvailableBJ(false, 'A04K', GetOwningPlayer(GetTriggerUnit()))
    else
        call UnitAddAbilityBJ('A04L', gg_unit_H00N_0277)
        call SetUnitAbilityLevelSwapped('A04L', gg_unit_H00N_0277, udg_BladeOfRetributionLvl)
        call SetPlayerAbilityAvailableBJ(false, 'A04O', GetOwningPlayer(GetTriggerUnit()))
    endif
endfunction

//===========================================================================
function InitTrig_TemplarsVerdictCast takes nothing returns nothing
    set gg_trg_TemplarsVerdictCast=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_TemplarsVerdictCast, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_TemplarsVerdictCast, Condition(function Trig_TemplarsVerdictCast_Conditions))
