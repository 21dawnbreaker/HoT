//===========================================================================
function Trig_InfernoNotEnoughHP_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A01A' ) ) then
        return false
    endif
    if ( not ( GetUnitStateSwap(UNIT_STATE_LIFE, GetTriggerUnit()) <= ( GetUnitStateSwap(UNIT_STATE_MAX_LIFE, GetTriggerUnit()) * ( 0.50 - ( 0.05 * I2R(GetUnitAbilityLevelSwapped('A01A', GetTriggerUnit())) ) ) ) ) ) then
        return false
    endif
    if ( not ( GetUnitStateSwap(UNIT_STATE_MANA, GetTriggerUnit()) <= ( GetUnitStateSwap(UNIT_STATE_MAX_MANA, GetTriggerUnit()) * ( 0.50 - ( 0.05 * I2R(GetUnitAbilityLevelSwapped('A01A', GetTriggerUnit())) ) ) ) ) ) then
        return false
    endif
    return true
endfunction

function Trig_InfernoNotEnoughHP_Func002C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 4) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_InfernoNotEnoughHP_Actions takes nothing returns nothing
    call IssueImmediateOrderBJ(GetTriggerUnit(), "stop")
    if ( Trig_InfernoNotEnoughHP_Func002C() ) then
        call CreateTextTagUnitBJ("TRIGSTR_9061", GetTriggerUnit(), 0, 10, 100, 100, 100, 0)
        call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
        call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 3.00)
        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
    else
    endif
endfunction

