//===========================================================================
// Trigger: TalentMushroomStew
//===========================================================================
function Trig_TalentMushroomStew_Conditions takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetSoldUnit()) == udg_TalentUnitType[39] ) ) then
        return false
    endif
    return true
endfunction

function Trig_TalentMushroomStew_Func001Func001Func003C takes nothing returns boolean
    if ( not ( udg_tempInt <= 30 ) ) then
        return false
    endif
    return true
endfunction

function Trig_TalentMushroomStew_Func001Func001Func004C takes nothing returns boolean
    if ( not ( udg_tempInt > 30 ) ) then
        return false
    endif
    if ( not ( udg_tempInt <= 60 ) ) then
        return false
    endif
    return true
endfunction

function Trig_TalentMushroomStew_Func001Func001Func005C takes nothing returns boolean
    if ( not ( udg_tempInt > 60 ) ) then
        return false
    endif
    if ( not ( udg_tempInt <= 70 ) ) then
        return false
    endif
    return true
endfunction

function Trig_TalentMushroomStew_Func001Func001Func006C takes nothing returns boolean
    if ( not ( udg_tempInt > 70 ) ) then
        return false
    endif
    return true
endfunction

function Trig_TalentMushroomStew_Func001Func001C takes nothing returns boolean
    if ( not ( IsUnitInGroup(GetEnumUnit(), udg_HeroesGroup) == true ) ) then
        return false
    endif
    if ( not ( IsUnitInGroup(GetEnumUnit(), udg_Metamorphosis) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_TalentMushroomStew_Func001A takes nothing returns nothing
    if ( Trig_TalentMushroomStew_Func001Func001C() ) then
        set udg_tempLoc=GetUnitLoc(GetEnumUnit())
        set udg_tempInt=GetRandomInt(1, 100)
        if ( Trig_TalentMushroomStew_Func001Func001Func003C() ) then
            call BlzSetUnitMaxHP(GetEnumUnit(), ( BlzGetUnitMaxHP(GetEnumUnit()) + ( BlzGetUnitMaxHP(GetEnumUnit()) / 10 ) ))
            call CreateTextTagUnitBJ("TRIGSTR_6194", GetEnumUnit(), 0, 10, 100, 100, 100, 0)
        else
        endif
        if ( Trig_TalentMushroomStew_Func001Func001Func004C() ) then
            call IncUnitAbilityLevelSwapped('A0FM', GetEnumUnit())
            call UnitAddAbilityBJ('A0FM', GetEnumUnit())
            call CreateTextTagUnitBJ("TRIGSTR_6195", GetEnumUnit(), 0, 10, 100, 100, 100, 0)
        else
        endif
        if ( Trig_TalentMushroomStew_Func001Func001Func005C() ) then
            call ModifyHeroStat(bj_HEROSTAT_STR, GetEnumUnit(), bj_MODIFYMETHOD_ADD, 25)
            call ModifyHeroStat(bj_HEROSTAT_AGI, GetEnumUnit(), bj_MODIFYMETHOD_ADD, 25)
            call ModifyHeroStat(bj_HEROSTAT_INT, GetEnumUnit(), bj_MODIFYMETHOD_ADD, 25)
            call CreateTextTagUnitBJ("TRIGSTR_6196", GetEnumUnit(), 0, 10, 100, 100, 100, 0)
        else
        endif
        if ( Trig_TalentMushroomStew_Func001Func001Func006C() ) then
            call UnitDamageTargetBJ(GetTriggerUnit(), GetEnumUnit(), ( GetUnitStateSwap(UNIT_STATE_MAX_LIFE, GetEnumUnit()) * 0.40 ), ATTACK_TYPE_MELEE, DAMAGE_TYPE_UNIVERSAL)
            call CreateTextTagUnitBJ("TRIGSTR_6197", GetEnumUnit(), 0, 10, 100, 100, 100, 0)
            call CreateNUnitsAtLoc(1, 'h028', Player(PLAYER_NEUTRAL_PASSIVE), udg_tempLoc, bj_UNIT_FACING)
            call UnitAddAbilityBJ('A0JT', GetLastCreatedUnit())
            call UnitApplyTimedLifeBJ(0.50, 'BTLF', GetLastCreatedUnit())
            call IssueTargetOrderBJ(GetLastCreatedUnit(), "slow", GetEnumUnit())
            set udg_mushroom_stew_unit=GetEnumUnit()
        else
        endif
        call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
        call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 3.00)
        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
        set udg_tempZ=GetLocationZ(udg_tempLoc)
        call PlaySoundAtPointBJ(gg_snd_Devour, 100, udg_tempLoc, udg_tempZ)
        set udg_tempZ=0.00
        call RemoveLocation(udg_tempLoc)
        set udg_tempInt=0
    else
    endif
endfunction

function Trig_TalentMushroomStew_Actions takes nothing returns nothing
    call ForGroupBJ(GetUnitsOfPlayerAll(GetOwningPlayer(GetTriggerUnit())), function Trig_TalentMushroomStew_Func001A)
    call TriggerSleepAction(0.50)
    set udg_tempUnit=udg_mushroom_stew_unit
    call TriggerExecute(gg_trg_PoisonedFunc)
    set udg_tempUnit=null
    set udg_mushroom_stew_unit=null
endfunction

//===========================================================================
function InitTrig_TalentMushroomStew takes nothing returns nothing
    set gg_trg_TalentMushroomStew=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_TalentMushroomStew, EVENT_PLAYER_UNIT_SELL)
    call TriggerAddCondition(gg_trg_TalentMushroomStew, Condition(function Trig_TalentMushroomStew_Conditions))
    call TriggerAddAction(gg_trg_TalentMushroomStew, function Trig_TalentMushroomStew_Actions)
endfunction

