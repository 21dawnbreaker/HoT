//===========================================================================
// Trigger: ChargeMove
//===========================================================================
function Trig_ChargeMove_Func001Func005Func009C takes nothing returns boolean
    if ( not ( IsUnitInGroup(udg_ChargeT, udg_not_knockbackable_UG) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_ChargeMove_Func001Func005C takes nothing returns boolean
    if ( not ( IsUnitEnemy(udg_ChargeT, GetOwningPlayer(udg_ChargeC)) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_ChargeMove_Func001C takes nothing returns boolean
    if ( not ( DistanceBetweenPoints(GetUnitLoc(udg_ChargeC), GetUnitLoc(udg_ChargeT)) <= 120.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ChargeMove_Actions takes nothing returns nothing
    if ( Trig_ChargeMove_Func001C() ) then
        call DisableTrigger(GetTriggeringTrigger())
        call SetUnitPathing(udg_ChargeC, true)
        call DestroyEffectBJ(udg_ChargeEff)
        call DestroyEffectBJ(udg_ChargeEff_Copy)
        if ( Trig_ChargeMove_Func001Func005C() ) then
            call PlaySoundOnUnitBJ(gg_snd_MetalHeavyBashMetal1, 100, udg_ChargeT)
            call IssueTargetOrderBJ(udg_ChargeC, "attack", udg_ChargeT)
            call SetUnitManaBJ(udg_ChargeC, ( GetUnitStateSwap(UNIT_STATE_MANA, udg_ChargeC) + 35.00 ))
            call UnitDamageTargetBJ(udg_ChargeC, udg_ChargeT, ( 120.00 * I2R(GetUnitAbilityLevelSwapped('A01Q', udg_ChargeC)) ), ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL)
            if ( Trig_ChargeMove_Func001Func005Func009C() ) then
                set udg_KBA_Caster=udg_ChargeC
                set udg_KBA_TargetUnit=udg_ChargeT
                set udg_KBA_Level=1
                set udg_KBA_StartingPosition=GetUnitLoc(udg_ChargeC)
                set udg_KBA_Speed=7.00
                set udg_KBA_DistancePerLevel=250.00
                set udg_KBA_SpecialEffects[1]="Abilities\\Spells\\Human\\FlakCannons\\FlakTarget.mdl"
                set udg_KBA_SpecialEffects[2]="Abilities\\Weapons\\AncientProtectorMissile\\AncientProtectorMissile.mdl"
                set udg_KBA_DestroyTrees=false
                call ConditionalTriggerExecute(gg_trg_Cast_A_Knockback)
            else
            endif
        else
            call CreateNUnitsAtLocFacingLocBJ(1, 'h000', GetOwningPlayer(udg_ChargeC), GetUnitLoc(udg_ChargeT), GetUnitLoc(udg_ChargeT))
            call UnitApplyTimedLifeBJ(1.00, 'BTLF', GetLastCreatedUnit())
            call IssueTargetOrderBJ(GetLastCreatedUnit(), "innerfire", udg_ChargeT)
        endif
    else
        call SetUnitFacingToFaceUnitTimed(udg_ChargeC, udg_ChargeT, 0)
        call SetUnitPositionLoc(udg_ChargeC, PolarProjectionBJ(GetUnitLoc(udg_ChargeC), 15.00, AngleBetweenPoints(GetUnitLoc(udg_ChargeC), GetUnitLoc(udg_ChargeT))))
    endif
endfunction

