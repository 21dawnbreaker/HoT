    set gg_trg_RicardessaPreparePeriodic=CreateTrigger()
    call DisableTrigger(gg_trg_RicardessaPreparePeriodic)
    call TriggerRegisterTimerEventPeriodic(gg_trg_RicardessaPreparePeriodic, 20.00)
    call TriggerAddAction(gg_trg_RicardessaPreparePeriodic, function Trig_RicardessaPreparePeriodic_Actions)
endfunction

