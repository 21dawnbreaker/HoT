//===========================================================================
function InitTrig_TalentsCheck takes nothing returns nothing
    set gg_trg_TalentsCheck=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_TalentsCheck, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_TalentsCheck, Condition(function Trig_TalentsCheck_Conditions))
    call TriggerAddAction(gg_trg_TalentsCheck, function Trig_TalentsCheck_Actions)
endfunction

//===========================================================================
// Trigger: TalentPointsGiveaway
//===========================================================================
function Trig_TalentPointsGiveaway_Func008C takes nothing returns boolean
    if ( ( GetHeroLevel(GetTriggerUnit()) == 3 ) ) then
        return true
    endif
    if ( ( GetHeroLevel(GetTriggerUnit()) == 6 ) ) then
        return true
    endif
    if ( ( GetHeroLevel(GetTriggerUnit()) == 9 ) ) then
        return true
    endif
    if ( ( GetHeroLevel(GetTriggerUnit()) == 12 ) ) then
        return true
    endif
    if ( ( GetHeroLevel(GetTriggerUnit()) == 15 ) ) then
        return true
    endif
    if ( ( GetHeroLevel(GetTriggerUnit()) == 18 ) ) then
        return true
    endif
    if ( ( GetHeroLevel(GetTriggerUnit()) == 21 ) ) then
        return true
    endif
    if ( ( GetHeroLevel(GetTriggerUnit()) == 24 ) ) then
        return true
    endif
    return false
endfunction

function Trig_TalentPointsGiveaway_Conditions takes nothing returns boolean
    if ( not ( IsUnitInGroup(GetTriggerUnit(), udg_HeroesGroup) == true ) ) then
        return false
    endif
    if ( not ( IsUnitInGroup(GetTriggerUnit(), udg_Metamorphosis) == false ) ) then
        return false
    endif
    if ( not Trig_TalentPointsGiveaway_Func008C() ) then
        return false
    endif
    return true
endfunction

function Trig_TalentPointsGiveaway_Actions takes nothing returns nothing
    call CreateTextTagUnitBJ("TRIGSTR_4792", GetTriggerUnit(), 0, 10, 100, 100, 100, 0)
    call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
    call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 3.00)
    call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 8.00, 135.00)
    call AdjustPlayerStateBJ(1, GetOwningPlayer(GetTriggerUnit()), PLAYER_STATE_RESOURCE_LUMBER)
endfunction

//===========================================================================
function InitTrig_TalentPointsGiveaway takes nothing returns nothing
    set gg_trg_TalentPointsGiveaway=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_TalentPointsGiveaway, EVENT_PLAYER_HERO_LEVEL)
    call TriggerAddCondition(gg_trg_TalentPointsGiveaway, Condition(function Trig_TalentPointsGiveaway_Conditions))
    call TriggerAddAction(gg_trg_TalentPointsGiveaway, function Trig_TalentPointsGiveaway_Actions)
endfunction

//===========================================================================
// Trigger: Anger
//===========================================================================
function Trig_Anger_Func004C takes nothing returns boolean
    if ( ( GetUnitAbilityLevelSwapped('A07Y', GetTriggerUnit()) >= 3 ) ) then
        return true
    endif
    if ( ( GetUnitAbilityLevelSwapped('A07Z', GetTriggerUnit()) >= 3 ) ) then
        return true
    endif
    return false
endfunction

function Trig_Anger_Conditions takes nothing returns boolean
    if ( not Trig_Anger_Func004C() ) then
        return false
    endif
    if ( not ( GetRandomInt(1, 100) <= 10 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Anger_Actions takes nothing returns nothing
    call PlaySoundOnUnitBJ(gg_snd_StampedeCaster1, 100, GetTriggerUnit())
    set udg_tempLoc=GetUnitLoc(GetTriggerUnit())
    call GroupAddUnitSimple(GetTriggerUnit(), udg_AngerUG)
    call UnitAddAbilityBJ('A08D', GetTriggerUnit())
    call CreateNUnitsAtLoc(1, 'h00W', Player(11), udg_tempLoc, bj_UNIT_FACING)
    call IssueTargetOrderBJ(GetLastCreatedUnit(), "acidbomb", GetTriggerUnit())
    call UnitApplyTimedLifeBJ(2.00, 'BTLF', GetLastCreatedUnit())
    call RemoveLocation(udg_tempLoc)
endfunction

//===========================================================================
function InitTrig_Anger takes nothing returns nothing
    set gg_trg_Anger=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Anger, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_Anger, Condition(function Trig_Anger_Conditions))
    call TriggerAddAction(gg_trg_Anger, function Trig_Anger_Actions)
endfunction

//===========================================================================
// Trigger: AngerStopDying
//===========================================================================
function Trig_AngerStopDying_Conditions takes nothing returns boolean
    if ( not ( IsUnitInGroup(GetTriggerUnit(), udg_AngerUG) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_AngerStopDying_Actions takes nothing returns nothing
    call UnitRemoveAbilityBJ('A08D', GetTriggerUnit())
    call GroupRemoveUnitSimple(GetTriggerUnit(), udg_AngerUG)
    call UnitRemoveBuffBJ('B022', GetTriggerUnit())
endfunction

//===========================================================================
function InitTrig_AngerStopDying takes nothing returns nothing
    set gg_trg_AngerStopDying=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_AngerStopDying, EVENT_PLAYER_UNIT_DEATH)
    call TriggerAddCondition(gg_trg_AngerStopDying, Condition(function Trig_AngerStopDying_Conditions))
    call TriggerAddAction(gg_trg_AngerStopDying, function Trig_AngerStopDying_Actions)
endfunction

