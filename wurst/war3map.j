    set gg_trg_ShoulderToShoulder=CreateTrigger()
    call DisableTrigger(gg_trg_ShoulderToShoulder)
    call TriggerRegisterTimerEventPeriodic(gg_trg_ShoulderToShoulder, 3.00)
    call TriggerAddAction(gg_trg_ShoulderToShoulder, function Trig_ShoulderToShoulder_Actions)
