//===========================================================================
// Trigger: tL11Periodic
//===========================================================================
function Trig_tL11Periodic_Func001Func001C takes nothing returns boolean
    if ( not ( IsUnitType(GetEnumUnit(), UNIT_TYPE_STRUCTURE) == false ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(udg_tL11C)) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_tL11Periodic_Func001A takes nothing returns nothing
    if ( Trig_tL11Periodic_Func001Func001C() ) then
        call UnitDamageTargetBJ(udg_tL11C, GetEnumUnit(), ( I2R(BlzGetUnitBaseDamage(udg_DamageEventSource, 0)) * 0.25 ), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_NORMAL)
    else
    endif
endfunction

function Trig_tL11Periodic_Func002C takes nothing returns boolean
    if ( not ( udg_tL11Int2 <= 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_tL11Periodic_Actions takes nothing returns nothing
    call ForGroupBJ(GetUnitsInRangeOfLocAll(200.00, udg_tL11Loc), function Trig_tL11Periodic_Func001A)
    if ( Trig_tL11Periodic_Func002C() ) then
        call AddSpecialEffectLocBJ(udg_tL11Loc, "Divine Edict.mdx")
        call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 0.50)
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        set udg_tL11Int2=4
    else
    endif
    set udg_tL11Int2=( udg_tL11Int2 - 1 )
endfunction

//===========================================================================
function InitTrig_tL11Periodic takes nothing returns nothing
    set gg_trg_tL11Periodic=CreateTrigger()
    call DisableTrigger(gg_trg_tL11Periodic)
    call TriggerRegisterTimerEventPeriodic(gg_trg_tL11Periodic, 0.25)
    call TriggerAddAction(gg_trg_tL11Periodic, function Trig_tL11Periodic_Actions)
endfunction

