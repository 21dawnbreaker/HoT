    if ( Trig_MinionSlayer_Func004Func001C() ) then
        call CreateNUnitsAtLoc(1, 'h028', GetOwningPlayer(udg_DamageEventSource), udg_tempLoc3, bj_UNIT_FACING)
        call UnitAddAbilityBJ('A0IK', GetLastCreatedUnit())
        call IssueTargetOrderBJ(GetLastCreatedUnit(), "chainlightning", GetEnumUnit())
        call UnitApplyTimedLifeBJ(1.00, 'BTLF', GetLastCreatedUnit())
        call UnitDamageTargetBJ(udg_DamageEventSource, GetEnumUnit(), ( udg_DamageEventAmount + 0.00 ), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_NORMAL)
