//===========================================================================
// Trigger: AimedDmg
//===========================================================================
function Trig_AimedDmg_Func002Func001Func001Func001Func001Func001C takes nothing returns boolean
    if ( not ( udg_ASLevel == 5 ) ) then
        return false
    endif
    return true
endfunction

function Trig_AimedDmg_Func002Func001Func001Func001Func001C takes nothing returns boolean
    if ( not ( udg_ASLevel == 4 ) ) then
        return false
    endif
    return true
endfunction

function Trig_AimedDmg_Func002Func001Func001Func001C takes nothing returns boolean
    if ( not ( udg_ASLevel == 3 ) ) then
        return false
    endif
    return true
endfunction

function Trig_AimedDmg_Func002Func001Func001C takes nothing returns boolean
    if ( not ( udg_ASLevel == 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_AimedDmg_Func002Func001C takes nothing returns boolean
    if ( not ( udg_ASLevel == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_AimedDmg_Func002C takes nothing returns boolean
    if ( not ( UnitHasBuffBJ(udg_ASTarget, 'B008') == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_AimedDmg_Actions takes nothing returns nothing
    set udg_ASi2=GetHeroStatBJ(bj_HEROSTAT_AGI, udg_ASCaster, true)
    if ( Trig_AimedDmg_Func002C() ) then
        if ( Trig_AimedDmg_Func002Func001C() ) then
            call UnitDamageTargetBJ(udg_ASCaster, udg_ASTarget, ( 125.00 + ( I2R(udg_ASi2) * 2.00 ) ), ATTACK_TYPE_PIERCE, DAMAGE_TYPE_NORMAL)
        else
            if ( Trig_AimedDmg_Func002Func001Func001C() ) then
                call UnitDamageTargetBJ(udg_ASCaster, udg_ASTarget, ( 250.00 + ( I2R(udg_ASi2) * 2.50 ) ), ATTACK_TYPE_PIERCE, DAMAGE_TYPE_NORMAL)
            else
                if ( Trig_AimedDmg_Func002Func001Func001Func001C() ) then
                    call UnitDamageTargetBJ(udg_ASCaster, udg_ASTarget, ( 375.00 + ( I2R(udg_ASi2) * 3.00 ) ), ATTACK_TYPE_PIERCE, DAMAGE_TYPE_NORMAL)
                else
                    if ( Trig_AimedDmg_Func002Func001Func001Func001Func001C() ) then
                        call UnitDamageTargetBJ(udg_ASCaster, udg_ASTarget, ( 500.00 + ( I2R(udg_ASi2) * 3.50 ) ), ATTACK_TYPE_PIERCE, DAMAGE_TYPE_NORMAL)
                    else
                        if ( Trig_AimedDmg_Func002Func001Func001Func001Func001Func001C() ) then
                            call UnitDamageTargetBJ(udg_ASCaster, udg_ASTarget, ( 625.00 + ( I2R(udg_ASi2) * 4.00 ) ), ATTACK_TYPE_PIERCE, DAMAGE_TYPE_NORMAL)
                        else
                        endif
                    endif
                endif
            endif
        endif
        call DisableTrigger(gg_trg_AimedDmg)
    else
    endif
endfunction

//===========================================================================
function InitTrig_AimedDmg takes nothing returns nothing
    set gg_trg_AimedDmg=CreateTrigger()
    call DisableTrigger(gg_trg_AimedDmg)
    call TriggerRegisterTimerEventPeriodic(gg_trg_AimedDmg, 0.05)
    call TriggerAddAction(gg_trg_AimedDmg, function Trig_AimedDmg_Actions)
endfunction

//===========================================================================
