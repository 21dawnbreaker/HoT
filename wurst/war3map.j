    if ( not ( GetUnitTypeId(udg_MutagenEffect) == 'o02U' ) ) then
        return false
    endif
    if ( not ( GetOwningPlayer(GetBuyingUnit()) == GetOwningPlayer(GetEnumUnit()) ) ) then
        return false
    endif
    return true
endfunction

function Trig_MutagenSelling_Func005Func001Func004C takes nothing returns boolean
    if ( not ( UnitHasItemOfTypeBJ(GetEnumUnit(), 'I08S') == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_MutagenSelling_Func005Func001Func007C takes nothing returns boolean
    if ( not ( GetItemCharges(GetItemOfTypeFromUnitBJ(udg_MutagenSeller, 'I08S')) > udg_MutagenPrice ) ) then
        return false
    endif
    return true
endfunction

function Trig_MutagenSelling_Func005Func001Func019C takes nothing returns boolean
    if ( ( GetItemCharges(GetItemOfTypeFromUnitBJ(udg_backpack_by_player[GetConvertedPlayerId(GetOwningPlayer(GetEnumUnit()))], 'I08S')) >= udg_MutagenPrice ) ) then
        return true
    endif
    if ( ( GetItemCharges(GetItemOfTypeFromUnitBJ(GetEnumUnit(), 'I08S')) >= udg_MutagenPrice ) ) then
        return true
    endif
    return false
endfunction

function Trig_MutagenSelling_Func005Func001C takes nothing returns boolean
    if ( not ( GetOwningPlayer(GetBuyingUnit()) == GetOwningPlayer(GetEnumUnit()) ) ) then
        return false
    endif
    if ( not Trig_MutagenSelling_Func005Func001Func019C() ) then
        return false
    endif
    return true
endfunction

function Trig_MutagenSelling_Func005A takes nothing returns nothing
    if ( Trig_MutagenSelling_Func005Func001C() ) then
        set udg_MutagenHero=GetEnumUnit()
        if ( Trig_MutagenSelling_Func005Func001Func004C() ) then
            set udg_MutagenSeller=GetEnumUnit()
        else
            set udg_MutagenSeller=udg_backpack_by_player[GetConvertedPlayerId(GetOwningPlayer(GetBuyingUnit()))]
        endif
        call ConditionalTriggerExecute(gg_trg_MutagenDealText)
        call TriggerExecute(gg_trg_MutagenApplyEffect)
        if ( Trig_MutagenSelling_Func005Func001Func007C() ) then
            call SetItemCharges(GetItemOfTypeFromUnitBJ(udg_MutagenSeller, 'I08S'), ( GetItemCharges(GetItemOfTypeFromUnitBJ(udg_MutagenSeller, 'I08S')) - udg_MutagenPrice ))
        else
            call RemoveItem(GetItemOfTypeFromUnitBJ(udg_MutagenSeller, 'I08S'))
        endif
        call AddSpecialEffectTargetUnitBJ("origin", udg_MutagenHero, "Abilities\\Spells\\Items\\AIre\\AIreTarget.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        set udg_tempLoc=PolarProjectionBJ(GetUnitLoc(udg_MutagenHero), 220.00, 180.00)
        call CreateTextTagLocBJ(( "|cff00ff00Мутагены|r: " + I2S(( GetItemCharges(GetItemOfTypeFromUnitBJ(udg_backpack_by_player[GetConvertedPlayerId(GetOwningPlayer(udg_MutagenSeller))], 'I08S')) + GetItemCharges(GetItemOfTypeFromUnitBJ(udg_hero_by_player[GetConvertedPlayerId(GetOwningPlayer(udg_MutagenSeller))], 'I08S')) )) ), udg_tempLoc, 0, 10, 100, 100, 100, 0)
        call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
        call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 1.00)
        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 90.00, 90.00)
        call RemoveLocation(udg_tempLoc)
        set udg_MutagenSeller=null
        set udg_MutagenHero=null
    else
        if ( Trig_MutagenSelling_Func005Func001Func001C() ) then
            call CreateTextTagUnitBJ(( "Не-а" ), udg_MutagenEiramonta, 0, 10, 100, 100, 100, 0)
            call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
            call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 4.00)
            call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
        else
        endif
        if ( Trig_MutagenSelling_Func005Func001Func002C() ) then
        else
        endif
    endif
endfunction

function Trig_MutagenSelling_Actions takes nothing returns nothing
    set udg_MutagenEiramonta=GetTriggerUnit()
    set udg_MutagenEffect=GetSoldUnit()
    call RemoveUnit(GetSoldUnit())
    if ( Trig_MutagenSelling_Func004C() ) then
        set udg_MutagenPrice=3
    else
        if ( Trig_MutagenSelling_Func004Func001C() ) then
            set udg_MutagenPrice=2
        else
            set udg_MutagenPrice=1
        endif
    endif
    call ForGroupBJ(udg_HeroesGroup, function Trig_MutagenSelling_Func005A)
    set udg_MutagenEiramonta=null
    set udg_MutagenEffect=null
endfunction

//===========================================================================
function InitTrig_MutagenSelling takes nothing returns nothing
    set gg_trg_MutagenSelling=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_MutagenSelling, EVENT_PLAYER_UNIT_SELL)
    call TriggerAddCondition(gg_trg_MutagenSelling, Condition(function Trig_MutagenSelling_Conditions))
    call TriggerAddAction(gg_trg_MutagenSelling, function Trig_MutagenSelling_Actions)
endfunction

