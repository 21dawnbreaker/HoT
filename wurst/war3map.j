function InitTrig_Phase3_Atkivus takes nothing returns nothing
    set gg_trg_Phase3_Atkivus=CreateTrigger()
    call h__TriggerRegisterVariableEvent(gg_trg_Phase3_Atkivus, "udg_DamageEvent", EQUAL, 1.00)
    call TriggerAddCondition(gg_trg_Phase3_Atkivus, Condition(function Trig_Phase3_Atkivus_Conditions))
    call TriggerAddAction(gg_trg_Phase3_Atkivus, function Trig_Phase3_Atkivus_Actions)
endfunction

//===========================================================================
// Trigger: EmilismaSpawn
//===========================================================================
function Trig_EmilismaSpawn_Actions takes nothing returns nothing
    call DisableTrigger(GetTriggeringTrigger())
    call SetTimeOfDay(24.00)
    call GroupRemoveUnitSimple(gg_unit_H012_0027, udg_BossUG)
    call GroupAddUnitSimple(gg_unit_H013_0011, udg_BossUG)
    call GroupAddUnitSimple(gg_unit_H013_0011, udg_not_knockbackable_UG)
    set udg_tempLoc=GetRectCenter(gg_rct_BossfightInnerLoc)
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=4
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        call AddSpecialEffectLocBJ(udg_tempLoc, "Conflagrate.mdx")
        call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 3.50)
        call BlzSetSpecialEffectHeight(GetLastCreatedEffectBJ(), ( BlzGetLocalUnitZ(udg_Boss[1]) - 0.00 ))
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    call RemoveUnit(udg_Boss[1])
    set udg_Boss[1]=gg_unit_H013_0011
    call PlaySoundOnUnitBJ(gg_snd_FacelessDeath1, 100, udg_Boss[1])
    call SetUnitPositionLocFacingBJ(udg_Boss[1], udg_tempLoc, 270.00)
    call SetUnitManaPercentBJ(udg_Boss[1], 0.00)
    set udg_emilisma_pos=GetUnitLoc(gg_unit_H013_0011)
    call EnableTrigger(gg_trg_EmilismaPeriodic)
    call EnableTrigger(gg_trg_HarvestPeriodic)
    call EnableTrigger(gg_trg_HopesEndPeriodic)
    call RemoveLocation(udg_tempLoc)
endfunction

