//===========================================================================
// Trigger: BossfightNataAraEnd
//===========================================================================
function Trig_BossfightNataAraEnd_Func001C takes nothing returns boolean
    if ( not ( IsUnitDeadBJ(gg_unit_U006_0283) == true ) ) then
        return false
    endif
    if ( not ( IsUnitDeadBJ(gg_unit_U005_0113) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_BossfightNataAraEnd_Actions takes nothing returns nothing
    if ( Trig_BossfightNataAraEnd_Func001C() ) then
        call GroupRemoveUnitSimple(gg_unit_U005_0113, udg_BossUG)
        call GroupRemoveUnitSimple(gg_unit_U006_0283, udg_BossUG)
        call DisableTrigger(gg_trg_StrangulateTriggerDifficulty)
        call DisableTrigger(gg_trg_ThePursuitTriggerDifficulty)
        call DisableTrigger(gg_trg_WillOfTheNecropolisDifficulty)
        call DisableTrigger(gg_trg_ShoulderToShoulder)
        call DisableTrigger(gg_trg_CallToArmsOnDamage)
        call DisableTrigger(gg_trg_ImpalesRandomPeriodic)
        call DisableTrigger(gg_trg_ImpalerPeriodicNightmare)
        call DisableTrigger(gg_trg_ThrowAxesTrigger)
        call DisableTrigger(gg_trg_NightHunterTrigger)
        call DisableTrigger(gg_trg_BossMusicHeroes)
        call DisableTrigger(gg_trg_BossMusicHeroesKilling)
        call DisableTrigger(gg_trg_BossMusicBossKilling)
        call DisableTrigger(gg_trg_BossMusicBoss)
        call DestroyEffectBJ(udg_CarrionSwarmLineEff)
        call GroupClear(udg_HeroesBossfightUG)
        set udg_BossPhase=0
        call EndThematicMusicBJ()
        set udg_BossTheme=1
        set udg_BossfightMainIsOn=0
        set udg_musicOn=0
        set udg_Boss[1]=null
        set udg_Boss[2]=null
        set udg_BossfightNataAra=- 1
        call TriggerSleepAction(2.00)
        set udg_tempUnit=GetTriggerUnit()
        call QuestSetCompletedBJ(udg_Quests[3], true)
        call TriggerExecute(gg_trg_BossDiesGeneralFunc)
    else
        call TriggerSleepAction(2)
        call RemoveUnit(GetTriggerUnit())
    endif
endfunction

