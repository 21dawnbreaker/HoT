function Trig_Righteous_Might_Actions takes nothing returns nothing
    call DisableTrigger(GetTriggeringTrigger())
    set udg_RighteousMightLoc=GetUnitLoc(GetTriggerUnit())
    call PlaySoundAtPointBJ(gg_snd_RighteousMight, 100, udg_RighteousMightLoc, 0)
    call CreateNUnitsAtLoc(1, 'h016', GetOwningPlayer(GetTriggerUnit()), udg_RighteousMightLoc, bj_UNIT_FACING)
    call IssueImmediateOrderBJ(GetLastCreatedUnit(), "roar")
    call UnitApplyTimedLifeBJ(2.00, 'BTLF', GetLastCreatedUnit())
    call ForGroupBJ(GetUnitsInRangeOfLocAll(900.00, udg_RighteousMightLoc), function Trig_Righteous_Might_Func007A)
    call TriggerSleepAction(0.50)
    call ForGroupBJ(GetUnitsInRangeOfLocAll(900.00, udg_RighteousMightLoc), function Trig_Righteous_Might_Func009A)
    call RemoveLocation(udg_RighteousMightLoc)
    call EnableTrigger(gg_trg_RighteousMightPeriodic)
endfunction

