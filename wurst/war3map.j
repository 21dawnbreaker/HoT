//===========================================================================
// Trigger: WaveOfForce
//===========================================================================
function Trig_WaveOfForce_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A05V' ) ) then
        return false
    endif
    return true
endfunction

function Trig_WaveOfForce_Func005Func001Func007C takes nothing returns boolean
    if ( not ( IsUnitInGroup(GetEnumUnit(), udg_not_knockbackable_UG) == false ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( BlzIsUnitInvulnerable(GetTriggerUnit()) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_WaveOfForce_Func005Func001C takes nothing returns boolean
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(GetTriggerUnit())) == true ) ) then
        return false
    endif
    if ( not ( IsUnitType(GetEnumUnit(), UNIT_TYPE_STRUCTURE) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_WaveOfForce_Func005A takes nothing returns nothing
    if ( Trig_WaveOfForce_Func005Func001C() ) then
        call CreateNUnitsAtLoc(1, 'h00I', GetOwningPlayer(gg_unit_H00D_0059), udg_tempLoc, bj_UNIT_FACING)
        call IssueTargetOrderBJ(GetLastCreatedUnit(), "faeriefire", GetEnumUnit())
        call UnitApplyTimedLifeBJ(2.00, 'BTLF', GetLastCreatedUnit())
        call UnitDamageTargetBJ(GetTriggerUnit(), GetEnumUnit(), ( ( 50.00 * I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) ) + ( ( 0.30 * I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) ) * I2R(GetHeroStatBJ(bj_HEROSTAT_INT, GetTriggerUnit(), true)) ) ), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_MAGIC)
        if ( Trig_WaveOfForce_Func005Func001Func007C() ) then
            set udg_KBA_Caster=GetTriggerUnit()
            set udg_KBA_TargetUnit=GetEnumUnit()
            set udg_KBA_Level=1
            set udg_KBA_StartingPosition=GetSpellTargetLoc()
            set udg_KBA_Speed=12.00
            set udg_KBA_DistancePerLevel=700.00
            set udg_KBA_SpecialEffects[1]="Abilities\\Spells\\Human\\FlakCannons\\FlakTarget.mdl"
            set udg_KBA_SpecialEffects[2]="Abilities\\Weapons\\AncientProtectorMissile\\AncientProtectorMissile.mdl"
            set udg_KBA_DestroyTrees=false
            call ConditionalTriggerExecute(gg_trg_Cast_A_Knockback)
        else
        endif
    else
    endif
endfunction

function Trig_WaveOfForce_Actions takes nothing returns nothing
    set udg_tempLoc=GetSpellTargetLoc()
    call PlaySoundAtPointBJ(gg_snd_Shockwave, 100, udg_tempLoc, 0)
    call AddSpecialEffectLocBJ(udg_tempLoc, "Singularity II Purple.mdx")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call ForGroupBJ(GetUnitsInRangeOfLocAll(300.00, udg_tempLoc), function Trig_WaveOfForce_Func005A)
    call RemoveLocation(udg_tempLoc)
endfunction

//===========================================================================
function InitTrig_WaveOfForce takes nothing returns nothing
    set gg_trg_WaveOfForce=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_WaveOfForce, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_WaveOfForce, Condition(function Trig_WaveOfForce_Conditions))
    call TriggerAddAction(gg_trg_WaveOfForce, function Trig_WaveOfForce_Actions)
endfunction

