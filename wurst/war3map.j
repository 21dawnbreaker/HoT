    set gg_trg_DifficultyVoteEnd=CreateTrigger()
    call TriggerRegisterTimerEventSingle(gg_trg_DifficultyVoteEnd, 30.00)
    call TriggerAddAction(gg_trg_DifficultyVoteEnd, function Trig_DifficultyVoteEnd_Actions)
endfunction

