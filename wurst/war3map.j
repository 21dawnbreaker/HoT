//===========================================================================
// Trigger: Phase2 NataAra
//===========================================================================
function Trig_Phase2_NataAra_Conditions takes nothing returns boolean
    if ( not ( ( GetUnitStateSwap(UNIT_STATE_LIFE, gg_unit_U005_0113) + GetUnitStateSwap(UNIT_STATE_LIFE, gg_unit_U006_0283) ) <= ( udg_BossHP * 0.70 ) ) ) then
        return false
    endif
    if ( not ( udg_BossfightMainIsOn == 1 ) ) then
        return false
    endif
    if ( not ( udg_BossfightNataAra == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Phase2_NataAra_Func003C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 2) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Phase2_NataAra_Actions takes nothing returns nothing
    call DisplayTextToForce(GetPlayersAll(), "TRIGSTR_3804")
    set udg_BossPhase=2
    if ( Trig_Phase2_NataAra_Func003C() ) then
        call EnableTrigger(gg_trg_ImpalerOnDamage)
    else
        call EnableTrigger(gg_trg_CallToArmsOnDamage)
    endif
    call EnableTrigger(gg_trg_ImpalesRandomPeriodic)
    call EndThematicMusicBJ()
    set udg_BossTheme=0
    call PlayThematicMusicBJ("xcombattle2.mp3")
    call DisableTrigger(GetTriggeringTrigger())
endfunction

//===========================================================================
function InitTrig_Phase2_NataAra takes nothing returns nothing
    set gg_trg_Phase2_NataAra=CreateTrigger()
    call h__TriggerRegisterVariableEvent(gg_trg_Phase2_NataAra, "udg_DamageEvent", EQUAL, 1.00)
    call TriggerAddCondition(gg_trg_Phase2_NataAra, Condition(function Trig_Phase2_NataAra_Conditions))
    call TriggerAddAction(gg_trg_Phase2_NataAra, function Trig_Phase2_NataAra_Actions)
endfunction

