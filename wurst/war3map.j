// Trigger: RallyPoint
//===========================================================================
function Trig_RallyPoint_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A04G' ) ) then
        return false
    endif
    return true
endfunction

function Trig_RallyPoint_Func015Func001Func001C takes nothing returns boolean
    if ( not ( IsUnitType(GetEnumUnit(), UNIT_TYPE_HERO) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_RallyPoint_Func015Func001Func002C takes nothing returns boolean
    if ( not ( IsUnitType(GetEnumUnit(), UNIT_TYPE_HERO) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_RallyPoint_Func015Func001C takes nothing returns boolean
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(GetTriggerUnit())) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_RallyPoint_Func015A takes nothing returns nothing
    if ( Trig_RallyPoint_Func015Func001C() ) then
        if ( Trig_RallyPoint_Func015Func001Func001C() ) then
            set udg_RallyPointEnemy=( udg_RallyPointEnemy + ( R2I(GetUnitStateSwap(UNIT_STATE_LIFE, GetEnumUnit())) * 2 ) )
        else
            set udg_RallyPointEnemy=( udg_RallyPointEnemy + R2I(GetUnitStateSwap(UNIT_STATE_LIFE, GetEnumUnit())) )
        endif
    else
        if ( Trig_RallyPoint_Func015Func001Func002C() ) then
            set udg_RallyPointAlly=( udg_RallyPointAlly + ( R2I(GetUnitStateSwap(UNIT_STATE_LIFE, GetEnumUnit())) * 2 ) )
        else
            set udg_RallyPointAlly=( udg_RallyPointAlly + R2I(GetUnitStateSwap(UNIT_STATE_LIFE, GetEnumUnit())) )
        endif
    endif
endfunction

function Trig_RallyPoint_Func017Func001C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 2) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_RallyPoint_Actions takes nothing returns nothing
    call PlaySoundOnUnitBJ(gg_snd_RallyPointPlace1, 100, gg_unit_H00O_0278)
    set udg_RallyPointPoint=GetSpellTargetLoc()
    call AddSpecialEffectLocBJ(GetSpellTargetLoc(), "UI\\Feedback\\RallyPoint\\RallyPoint.mdl")
    set udg_RallyPointEff=GetLastCreatedEffectBJ()
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 1.50)
    call BlzSetSpecialEffectColorByPlayer(GetLastCreatedEffectBJ(), Player(1))
    call AddSpecialEffectLocBJ(GetSpellTargetLoc(), "UI\\Feedback\\TargetPreSelected\\TargetPreSelected.mdl")
    set udg_RallyPointEff2=GetLastCreatedEffectBJ()
    call BlzSetSpecialEffectHeight(GetLastCreatedEffectBJ(), ( BlzGetLocalUnitZ(GetTriggerUnit()) - 150.00 ))
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 15.00)
    call TriggerSleepAction(27.00)
    call DestroyEffectBJ(udg_RallyPointEff)
    call DestroyEffectBJ(udg_RallyPointEff2)
    call TriggerSleepAction(3.00)
    call ForGroupBJ(GetUnitsInRangeOfLocAll(600.00, udg_RallyPointPoint), function Trig_RallyPoint_Func015A)
    call PlaySoundBJ(gg_snd_Press_the_Attack_mp3)
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=( 3 + GetUnitAbilityLevelSwapped('A04G', gg_unit_H00O_0278) )
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        if ( Trig_RallyPoint_Func017Func001C() ) then
            call CreateNUnitsAtLoc(1, 'h00R', GetOwningPlayer(GetTriggerUnit()), PolarProjectionBJ(udg_RallyPointPoint, 600.00, GetRandomDirectionDeg()), bj_UNIT_FACING)
            call BlzSetUnitMaxHP(GetLastCreatedUnit(), ( BlzGetUnitMaxHP(GetLastCreatedUnit()) + ( BlzGetUnitMaxHP(GetTriggerUnit()) / 10 ) ))
            call SetUnitLifePercentBJ(GetLastCreatedUnit(), 100)
            call BlzSetUnitBaseDamage(GetLastCreatedUnit(), ( BlzGetUnitBaseDamage(GetLastCreatedUnit(), 0) + ( GetHeroStatBJ(bj_HEROSTAT_STR, GetTriggerUnit(), true) / 2 ) ), 0)
            call SetUnitColor(GetLastCreatedUnit(), PLAYER_COLOR_BLUE)
            call IssuePointOrderLocBJ(GetLastCreatedUnit(), "attack", udg_RallyPointPoint)
        else
            call CreateNUnitsAtLoc(1, 'e003', GetOwningPlayer(GetTriggerUnit()), PolarProjectionBJ(udg_RallyPointPoint, 600.00, GetRandomDirectionDeg()), bj_UNIT_FACING)
            call BlzSetUnitMaxHP(GetLastCreatedUnit(), ( BlzGetUnitMaxHP(GetLastCreatedUnit()) + ( BlzGetUnitMaxHP(GetTriggerUnit()) / 20 ) ))
            call SetUnitLifePercentBJ(GetLastCreatedUnit(), 100)
            call BlzSetUnitBaseDamage(GetLastCreatedUnit(), ( BlzGetUnitBaseDamage(GetLastCreatedUnit(), 0) + ( GetHeroStatBJ(bj_HEROSTAT_STR, GetTriggerUnit(), true) / 3 ) ), 0)
            call SetUnitColor(GetLastCreatedUnit(), PLAYER_COLOR_BLUE)
            call IssuePointOrderLocBJ(GetLastCreatedUnit(), "attack", udg_RallyPointPoint)
        endif
        set udg_tempLoc=GetUnitLoc(GetLastCreatedUnit())
        call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\Human\\MassTeleport\\MassTeleportTarget.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call RemoveLocation(udg_tempLoc)
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
endfunction

//===========================================================================
function InitTrig_RallyPoint takes nothing returns nothing
