//===========================================================================
function Trig_Supression_Conditions takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped('A07Y', GetTriggerUnit()) >= 6 ) ) then
        return false
    endif
    if ( not ( GetRandomInt(1, 100) <= 10 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Supression_Func002Func001Func008C takes nothing returns boolean
    if ( ( GetUnitAbilityLevelSwapped('A082', GetEnumUnit()) >= 1 ) ) then
        return true
    endif
    if ( ( GetUnitAbilityLevelSwapped('A081', GetEnumUnit()) >= 1 ) ) then
        return true
    endif
    return false
endfunction

function Trig_Supression_Func002Func001C takes nothing returns boolean
    if ( not ( IsUnitType(GetEnumUnit(), UNIT_TYPE_HERO) == true ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not Trig_Supression_Func002Func001Func008C() ) then
        return false
    endif
    return true
endfunction

function Trig_Supression_Func002A takes nothing returns nothing
    if ( Trig_Supression_Func002Func001C() ) then
        call AddSpecialEffectTargetUnitBJ("origin", GetEnumUnit(), "Soul Beam Red.mdx")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call CreateNUnitsAtLoc(1, 'h00W', Player(11), udg_tempLoc, bj_UNIT_FACING)
        call IssueTargetOrderBJ(GetLastCreatedUnit(), "cripple", GetEnumUnit())
        call UnitApplyTimedLifeBJ(2.00, 'BTLF', GetLastCreatedUnit())
    else
    endif
endfunction

function Trig_Supression_Actions takes nothing returns nothing
    set udg_tempLoc=GetUnitLoc(GetTriggerUnit())
    call ForGroupBJ(GetUnitsInRangeOfLocAll(900.00, udg_tempLoc), function Trig_Supression_Func002A)
    call RemoveLocation(udg_tempLoc)
endfunction

