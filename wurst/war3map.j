        call CreateNUnitsAtLoc(1, 'h00U', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc, bj_UNIT_FACING)
        call SetUnitVertexColorBJ(GetLastCreatedUnit(), 100, 100, 100, 100.00)
        call UnitApplyTimedLifeBJ(1.00, 'BTLF', GetLastCreatedUnit())
        call IssueTargetOrderBJ(GetLastCreatedUnit(), "thunderbolt", GetEnumUnit())
        call GroupAddUnitSimple(GetEnumUnit(), udg_RunestoneMasterUG)
    else
