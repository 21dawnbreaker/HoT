    else
    endif
    if ( Trig_TomeOfWonders_Func010C() ) then
        call UnitAddItemByIdSwapped('I01E', GetLastCreatedUnit())
    else
    endif
    call UnitUseItem(GetLastCreatedUnit(), UnitItemInSlotBJ(GetLastCreatedUnit(), 1))
    call RemoveLocation(udg_tempLoc)
    set udg_tempInt=0
endfunction

