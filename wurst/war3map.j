function Trig_AoSChestM3_Conditions takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetSoldUnit()) == 'o00O' ) ) then
        return false
    endif
    if ( not ( UnitHasItemOfTypeBJ(GetBuyingUnit(), 'I063') == true ) ) then
        return false
    endif
    if ( not ( UnitHasItemOfTypeBJ(GetBuyingUnit(), 'I01K') == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_AoSChestM3_Func001C takes nothing returns boolean
    if ( not ( GetItemCharges(GetItemOfTypeFromUnitBJ(GetBuyingUnit(), 'I01K')) >= 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_AoSChestM3_Actions takes nothing returns nothing
    if ( Trig_AoSChestM3_Func001C() ) then
        call RemoveItem(GetItemOfTypeFromUnitBJ(GetBuyingUnit(), 'I063'))
        call SetItemCharges(GetItemOfTypeFromUnitBJ(GetBuyingUnit(), 'I01K'), ( GetItemCharges(GetItemOfTypeFromUnitBJ(GetBuyingUnit(), 'I01K')) - 2 ))
        call AddSpecialEffectTargetUnitBJ("origin", GetBuyingUnit(), "Abilities\\Spells\\Human\\ManaFlare\\ManaFlareBoltImpact.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call UnitAddItemByIdSwapped('I064', GetBuyingUnit())
        set udg_tempInt=1
    else
    endif
endfunction

//===========================================================================
function InitTrig_AoSChestM3 takes nothing returns nothing
    set gg_trg_AoSChestM3=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_AoSChestM3, EVENT_PLAYER_UNIT_SELL)
    call TriggerAddCondition(gg_trg_AoSChestM3, Condition(function Trig_AoSChestM3_Conditions))
    call TriggerAddAction(gg_trg_AoSChestM3, function Trig_AoSChestM3_Actions)
endfunction

