    call h__TriggerRegisterVariableEvent(gg_trg_RoomChangingLoc, "udg_RoomMultiboardCounting", EQUAL, 200.00)
    call h__TriggerRegisterVariableEvent(gg_trg_RoomChangingLoc, "udg_RoomMultiboardCounting", EQUAL, 250.00)
    call h__TriggerRegisterVariableEvent(gg_trg_RoomChangingLoc, "udg_RoomMultiboardCounting", EQUAL, 275.00)
    call h__TriggerRegisterVariableEvent(gg_trg_RoomChangingLoc, "udg_RoomMultiboardCounting", EQUAL, 300.00)
