    if ( not ( IsUnitAliveBJ(udg_ricardessa) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Phase2_Atkivus_Actions takes nothing returns nothing
    call DisplayTextToForce(GetPlayersAll(), "TRIGSTR_8921")
    set udg_BossPhase=2
    call EndThematicMusicBJ()
    set udg_BossTheme=0
    call PlayThematicMusicBJ("xcombattle2.mp3")
    if ( Trig_Phase2_Atkivus_Func006C() ) then
        call EnableTrigger(gg_trg_RicardessaPreparePeriodic)
    else
    endif
    call EnableTrigger(gg_trg_ShadowdancePeriodic)
    call DisableTrigger(GetTriggeringTrigger())
endfunction

