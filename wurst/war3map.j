//===========================================================================
// Trigger: AlterTime
//===========================================================================
function Trig_AlterTime_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A050' ) ) then
        return false
    endif
    return true
endfunction

function Trig_AlterTime_Func003C takes nothing returns boolean
    if ( not ( udg_ArcaneBarrageLvl > 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_AlterTime_Func012Func002C takes nothing returns boolean
    if ( not ( IsUnitAliveBJ(GetTriggerUnit()) == true ) ) then
        return false
    endif
    if ( not ( udg_ATisOn == 1 ) ) then
        return false
    endif
    if ( not ( UnitHasBuffBJ(GetTriggerUnit(), 'B012') == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_AlterTime_Func012C takes nothing returns boolean
    if ( not ( udg_AlterTimeDemand == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_AlterTime_Actions takes nothing returns nothing
    set udg_AlterTimeDemand=0
    set udg_ArcaneBarrageLvl=GetUnitAbilityLevelSwapped('A04Y', GetTriggerUnit())
    if ( Trig_AlterTime_Func003C() ) then
        call UnitRemoveAbilityBJ('A04Y', GetTriggerUnit())
        call UnitAddAbilityBJ('A04Y', GetTriggerUnit())
        call SetUnitAbilityLevelSwapped('A04Y', GetTriggerUnit(), udg_ArcaneBarrageLvl)
    else
    endif
    set udg_ATlife=R2I(GetUnitStateSwap(UNIT_STATE_LIFE, GetTriggerUnit()))
    set udg_ATmana=R2I(GetUnitStateSwap(UNIT_STATE_MANA, GetTriggerUnit()))
    set udg_ATpoint=GetUnitLoc(GetTriggerUnit())
    set udg_ATisOn=1
    call TriggerSleepAction(0.50)
    call BlzUnitDisableAbility(GetTriggerUnit(), 'A050', true, true)
    call UnitAddAbilityBJ('A00P', GetTriggerUnit())
    call TriggerSleepAction(14.00)
    if ( Trig_AlterTime_Func012C() ) then
        if ( Trig_AlterTime_Func012Func002C() ) then
            set udg_ATisOn=0
            call AddSpecialEffectTargetUnitBJ("origin", GetTriggerUnit(), "Abilities\\Spells\\Human\\MassTeleport\\MassTeleportTarget.mdl")
            call DestroyEffectBJ(GetLastCreatedEffectBJ())
            call SetUnitLifeBJ(GetTriggerUnit(), I2R(udg_ATlife))
            call SetUnitManaBJ(GetTriggerUnit(), I2R(udg_ATmana))
            call SetUnitPositionLoc(gg_unit_H009_0081, udg_ATpoint)
            call PanCameraToTimedLocForPlayer(GetOwningPlayer(gg_unit_H009_0081), GetUnitLoc(gg_unit_H009_0081), 0.10)
            call UnitRemoveBuffBJ('B012', gg_unit_H009_0081)
            call UnitRemoveAbilityBJ('A00P', GetTriggerUnit())
            call BlzUnitDisableAbility(GetTriggerUnit(), 'A050', false, false)
        else
            set udg_ATisOn=0
            call UnitRemoveAbilityBJ('A00P', GetTriggerUnit())
            call BlzUnitDisableAbility(GetTriggerUnit(), 'A050', false, false)
        endif
    else
    endif
endfunction

//===========================================================================
function InitTrig_AlterTime takes nothing returns nothing
    set gg_trg_AlterTime=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_AlterTime, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_AlterTime, Condition(function Trig_AlterTime_Conditions))
    call TriggerAddAction(gg_trg_AlterTime, function Trig_AlterTime_Actions)
endfunction

//===========================================================================
// Trigger: AlterTimeActivate
//===========================================================================
function Trig_AlterTimeActivate_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A00P' ) ) then
        return false
    endif
    return true
endfunction

function Trig_AlterTimeActivate_Func002C takes nothing returns boolean
    if ( not ( UnitHasBuffBJ(GetTriggerUnit(), 'B012') == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_AlterTimeActivate_Actions takes nothing returns nothing
    set udg_AlterTimeDemand=1
    if ( Trig_AlterTimeActivate_Func002C() ) then
        set udg_ATisOn=0
        call UnitRemoveBuffBJ('B012', gg_unit_H009_0081)
        call UnitRemoveAbilityBJ('A00P', GetTriggerUnit())
        call BlzUnitDisableAbility(GetTriggerUnit(), 'A050', false, false)
    else
        call AddSpecialEffectTargetUnitBJ("origin", GetTriggerUnit(), "Abilities\\Spells\\Human\\MassTeleport\\MassTeleportTarget.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        set udg_ATisOn=0
        call SetUnitLifeBJ(GetTriggerUnit(), I2R(udg_ATlife))
        call SetUnitManaBJ(GetTriggerUnit(), I2R(udg_ATmana))
        call SetUnitPositionLoc(gg_unit_H009_0081, udg_ATpoint)
        call PanCameraToTimedLocForPlayer(GetOwningPlayer(gg_unit_H009_0081), GetUnitLoc(gg_unit_H009_0081), 0.10)
        call UnitRemoveBuffBJ('B012', gg_unit_H009_0081)
        call UnitRemoveAbilityBJ('A00P', GetTriggerUnit())
        call BlzUnitDisableAbility(GetTriggerUnit(), 'A050', false, false)
    endif
endfunction

//===========================================================================
function InitTrig_AlterTimeActivate takes nothing returns nothing
    set gg_trg_AlterTimeActivate=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_AlterTimeActivate, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_AlterTimeActivate, Condition(function Trig_AlterTimeActivate_Conditions))
    call TriggerAddAction(gg_trg_AlterTimeActivate, function Trig_AlterTimeActivate_Actions)
