    if ( not ( RectContainsUnit(udg_RoomReg[udg_RoomInt], GetTriggerUnit()) == true ) ) then
        return false
    endif
    if ( not ( CountUnitsInGroup(udg_RoomEnemyUG) == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ObjectRewardingGeneral_Actions takes nothing returns nothing
    call GroupRemoveUnitSimple(GetTriggerUnit(), udg_RoomEnemyUG)
    if ( Trig_ObjectRewardingGeneral_Func002C() ) then
        call TriggerExecute(gg_trg_RewardingGeneral)
        call ConditionalTriggerExecute(gg_trg_HeroResFunc)
        set udg_EncounterEndInt=1
        call ConditionalTriggerExecute(gg_trg_RewardingChestsRollFunc)
        set udg_tempLoc=GetRandomLocInRect(udg_RewardRoom[udg_RoomInt])
        set udg_tempInt=GetRandomInt(1, 5)
        if ( Trig_ObjectRewardingGeneral_Func002Func007C() ) then
            call CreateNUnitsAtLoc(1, 'h027', Player(PLAYER_NEUTRAL_PASSIVE), udg_tempLoc, bj_UNIT_FACING)
        else
        endif
        if ( Trig_ObjectRewardingGeneral_Func002Func008C() ) then
            call CreateNUnitsAtLoc(1, 'h01O', Player(PLAYER_NEUTRAL_PASSIVE), udg_tempLoc, 300.00)
        else
        endif
        if ( Trig_ObjectRewardingGeneral_Func002Func009C() ) then
            call CreateNUnitsAtLoc(1, 'h025', Player(20), udg_tempLoc, 250.00)
        else
        endif
        if ( Trig_ObjectRewardingGeneral_Func002Func010C() ) then
            call CreateNUnitsAtLoc(1, 'h026', Player(20), udg_tempLoc, 250.00)
            call CreateNUnitsAtLoc(1, 'h01S', Player(20), PolarProjectionBJ(udg_tempLoc, 150.00, 270.00), GetRandomDirectionDeg())
            call UnitPauseTimedLifeBJ(true, GetLastCreatedUnit())
            call UnitAddAbilityBJ('Avul', GetLastCreatedUnit())
        else
        endif
        if ( Trig_ObjectRewardingGeneral_Func002Func011C() ) then
            call CreateNUnitsAtLoc(1, 'o02D', Player(PLAYER_NEUTRAL_PASSIVE), udg_tempLoc, GetRandomDirectionDeg())
        else
        endif
        call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\NightElf\\Blink\\BlinkTarget.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call RemoveLocation(udg_tempLoc)
        set udg_tempInt=0
    else
    endif
endfunction

