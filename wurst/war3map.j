    set gg_trg_tL33_Copy_Copy=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_tL33_Copy_Copy, EVENT_PLAYER_UNIT_PAWN_ITEM)
    call TriggerAddCondition(gg_trg_tL33_Copy_Copy, Condition(function Trig_tL33_Copy_Copy_Conditions))
