//===========================================================================
// Trigger: WillOfTheNecropolisDifficulty
//===========================================================================
function Trig_WillOfTheNecropolisDifficulty_Conditions takes nothing returns boolean
    if ( not ( udg_BossfightDialogueInt == 0 ) ) then
        return false
    endif
    if ( not ( udg_DamageEventTarget == gg_unit_U005_0113 ) ) then
        return false
    endif
    if ( not ( GetUnitLifePercent(udg_DamageEventTarget) <= 35.00 ) ) then
        return false
    endif
    if ( not ( udg_DIFFICULTY >= 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_WillOfTheNecropolisDifficulty_Func003C takes nothing returns boolean
    if ( not ( UnitHasBuffBJ(gg_unit_U005_0113, 'B01V') == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_WillOfTheNecropolisDifficulty_Actions takes nothing returns nothing
    set udg_DamageEventAmount=( udg_DamageEventAmount * 0.65 )
    if ( Trig_WillOfTheNecropolisDifficulty_Func003C() ) then
        call PlaySoundOnUnitBJ(gg_snd_GromPissed2, 100, gg_unit_U005_0113)
        call IssueImmediateOrderBJ(gg_unit_U005_0113, "berserk")
    else
    endif
endfunction

//===========================================================================
function InitTrig_WillOfTheNecropolisDifficulty takes nothing returns nothing
    set gg_trg_WillOfTheNecropolisDifficulty=CreateTrigger()
    call DisableTrigger(gg_trg_WillOfTheNecropolisDifficulty)
    call h__TriggerRegisterVariableEvent(gg_trg_WillOfTheNecropolisDifficulty, "udg_DamageEvent", EQUAL, 1.00)
    call TriggerAddCondition(gg_trg_WillOfTheNecropolisDifficulty, Condition(function Trig_WillOfTheNecropolisDifficulty_Conditions))
    call TriggerAddAction(gg_trg_WillOfTheNecropolisDifficulty, function Trig_WillOfTheNecropolisDifficulty_Actions)
endfunction

