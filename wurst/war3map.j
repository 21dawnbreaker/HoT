function Trig_FallenShrinePeriodic_Actions takes nothing returns nothing
    set udg_tempLoc=PolarProjectionBJ(GetUnitLoc(udg_fallen_shrine_shrine), 600.00, GetRandomDirectionDeg())
    set udg_tempLoc2=GetUnitLoc(udg_fallen_shrine_shrine)
    call CreateNUnitsAtLocFacingLocBJ(1, 'n00Q', Player(23), udg_tempLoc, udg_tempLoc2)
