endfunction

//===========================================================================
// Trigger: BladeOfJusticeEmpowered
//===========================================================================
function Trig_BladeOfJusticeEmpowered_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A04L' ) ) then
        return false
    endif
    return true
endfunction

function Trig_BladeOfJusticeEmpowered_Func015C takes nothing returns boolean
    if ( not ( udg_RetributionIsOn == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_BladeOfJusticeEmpowered_Actions takes nothing returns nothing
    set udg_tempLoc=GetUnitLoc(GetSpellTargetUnit())
    call StopSoundBJ(udg_blade_of_justice_sound, false)
    call PlaySoundOnUnitBJ(gg_snd_Spell_PA_BladeofJustice_Cast_Revamp_03, 100, GetTriggerUnit())
    set udg_blade_of_justice_sound=GetLastPlayedSound()
    call UnitDamageTargetBJ(GetTriggerUnit(), GetSpellTargetUnit(), ( ( I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) * 1.00 ) * I2R(GetHeroStatBJ(bj_HEROSTAT_STR, GetTriggerUnit(), true)) ), ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL)
    call UnitDamageTargetBJ(GetTriggerUnit(), GetSpellTargetUnit(), ( 150.00 * I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) ), ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL)
    call SetUnitLifePercentBJ(GetTriggerUnit(), ( GetUnitLifePercent(GetTriggerUnit()) + ( I2R(GetUnitAbilityLevelSwapped('A04L', gg_unit_H00N_0277)) * 3.00 ) ))
    call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\Undead\\Impale\\ImpaleHitTarget.mdl")
    call BlzSetSpecialEffectColor(GetLastCreatedEffectBJ(), 255, 255, 0)
    call BlzSetSpecialEffectAlpha(GetLastCreatedEffectBJ(), 200)
    call BlzSetSpecialEffectColorByPlayer(GetLastCreatedEffectBJ(), Player(4))
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call RemoveLocation(udg_tempLoc)
    call UnitRemoveAbilityBJ('A04L', gg_unit_H00N_0277)
    if ( Trig_BladeOfJusticeEmpowered_Func015C() ) then
        call SetPlayerAbilityAvailableBJ(true, 'A04K', GetOwningPlayer(GetTriggerUnit()))
    else
        call SetPlayerAbilityAvailableBJ(true, 'A04O', GetOwningPlayer(GetTriggerUnit()))
    endif
endfunction

//===========================================================================
function InitTrig_BladeOfJusticeEmpowered takes nothing returns nothing
    set gg_trg_BladeOfJusticeEmpowered=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_BladeOfJusticeEmpowered, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_BladeOfJusticeEmpowered, Condition(function Trig_BladeOfJusticeEmpowered_Conditions))
    call TriggerAddAction(gg_trg_BladeOfJusticeEmpowered, function Trig_BladeOfJusticeEmpowered_Actions)
endfunction

