// Trigger: tL33 Copy Copy
//===========================================================================
function Trig_tL33_Copy_Copy_Conditions takes nothing returns boolean
    if ( not ( IsPlayerInForce(GetOwningPlayer(GetSellingUnit()), udg_HeadhunterPG) == true ) ) then
        return false
    endif
    if ( not ( GetItemTypeId(GetSoldItem()) == 'I020' ) ) then
        return false
    endif
    return true
endfunction

function Trig_tL33_Copy_Copy_Func001001002 takes nothing returns boolean
    return ( IsUnitInGroup(GetFilterUnit(), udg_HeroesGroup) == true )
endfunction

function Trig_tL33_Copy_Copy_Func001Func001C takes nothing returns boolean
    if ( not ( IsUnitInGroup(GetEnumUnit(), udg_Metamorphosis) == false ) ) then
        return false
    endif
    if ( not ( GetUnitAbilityLevelSwapped('A0AA', GetEnumUnit()) >= 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_tL33_Copy_Copy_Func001A takes nothing returns nothing
    if ( Trig_tL33_Copy_Copy_Func001Func001C() ) then
        call AdjustPlayerStateBJ(( 300 * GetUnitAbilityLevelSwapped('A0AA', GetEnumUnit()) ), GetOwningPlayer(GetTriggerUnit()), PLAYER_STATE_RESOURCE_GOLD)
        call AdjustPlayerStateBJ(- 300, GetOwningPlayer(GetTriggerUnit()), PLAYER_STATE_RESOURCE_GOLD)
        call CreateTextTagUnitBJ(( "Headhunting bonus: |cffffff00+" + I2S(( ( 300 * GetUnitAbilityLevelSwapped('A0AA', GetEnumUnit()) ) - 300 )) ), GetTriggerUnit(), 0, 10, 100, 100, 100, 0)
        call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
        call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 3.00)
        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 90.00)
    else
    endif
endfunction

function Trig_tL33_Copy_Copy_Actions takes nothing returns nothing
    call ForGroupBJ(GetUnitsOfPlayerMatching(GetOwningPlayer(GetTriggerUnit()), Condition(function Trig_tL33_Copy_Copy_Func001001002)), function Trig_tL33_Copy_Copy_Func001A)
endfunction

