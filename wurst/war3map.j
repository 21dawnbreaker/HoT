function Trig_AimedShotResetRF_Func002C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 100) <= ( udg_tempInt * 25 ) ) ) then
        return false
    endif
    return true
endfunction

function Trig_AimedShotResetRF_Actions takes nothing returns nothing
    set udg_tempInt=GetUnitAbilityLevelSwapped('A0JL', gg_unit_H001_0116)
    if ( Trig_AimedShotResetRF_Func002C() ) then
        call BlzEndUnitAbilityCooldown(gg_unit_H001_0116, 'A0JL')
        set udg_tempLoc=GetUnitLoc(gg_unit_H001_0116)
        call PlaySoundAtPointBJ(gg_snd_Hunter_LockAndLoad_3, 100, udg_tempLoc, BlzGetLocalUnitZ(gg_unit_H001_0116))
        call RemoveLocation(udg_tempLoc)
        call AddSpecialEffectTargetUnitBJ("overhead", gg_unit_H001_0116, "MarkofThievery.mdx")
        set udg_AS_reset_eff=GetLastCreatedEffectBJ()
    else
    endif
    set udg_tempInt=0
    call TriggerSleepAction(1.00)
    call DestroyEffectBJ(udg_AS_reset_eff)
endfunction

//===========================================================================
function InitTrig_AimedShotResetRF takes nothing returns nothing
    set gg_trg_AimedShotResetRF=CreateTrigger()
