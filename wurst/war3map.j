    call ForGroupBJ(GetUnitsInRangeOfLocAll(300.00, GetUnitLoc(GetTriggerUnit())), function Trig_IntimidatingShout_Func007A)
    call EnableTrigger(gg_trg_IntimidatingShoutMove)
    call TriggerSleepAction(4.50)
    set udg_IntimidatingShoutC=null
    call ForGroupBJ(udg_IntimidatingShoutGroup, function Trig_IntimidatingShout_Func011A)
    call GroupRemoveGroup(udg_IntimidatingShoutGroup, udg_IntimidatingShoutGroup)
    call DisableTrigger(gg_trg_IntimidatingShoutMove)
