function Trig_HeroicLeap_Func026Func001C takes nothing returns boolean
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(GetTriggerUnit())) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_HeroicLeap_Func026A takes nothing returns nothing
    if ( Trig_HeroicLeap_Func026Func001C() ) then
        call UnitDamageTargetBJ(GetTriggerUnit(), GetEnumUnit(), ( ( 100.00 + ( I2R(GetHeroStatBJ(bj_HEROSTAT_STR, GetTriggerUnit(), true)) * 2.00 ) ) * 1.00 ), ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL)
    else
    endif
endfunction

function Trig_HeroicLeap_Actions takes nothing returns nothing
    set udg_tempLoc2=GetUnitLoc(GetTriggerUnit())
    call AddSpecialEffectLocBJ(udg_tempLoc2, "Valiant Charge.mdx")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call RemoveLocation(udg_tempLoc2)
    call PlaySoundAtPointBJ(gg_snd_GryphonRiderMissileLaunch3, 100, GetUnitLoc(GetTriggerUnit()), 0)
    set udg_hlC=GetTriggerUnit()
    call UnitAddAbilityBJ('Amrf', GetTriggerUnit())
    call UnitRemoveAbilityBJ('Amrf', GetTriggerUnit())
    call SetUnitPathing(GetTriggerUnit(), false)
    set udg_HeroicLeapDistance=DistanceBetweenPoints(GetUnitLoc(GetTriggerUnit()), GetSpellTargetLoc())
    set udg_HeroicLeapDistance=( udg_HeroicLeapDistance * 0.50 )
    call EnableTrigger(gg_trg_HeroicLeapMove)
    call SetUnitFlyHeightBJ(GetTriggerUnit(), ( udg_HeroicLeapDistance * 3.50 ), ( udg_HeroicLeapDistance * 3.50 ))
    call TriggerSleepAction(( udg_HeroicLeapDistance * ( 0.03 * 0.05 ) ))
    call SetUnitAnimation(GetTriggerUnit(), "slam")
    call SetUnitFlyHeightBJ(GetTriggerUnit(), 0.00, ( udg_HeroicLeapDistance * 4.70 ))
    call TriggerSleepAction(( udg_HeroicLeapDistance * ( 0.06 * ( 0.01 * 1.00 ) ) ))
    call SetUnitPathing(GetTriggerUnit(), true)
    set udg_tempLoc=GetUnitLoc(GetTriggerUnit())
    call CreateNUnitsAtLoc(1, 'h000', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc, bj_UNIT_FACING)
    call RemoveLocation(udg_tempLoc)
    call IssueImmediateOrderBJ(GetLastCreatedUnit(), "stomp")
    call UnitApplyTimedLifeBJ(1.00, 'BTLF', GetLastCreatedUnit())
    call ForGroupBJ(GetUnitsInRangeOfLocAll(250.00, GetUnitLoc(GetLastCreatedUnit())), function Trig_HeroicLeap_Func026A)
    call DisableTrigger(gg_trg_HeroicLeapMove)
    call PlaySoundAtPointBJ(gg_snd_ThunderClapCaster, 100, GetUnitLoc(GetLastCreatedUnit()), 0)
    call SetUnitManaBJ(GetTriggerUnit(), ( GetUnitStateSwap(UNIT_STATE_MANA, GetTriggerUnit()) + ( 15.00 + ( 5.00 * I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) ) ) ))
    set udg_tempLoc2=GetUnitLoc(GetTriggerUnit())
    call AddSpecialEffectLocBJ(udg_tempLoc2, "Valiant Charge.mdx")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call RemoveLocation(udg_tempLoc2)
    call TriggerSleepAction(0.50)
    call SetUnitAnimation(GetTriggerUnit(), "ready")
endfunction

