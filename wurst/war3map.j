    set udg_tempUnit=GetLastCreatedUnit()
    call GroupAddUnitSimple(GetLastCreatedUnit(), udg_fallen_shrine_UG)
    call IssuePointOrderLocBJ(GetLastCreatedUnit(), "attack", udg_tempLoc2)
    call UnitRemoveAbilityBJ('Awan', GetLastCreatedUnit())
    call CreateNUnitsAtLoc(1, 'u00H', Player(PLAYER_NEUTRAL_PASSIVE), udg_tempLoc2, bj_UNIT_FACING)
    call UnitApplyTimedLifeBJ(1.00, 'BTLF', GetLastCreatedUnit())
    call UnitAddAbilityBJ('A09S', GetLastCreatedUnit())
    call IssueTargetOrderBJ(GetLastCreatedUnit(), "chainlightning", udg_tempUnit)
    call RemoveLocation(udg_tempLoc)
    call RemoveLocation(udg_tempLoc2)
    set udg_tempUnit=null
    call TriggerSleepAction(0.15)
    set udg_tempLoc=PolarProjectionBJ(GetUnitLoc(udg_fallen_shrine_shrine), 600.00, GetRandomDirectionDeg())
