function Trig_Phase2_Atkivus_Conditions takes nothing returns boolean
    if ( not ( GetUnitStateSwap(UNIT_STATE_LIFE, gg_unit_H012_0027) <= ( udg_BossHP * 0.70 ) ) ) then
        return false
    endif
    if ( not ( udg_BossfightMainIsOn == 1 ) ) then
        return false
    endif
    if ( not ( udg_BossfightAtkivus == 1 ) ) then
        return false
    endif
    return true
endfunction

