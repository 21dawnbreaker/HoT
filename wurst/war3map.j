    call ForGroupBJ(GetUnitsInRangeOfLocAll(200.00, udg_tempLoc), function Trig_MinionSlayer_Func004A)
    call RemoveLocation(udg_tempLoc2)
    call RemoveLocation(udg_tempLoc3)
    call RemoveLocation(udg_tempLoc)
endfunction

