    call TriggerAddCondition(gg_trg_ShadowdancePeriodic, Condition(function Trig_ShadowdancePeriodic_Conditions))
    call TriggerAddAction(gg_trg_ShadowdancePeriodic, function Trig_ShadowdancePeriodic_Actions)
endfunction

//===========================================================================
// Trigger: ShadowdanceTimer
//===========================================================================
function Trig_ShadowdanceTimer_Actions takes nothing returns nothing
    call GroupClear(udg_shadowdance_damaged_UG)
    call DestroyEffectBJ(udg_shadowdance_line)
    call RemoveLocation(udg_shadowdance_final_pos)
    set udg_tempLoc=GetUnitLoc(gg_unit_H012_0027)
    set udg_shadowdance_final_pos=GetUnitLoc(GroupPickRandomUnit(udg_HeroesAlive_UG))
    set udg_tempLoc2=PolarProjectionBJ(udg_shadowdance_final_pos, 250.00, GetRandomDirectionDeg())
    call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\Human\\MassTeleport\\MassTeleportTarget.mdl")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call SetUnitPositionLocFacingLocBJ(gg_unit_H012_0027, udg_tempLoc2, udg_shadowdance_final_pos)
    call SetUnitAnimation(gg_unit_H012_0027, "ready")
    call AddSpecialEffectLocBJ(udg_tempLoc2, "Abilities\\Spells\\Human\\MassTeleport\\MassTeleportTarget.mdl")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call AddSpecialEffectLocBJ(udg_tempLoc2, "Skill_Indicator_Move.mdx")
    call BlzSetSpecialEffectYaw(GetLastCreatedEffectBJ(), Deg2Rad(AngleBetweenPoints(udg_tempLoc2, udg_shadowdance_final_pos)))
    set udg_shadowdance_line=GetLastCreatedEffectBJ()
    call RemoveLocation(udg_tempLoc)
    call RemoveLocation(udg_tempLoc2)
    call RemoveLocation(udg_tempLoc3)
    call TriggerSleepAction(0.50)
    call SetUnitAnimation(gg_unit_H012_0027, "attack")
    call EnableTrigger(gg_trg_ShadowdanceMovePeriodic)
endfunction

