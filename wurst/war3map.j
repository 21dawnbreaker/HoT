function CreateCameras takes nothing returns nothing

    set gg_cam_OrcStart=CreateCameraSetup()
    call CameraSetupSetField(gg_cam_OrcStart, CAMERA_FIELD_ZOFFSET, 0.0, 0.0)
    call CameraSetupSetField(gg_cam_OrcStart, CAMERA_FIELD_ROTATION, 87.3, 0.0)
    call CameraSetupSetField(gg_cam_OrcStart, CAMERA_FIELD_ANGLE_OF_ATTACK, 336.4, 0.0)
    call CameraSetupSetField(gg_cam_OrcStart, CAMERA_FIELD_TARGET_DISTANCE, 1650.0, 0.0)
    call CameraSetupSetField(gg_cam_OrcStart, CAMERA_FIELD_ROLL, 0.0, 0.0)
    call CameraSetupSetField(gg_cam_OrcStart, CAMERA_FIELD_FIELD_OF_VIEW, 70.0, 0.0)
    call CameraSetupSetField(gg_cam_OrcStart, CAMERA_FIELD_FARZ, 10000.0, 0.0)
    call CameraSetupSetField(gg_cam_OrcStart, CAMERA_FIELD_NEARZ, 16.0, 0.0)
    call CameraSetupSetField(gg_cam_OrcStart, CAMERA_FIELD_LOCAL_PITCH, 0.0, 0.0)
    call CameraSetupSetField(gg_cam_OrcStart, CAMERA_FIELD_LOCAL_YAW, 0.0, 0.0)
    call CameraSetupSetField(gg_cam_OrcStart, CAMERA_FIELD_LOCAL_ROLL, 0.0, 0.0)
    call CameraSetupSetDestPosition(gg_cam_OrcStart, - 231.9, - 20241.5, 0.0)

    set gg_cam_NaluaraStart=CreateCameraSetup()
    call CameraSetupSetField(gg_cam_NaluaraStart, CAMERA_FIELD_ZOFFSET, 0.0, 0.0)
    call CameraSetupSetField(gg_cam_NaluaraStart, CAMERA_FIELD_ROTATION, 170.8, 0.0)
    call CameraSetupSetField(gg_cam_NaluaraStart, CAMERA_FIELD_ANGLE_OF_ATTACK, 310.4, 0.0)
    call CameraSetupSetField(gg_cam_NaluaraStart, CAMERA_FIELD_TARGET_DISTANCE, 4269.6, 0.0)
    call CameraSetupSetField(gg_cam_NaluaraStart, CAMERA_FIELD_ROLL, 0.0, 0.0)
    call CameraSetupSetField(gg_cam_NaluaraStart, CAMERA_FIELD_FIELD_OF_VIEW, 70.0, 0.0)
    call CameraSetupSetField(gg_cam_NaluaraStart, CAMERA_FIELD_FARZ, 10000.0, 0.0)
    call CameraSetupSetField(gg_cam_NaluaraStart, CAMERA_FIELD_NEARZ, 16.0, 0.0)
    call CameraSetupSetField(gg_cam_NaluaraStart, CAMERA_FIELD_LOCAL_PITCH, 0.0, 0.0)
    call CameraSetupSetField(gg_cam_NaluaraStart, CAMERA_FIELD_LOCAL_YAW, 0.0, 0.0)
    call CameraSetupSetField(gg_cam_NaluaraStart, CAMERA_FIELD_LOCAL_ROLL, 0.0, 0.0)
    call CameraSetupSetDestPosition(gg_cam_NaluaraStart, 17854.6, 17359.8, 0.0)

endfunction

