function Trig_TalentsCheck_Actions takes nothing returns nothing
    // NEUTRAL TALENTS
    if ( Trig_TalentsCheck_Func003C() ) then
        call DisplayTimedTextToForce(GetForceOfPlayer(GetOwningPlayer(GetTriggerUnit())), 12.00, "TRIGSTR_249")
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=udg_HeroNumber
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            if ( Trig_TalentsCheck_Func003Func003Func001C() ) then
                if ( Trig_TalentsCheck_Func003Func003Func001Func001C() ) then
                    set udg_tempString="|cffc0c0c0Headhunting|r"
                    set udg_tempInt=GetUnitAbilityLevelSwapped('A0AA', udg_Hero[GetForLoopIndexA()])
                    set udg_tempInt2=( GetUnitAbilityLevelSwapped('A0AA', udg_Hero[GetForLoopIndexA()]) * 300 )
                    call DisplayTimedTextToForce(GetForceOfPlayer(GetOwningPlayer(GetTriggerUnit())), 12.00, ( udg_tempString + ( " - Level |cffff0000" + ( I2S(udg_tempInt) + ( "|r - Current reward: |cffffff00" + ( I2S(udg_tempInt2) + "|r" ) ) ) ) ))
                    set udg_tempString=""
                    set udg_tempInt=0
                    set udg_tempInt2=0
                else
                endif
                if ( Trig_TalentsCheck_Func003Func003Func001Func005C() ) then
                    set udg_tempString="|cffc0c0c0Armor Up!|r"
                    set udg_tempInt=GetUnitAbilityLevelSwapped('A0AF', udg_Hero[GetForLoopIndexA()])
                    set udg_tempInt2=( GetUnitAbilityLevelSwapped('A0AF', udg_Hero[GetForLoopIndexA()]) * 3 )
                    call DisplayTimedTextToForce(GetForceOfPlayer(GetOwningPlayer(GetTriggerUnit())), 12.00, ( udg_tempString + ( " - Level |cffff0000" + ( I2S(udg_tempInt) + ( "|r - Current bonus: |cffff0000" + ( I2S(udg_tempInt2) + "|r" ) ) ) ) ))
                    set udg_tempString=""
                    set udg_tempInt=0
                    set udg_tempInt2=0
                else
                endif
                if ( Trig_TalentsCheck_Func003Func003Func001Func007C() ) then
                    set udg_tempString="|cffc0c0c0Evasion|r"
                    set udg_tempInt=GetUnitAbilityLevelSwapped('A0AI', udg_Hero[GetForLoopIndexA()])
                    set udg_tempInt2=( GetUnitAbilityLevelSwapped('A0AI', udg_Hero[GetForLoopIndexA()]) * 9 )
                    call DisplayTimedTextToForce(GetForceOfPlayer(GetOwningPlayer(GetTriggerUnit())), 12.00, ( udg_tempString + ( " - Level |cffff0000" + ( I2S(udg_tempInt) + ( "|r - Current chance: |cffff0000" + ( I2S(udg_tempInt2) + "%|r" ) ) ) ) ))
                    set udg_tempString=""
                    set udg_tempInt=0
                    set udg_tempInt2=0
                else
                endif
                if ( Trig_TalentsCheck_Func003Func003Func001Func008C() ) then
                    set udg_tempString="|cffc0c0c0Fortitude|r"
                    set udg_tempInt=GetUnitAbilityLevelSwapped('A0AJ', udg_Hero[GetForLoopIndexA()])
                    set udg_tempInt2=( GetUnitAbilityLevelSwapped('A0AJ', udg_Hero[GetForLoopIndexA()]) * 8 )
                    call DisplayTimedTextToForce(GetForceOfPlayer(GetOwningPlayer(GetTriggerUnit())), 12.00, ( udg_tempString + ( " - Level |cffff0000" + ( I2S(udg_tempInt) + ( "|r - Current bonus: |cffff0000" + ( I2S(udg_tempInt2) + "%|r" ) ) ) ) ))
                    set udg_tempString=""
                    set udg_tempInt=0
                    set udg_tempInt2=0
                else
                endif
                if ( Trig_TalentsCheck_Func003Func003Func001Func009C() ) then
                    set udg_tempString="|cffc0c0c0Witcher's Dodge|r"
                    set udg_tempInt=GetUnitAbilityLevelSwapped('A0AM', udg_Hero[GetForLoopIndexA()])
                    set udg_tempInt2=( 1400 - ( 100 * GetUnitAbilityLevelSwapped('A0AM', udg_Hero[GetForLoopIndexA()]) ) )
                    call DisplayTimedTextToForce(GetForceOfPlayer(GetOwningPlayer(GetTriggerUnit())), 12.00, ( udg_tempString + ( " - Level |cffff0000" + ( I2S(udg_tempInt) + ( "|r - Current distance: |cffff0000" + ( I2S(udg_tempInt2) + "|r" ) ) ) ) ))
                    set udg_tempString=""
                    set udg_tempInt=0
                    set udg_tempInt2=0
                else
                endif
            else
            endif
            set bj_forLoopAIndex=bj_forLoopAIndex + 1
        endloop
    else
    endif
    // LAWFUL TALENTS
    if ( Trig_TalentsCheck_Func005C() ) then
        call DisplayTimedTextToForce(GetForceOfPlayer(GetOwningPlayer(GetTriggerUnit())), 12.00, "TRIGSTR_250")
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=udg_HeroNumber
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            if ( Trig_TalentsCheck_Func005Func003Func001C() ) then
                if ( Trig_TalentsCheck_Func005Func003Func001Func001C() ) then
                    set udg_tempString="|cffffff00Devotion|r"
                    set udg_tempInt=GetUnitAbilityLevelSwapped('A0HE', udg_Hero[GetForLoopIndexA()])
                    call DisplayTimedTextToForce(GetForceOfPlayer(GetOwningPlayer(GetTriggerUnit())), 12.00, ( udg_tempString + ( " - Level |cffff0000" + ( I2S(udg_tempInt) + ( "|r - |cffff0000MAX|r" ) ) ) ))
                    set udg_tempString=""
                    set udg_tempInt=0
                else
                endif
                if ( Trig_TalentsCheck_Func005Func003Func001Func002C() ) then
                    set udg_tempString="|cffffff00Determination|r"
                    set udg_tempInt=GetUnitAbilityLevelSwapped('A099', udg_Hero[GetForLoopIndexA()])
                    set udg_tempInt2=( GetUnitAbilityLevelSwapped('A099', udg_Hero[GetForLoopIndexA()]) * 20 )
                    call DisplayTimedTextToForce(GetForceOfPlayer(GetOwningPlayer(GetTriggerUnit())), 12.00, ( udg_tempString + ( " - Level |cffff0000" + ( I2S(udg_tempInt) + ( "|r - Current healing: |cffff0000" + ( I2S(udg_tempInt2) + "|r%" ) ) ) ) ))
                    set udg_tempString=""
                    set udg_tempInt=0
                    set udg_tempInt2=0
                else
                endif
                if ( Trig_TalentsCheck_Func005Func003Func001Func003C() ) then
                    set udg_tempString="|cffffff00Pursuit of Justice|r"
                    set udg_tempInt=GetUnitAbilityLevelSwapped('A08Z', udg_Hero[GetForLoopIndexA()])
                    set udg_tempInt2=( GetUnitAbilityLevelSwapped('A08Z', udg_Hero[GetForLoopIndexA()]) * 5 )
                    call DisplayTimedTextToForce(GetForceOfPlayer(GetOwningPlayer(GetTriggerUnit())), 12.00, ( udg_tempString + ( " - Level |cffff0000" + ( I2S(udg_tempInt) + ( "|r - Current chance: |cffff0000" + ( I2S(udg_tempInt2) + "|r%" ) ) ) ) ))
                    set udg_tempString=""
                    set udg_tempInt=0
                    set udg_tempInt2=0
                else
                endif
                if ( Trig_TalentsCheck_Func005Func003Func001Func004C() ) then
                    set udg_tempString="|cffffff00Holy Fire|r"
                    set udg_tempInt=GetUnitAbilityLevelSwapped('A090', udg_Hero[GetForLoopIndexA()])
                    set udg_tempInt2=( GetUnitAbilityLevelSwapped('A090', udg_Hero[GetForLoopIndexA()]) * 10 )
                    call DisplayTimedTextToForce(GetForceOfPlayer(GetOwningPlayer(GetTriggerUnit())), 12.00, ( udg_tempString + ( " - Level |cffff0000" + ( I2S(udg_tempInt) + ( "|r - Current damage: |cffff0000" + ( I2S(udg_tempInt2) + "|r" ) ) ) ) ))
                    set udg_tempString=""
                    set udg_tempInt=0
                    set udg_tempInt2=0
                else
                endif
                if ( Trig_TalentsCheck_Func005Func003Func001Func005C() ) then
                    set udg_tempString="|cffffff00Rune of Vindication|r"
                    set udg_tempInt=GetUnitAbilityLevelSwapped('A091', udg_Hero[GetForLoopIndexA()])
                    set udg_tempInt2=( GetUnitAbilityLevelSwapped('A091', udg_Hero[GetForLoopIndexA()]) * 15 )
                    call DisplayTimedTextToForce(GetForceOfPlayer(GetOwningPlayer(GetTriggerUnit())), 12.00, ( udg_tempString + ( " - Level |cffff0000" + ( I2S(udg_tempInt) + ( "|r - Current bonus: |cffff0000" + ( I2S(udg_tempInt2) + "|r" ) ) ) ) ))
                    set udg_tempString=""
                    set udg_tempInt=0
                    set udg_tempInt2=0
                else
                endif
