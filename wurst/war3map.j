//===========================================================================
// Trigger: RicardessaDying
//===========================================================================
function Trig_RicardessaDying_Actions takes nothing returns nothing
    call GroupClear(udg_ricardessa_damaged_UG)
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=20
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        call DestroyEffectBJ(udg_ricardessa_line[GetForLoopIndexA()])
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    call DisableTrigger(gg_trg_RicardessaPreparePeriodic)
    call DisableTrigger(gg_trg_RicardessaMovePeriodic)
    call DisableTrigger(gg_trg_RicardessaAnimationPeriodic)
    call TriggerSleepAction(3.00)
    call RemoveUnit(udg_ricardessa)
