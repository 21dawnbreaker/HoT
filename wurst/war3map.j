function Trig_Charge_Func001C takes nothing returns boolean
    if ( ( GetSpellAbilityId() == 'A01Q' ) ) then
        return true
    endif
    if ( ( GetSpellAbilityId() == 'A03M' ) ) then
        return true
    endif
    return false
endfunction

function Trig_Charge_Conditions takes nothing returns boolean
    if ( not Trig_Charge_Func001C() ) then
        return false
    endif
    return true
endfunction

