//===========================================================================
// Trigger: ArcM
//===========================================================================
function Trig_ArcM_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A04Y' ) ) then
        return false
    endif
    return true
endfunction

function Trig_ArcM_Func008Func001Func001C takes nothing returns boolean
    if ( ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(GetTriggerUnit())) == false ) ) then
        return true
    endif
    if ( ( IsUnitDeadBJ(GetEnumUnit()) == true ) ) then
        return true
    endif
    if ( ( IsUnitType(GetEnumUnit(), UNIT_TYPE_STRUCTURE) == true ) ) then
        return true
    endif
    return false
endfunction

function Trig_ArcM_Func008Func001C takes nothing returns boolean
    if ( not Trig_ArcM_Func008Func001Func001C() ) then
        return false
    endif
    return true
endfunction

function Trig_ArcM_Func008A takes nothing returns nothing
    if ( Trig_ArcM_Func008Func001C() ) then
        call GroupRemoveUnitSimple(GetEnumUnit(), udg_ArcMug)
    else
    endif
endfunction

function Trig_ArcM_Actions takes nothing returns nothing
    call BlzSetUnitFacingEx(gg_unit_H009_0081, AngleBetweenPoints(GetUnitLoc(GetTriggerUnit()), GetUnitLoc(GetSpellTargetUnit())))
    call EnableTrigger(gg_trg_ArcMdmg)
    call CreateNUnitsAtLocFacingLocBJ(1, 'h00T', GetOwningPlayer(GetTriggerUnit()), PolarProjectionBJ(GetUnitLoc(GetTriggerUnit()), 150.00, ( GetUnitFacing(GetTriggerUnit()) + 90.00 )), GetUnitLoc(GetTriggerUnit()))
    call SetUnitColor(GetLastCreatedUnit(), PLAYER_COLOR_SNOW)
    call SetUnitAbilityLevelSwapped('A04Z', GetLastCreatedUnit(), GetUnitAbilityLevelSwapped('A04Y', GetTriggerUnit()))
    set udg_ArcMu1=GetLastCreatedUnit()
    call GroupAddGroup(GetUnitsInRangeOfLocAll(350.00, GetUnitLoc(GetSpellTargetUnit())), udg_ArcMug)
    call ForGroupBJ(udg_ArcMug, function Trig_ArcM_Func008A)
    call IssueTargetOrderBJ(GetLastCreatedUnit(), "thunderbolt", GroupPickRandomUnit(udg_ArcMug))
    call AddSpecialEffectTargetUnitBJ("origin", GetLastCreatedUnit(), "Abilities\\Spells\\NightElf\\Blink\\BlinkTarget.mdl")
    set udg_ArcMeff=GetLastCreatedEffectBJ()
    call CreateNUnitsAtLocFacingLocBJ(1, 'h00T', GetOwningPlayer(GetTriggerUnit()), PolarProjectionBJ(GetUnitLoc(GetTriggerUnit()), 150.00, ( GetUnitFacing(GetTriggerUnit()) - 90.00 )), GetUnitLoc(GetTriggerUnit()))
    call SetUnitColor(GetLastCreatedUnit(), PLAYER_COLOR_SNOW)
    call SetUnitAbilityLevelSwapped('A04Z', GetLastCreatedUnit(), GetUnitAbilityLevelSwapped('A04Y', GetTriggerUnit()))
    set udg_ArcMu1_Copy_2=GetLastCreatedUnit()
    call IssueTargetOrderBJ(GetLastCreatedUnit(), "thunderbolt", GroupPickRandomUnit(udg_ArcMug))
    call AddSpecialEffectTargetUnitBJ("origin", GetLastCreatedUnit(), "Abilities\\Spells\\NightElf\\Blink\\BlinkTarget.mdl")
    set udg_ArcMeff_Copy=GetLastCreatedEffectBJ()
    call CreateNUnitsAtLocFacingLocBJ(1, 'h00T', GetOwningPlayer(GetTriggerUnit()), PolarProjectionBJ(GetUnitLoc(GetTriggerUnit()), 75.00, ( GetUnitFacing(GetTriggerUnit()) - 90.00 )), GetUnitLoc(GetTriggerUnit()))
    call SetUnitColor(GetLastCreatedUnit(), PLAYER_COLOR_SNOW)
    call SetUnitAbilityLevelSwapped('A04Z', GetLastCreatedUnit(), GetUnitAbilityLevelSwapped('A04Y', GetTriggerUnit()))
    set udg_ArcMu1_Copy_3=GetLastCreatedUnit()
    call UnitAddAbilityBJ('Amrf', GetLastCreatedUnit())
    call UnitRemoveAbilityBJ('Amrf', GetLastCreatedUnit())
    call SetUnitFlyHeightBJ(GetLastCreatedUnit(), 150.00, 99999.00)
    call IssueTargetOrderBJ(GetLastCreatedUnit(), "thunderbolt", GroupPickRandomUnit(udg_ArcMug))
    call AddSpecialEffectTargetUnitBJ("origin", GetLastCreatedUnit(), "Abilities\\Spells\\NightElf\\Blink\\BlinkTarget.mdl")
    set udg_ArcMeff_Copy_2=GetLastCreatedEffectBJ()
    call CreateNUnitsAtLocFacingLocBJ(1, 'h00T', GetOwningPlayer(GetTriggerUnit()), PolarProjectionBJ(GetUnitLoc(GetTriggerUnit()), 75.00, ( GetUnitFacing(GetTriggerUnit()) + 90.00 )), GetUnitLoc(GetTriggerUnit()))
    call SetUnitColor(GetLastCreatedUnit(), PLAYER_COLOR_SNOW)
    call SetUnitAbilityLevelSwapped('A04Z', GetLastCreatedUnit(), GetUnitAbilityLevelSwapped('A04Y', GetTriggerUnit()))
    set udg_ArcMu4=GetLastCreatedUnit()
    call UnitAddAbilityBJ('Amrf', GetLastCreatedUnit())
    call UnitRemoveAbilityBJ('Amrf', GetLastCreatedUnit())
    call SetUnitFlyHeightBJ(GetLastCreatedUnit(), 150.00, 99999.00)
    call IssueTargetOrderBJ(GetLastCreatedUnit(), "thunderbolt", GroupPickRandomUnit(udg_ArcMug))
    call AddSpecialEffectTargetUnitBJ("origin", GetLastCreatedUnit(), "Abilities\\Spells\\NightElf\\Blink\\BlinkTarget.mdl")
    set udg_ArcMeff_Copy_3=GetLastCreatedEffectBJ()
    call GroupRemoveGroup(udg_ArcMug, udg_ArcMug)
    call TriggerSleepAction(1.00)
    call DestroyEffectBJ(udg_ArcMeff)
    call DestroyEffectBJ(udg_ArcMeff_Copy)
    call DestroyEffectBJ(udg_ArcMeff_Copy_2)
    call DestroyEffectBJ(udg_ArcMeff_Copy_3)
    call AddSpecialEffectTargetUnitBJ("origin", udg_ArcMu1, "Abilities\\Spells\\NightElf\\Blink\\BlinkCaster.mdl")
    set udg_ArcMeff=GetLastCreatedEffectBJ()
    call AddSpecialEffectTargetUnitBJ("origin", udg_ArcMu1_Copy_2, "Abilities\\Spells\\NightElf\\Blink\\BlinkCaster.mdl")
    set udg_ArcMeff_Copy=GetLastCreatedEffectBJ()
    call AddSpecialEffectTargetUnitBJ("origin", udg_ArcMu1_Copy_3, "Abilities\\Spells\\NightElf\\Blink\\BlinkCaster.mdl")
    set udg_ArcMeff_Copy_2=GetLastCreatedEffectBJ()
    call AddSpecialEffectTargetUnitBJ("origin", udg_ArcMu4, "Abilities\\Spells\\NightElf\\Blink\\BlinkCaster.mdl")
    set udg_ArcMeff_Copy_3=GetLastCreatedEffectBJ()
    call TriggerSleepAction(0.20)
    call RemoveUnit(udg_ArcMu1)
    call RemoveUnit(udg_ArcMu1_Copy_2)
    call RemoveUnit(udg_ArcMu1_Copy_3)
    call RemoveUnit(udg_ArcMu4)
    call TriggerSleepAction(0.70)
    call DestroyEffectBJ(udg_ArcMeff)
    call DestroyEffectBJ(udg_ArcMeff_Copy)
    call DestroyEffectBJ(udg_ArcMeff_Copy_2)
    call DestroyEffectBJ(udg_ArcMeff_Copy_3)
    call TriggerSleepAction(2.50)
    call DisableTrigger(gg_trg_ArcMdmg)
endfunction

