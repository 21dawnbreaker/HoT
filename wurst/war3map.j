//===========================================================================
// Trigger: tL33 Copy
//===========================================================================
function Trig_tL33_Copy_Conditions takes nothing returns boolean
    if ( not ( IsPlayerInForce(GetOwningPlayer(GetKillingUnitBJ()), udg_HeadhunterPG) == true ) ) then
        return false
    endif
    if ( not ( IsUnitType(GetDyingUnit(), UNIT_TYPE_HERO) == true ) ) then
        return false
    endif
    if ( not ( IsUnitAlly(GetDyingUnit(), GetOwningPlayer(GetKillingUnitBJ())) == false ) ) then
        return false
    endif
    if ( not ( GetUnitTypeId(GetTriggerUnit()) != 'U00L' ) ) then
        return false
    endif
    if ( not ( GetUnitTypeId(GetTriggerUnit()) != 'E00B' ) ) then
        return false
    endif
    return true
endfunction

function Trig_tL33_Copy_Actions takes nothing returns nothing
    set udg_tempLoc=GetUnitLoc(GetTriggerUnit())
    call CreateItemLoc('I020', udg_tempLoc)
    call RemoveLocation(udg_tempLoc)
endfunction

