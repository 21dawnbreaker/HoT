// Trigger: ElementalSummoning
//===========================================================================
function Trig_ElementalSummoning_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A065' ) ) then
        return false
    endif
    return true
endfunction

function Trig_ElementalSummoning_Func001Func004C takes nothing returns boolean
    if ( not ( udg_ElementalSummInt == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ElementalSummoning_Func001Func005C takes nothing returns boolean
    if ( not ( udg_ElementalSummInt == 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ElementalSummoning_Func001Func006C takes nothing returns boolean
    if ( not ( udg_ElementalSummInt == 3 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ElementalSummoning_Actions takes nothing returns nothing
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        set udg_ElementalSummReal=( udg_ElementalSummReal + 72.00 )
        set udg_ElementalSummInt=GetRandomInt(1, 3)
        set udg_tempLoc=PolarProjectionBJ(GetUnitLoc(GetTriggerUnit()), 230.00, udg_ElementalSummReal)
        if ( Trig_ElementalSummoning_Func001Func004C() ) then
            call CreateNUnitsAtLoc(1, 'o00N', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc, GetUnitFacing(GetTriggerUnit()))
            call BlzSetUnitMaxHP(GetLastCreatedUnit(), ( 400 + ( 10 * GetHeroStatBJ(bj_HEROSTAT_INT, GetTriggerUnit(), true) ) ))
            call SetUnitLifePercentBJ(GetLastCreatedUnit(), 100)
            call BlzSetUnitBaseDamage(GetLastCreatedUnit(), ( 0 + ( R2I(( GetUnitStateSwap(UNIT_STATE_MANA, GetTriggerUnit()) * 0.25 )) * 1 ) ), 0)
            call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\Items\\AIil\\AIilTarget.mdl")
            call DestroyEffectBJ(GetLastCreatedEffectBJ())
        else
        endif
        if ( Trig_ElementalSummoning_Func001Func005C() ) then
            call CreateNUnitsAtLoc(1, 'h00Y', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc, GetUnitFacing(GetTriggerUnit()))
            call BlzSetUnitMaxHP(GetLastCreatedUnit(), ( 150 + ( 6 * GetHeroStatBJ(bj_HEROSTAT_INT, GetTriggerUnit(), true) ) ))
            call SetUnitLifePercentBJ(GetLastCreatedUnit(), 100)
            call BlzSetUnitBaseDamage(GetLastCreatedUnit(), ( 0 + ( GetHeroStatBJ(bj_HEROSTAT_INT, GetTriggerUnit(), true) * 2 ) ), 0)
            call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\Items\\AIil\\AIilTarget.mdl")
            call DestroyEffectBJ(GetLastCreatedEffectBJ())
        else
        endif
        if ( Trig_ElementalSummoning_Func001Func006C() ) then
            call CreateNUnitsAtLoc(1, 'h00X', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc, GetUnitFacing(GetTriggerUnit()))
            call BlzSetUnitMaxHP(GetLastCreatedUnit(), ( 100 + ( 6 * GetHeroStatBJ(bj_HEROSTAT_INT, GetTriggerUnit(), true) ) ))
            call SetUnitLifePercentBJ(GetLastCreatedUnit(), 100)
            call BlzSetUnitBaseDamage(GetLastCreatedUnit(), ( 0 + ( GetHeroStatBJ(bj_HEROSTAT_INT, GetTriggerUnit(), true) * 1 ) ), 0)
            call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\Items\\AIil\\AIilTarget.mdl")
            call DestroyEffectBJ(GetLastCreatedEffectBJ())
        else
        endif
        call RemoveLocation(udg_tempLoc)
        call UnitApplyTimedLifeBJ(60, 'BTLF', GetLastCreatedUnit())
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    call TriggerSleepAction(5.00)
    set udg_ElementalSummReal=0.00
endfunction

