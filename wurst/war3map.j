    set gg_trg_Impaler=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Impaler, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_Impaler, Condition(function Trig_Impaler_Conditions))
    call TriggerAddAction(gg_trg_Impaler, function Trig_Impaler_Actions)
endfunction

//===========================================================================
// Trigger: ImpalerPeriodicNightmare
//===========================================================================
function Trig_ImpalerPeriodicNightmare_Func001C takes nothing returns boolean
    if ( not ( udg_ImpalerInt > 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ImpalerPeriodicNightmare_Actions takes nothing returns nothing
    if ( Trig_ImpalerPeriodicNightmare_Func001C() ) then
        set udg_ImpalerInt=( udg_ImpalerInt - 1 )
        set udg_ImpalerDistance=( udg_ImpalerDistance + 90.00 )
        call StartTimerBJ(udg_ImpalerTimer, false, 0.70)
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=8
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            call RemoveLocation(udg_ImpalerDamage[GetForLoopIndexA()])
            set udg_ImpalerReady[GetForLoopIndexA()]=PolarProjectionBJ(udg_ImpalerStartLoc, udg_ImpalerDistance, udg_ImpalerReal[GetForLoopIndexA()])
            call AddSpecialEffectLocBJ(udg_ImpalerReady[GetForLoopIndexA()], "Skill_Indicator_Circle.mdx")
            call DestroyEffectBJ(GetLastCreatedEffectBJ())
            set udg_ImpalerDamage[GetForLoopIndexA()]=PolarProjectionBJ(udg_ImpalerStartLoc, udg_ImpalerDistance, udg_ImpalerReal[GetForLoopIndexA()])
            call RemoveLocation(udg_ImpalerReady[GetForLoopIndexA()])
            set bj_forLoopAIndex=bj_forLoopAIndex + 1
        endloop
    else
        call DisableTrigger(GetTriggeringTrigger())
    endif
endfunction

