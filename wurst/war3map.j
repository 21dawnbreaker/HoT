function Trig_KillCommand_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A00V' ) ) then
        return false
    endif
    return true
endfunction

function Trig_KillCommand_Func001Func001Func011C takes nothing returns boolean
    if ( not ( udg_KillSoundProc >= 66 ) ) then
        return false
    endif
    return true
endfunction

function Trig_KillCommand_Func001Func001Func012C takes nothing returns boolean
    if ( ( GetUnitTypeId(GetEnumUnit()) == 'n01O' ) ) then
        return true
    endif
    if ( ( GetUnitTypeId(GetEnumUnit()) == 'n01M' ) ) then
        return true
    endif
    if ( ( GetUnitTypeId(GetEnumUnit()) == 'n01P' ) ) then
        return true
    endif
    if ( ( GetUnitTypeId(GetEnumUnit()) == 'n01Q' ) ) then
        return true
    endif
    if ( ( GetUnitTypeId(GetEnumUnit()) == 'n01R' ) ) then
        return true
    endif
    return false
endfunction

function Trig_KillCommand_Func001Func001C takes nothing returns boolean
    if ( not Trig_KillCommand_Func001Func001Func012C() ) then
        return false
    endif
    return true
endfunction

function Trig_KillCommand_Func001A takes nothing returns nothing
    if ( Trig_KillCommand_Func001Func001C() ) then
        set udg_KillInteger=1
        set udg_TurtleKill=GetEnumUnit()
        set udg_tempLoc=GetUnitLoc(GetEnumUnit())
        call SetUnitPathing(udg_TurtleKill, false)
        call PlaySoundOnUnitBJ(gg_snd_Spell_HU_Kill_Command_Cast_03, 100, udg_TurtleKill)
        set udg_TargetKill=GetSpellTargetUnit()
        call AddSpecialEffectTargetUnitBJ("overhead", udg_TargetKill, "Abilities\\Spells\\Items\\OrbCorruption\\OrbCorruptionSpecialArt.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call EnableTrigger(gg_trg_KillCommandPeriodic)
        set udg_KillSoundProc=GetRandomInt(1, 100)
        if ( Trig_KillCommand_Func001Func001Func011C() ) then
            set udg_tempLoc=GetUnitLoc(gg_unit_H001_0116)
            call PlaySoundAtPointBJ(gg_snd_HuntressYesAttack1, 100, udg_tempLoc, 0)
            call RemoveLocation(udg_tempLoc)
        else
        endif
    else
    endif
endfunction

function Trig_KillCommand_Func002C takes nothing returns boolean
    if ( not ( udg_KillInteger == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_KillCommand_Actions takes nothing returns nothing
    call ForGroupBJ(GetUnitsInRangeOfLocAll(1600.00, GetUnitLoc(GetSpellTargetUnit())), function Trig_KillCommand_Func001A)
    if ( Trig_KillCommand_Func002C() ) then
        call BlzEndUnitAbilityCooldown(GetTriggerUnit(), 'A00V')
        call SetUnitManaBJ(GetTriggerUnit(), ( GetUnitStateSwap(UNIT_STATE_MANA, GetTriggerUnit()) + 50.00 ))
        call CreateTextTagUnitBJ("TRIGSTR_539", GetTriggerUnit(), 0, 10, 100, 100, 100, 0)
        call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
        call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 3.00)
        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
    else
    endif
endfunction

//===========================================================================
function InitTrig_KillCommand takes nothing returns nothing
    set gg_trg_KillCommand=CreateTrigger()
    call TriggerRegisterUnitEvent(gg_trg_KillCommand, gg_unit_H001_0116, EVENT_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_KillCommand, Condition(function Trig_KillCommand_Conditions))
    call TriggerAddAction(gg_trg_KillCommand, function Trig_KillCommand_Actions)
endfunction

//===========================================================================
// Trigger: KillCommandPeriodic
//===========================================================================
function Trig_KillCommandPeriodic_Func001C takes nothing returns boolean
    if ( not ( DistanceBetweenPoints(GetUnitLoc(udg_TurtleKill), GetUnitLoc(udg_TargetKill)) <= 120.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_KillCommandPeriodic_Actions takes nothing returns nothing
    if ( Trig_KillCommandPeriodic_Func001C() ) then
        set udg_tempLoc=GetUnitLoc(udg_TurtleKill)
        call PlaySoundAtPointBJ(gg_snd_RockHeavyBashFlesh1, 100, udg_tempLoc, 0)
        call RemoveLocation(udg_tempLoc)
        set udg_KillInteger=0
        call UnitDamageTargetBJ(gg_unit_H001_0116, udg_TargetKill, ( ( 90.00 * I2R(GetUnitAbilityLevelSwapped('A00V', gg_unit_H001_0116)) ) + ( I2R(GetHeroStatBJ(bj_HEROSTAT_AGI, gg_unit_H001_0116, true)) * 0.50 ) ), ATTACK_TYPE_MELEE, DAMAGE_TYPE_NORMAL)
        call UnitDamageTargetBJ(gg_unit_H001_0116, udg_TargetKill, ( ( I2R(GetHeroStatBJ(bj_HEROSTAT_AGI, gg_unit_H001_0116, true)) * 0.50 ) * I2R(GetUnitAbilityLevelSwapped('A00V', gg_unit_H001_0116)) ), ATTACK_TYPE_MELEE, DAMAGE_TYPE_NORMAL)
        call SetUnitManaBJ(gg_unit_H001_0116, ( GetUnitStateSwap(UNIT_STATE_MANA, gg_unit_H001_0116) + 50.00 ))
        call SetUnitPathing(udg_TurtleKill, true)
        call IssueTargetOrderBJ(udg_TurtleKill, "attack", udg_TargetKill)
        call IssueTargetOrderBJ(udg_TargetKill, "attack", udg_TurtleKill)
        call DisableTrigger(GetTriggeringTrigger())
    else
        call SetUnitFacingToFaceUnitTimed(udg_TurtleKill, udg_TargetKill, 0)
        call SetUnitPositionLoc(udg_TurtleKill, PolarProjectionBJ(GetUnitLoc(udg_TurtleKill), 15.00, AngleBetweenPoints(GetUnitLoc(udg_TurtleKill), GetUnitLoc(udg_TargetKill))))
    endif
endfunction

//===========================================================================
function InitTrig_KillCommandPeriodic takes nothing returns nothing
    set gg_trg_KillCommandPeriodic=CreateTrigger()
    call DisableTrigger(gg_trg_KillCommandPeriodic)
    call TriggerRegisterTimerEventPeriodic(gg_trg_KillCommandPeriodic, 0.01)
    call TriggerAddAction(gg_trg_KillCommandPeriodic, function Trig_KillCommandPeriodic_Actions)
endfunction

