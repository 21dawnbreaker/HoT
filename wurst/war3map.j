        return false
    endif
    return true
endfunction

function Trig_Inferno_Func003C takes nothing returns boolean
    if ( not ( GetUnitManaPercent(GetTriggerUnit()) < ( 50.00 - ( 5.00 * I2R(udg_Infernoi) ) ) ) ) then
        return false
