        set udg_HERO_DAMAGE_BONUS_MAGIC[udg_player_num]=( udg_HERO_DAMAGE_BONUS_MAGIC[udg_player_num] - 1 )
    else
    endif
    if ( Trig_MagicAmpDrop_Func003C() ) then
