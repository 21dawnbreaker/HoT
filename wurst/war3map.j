//===========================================================================
// Trigger: ThunderStrike
//===========================================================================
function Trig_ThunderStrike_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A00F' ) ) then
        return false
    endif
    return true
endfunction

function Trig_ThunderStrike_Func004Func001Func004C takes nothing returns boolean
    if ( not ( IsUnitInGroup(GetEnumUnit(), udg_not_knockbackable_UG) == false ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( BlzIsUnitInvulnerable(GetTriggerUnit()) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_ThunderStrike_Func004Func001C takes nothing returns boolean
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(GetTriggerUnit())) == true ) ) then
        return false
    endif
    if ( not ( IsUnitType(GetEnumUnit(), UNIT_TYPE_STRUCTURE) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_ThunderStrike_Func004A takes nothing returns nothing
    if ( Trig_ThunderStrike_Func004Func001C() ) then
        call UnitDamageTargetBJ(GetTriggerUnit(), GetEnumUnit(), ( ( 100.00 * I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) ) + ( ( 0.50 * I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) ) * I2R(GetHeroStatBJ(bj_HEROSTAT_INT, GetTriggerUnit(), true)) ) ), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_MAGIC)
        if ( Trig_ThunderStrike_Func004Func001Func004C() ) then
            set udg_KBA_Caster=GetTriggerUnit()
            set udg_KBA_TargetUnit=GetEnumUnit()
            set udg_KBA_Level=1
            set udg_KBA_StartingPosition=GetSpellTargetLoc()
            set udg_KBA_Speed=10.00
            set udg_KBA_DistancePerLevel=300.00
            set udg_KBA_SpecialEffects[1]="Abilities\\Spells\\Human\\FlakCannons\\FlakTarget.mdl"
            set udg_KBA_SpecialEffects[2]="Abilities\\Weapons\\AncientProtectorMissile\\AncientProtectorMissile.mdl"
            set udg_KBA_DestroyTrees=false
            call ConditionalTriggerExecute(gg_trg_Cast_A_Knockback)
        else
        endif
    else
    endif
endfunction

function Trig_ThunderStrike_Actions takes nothing returns nothing
    set udg_tempLoc=GetSpellTargetLoc()
    call AddSpecialEffectLocBJ(udg_tempLoc, "Stormfall.mdx")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call ForGroupBJ(GetUnitsInRangeOfLocAll(250.00, udg_tempLoc), function Trig_ThunderStrike_Func004A)
    call RemoveLocation(udg_tempLoc)
endfunction

