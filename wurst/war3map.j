//===========================================================================
// Trigger: ShieldBash
//===========================================================================
function Trig_ShieldBash_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A01C' ) ) then
        return false
    endif
    return true
endfunction

function Trig_ShieldBash_Func011C takes nothing returns boolean
    if ( not ( IsUnitInGroup(GetSpellTargetUnit(), udg_not_knockbackable_UG) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_ShieldBash_Actions takes nothing returns nothing
    call AddSpecialEffectTargetUnitBJ("Hand Right", GetTriggerUnit(), "Ember Shield II FX 5.mdx")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call AddSpecialEffectTargetUnitBJ("chest", GetTriggerUnit(), "Abilities\\Spells\\Human\\Defend\\DefendCaster.mdl")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    set udg_ShieldBashInt=GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())
    call UnitDamageTargetBJ(GetTriggerUnit(), GetSpellTargetUnit(), ( I2R(GetHeroStatBJ(bj_HEROSTAT_STR, GetTriggerUnit(), true)) * ( 1.00 * I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) ) ), ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL)
    call UnitDamageTargetBJ(GetTriggerUnit(), GetSpellTargetUnit(), ( BlzGetUnitArmor(GetTriggerUnit()) * 20.00 ), ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL)
    call PlaySoundOnUnitBJ(gg_snd_Dragon_Tail_mp3, 100, GetTriggerUnit())
    if ( Trig_ShieldBash_Func011C() ) then
        set udg_KBA_Caster=GetTriggerUnit()
        set udg_KBA_TargetUnit=GetSpellTargetUnit()
        set udg_KBA_Level=1
        set udg_KBA_StartingPosition=GetUnitLoc(GetTriggerUnit())
        set udg_KBA_Speed=7.00
        set udg_KBA_DistancePerLevel=300.00
        set udg_KBA_SpecialEffects[1]="Abilities\\Spells\\Human\\FlakCannons\\FlakTarget.mdl"
        set udg_KBA_SpecialEffects[2]="Abilities\\Weapons\\AncientProtectorMissile\\AncientProtectorMissile.mdl"
        set udg_KBA_DestroyTrees=false
        call ConditionalTriggerExecute(gg_trg_Cast_A_Knockback)
    else
    endif
    call TriggerSleepAction(0.35)
    call SetUnitAnimation(GetTriggerUnit(), "ready")
endfunction

