endfunction

//===========================================================================
// Trigger: GUI AllowPlayerSave
//
// NSL_AllowCheckPlayer (variable type=Player) is the player being checked for saving
// 	• set `NSL_AllowPlayerSave` to `true` if the player is allowed to save
// 	• by default, `NSL_AllowPlayerSave` is set to `false` -- you only need to care about setting it to `true` according do your design
// > Enabled and don't turn Initially On
// > Add condition (if needed) within the `Actions` block using `If / Then / Else, Multiple Functions` to set `NSL_AllowPlayerSave = true` (if needed)
// > Do not add anything in the `Events` and `Conditions` blocks
// > When finished, set `NSL_EventCheckSaveCompleted` to 1.0
//===========================================================================
function Trig_GUI_AllowPlayerSave_Actions takes nothing returns nothing
    set udg_NSL_AllowPlayerSave=true
    // When finished checking, set `NSL_EventCheckSaveCompleted` to 1.0
    set udg_NSL_EventCheckSaveCompleted=1.00
endfunction

//===========================================================================
function InitTrig_GUI_AllowPlayerSave takes nothing returns nothing
    set gg_trg_GUI_AllowPlayerSave=CreateTrigger()
    call DisableTrigger(gg_trg_GUI_AllowPlayerSave)
    call TriggerAddAction(gg_trg_GUI_AllowPlayerSave, function Trig_GUI_AllowPlayerSave_Actions)
endfunction

//===========================================================================
// Trigger: GUI AllowPlayerLoad
//
// NSL_AllowCheckPlayer (variable type=Player) is the player being checked for loading
// 	• set `NSL_AllowPlayerLoad` to `true` if the player is allowed to load
// 	• by default, `NSL_AllowPlayerLoad` is set to `false` -- you only need to care about setting it to `true` according do your design
// > Enabled and don't turn Initially On
// > Add condition (if needed) within the `Actions` block using `If / Then / Else, Multiple Functions` to set `NSL_AllowPlayerLoad = true` (if needed)
// > Do not add anything in the `Events` and `Conditions` blocks
// > When finished, set `NSL_EventCheckLoadCompleted` to 1.0
//===========================================================================
function Trig_GUI_AllowPlayerLoad_Actions takes nothing returns nothing
    set udg_NSL_AllowPlayerLoad=true
    // When finished checking, set `NSL_EventCheckLoadCompleted` to 1.0
    set udg_NSL_EventCheckLoadCompleted=1.00
endfunction

