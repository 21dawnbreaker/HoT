    endif
    return true
endfunction

function Trig_tL7_Copy_Copy_Func003A takes nothing returns nothing
    if ( Trig_tL7_Copy_Copy_Func003Func001C() ) then
        call UnitRemoveBuffBJ('B029', GetEnumUnit())
        set udg_tempLoc2=GetUnitLoc(GetEnumUnit())
        call CreateNUnitsAtLoc(1, 'h00I', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc2, bj_UNIT_FACING)
        call SetUnitAbilityLevelSwapped('A093', GetLastCreatedUnit(), GetUnitAbilityLevelSwapped('A09B', udg_BlindingLightC[GetConvertedPlayerId(GetOwningPlayer(GetLastCreatedUnit()))]))
        call RemoveLocation(udg_tempLoc2)
        call IssueTargetOrderBJ(GetLastCreatedUnit(), "curse", GetEnumUnit())
        call UnitApplyTimedLifeBJ(1.00, 'BTLF', GetLastCreatedUnit())
    else
    endif
endfunction

