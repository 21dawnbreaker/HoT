function InitTrig_Slots takes nothing returns nothing
    set gg_trg_Slots=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Slots, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_Slots, Condition(function Trig_Slots_Conditions))
    call TriggerAddAction(gg_trg_Slots, function Trig_Slots_Actions)
endfunction

//===========================================================================
// Trigger: DropDuplicateItemTimer
//===========================================================================
function Trig_DropDuplicateItemTimer_Actions takes nothing returns nothing
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=udg_HeroNumber
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        call UnitRemoveItemSwapped(udg_duplicate_item_item[GetForLoopIndexA()], udg_duplicate_item_hero[GetForLoopIndexA()])
        set udg_duplicate_item_hero[GetForLoopIndexA()]=null
        set udg_duplicate_item_item[GetForLoopIndexA()]=null
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
endfunction

//===========================================================================
function InitTrig_DropDuplicateItemTimer takes nothing returns nothing
    set gg_trg_DropDuplicateItemTimer=CreateTrigger()
    call TriggerRegisterTimerExpireEventBJ(gg_trg_DropDuplicateItemTimer, udg_duplicate_item_timer)
    call TriggerAddAction(gg_trg_DropDuplicateItemTimer, function Trig_DropDuplicateItemTimer_Actions)
endfunction

//===========================================================================
// Trigger: JuiceCactus
//===========================================================================
function Trig_JuiceCactus_Conditions takes nothing returns boolean
    if ( not ( GetItemTypeId(GetManipulatedItem()) == 'I03Q' ) ) then
        return false
    endif
    return true
endfunction

function Trig_JuiceCactus_Func001Func001C takes nothing returns boolean
    if ( not ( GetItemTypeId(UnitItemInSlotBJ(GetTriggerUnit(), GetForLoopIndexA())) == 'I03Q' ) ) then
        return false
    endif
    if ( not ( GetItemCharges(UnitItemInSlotBJ(GetTriggerUnit(), GetForLoopIndexA())) == 6 ) ) then
        return false
    endif
    return true
endfunction

function Trig_JuiceCactus_Actions takes nothing returns nothing
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=6
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        if ( Trig_JuiceCactus_Func001Func001C() ) then
            call RemoveItem(UnitItemInSlotBJ(GetTriggerUnit(), GetForLoopIndexA()))
            call UnitAddItemByIdSwapped('I03P', GetTriggerUnit())
        else
        endif
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
endfunction

//===========================================================================
function InitTrig_JuiceCactus takes nothing returns nothing
    set gg_trg_JuiceCactus=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_JuiceCactus, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_JuiceCactus, Condition(function Trig_JuiceCactus_Conditions))
    call TriggerAddAction(gg_trg_JuiceCactus, function Trig_JuiceCactus_Actions)
endfunction

//===========================================================================
// Trigger: MultiboardKillsUpdate
//===========================================================================
function Trig_MultiboardKillsUpdate_Func002C takes nothing returns boolean
    if ( ( GetOwningPlayer(GetTriggerUnit()) == Player(22) ) ) then
        return true
    endif
    if ( ( GetOwningPlayer(GetTriggerUnit()) == Player(19) ) ) then
        return true
    endif
    if ( ( GetOwningPlayer(GetTriggerUnit()) == Player(23) ) ) then
        return true
    endif
    return false
endfunction

function Trig_MultiboardKillsUpdate_Conditions takes nothing returns boolean
    if ( not Trig_MultiboardKillsUpdate_Func002C() ) then
        return false
    endif
    if ( not ( IsPlayerInForce(GetOwningPlayer(GetKillingUnitBJ()), udg_PlayerGroup) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_MultiboardKillsUpdate_Func001Func001C takes nothing returns boolean
    if ( not ( GetOwningPlayer(GetKillingUnitBJ()) == GetOwningPlayer(udg_Hero[GetForLoopIndexA()]) ) ) then
        return false
    endif
    return true
endfunction

function Trig_MultiboardKillsUpdate_Actions takes nothing returns nothing
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=CountUnitsInGroup(udg_HeroesGroup)
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        if ( Trig_MultiboardKillsUpdate_Func001Func001C() ) then
            set udg_multiboard_kills[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))]=( udg_multiboard_kills[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] + 1 )
            call MultiboardSetItemValueBJ(udg_Multiboard1, 3, ( GetForLoopIndexA() + 1 ), I2S(udg_multiboard_kills[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))]))
        else
        endif
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
endfunction

//===========================================================================
function InitTrig_MultiboardKillsUpdate takes nothing returns nothing
    set gg_trg_MultiboardKillsUpdate=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_MultiboardKillsUpdate, EVENT_PLAYER_UNIT_DEATH)
    call TriggerAddCondition(gg_trg_MultiboardKillsUpdate, Condition(function Trig_MultiboardKillsUpdate_Conditions))
    call TriggerAddAction(gg_trg_MultiboardKillsUpdate, function Trig_MultiboardKillsUpdate_Actions)
endfunction

