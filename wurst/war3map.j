//===========================================================================
function Trig_Charity_Conditions takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped('A08G', GetTriggerUnit()) == 1 ) ) then
        return false
    endif
    if ( not ( GetRandomInt(1, 100) <= 10 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Charity_Actions takes nothing returns nothing
    set udg_CharityLoc=PolarProjectionBJ(GetUnitLoc(GetTriggerUnit()), GetRandomReal(150.00, 500.00), GetRandomDirectionDeg())
    set udg_tempLoc=GetUnitLoc(GetTriggerUnit())
    call AddSpecialEffectLocBJ(udg_CharityLoc, "Abilities\\Spells\\Human\\Resurrect\\ResurrectTarget.mdl")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call AddSpecialEffectLocBJ(udg_CharityLoc, "spirithealer2.mdx")
    call BlzSetSpecialEffectYaw(GetLastCreatedEffectBJ(), Deg2Rad(AngleBetweenPoints(udg_CharityLoc, udg_tempLoc)))
    call BlzSetSpecialEffectColor(GetLastCreatedEffectBJ(), 255, 255, 50)
    set udg_CharityEff=GetLastCreatedEffectBJ()
    call RemoveLocation(udg_tempLoc)
    call DisableTrigger(GetTriggeringTrigger())
    call DisableTrigger(gg_trg_Radiance)
    call EnableTrigger(gg_trg_RadianceBuffed)
    call EnableTrigger(gg_trg_CharityPeriodic)
    call TriggerSleepAction(2.00)
    call DestroyEffectBJ(udg_CharityEff)
    call TriggerSleepAction(4.00)
    call AddSpecialEffectLocBJ(udg_CharityLoc, "Abilities\\Spells\\Human\\Resurrect\\ResurrectTarget.mdl")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call DisableTrigger(gg_trg_CharityPeriodic)
    call DisableTrigger(gg_trg_RadianceBuffed)
    call EnableTrigger(gg_trg_Radiance)
    call EnableTrigger(GetTriggeringTrigger())
    call RemoveLocation(udg_CharityLoc)
endfunction

