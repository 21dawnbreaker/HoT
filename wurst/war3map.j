    set gg_trg_RoomCreateExitTownBeforeBoss=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_RoomCreateExitTownBeforeBoss, EVENT_PLAYER_UNIT_DEATH)
