function Trig_Envy_Actions takes nothing returns nothing
    set udg_tempLoc=GetUnitLoc(GetTriggerUnit())
    call PlaySoundAtPointBJ(gg_snd_ShadePissed1, 100, udg_tempLoc, 0)
    if ( Trig_Envy_Func003C() ) then
        call CreateNUnitsAtLocFacingLocBJ(1, 'h01H', Player(11), PolarProjectionBJ(udg_tempLoc, 250.00, GetRandomDirectionDeg()), udg_tempLoc)
    else
        if ( Trig_Envy_Func003Func001C() ) then
            call CreateNUnitsAtLocFacingLocBJ(1, 'o00T', Player(11), PolarProjectionBJ(udg_tempLoc, 250.00, GetRandomDirectionDeg()), udg_tempLoc)
        else
            call CreateNUnitsAtLocFacingLocBJ(1, 'h01I', Player(11), PolarProjectionBJ(udg_tempLoc, 250.00, GetRandomDirectionDeg()), udg_tempLoc)
