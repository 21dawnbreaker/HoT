        return false
    endif
    return true
endfunction

function Trig_DeepWoundsPeriodic_Func001A takes nothing returns nothing
    if ( Trig_DeepWoundsPeriodic_Func001Func001C() ) then
        call UnitDamageTargetBJ(udg_LycantrophyC, GetEnumUnit(), ( I2R(BlzGetUnitBaseDamage(udg_LycantrophyC, 0)) * 0.37 ), ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL)
    else
        call GroupRemoveUnitSimple(GetEnumUnit(), udg_DeepWoundsUG)
    endif
endfunction

function Trig_DeepWoundsPeriodic_Actions takes nothing returns nothing
    call ForGroupBJ(udg_DeepWoundsUG, function Trig_DeepWoundsPeriodic_Func001A)
endfunction

