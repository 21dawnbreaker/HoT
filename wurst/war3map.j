    if ( not ( GetUnitAbilityLevelSwapped('A07Y', GetTriggerUnit()) >= 6 ) ) then
        return false
    endif
    if ( not ( GetRandomInt(1, 100) <= 15 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Envy_Func003Func001C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 2) == 1 ) ) then
        return false
    endif
    return true
endfunction

