    set gg_trg_Chain_of_Disturbance=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Chain_of_Disturbance, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_Chain_of_Disturbance, Condition(function Trig_Chain_of_Disturbance_Conditions))
