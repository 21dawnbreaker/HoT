    set gg_trg_TornadoMove=CreateTrigger()
    call DisableTrigger(gg_trg_TornadoMove)
    call TriggerRegisterTimerEventPeriodic(gg_trg_TornadoMove, 0.01)
    call TriggerAddAction(gg_trg_TornadoMove, function Trig_TornadoMove_Actions)
endfunction

