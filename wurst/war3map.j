function Trig_TimeElapsedNPC_Func001A takes nothing returns nothing
    set udg_tempInt=GetConvertedPlayerId(GetEnumPlayer())
    set udg_disobidience_of_deathUG[udg_tempInt]=CreateGroup()
    call GroupAddGroup(GetUnitsOfPlayerAll(GetEnumPlayer()), udg_disobidience_of_deathUG[GetConvertedPlayerId(GetEnumPlayer())])
    call GroupClear(udg_disobidience_of_deathUG[GetConvertedPlayerId(GetEnumPlayer())])
    set udg_tempInt=0
endfunction

function Trig_TimeElapsedNPC_Func003A takes nothing returns nothing
    call GroupAddUnitSimple(GetEnumUnit(), udg_npc_static)
endfunction

function Trig_TimeElapsedNPC_Func004A takes nothing returns nothing
    call GroupAddUnitSimple(GetEnumUnit(), udg_npc_static)
endfunction

function Trig_TimeElapsedNPC_Func005A takes nothing returns nothing
    call GroupAddUnitSimple(GetEnumUnit(), udg_npc_static)
endfunction

function Trig_TimeElapsedNPC_Func008Func001C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 100) <= udg_TOWN_TRADER_CHANCE ) ) then
        return false
    endif
    return true
endfunction

function Trig_TimeElapsedNPC_Func008C takes nothing returns boolean
    if ( not ( udg_CurrentLocation == 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_TimeElapsedNPC_Func010Func001C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 100) <= udg_TOWN_TRADER_CHANCE ) ) then
        return false
    endif
    return true
endfunction

function Trig_TimeElapsedNPC_Func010C takes nothing returns boolean
    if ( not ( udg_CurrentLocation == 3 ) ) then
        return false
    endif
    return true
endfunction

function Trig_TimeElapsedNPC_Func012Func001C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 100) <= udg_TOWN_TRADER_CHANCE ) ) then
        return false
    endif
    return true
endfunction

function Trig_TimeElapsedNPC_Func012C takes nothing returns boolean
    if ( not ( udg_CurrentLocation == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_TimeElapsedNPC_Actions takes nothing returns nothing
    call ForForce(udg_PlayerGroup, function Trig_TimeElapsedNPC_Func001A)
    set bj_forLoopAIndex=2
    set bj_forLoopAIndexEnd=4
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        set udg_GoldenConsulStoriesAvaible[GetForLoopIndexA()]=1
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    call ForGroupBJ(GetUnitsInRectAll(gg_rct_Room12_TRADE), function Trig_TimeElapsedNPC_Func003A)
    call ForGroupBJ(GetUnitsInRectAll(gg_rct_Room18_TRADE), function Trig_TimeElapsedNPC_Func004A)
    call ForGroupBJ(GetUnitsInRectAll(gg_rct_Room6_TRADE), function Trig_TimeElapsedNPC_Func005A)
    // -
    // Traders - Naluara
    if ( Trig_TimeElapsedNPC_Func008C() ) then
        if ( Trig_TimeElapsedNPC_Func008Func001C() ) then
            set udg_tempLoc=GetRectCenter(gg_rct_cheed1)
            call CreateNUnitsAtLoc(1, 'h025', Player(20), udg_tempLoc, 230.00)
            call RemoveLocation(udg_tempLoc)
        else
        endif
    else
    endif
    // Traders - Alliance
    if ( Trig_TimeElapsedNPC_Func010C() ) then
        if ( Trig_TimeElapsedNPC_Func010Func001C() ) then
            set udg_tempLoc=GetRectCenter(gg_rct_cheed2)
            call CreateNUnitsAtLoc(1, 'h025', Player(20), udg_tempLoc, 270.00)
            call RemoveLocation(udg_tempLoc)
        else
        endif
    else
    endif
    // Traders - Orc
    if ( Trig_TimeElapsedNPC_Func012C() ) then
        if ( Trig_TimeElapsedNPC_Func012Func001C() ) then
            set udg_tempLoc=GetRectCenter(gg_rct_cheed3)
            call CreateNUnitsAtLoc(1, 'h025', Player(20), udg_tempLoc, 45.00)
            call RemoveLocation(udg_tempLoc)
        else
        endif
    else
    endif
endfunction

