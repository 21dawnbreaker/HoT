function Trig_StrangulateTriggerDifficulty_Func021C takes nothing returns boolean
    return true
endfunction

function Trig_StrangulateTriggerDifficulty_Actions takes nothing returns nothing
    set udg_tempLoc=GetUnitLoc(gg_unit_U006_0283)
    call AddSpecialEffectLocBJ(udg_tempLoc, "Call of Dread Red.mdx")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call RemoveLocation(udg_tempLoc)
    set udg_tempLoc=GetUnitLoc(GroupPickRandomUnit(GetUnitsInRectMatching(gg_rct_MainBossLoc, Condition(function Trig_StrangulateTriggerDifficulty_Func006002001001002))))
    set udg_RandomU=null
    set udg_RandomU=GroupPickRandomUnit(GetUnitsInRectMatching(gg_rct_MainBossLoc, Condition(function Trig_StrangulateTriggerDifficulty_Func008002001002)))
    call AddSpecialEffectTargetUnitBJ("chest", gg_unit_U006_0283, "Abilities\\Weapons\\AvengerMissile\\AvengerMissile.mdl")
    if ( Trig_StrangulateTriggerDifficulty_Func010C() ) then
        set udg_tempLoc=GetUnitLoc(udg_RandomU)
        call SetUnitPositionLocFacingLocBJ(gg_unit_U006_0283, PolarProjectionBJ(udg_tempLoc, 75.00, GetRandomDirectionDeg()), udg_tempLoc)
        call RemoveLocation(udg_tempLoc)
    else
        set udg_RandomU=null
        set udg_RandomU=GroupPickRandomUnit(GetUnitsInRectMatching(gg_rct_MainBossLoc, Condition(function Trig_StrangulateTriggerDifficulty_Func010Func002002001002)))
        if ( Trig_StrangulateTriggerDifficulty_Func010Func003C() ) then
            set udg_tempLoc=GetUnitLoc(udg_RandomU)
            call SetUnitPositionLocFacingLocBJ(gg_unit_U006_0283, PolarProjectionBJ(udg_tempLoc, 75.00, GetRandomDirectionDeg()), udg_tempLoc)
            call RemoveLocation(udg_tempLoc)
        else
            set udg_RandomU=null
            set udg_RandomU=GroupPickRandomUnit(GetUnitsInRectMatching(gg_rct_MainBossLoc, Condition(function Trig_StrangulateTriggerDifficulty_Func010Func003Func002002001002)))
            if ( Trig_StrangulateTriggerDifficulty_Func010Func003Func003C() ) then
                set udg_tempLoc=GetUnitLoc(udg_RandomU)
                call SetUnitPositionLocFacingLocBJ(gg_unit_U006_0283, PolarProjectionBJ(udg_tempLoc, 75.00, GetRandomDirectionDeg()), udg_tempLoc)
                call RemoveLocation(udg_tempLoc)
            else
                set udg_RandomU=null
                set udg_RandomU=GroupPickRandomUnit(GetUnitsInRectMatching(gg_rct_MainBossLoc, Condition(function Trig_StrangulateTriggerDifficulty_Func010Func003Func003Func002002001002)))
                if ( Trig_StrangulateTriggerDifficulty_Func010Func003Func003Func003C() ) then
                    set udg_tempLoc=GetUnitLoc(udg_RandomU)
                    call SetUnitPositionLocFacingLocBJ(gg_unit_U006_0283, PolarProjectionBJ(udg_tempLoc, 75.00, GetRandomDirectionDeg()), udg_tempLoc)
                    call RemoveLocation(udg_tempLoc)
                else
                    set udg_RandomU=null
                    set udg_RandomU=GroupPickRandomUnit(GetUnitsInRectMatching(gg_rct_MainBossLoc, Condition(function Trig_StrangulateTriggerDifficulty_Func010Func003Func003Func003Func002002001002)))
                    if ( Trig_StrangulateTriggerDifficulty_Func010Func003Func003Func003Func003C() ) then
                        set udg_tempLoc=GetUnitLoc(udg_RandomU)
                        call SetUnitPositionLocFacingLocBJ(gg_unit_U006_0283, PolarProjectionBJ(udg_tempLoc, 75.00, GetRandomDirectionDeg()), udg_tempLoc)
                        call RemoveLocation(udg_tempLoc)
                    else
                        call RemoveLocation(udg_tempLoc)
                    endif
                    call RemoveLocation(udg_tempLoc)
                endif
                call RemoveLocation(udg_tempLoc)
            endif
            call RemoveLocation(udg_tempLoc)
        endif
        call RemoveLocation(udg_tempLoc)
    endif
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    set udg_NearestU=null
    set udg_tempLoc=GetUnitLoc(gg_unit_U006_0283)
    call AddSpecialEffectLocBJ(udg_tempLoc, "Call of Dread Red.mdx")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    set udg_NearestUDistance=999999.00
    call ForGroupBJ(GetUnitsInRangeOfLocAll(700.00, udg_tempLoc), function Trig_StrangulateTriggerDifficulty_Func017A)
    call RemoveLocation(udg_tempLoc)
    call PauseUnitBJ(true, udg_NearestU)
    call PauseUnitBJ(true, gg_unit_U006_0283)
    if ( (true) ) then // INLINED!!
        set udg_StrangulateDifficultyT=udg_NearestU
        call SetUnitAnimation(gg_unit_U006_0283, "spell")
        call TriggerSleepAction(0.35)
        set udg_tempLoc=GetUnitLoc(gg_unit_U006_0283)
        set udg_tempLoc2=GetUnitLoc(udg_StrangulateDifficultyT)
        call BlzSetUnitFacingEx(gg_unit_U006_0283, AngleBetweenPoints(udg_tempLoc, udg_tempLoc2))
        call PlaySoundAtPointBJ(gg_snd_VarimathrasYesAttack4, 100, udg_tempLoc, 0)
        call UnitAddAbilityBJ('Amrf', udg_StrangulateDifficultyT)
        call SetUnitFlyHeightBJ(udg_StrangulateDifficultyT, 40.00, 500.00)
        call UnitDamageTargetBJ(gg_unit_U006_0283, udg_StrangulateDifficultyT, I2R(BlzGetUnitBaseDamage(gg_unit_U006_0283, 0)), ATTACK_TYPE_MELEE, DAMAGE_TYPE_NORMAL)
        call SetUnitLifeBJ(gg_unit_U006_0283, ( GetUnitStateSwap(UNIT_STATE_LIFE, gg_unit_U006_0283) + ( I2R(BlzGetUnitBaseDamage(gg_unit_U006_0283, 0)) * ( 0.15 * I2R(GetUnitAbilityLevelSwapped('A06J', gg_unit_U006_0283)) ) ) ))
        call UnitRemoveAbilityBJ('Amrf', udg_StrangulateDifficultyT)
        call PlaySoundAtPointBJ(gg_snd_MetalHeavyChopFlesh2, 100, udg_tempLoc, 0)
        call RemoveLocation(udg_tempLoc)
        call RemoveLocation(udg_tempLoc2)
        call TriggerSleepAction(0.80)
        call SetUnitFlyHeightBJ(udg_StrangulateDifficultyT, 0.00, 300.00)
        call PauseUnitBJ(false, udg_StrangulateDifficultyT)
        call TriggerSleepAction(0.50)
        call PauseUnitBJ(false, gg_unit_U006_0283)
        set udg_StrangulateDifficultyT=null
    else
    endif
endfunction

