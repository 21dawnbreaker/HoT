//===========================================================================
// Trigger: AraNataPeriodic
//===========================================================================
function Trig_AraNataPeriodic_Conditions takes nothing returns boolean
    if ( not ( udg_BossfightDialogueInt == 0 ) ) then
        return false
    endif
    if ( not ( udg_BossfightMainIsOn == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_AraNataPeriodic_Func001Func001C takes nothing returns boolean
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( BlzIsUnitInvulnerable(GetEnumUnit()) == false ) ) then
        return false
    endif
    if ( not ( IsUnitEnemy(GetEnumUnit(), Player(12)) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_AraNataPeriodic_Func001A takes nothing returns nothing
    if ( Trig_AraNataPeriodic_Func001Func001C() ) then
        set udg_tempLoc=GetUnitLoc(GroupPickRandomUnit(udg_HeroesBossfightUG))
        call IssuePointOrderLocBJ(GetEnumUnit(), "attack", udg_tempLoc)
        call RemoveLocation(udg_tempLoc)
    else
    endif
endfunction

function Trig_AraNataPeriodic_Func006Func001Func002C takes nothing returns boolean
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(gg_unit_U005_0113)) == true ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( BlzIsUnitInvulnerable(GetEnumUnit()) == false ) ) then
        return false
    endif
    if ( not ( DistanceBetweenPoints(udg_tempLoc, udg_tempLoc7) < udg_NearestUDistance ) ) then
        return false
    endif
    return true
endfunction

function Trig_AraNataPeriodic_Func006Func001C takes nothing returns boolean
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(gg_unit_U005_0113)) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_AraNataPeriodic_Func006A takes nothing returns nothing
    if ( Trig_AraNataPeriodic_Func006Func001C() ) then
        set udg_tempLoc7=GetUnitLoc(GetEnumUnit())
        if ( Trig_AraNataPeriodic_Func006Func001Func002C() ) then
            set udg_NearestU=GetEnumUnit()
            set udg_NearestUDistance=DistanceBetweenPoints(udg_tempLoc, udg_tempLoc7)
            call RemoveLocation(udg_tempLoc7)
        else
        endif
    else
    endif
endfunction

function Trig_AraNataPeriodic_Func012Func001Func002C takes nothing returns boolean
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(gg_unit_U005_0113)) == true ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( GetEnumUnit() != gg_unit_U005_0113 ) ) then
        return false
    endif
    if ( not ( GetEnumUnit() != gg_unit_U006_0283 ) ) then
        return false
    endif
    if ( not ( BlzIsUnitInvulnerable(GetEnumUnit()) == false ) ) then
        return false
    endif
    if ( not ( DistanceBetweenPoints(udg_tempLoc, udg_tempLoc7) < udg_NearestUDistance ) ) then
        return false
    endif
    return true
endfunction

function Trig_AraNataPeriodic_Func012Func001C takes nothing returns boolean
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(gg_unit_U005_0113)) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_AraNataPeriodic_Func012A takes nothing returns nothing
    if ( Trig_AraNataPeriodic_Func012Func001C() ) then
        set udg_tempLoc7=GetUnitLoc(GetEnumUnit())
        if ( Trig_AraNataPeriodic_Func012Func001Func002C() ) then
            set udg_NearestU=GetEnumUnit()
            set udg_NearestUDistance=DistanceBetweenPoints(udg_tempLoc, udg_tempLoc7)
            call RemoveLocation(udg_tempLoc7)
        else
        endif
    else
    endif
endfunction

function Trig_AraNataPeriodic_Actions takes nothing returns nothing
    call ForGroupBJ(GetUnitsInRectAll(gg_rct_MainBossLoc), function Trig_AraNataPeriodic_Func001A)
    set udg_tempLoc=GetUnitLoc(gg_unit_U005_0113)
    set udg_NearestUDistance=999999.00
    call ForGroupBJ(GetUnitsInRectAll(gg_rct_MainBossLoc), function Trig_AraNataPeriodic_Func006A)
    call RemoveLocation(udg_tempLoc)
    call IssueTargetOrderBJ(gg_unit_U005_0113, "attack", udg_NearestU)
    call TriggerSleepAction(1.00)
    set udg_tempLoc=GetUnitLoc(gg_unit_U006_0283)
    set udg_NearestUDistance=999999.00
    call ForGroupBJ(GetUnitsInRectAll(gg_rct_MainBossLoc), function Trig_AraNataPeriodic_Func012A)
    call RemoveLocation(udg_tempLoc)
    call IssueTargetOrderBJ(gg_unit_U006_0283, "attack", udg_NearestU)
endfunction

//===========================================================================
function InitTrig_AraNataPeriodic takes nothing returns nothing
    set gg_trg_AraNataPeriodic=CreateTrigger()
    call DisableTrigger(gg_trg_AraNataPeriodic)
    call TriggerRegisterTimerEventPeriodic(gg_trg_AraNataPeriodic, 6.00)
    call TriggerAddCondition(gg_trg_AraNataPeriodic, Condition(function Trig_AraNataPeriodic_Conditions))
    call TriggerAddAction(gg_trg_AraNataPeriodic, function Trig_AraNataPeriodic_Actions)
endfunction

//===========================================================================
// Trigger: BossfightNataAraInit
//===========================================================================
function Trig_BossfightNataAraInit_Func001A takes nothing returns nothing
    call SetCameraBoundsToRectForPlayerBJ(GetEnumPlayer(), gg_rct_MainBossLoc)
    call PanCameraToTimedLocForPlayer(GetEnumPlayer(), GetRectCenter(gg_rct_StartLoc), 0)
endfunction

function Trig_BossfightNataAraInit_Actions takes nothing returns nothing
    call ForForce(udg_PlayerGroup, function Trig_BossfightNataAraInit_Func001A)
    set udg_BossPhase=1
    set udg_Boss[1]=gg_unit_U005_0113
    set udg_Boss[2]=gg_unit_U006_0283
    call GroupAddUnitSimple(gg_unit_U006_0283, udg_BossUG)
    call GroupAddUnitSimple(gg_unit_U005_0113, udg_BossUG)
    call SetUnitPositionLocFacingBJ(gg_unit_U005_0113, GetRectCenter(gg_rct_BossfightNatargad), 0.00)
    call SetUnitPositionLocFacingBJ(gg_unit_U006_0283, GetRectCenter(gg_rct_BossfightAraman), 0.00)
    // BOSS STATS
    call BlzSetUnitMaxHP(gg_unit_U005_0113, ( BlzGetUnitMaxHP(gg_unit_U005_0113) + ( R2I(( udg_difficultyReal * GetUnitStateSwap(UNIT_STATE_MAX_LIFE, gg_unit_U005_0113) )) * R2I(udg_RoomMultiboardCounting) ) ))
    call BlzSetUnitMaxHP(udg_Boss[1], ( BlzGetUnitMaxHP(udg_Boss[1]) * 2 ))
    call SetUnitLifePercentBJ(udg_Boss[1], 100)
    set udg_tempReal=I2R(BlzGetUnitBaseDamage(gg_unit_U006_0283, 0))
    call BlzSetUnitBaseDamage(gg_unit_U006_0283, ( BlzGetUnitBaseDamage(gg_unit_U006_0283, 0) + ( R2I(( udg_tempReal * udg_difficultyReal )) * R2I(udg_RoomMultiboardCounting) ) ), 0)
    call BlzSetUnitBaseDamage(gg_unit_U006_0283, ( BlzGetUnitBaseDamage(gg_unit_U006_0283, 0) * 2 ), 0)
    set udg_tempReal=0.00
    call SetUnitManaPercentBJ(gg_unit_U006_0283, 0.00)
    call SetHeroLevelBJ(gg_unit_U006_0283, GetUnitLevel(GroupPickRandomUnit(udg_HeroesGroup)), false)
    // BOSS STATS
    call BlzSetUnitMaxHP(gg_unit_U006_0283, ( BlzGetUnitMaxHP(gg_unit_U006_0283) + ( R2I(( udg_difficultyReal * GetUnitStateSwap(UNIT_STATE_MAX_LIFE, gg_unit_U006_0283) )) * R2I(udg_RoomMultiboardCounting) ) ))
    call BlzSetUnitMaxHP(udg_Boss[2], ( BlzGetUnitMaxHP(udg_Boss[2]) * 2 ))
    call SetUnitLifePercentBJ(udg_Boss[2], 100)
    set udg_tempReal=I2R(BlzGetUnitBaseDamage(gg_unit_U005_0113, 0))
    call BlzSetUnitBaseDamage(gg_unit_U005_0113, ( BlzGetUnitBaseDamage(gg_unit_U005_0113, 0) + ( R2I(( udg_tempReal * udg_difficultyReal )) * R2I(udg_RoomMultiboardCounting) ) ), 0)
    call BlzSetUnitBaseDamage(gg_unit_U005_0113, ( BlzGetUnitBaseDamage(gg_unit_U005_0113, 0) * 2 ), 0)
    set udg_tempReal=0.00
    call SetUnitManaPercentBJ(gg_unit_U005_0113, 0.00)
    call SetHeroLevelBJ(gg_unit_U005_0113, GetUnitLevel(GroupPickRandomUnit(udg_HeroesGroup)), false)
    // ---
    set udg_BossHP=( GetUnitStateSwap(UNIT_STATE_LIFE, gg_unit_U005_0113) + GetUnitStateSwap(UNIT_STATE_LIFE, gg_unit_U006_0283) )
    set udg_BossfightNataAra=1
    // ---
    call EnableTrigger(gg_trg_ShoulderToShoulder)
    call EnableTrigger(gg_trg_AraDying)
    call EnableTrigger(gg_trg_NataDying)
    call EnableTrigger(gg_trg_VulnerableOnDeath)
    call PauseUnitBJ(true, udg_Boss[1])
    call PauseUnitBJ(true, udg_Boss[2])
    call SetUnitInvulnerable(udg_Boss[1], true)
    call SetUnitInvulnerable(udg_Boss[2], true)
    call TriggerSleepAction(7.00)
    call PauseUnitBJ(false, udg_Boss[1])
    call PauseUnitBJ(false, udg_Boss[2])
    call SetUnitInvulnerable(udg_Boss[1], false)
    call SetUnitInvulnerable(udg_Boss[2], false)
    call EnableTrigger(gg_trg_AraNataPeriodic)
    call TriggerExecute(gg_trg_Phase_1_NataAra)
endfunction

//===========================================================================
function InitTrig_BossfightNataAraInit takes nothing returns nothing
    set gg_trg_BossfightNataAraInit=CreateTrigger()
    call TriggerAddAction(gg_trg_BossfightNataAraInit, function Trig_BossfightNataAraInit_Actions)
endfunction

