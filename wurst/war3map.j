function Trig_CallToArms_Actions takes nothing returns nothing
    call PlaySoundBJ(gg_snd_O03Grom07)
    set udg_BossfightDialogueInt=1
    call ForGroupBJ(GetUnitsInRectMatching(gg_rct_MainBossLoc, Condition(function Trig_CallToArms_Func003001002)), function Trig_CallToArms_Func003A)
    call ForGroupBJ(GetUnitsInRectAll(gg_rct_MainBossLoc), function Trig_CallToArms_Func004A)
    call TriggerSleepAction(3.00)
    call ForGroupBJ(GetUnitsInRectMatching(gg_rct_MainBossLoc, Condition(function Trig_CallToArms_Func006001002)), function Trig_CallToArms_Func006A)
    call ForGroupBJ(GetUnitsInRectAll(gg_rct_MainBossLoc), function Trig_CallToArms_Func007A)
    call ForGroupBJ(GetUnitsInRectAll(gg_rct_MainBossLoc), function Trig_CallToArms_Func008A)
    set udg_HeroesBossfightInt=1
    //  
    call SetUnitAnimation(GetTriggerUnit(), "birth")
    call SetUnitPositionLocFacingBJ(GetTriggerUnit(), GetRectCenter(gg_rct_BossfightNatargad), 0.00)
    call AddSpecialEffectTargetUnitBJ("origin", GetTriggerUnit(), "Abilities\\Spells\\Other\\Stampede\\StampedeMissileDeath.mdl")
    if ( Trig_CallToArms_Func014C() ) then
        set udg_tempLoc=GetUnitLoc(gg_unit_U006_0283)
        call AddSpecialEffectLocBJ(udg_tempLoc, "Call of Dread Red.mdx")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call RemoveLocation(udg_tempLoc)
        call AddSpecialEffectTargetUnitBJ("chest", gg_unit_U006_0283, "Abilities\\Weapons\\AvengerMissile\\AvengerMissile.mdl")
        call SetUnitPositionLocFacingBJ(gg_unit_U006_0283, GetRectCenter(gg_rct_BossfightAraman), 0.00)
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        set udg_tempLoc=GetUnitLoc(gg_unit_U006_0283)
        call AddSpecialEffectLocBJ(udg_tempLoc, "Call of Dread Red.mdx")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call RemoveLocation(udg_tempLoc)
    else
    endif
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=20
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        set udg_tempLoc=GetRandomLocInRect(gg_rct_BossfightBoss)
        call CreateNUnitsAtLoc(1, udg_EnemyRoom[GetRandomInt(1, 17)], Player(22), udg_tempLoc, 0.00)
        call SetUnitAnimation(GetLastCreatedUnit(), "ready")
        call AddSpecialEffectTargetUnitBJ("origin", GetLastCreatedUnit(), "Abilities\\Spells\\Undead\\AnimateDead\\AnimateDeadTarget.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call RemoveLocation(udg_tempLoc)
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    //  
    call TriggerSleepAction(2.00)
    call SetUnitAnimation(GetTriggerUnit(), "alive")
    call TriggerSleepAction(4.00)
    call ForGroupBJ(GetUnitsInRectAll(gg_rct_BossfightBoss), function Trig_CallToArms_Func020A)
    call TriggerSleepAction(2.00)
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=30
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        call DestroyEffectBJ(udg_CallToArmsEff[GetForLoopIndexA()])
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    call ForGroupBJ(GetUnitsInRectAll(gg_rct_MainBossLoc), function Trig_CallToArms_Func023A)
    call ForGroupBJ(GetUnitsInRectAll(gg_rct_MainBossLoc), function Trig_CallToArms_Func024A)
    call CreateNUnitsAtLoc(1, 'h015', GetOwningPlayer(GetTriggerUnit()), GetUnitLoc(GetTriggerUnit()), 0.00)
    call UnitAddAbilityBJ('Amrf', GetLastCreatedUnit())
    call SetUnitFlyHeightBJ(GetLastCreatedUnit(), 89999.00, 9999.00)
    call UnitRemoveAbilityBJ('A04M', GetLastCreatedUnit())
    call UnitAddAbilityBJ('A06L', GetLastCreatedUnit())
    call SetUnitAbilityLevelSwapped('A06L', GetLastCreatedUnit(), udg_DIFFICULTY)
    call IssueImmediateOrderBJ(GetLastCreatedUnit(), "roar")
    call UnitApplyTimedLifeBJ(2.00, 'BTLF', GetLastCreatedUnit())
    call PlaySoundOnUnitBJ(gg_snd_TheHornOfCenarius, 100, gg_unit_U005_0113)
    call TriggerSleepAction(6.00)
    set udg_BossfightDialogueInt=0
endfunction

