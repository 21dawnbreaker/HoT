    call UnitRemoveBuffBJ('B00O', udg_DuelT)
    call UnitRemoveBuffBJ('B02J', udg_DuelT)
    call UnitRemoveBuffBJ('B02J', udg_DuelC)
    call PlaySoundOnUnitBJ(gg_snd_Press_the_Attack_mp301, 100, udg_DuelC)
    set udg_tempLoc=GetUnitLoc(gg_unit_E001_0061)
    call CreateNUnitsAtLoc(1, 'h00I', GetOwningPlayer(gg_unit_E001_0061), udg_tempLoc, bj_UNIT_FACING)
    call UnitApplyTimedLifeBJ(2.00, 'BTLF', GetLastCreatedUnit())
    call IssueImmediateOrderBJ(GetLastCreatedUnit(), "roar")
    call RemoveLocation(udg_tempLoc)
    call DestroyEffectBJ(udg_DuelEff)
    call DestroyEffectBJ(udg_DuelEff1)
    call DestroyEffectBJ(udg_DuelEff1_Copy)
    call DestroyEffectBJ(udg_DuelEff1_Copy_2)
    call DestroyEffectBJ(udg_DuelEff1_Copy_3)
    call DestroyEffectBJ(udg_DuelEff1_Copy_4)
    call DestroyEffectBJ(udg_DuelEff1_Copy_5)
    call DestroyEffectBJ(udg_DuelEff1_Copy_6)
    call DestroyEffectBJ(udg_DuelEff1_Copy_7)
    call StopSoundBJ(udg_DuelSound, false)
endfunction

