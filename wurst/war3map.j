function Trig_Phase3_NataAra_Conditions takes nothing returns boolean
    if ( not ( ( GetUnitStateSwap(UNIT_STATE_LIFE, gg_unit_U005_0113) + GetUnitStateSwap(UNIT_STATE_LIFE, gg_unit_U006_0283) ) <= ( udg_BossHP * 0.40 ) ) ) then
        return false
    endif
    if ( not ( udg_BossfightMainIsOn == 1 ) ) then
        return false
    endif
    if ( not ( udg_BossfightNataAra == 1 ) ) then
        return false
    endif
    return true
endfunction

