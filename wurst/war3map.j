    if ( not ( GetUnitTypeId(GetSoldUnit()) == 'o033' ) ) then
        return false
    endif
    return true
endfunction

function Trig_CheedSelling_Func008Func001C takes nothing returns boolean
    if ( ( GetItemTypeId(GetSoldItem()) == 'I03R' ) ) then
        return true
    endif
    if ( ( GetItemTypeId(GetSoldItem()) == 'I08S' ) ) then
        return true
    endif
    return false
endfunction

function Trig_CheedSelling_Func008C takes nothing returns boolean
    if ( not Trig_CheedSelling_Func008Func001C() ) then
        return false
    endif
    return true
endfunction

function Trig_CheedSelling_Actions takes nothing returns nothing
    set udg_tempUnit=GetBuyingUnit()
    set udg_tempLoc=GetUnitLoc(GetTriggerUnit())
    if ( Trig_CheedSelling_Func006C() ) then
        set udg_tempZ=GetLocationZ(udg_tempLoc)
        call StopSoundBJ(udg_CheedSellingSound, false)
        call PlaySoundAtPointBJ(gg_snd_diablo2identify, 100, udg_tempLoc, udg_tempZ)
        set udg_CheedSellingSound=GetLastPlayedSound()
        set udg_tempZ=0.00
        call ConditionalTriggerExecute(gg_trg_GenerateLootForHeroFunc)
    else
    endif
    if ( Trig_CheedSelling_Func007C() ) then
        set udg_tempZ=GetLocationZ(udg_tempLoc)
        call StopSoundBJ(udg_CheedSellingSound, false)
        call PlaySoundAtPointBJ(gg_snd_diablo2rune, 100, udg_tempLoc, udg_tempZ)
        set udg_CheedSellingSound=GetLastPlayedSound()
        set udg_tempZ=0.00
        call UnitAddItemByIdSwapped(ChooseRandomItemBJ(2), udg_tempUnit)
    else
    endif
    if ( Trig_CheedSelling_Func008C() ) then
    else
        call RemoveItemFromStockBJ(GetItemTypeId(GetSoldItem()), GetTriggerUnit())
    endif
    call RemoveUnit(GetSoldUnit())
    set udg_tempUnit=null
    call RemoveLocation(udg_tempLoc)
endfunction

