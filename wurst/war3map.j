endfunction

function Trig_ShadowdanceMovePeriodic_Func003Func004A takes nothing returns nothing
    if ( Trig_ShadowdanceMovePeriodic_Func003Func004Func001C() ) then
        call StopSoundBJ(udg_shadowdance_sound, false)
        call PlaySoundAtPointBJ(gg_snd_MetalHeavySliceFlesh2, 100, udg_tempLoc2, GetUnitFlyHeight(gg_unit_H012_0027))
        set udg_shadowdance_sound=GetLastPlayedSound()
        if ( Trig_ShadowdanceMovePeriodic_Func003Func004Func001Func004C() ) then
            call UnitDamageTargetBJ(gg_unit_H012_0027, GetEnumUnit(), ( I2R(BlzGetUnitBaseDamage(udg_Boss[1], 0)) * 8.00 ), ATTACK_TYPE_MELEE, DAMAGE_TYPE_NORMAL)
        else
            call UnitDamageTargetBJ(gg_unit_H012_0027, GetEnumUnit(), ( I2R(BlzGetUnitBaseDamage(udg_Boss[1], 0)) * 0.80 ), ATTACK_TYPE_MELEE, DAMAGE_TYPE_NORMAL)
        endif
        call GroupAddUnitSimple(GetEnumUnit(), udg_shadowdance_damaged_UG)
    else
    endif
endfunction

function Trig_ShadowdanceMovePeriodic_Func003C takes nothing returns boolean
    if ( not ( DistanceBetweenPoints(udg_tempLoc, udg_shadowdance_final_pos) > 5.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ShadowdanceMovePeriodic_Actions takes nothing returns nothing
    set udg_tempLoc=GetUnitLoc(gg_unit_H012_0027)
    if ( Trig_ShadowdanceMovePeriodic_Func003C() ) then
        set udg_tempLoc2=PolarProjectionBJ(udg_tempLoc, 8.00, AngleBetweenPoints(udg_tempLoc, udg_shadowdance_final_pos))
        call SetUnitPositionLoc(udg_Boss[1], udg_tempLoc2)
        call ForGroupBJ(GetUnitsInRangeOfLocAll(100.00, udg_tempLoc2), function Trig_ShadowdanceMovePeriodic_Func003Func004A)
        call RemoveLocation(udg_tempLoc2)
    else
        if ( Trig_ShadowdanceMovePeriodic_Func003Func001C() ) then
            set udg_shadowdance_count=( udg_shadowdance_count - 1 )
            call StartTimerBJ(udg_shadowdance_timer, false, 0.01)
        else
            call TriggerExecute(gg_trg_ShadowdanceEnd)
        endif
        call RemoveLocation(udg_shadowdance_final_pos)
        call DisableTrigger(GetTriggeringTrigger())
    endif
    call RemoveLocation(udg_tempLoc)
endfunction

