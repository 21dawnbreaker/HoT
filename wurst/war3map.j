//===========================================================================
function InitTrig_ThePursuitTriggerDifficulty takes nothing returns nothing
    set gg_trg_ThePursuitTriggerDifficulty=CreateTrigger()
    call DisableTrigger(gg_trg_ThePursuitTriggerDifficulty)
