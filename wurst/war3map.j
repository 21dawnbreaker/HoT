function Trig_TimeElapsedInit_Func008A takes nothing returns nothing
endfunction

function Trig_TimeElapsedInit_Func056Func001Func004C takes nothing returns boolean
    if ( ( GetUnitTypeId(GetEnumUnit()) == 'h029' ) ) then
        return true
    endif
    if ( ( GetUnitTypeId(GetEnumUnit()) == 'h02A' ) ) then
        return true
    endif
    return false
endfunction

function Trig_TimeElapsedInit_Func056Func001C takes nothing returns boolean
    if ( not Trig_TimeElapsedInit_Func056Func001Func004C() ) then
        return false
    endif
    return true
endfunction

function Trig_TimeElapsedInit_Func056A takes nothing returns nothing
    if ( Trig_TimeElapsedInit_Func056Func001C() ) then
        call GroupAddUnitSimple(GetEnumUnit(), udg_ManekenUG)
        call GroupAddUnitSimple(GetEnumUnit(), udg_not_knockbackable_UG)
        call GroupAddUnitSimple(GetEnumUnit(), udg_frozen_immune_UG)
    else
    endif
endfunction

function Trig_TimeElapsedInit_Func059Func001Func010C takes nothing returns boolean
    if ( not ( udg_debug_mode == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_TimeElapsedInit_Func059Func001C takes nothing returns boolean
    if ( not ( GetPlayerColor(GetEnumPlayer()) != PLAYER_COLOR_PEANUT ) ) then
        return false
    endif
    if ( not ( GetPlayerColor(GetEnumPlayer()) != PLAYER_COLOR_SNOW ) ) then
        return false
    endif
    if ( not ( GetPlayerColor(GetEnumPlayer()) != PLAYER_COLOR_NAVY ) ) then
        return false
    endif
    if ( not ( GetPlayerColor(GetEnumPlayer()) != PLAYER_COLOR_MAROON ) ) then
        return false
    endif
    if ( not ( GetPlayerColor(GetEnumPlayer()) != PLAYER_COLOR_EMERALD ) ) then
        return false
    endif
    if ( not ( GetPlayerColor(GetEnumPlayer()) != PLAYER_COLOR_COAL ) ) then
        return false
    endif
    return true
endfunction

function Trig_TimeElapsedInit_Func059A takes nothing returns nothing
    if ( Trig_TimeElapsedInit_Func059Func001C() ) then
        set udg_PlayerCountChoosing=( udg_PlayerCountChoosing + 1 )
        call SetPlayerAllianceStateBJ(Player(19), GetEnumPlayer(), bj_ALLIANCE_UNALLIED)
        call SetPlayerAllianceStateBJ(GetEnumPlayer(), Player(19), bj_ALLIANCE_UNALLIED)
        call ForceAddPlayerSimple(GetEnumPlayer(), udg_PlayerGroup)
        call SetPlayerStateBJ(GetEnumPlayer(), PLAYER_STATE_RESOURCE_GOLD, 80)
        call SetCameraBoundsToRectForPlayerBJ(GetEnumPlayer(), gg_rct_MainBossLoc)
        call CreateNUnitsAtLoc(1, 'e000', GetEnumPlayer(), GetRectCenter(gg_rct_StartLoc), bj_UNIT_FACING)
        call IssuePointOrderLocBJ(GetLastCreatedUnit(), "move", PolarProjectionBJ(GetRectCenter(gg_rct_StartLoc), 300.00, AngleBetweenPoints(GetRectCenter(gg_rct_StartLoc), GetUnitLoc(GetLastCreatedUnit()))))
        if ( Trig_TimeElapsedInit_Func059Func001Func010C() ) then
            call SetUnitManaPercentBJ(GetLastCreatedUnit(), 100)
        else
        endif
        call CreateFogModifierRectBJ(true, GetEnumPlayer(), FOG_OF_WAR_VISIBLE, gg_rct_PlayableMapAreaLoc)
    else
    endif
endfunction

function Trig_TimeElapsedInit_Func060Func001Func001C takes nothing returns boolean
    if ( ( GetPlayerColor(GetEnumPlayer()) == PLAYER_COLOR_SNOW ) ) then
        return true
    endif
    if ( ( GetPlayerColor(GetEnumPlayer()) == PLAYER_COLOR_NAVY ) ) then
        return true
    endif
    if ( ( GetPlayerColor(GetEnumPlayer()) == PLAYER_COLOR_MAROON ) ) then
        return true
    endif
    return false
endfunction

