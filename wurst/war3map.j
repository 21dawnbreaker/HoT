function Trig_Damnation_Func007Func001A takes nothing returns nothing
    if ( Trig_Damnation_Func007Func001Func001C() ) then
        if ( Trig_Damnation_Func007Func001Func001Func001C() ) then
            if ( Trig_Damnation_Func007Func001Func001Func001Func002C() ) then
                call GroupAddUnitSimple(GetEnumUnit(), udg_DamnationUG)
                call GroupAddUnitSimple(GetEnumUnit(), udg_DamnationAgonyUG)
                call CreateNUnitsAtLoc(1, 'h00U', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc, bj_UNIT_FACING)
                call SetUnitAbilityLevelSwapped('A063', GetLastCreatedUnit(), GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()))
                call SetUnitAbilityLevelSwapped('A062', GetLastCreatedUnit(), GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()))
                call SetUnitAbilityLevelSwapped('A061', GetLastCreatedUnit(), GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()))
                call IssueTargetOrderBJ(GetLastCreatedUnit(), "innerfire", GetEnumUnit())
                call UnitApplyTimedLifeBJ(GetRandomReal(1.00, 2.00), 'BTLF', GetLastCreatedUnit())
            else
                call GroupAddUnitSimple(GetEnumUnit(), udg_DamnationUG)
                call CreateNUnitsAtLoc(1, 'h00U', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc, bj_UNIT_FACING)
                call SetUnitAbilityLevelSwapped('A063', GetLastCreatedUnit(), GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()))
                call SetUnitAbilityLevelSwapped('A062', GetLastCreatedUnit(), GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()))
                call SetUnitAbilityLevelSwapped('A061', GetLastCreatedUnit(), GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()))
                call IssueTargetOrderBJ(GetLastCreatedUnit(), "cripple", GetEnumUnit())
                call UnitApplyTimedLifeBJ(GetRandomReal(1.00, 2.00), 'BTLF', GetLastCreatedUnit())
            endif
        else
            call GroupAddUnitSimple(GetEnumUnit(), udg_DamnationUG)
            call CreateNUnitsAtLoc(1, 'h00U', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc, bj_UNIT_FACING)
            call SetUnitAbilityLevelSwapped('A063', GetLastCreatedUnit(), GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()))
            call SetUnitAbilityLevelSwapped('A062', GetLastCreatedUnit(), GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()))
            call SetUnitAbilityLevelSwapped('A061', GetLastCreatedUnit(), GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()))
            call IssueTargetOrderBJ(GetLastCreatedUnit(), "faeriefire", GetEnumUnit())
            call UnitApplyTimedLifeBJ(GetRandomReal(1.00, 2.00), 'BTLF', GetLastCreatedUnit())
        endif
    else
    endif
endfunction

