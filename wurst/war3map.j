//===========================================================================
// Trigger: LycantrophyEnd
//===========================================================================
function Trig_LycantrophyEnd_Func021Func001C takes nothing returns boolean
    if ( not ( GetOwningPlayer(udg_LycantrophyC) == udg_Player[GetForLoopIndexA()] ) ) then
        return false
    endif
    return true
endfunction

function Trig_LycantrophyEnd_Actions takes nothing returns nothing
    set udg_tempLoc=GetUnitLoc(udg_LycantrophyC2)
    call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\Human\\Polymorph\\PolyMorphTarget.mdl")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 2.00)
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call SetHeroXP(udg_LycantrophyC, GetHeroXP(udg_LycantrophyC2), true)
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=6
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        set udg_LycantrophyIT[GetForLoopIndexA()]=GetItemTypeId(UnitItemInSlotBJ(udg_LycantrophyC2, GetForLoopIndexA()))
        call UnitRemoveItemFromSlotSwapped(GetForLoopIndexA(), udg_LycantrophyC2)
        set udg_LycantrophyI[GetForLoopIndexA()]=GetLastRemovedItem()
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    call ClearSelectionForPlayer(GetOwningPlayer(udg_LycantrophyC))
    call SelectUnitForPlayerSingle(udg_LycantrophyC, GetOwningPlayer(udg_LycantrophyC))
    call SetUnitManaBJ(udg_LycantrophyC, GetUnitStateSwap(UNIT_STATE_MANA, udg_LycantrophyC2))
    call SetUnitLifeBJ(udg_LycantrophyC, GetUnitStateSwap(UNIT_STATE_LIFE, udg_LycantrophyC))
    set bj_forLoopBIndex=1
    set bj_forLoopBIndexEnd=6
    loop
        exitwhen bj_forLoopBIndex > bj_forLoopBIndexEnd
        call UnitAddItemSwapped(udg_LycantrophyI[GetForLoopIndexB()], udg_LycantrophyC)
        set bj_forLoopBIndex=bj_forLoopBIndex + 1
    endloop
    call GroupRemoveUnitSimple(GetLastCreatedUnit(), udg_Metamorphosis)
    call GroupRemoveUnitSimple(GetLastCreatedUnit(), udg_HeroesGroup)
    call RemoveUnit(udg_LycantrophyC2)
    call SetUnitPositionLoc(udg_LycantrophyC, udg_tempLoc)
    call ShowUnitShow(udg_LycantrophyC)
    call SetUnitInvulnerable(udg_LycantrophyC, false)
    call PauseUnitBJ(false, udg_LycantrophyC)
    call ClearSelectionForPlayer(GetOwningPlayer(udg_LycantrophyC))
    call SelectUnitForPlayerSingle(udg_LycantrophyC, GetOwningPlayer(udg_LycantrophyC))
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=udg_HeroNumber
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        if ( Trig_LycantrophyEnd_Func021Func001C() ) then
            call SetUnitOwner(udg_Backpack[GetForLoopIndexA()], GetOwningPlayer(udg_LycantrophyC), false)
        else
        endif
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    call TriggerSleepAction(8.00)
    call EnableTrigger(gg_trg_Lycantrophy)
    call DisableTrigger(gg_trg_DeepWoundsPeriodic)
endfunction

