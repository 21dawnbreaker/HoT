function Trig_FireBombSpread_Func007A takes nothing returns nothing
    if ( Trig_FireBombSpread_Func007Func001C() ) then
        if ( Trig_FireBombSpread_Func007Func001Func001C() ) then
            call UnitDamageTargetBJ(udg_FireBombC, GetEnumUnit(), udg_tempReal, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_MAGIC)
            call UnitDamageTargetBJ(udg_FireBombC, GetEnumUnit(), udg_tempReal, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_MAGIC)
            call CreateTextTagUnitBJ("TRIGSTR_6353", GetEnumUnit(), 0, 9.00, 100, 100, 100, 0)
            call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
