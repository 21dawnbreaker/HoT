//===========================================================================
// Trigger: FreezeFunc
//
// func expects tempUnit, DamageEventAmount=0
//===========================================================================
function Trig_FreezeFunc_Func001C takes nothing returns boolean
    if ( not ( IsUnitType(udg_tempUnit, UNIT_TYPE_HERO) == false ) ) then
        return false
    endif
    if ( not ( IsUnitType(udg_tempUnit, UNIT_TYPE_STRUCTURE) == false ) ) then
        return false
    endif
    if ( not ( IsUnitInGroup(udg_tempUnit, udg_frozen_immune_UG) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_FreezeFunc_Actions takes nothing returns nothing
    if ( Trig_FreezeFunc_Func001C() ) then
        call UnitRemoveBuffsBJ(bj_REMOVEBUFFS_ALL, udg_tempUnit)
        call PauseUnitBJ(true, udg_tempUnit)
        call SetUnitTimeScalePercent(udg_tempUnit, 0.00)
        call BlzSetUnitMaxHP(udg_tempUnit, 1)
        call SetUnitVertexColorBJ(udg_tempUnit, 0.00, 0.00, 100, 0)
        call GroupAddUnitSimple(udg_tempUnit, udg_frozen_UG)
        call PlaySoundOnUnitBJ(gg_snd_diablo2cold3, 100, udg_tempUnit)
        set udg_frozen_sound[2]=GetLastPlayedSound()
    else
    endif
endfunction

//===========================================================================
function InitTrig_FreezeFunc takes nothing returns nothing
    set gg_trg_FreezeFunc=CreateTrigger()
    call TriggerAddAction(gg_trg_FreezeFunc, function Trig_FreezeFunc_Actions)
endfunction

//===========================================================================
// Trigger: FallenShrineSell
//===========================================================================
function Trig_FallenShrineSell_Conditions takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetTriggerUnit()) == 'h01O' ) ) then
        return false
    endif
    return true
endfunction

function Trig_FallenShrineSell_Actions takes nothing returns nothing
    call RemoveUnit(GetSoldUnit())
    call PauseUnitBJ(true, GetTriggerUnit())
    set udg_tempLoc=GetUnitLoc(GetTriggerUnit())
    call AddSpecialEffectLocBJ(udg_tempLoc, "Skill_Indicator_Circle.mdx")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 13.00)
    call RemoveLocation(udg_tempLoc)
    set udg_fallen_shrine_eff=GetLastCreatedEffectBJ()
    set udg_fallen_shrine_shrine=GetTriggerUnit()
    call StartTimerBJ(udg_fallen_shrine_timer, false, 60.00)
    call CreateTimerDialogBJ(GetLastCreatedTimerBJ(), "TRIGSTR_8880")
    call TimerDialogDisplayBJ(true, GetLastCreatedTimerDialogBJ())
    set udg_fallen_shrine_timer_window=GetLastCreatedTimerDialogBJ()
    call PlaySoundBJ(gg_snd_diablo2arcaneportal)
    call CreateTextTagUnitBJ(( ( I2S(udg_fallen_shrine_int) + " / " ) + I2S(udg_FALLEN_SHRINE_DIFFICULTY_INT) ), udg_fallen_shrine_shrine, 0, 10, 100, 100, 100, 0)
    set udg_fallen_shrine_text=GetLastCreatedTextTag()
    set udg_RoomCleared=false
    call TriggerSleepAction(2)
    call EnableTrigger(gg_trg_FallenShrinePeriodic)
endfunction

//===========================================================================
function InitTrig_FallenShrineSell takes nothing returns nothing
    set gg_trg_FallenShrineSell=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_FallenShrineSell, EVENT_PLAYER_UNIT_SELL)
    call TriggerAddCondition(gg_trg_FallenShrineSell, Condition(function Trig_FallenShrineSell_Conditions))
    call TriggerAddAction(gg_trg_FallenShrineSell, function Trig_FallenShrineSell_Actions)
endfunction

//===========================================================================
// Trigger: FallenShrineDeath
//===========================================================================
function Trig_FallenShrineDeath_Conditions takes nothing returns boolean
    if ( not ( GetUnitTypeId(udg_fallen_shrine_shrine) == 'h01O' ) ) then
        return false
    endif
    if ( not ( GetUnitTypeId(GetTriggerUnit()) == 'n00Q' ) ) then
        return false
    endif
    return true
endfunction

function Trig_FallenShrineDeath_Func004C takes nothing returns boolean
    if ( not ( DistanceBetweenPoints(udg_tempLoc, udg_tempLoc2) < 600.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_FallenShrineDeath_Func007C takes nothing returns boolean
    if ( not ( udg_fallen_shrine_int >= udg_FALLEN_SHRINE_DIFFICULTY_INT ) ) then
        return false
    endif
    return true
endfunction

function Trig_FallenShrineDeath_Actions takes nothing returns nothing
    call GroupRemoveUnitSimple(GetTriggerUnit(), udg_fallen_shrine_UG)
    set udg_tempLoc=GetUnitLoc(GetTriggerUnit())
    set udg_tempLoc2=GetUnitLoc(udg_fallen_shrine_shrine)
    if ( Trig_FallenShrineDeath_Func004C() ) then
        set udg_fallen_shrine_int=( udg_fallen_shrine_int + 1 )
        call DestroyTextTagBJ(udg_fallen_shrine_text)
        call CreateTextTagUnitBJ(( ( I2S(udg_fallen_shrine_int) + " / " ) + I2S(udg_FALLEN_SHRINE_DIFFICULTY_INT) ), udg_fallen_shrine_shrine, 0, 10, 100, 100, 100, 0)
        set udg_fallen_shrine_text=GetLastCreatedTextTag()
    else
    endif
    call RemoveLocation(udg_tempLoc)
    call RemoveLocation(udg_tempLoc2)
    if ( Trig_FallenShrineDeath_Func007C() ) then
        call TriggerExecute(gg_trg_FallenShrineEnd)
    else
    endif
endfunction

//===========================================================================
function InitTrig_FallenShrineDeath takes nothing returns nothing
    set gg_trg_FallenShrineDeath=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_FallenShrineDeath, EVENT_PLAYER_UNIT_DEATH)
    call TriggerAddCondition(gg_trg_FallenShrineDeath, Condition(function Trig_FallenShrineDeath_Conditions))
    call TriggerAddAction(gg_trg_FallenShrineDeath, function Trig_FallenShrineDeath_Actions)
