    if ( Trig_Inferno_Func004Func001C() ) then
        call GroupAddUnitSimple(GetEnumUnit(), udg_InfernoTargets)
    else
    endif
endfunction

function Trig_Inferno_Actions takes nothing returns nothing
    call GroupRemoveGroup(udg_InfernoTargets, udg_InfernoTargets)
    set udg_Infernoi=GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())
    if ( Trig_Inferno_Func003C() ) then
        call SetUnitLifePercentBJ(GetTriggerUnit(), ( GetUnitLifePercent(GetTriggerUnit()) - ( 50.00 - ( 5.00 * I2R(udg_Infernoi) ) ) ))
    else
        call SetUnitManaPercentBJ(GetTriggerUnit(), ( GetUnitManaPercent(GetTriggerUnit()) - ( 50.00 - ( 5.00 * I2R(udg_Infernoi) ) ) ))
    endif
    call ForGroupBJ(GetUnitsInRangeOfLocAll(260.00, GetSpellTargetLoc()), function Trig_Inferno_Func004A)
endfunction

