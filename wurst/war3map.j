function Trig_HarvestMovePeriodic_Func001Func001Func006A takes nothing returns nothing
    if ( Trig_HarvestMovePeriodic_Func001Func001Func006Func001C() ) then
        if ( Trig_HarvestMovePeriodic_Func001Func001Func006Func001Func001C() ) then
            call UnitAddItemByIdSwapped('I03W', GetEnumUnit())
            set udg_harvest_inactive_int[GetForLoopIndexA()]=1
            call DestroyEffectBJ(udg_harvest_eff[GetForLoopIndexA()])
            set udg_harvest_int=( udg_harvest_int + udg_harvest_inactive_int[GetForLoopIndexA()] )
            call AddSpecialEffectLocBJ(udg_harvest_pos[GetForLoopIndexA()], "Conflagrate.mdx")
            call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 1.00)
            call BlzSetSpecialEffectHeight(GetLastCreatedEffectBJ(), ( BlzGetLocalUnitZ(udg_Boss[1]) - 0.00 ))
            call DestroyEffectBJ(GetLastCreatedEffectBJ())
            call RemoveLocation(udg_harvest_pos[GetForLoopIndexA()])
        else
            if ( Trig_HarvestMovePeriodic_Func001Func001Func006Func001Func001Func001C() ) then
                set udg_harvest_int=8
            else
                if ( Trig_HarvestMovePeriodic_Func001Func001Func006Func001Func001Func001Func001C() ) then
                    call AddSpecialEffectTargetUnitBJ("chest", GetEnumUnit(), "Abilities\\Weapons\\FireBallMissile\\FireBallMissile.mdl")
                    call DestroyEffectBJ(GetLastCreatedEffectBJ())
                    set udg_tempUnit=GetEnumUnit()
                    if ( Trig_HarvestMovePeriodic_Func001Func001Func006Func001Func001Func001Func001Func004C() ) then
                        set udg_harvest_inactive_int[GetForLoopIndexA()]=1
                        call DestroyEffectBJ(udg_harvest_eff[GetForLoopIndexA()])
                        set udg_harvest_int=( udg_harvest_int + udg_harvest_inactive_int[GetForLoopIndexA()] )
                        call AddSpecialEffectLocBJ(udg_harvest_pos[GetForLoopIndexA()], "Conflagrate.mdx")
                        call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 1.00)
                        call BlzSetSpecialEffectHeight(GetLastCreatedEffectBJ(), ( BlzGetLocalUnitZ(udg_Boss[1]) - 0.00 ))
                        call DestroyEffectBJ(GetLastCreatedEffectBJ())
                        call RemoveLocation(udg_harvest_pos[GetForLoopIndexA()])
                    else
                    endif
                else
                endif
            endif
        endif
    else
    endif
endfunction

function Trig_HarvestMovePeriodic_Func001Func001C takes nothing returns boolean
    if ( not ( udg_harvest_inactive_int[GetForLoopIndexA()] == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_HarvestMovePeriodic_Func001Func002C takes nothing returns boolean
    if ( not ( udg_tempUnit != null ) ) then
        return false
    endif
    return true
endfunction

function Trig_HarvestMovePeriodic_Func003C takes nothing returns boolean
    if ( not ( DistanceBetweenPoints(udg_emilisma_pos, udg_harvest_pos[udg_harvest_heal_int]) <= 110.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_HarvestMovePeriodic_Func004C takes nothing returns boolean
    if ( not ( udg_harvest_int >= 8 ) ) then
        return false
    endif
    return true
endfunction

function Trig_HarvestMovePeriodic_Actions takes nothing returns nothing
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=8
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        if ( Trig_HarvestMovePeriodic_Func001Func001C() ) then
            set udg_tempLoc=PolarProjectionBJ(udg_harvest_pos[GetForLoopIndexA()], 5.00, AngleBetweenPoints(udg_harvest_pos[GetForLoopIndexA()], udg_emilisma_pos))
            call BlzSetSpecialEffectPositionLoc(udg_harvest_eff[GetForLoopIndexA()], udg_tempLoc)
            call RemoveLocation(udg_harvest_pos[GetForLoopIndexA()])
            set udg_harvest_pos[GetForLoopIndexA()]=PolarProjectionBJ(udg_tempLoc, 0.00, 0)
            call RemoveLocation(udg_tempLoc)
            call ForGroupBJ(GetUnitsInRangeOfLocAll(90.00, udg_harvest_pos[GetForLoopIndexA()]), function Trig_HarvestMovePeriodic_Func001Func001Func006A)
        else
        endif
        if ( Trig_HarvestMovePeriodic_Func001Func002C() ) then
            call UnitDamageTargetBJ(udg_Boss[1], udg_tempUnit, ( GetUnitStateSwap(UNIT_STATE_MAX_LIFE, udg_tempUnit) * 1.00 ), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_MAGIC)
        else
            call UnitDamageTargetBJ(udg_Boss[1], udg_tempUnit, ( GetUnitStateSwap(UNIT_STATE_MAX_LIFE, udg_tempUnit) * 0.05 ), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_MAGIC)
        endif
        set udg_tempUnit=null
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    // Chek if heal near boss
    if ( Trig_HarvestMovePeriodic_Func003C() ) then
        call UnitAddItemByIdSwapped('I03W', gg_unit_H013_0011)
        set udg_harvest_int=8
    else
    endif
    if ( Trig_HarvestMovePeriodic_Func004C() ) then
        set bj_forLoopBIndex=1
        set bj_forLoopBIndexEnd=8
        loop
            exitwhen bj_forLoopBIndex > bj_forLoopBIndexEnd
            call DestroyEffectBJ(udg_harvest_eff[GetForLoopIndexB()])
            set udg_harvest_inactive_int[GetForLoopIndexB()]=0
            call AddSpecialEffectLocBJ(udg_harvest_pos[GetForLoopIndexB()], "Conflagrate.mdx")
            call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 1.00)
            call BlzSetSpecialEffectHeight(GetLastCreatedEffectBJ(), ( BlzGetLocalUnitZ(udg_Boss[1]) - 0.00 ))
            call DestroyEffectBJ(GetLastCreatedEffectBJ())
            call RemoveLocation(udg_harvest_pos[GetForLoopIndexB()])
            set bj_forLoopBIndex=bj_forLoopBIndex + 1
        endloop
        call DisableTrigger(GetTriggeringTrigger())
    else
    endif
endfunction

//===========================================================================
function InitTrig_HarvestMovePeriodic takes nothing returns nothing
    set gg_trg_HarvestMovePeriodic=CreateTrigger()
    call DisableTrigger(gg_trg_HarvestMovePeriodic)
    call TriggerRegisterTimerEventPeriodic(gg_trg_HarvestMovePeriodic, 0.02)
    call TriggerAddAction(gg_trg_HarvestMovePeriodic, function Trig_HarvestMovePeriodic_Actions)
endfunction

//===========================================================================
// Trigger: HopesEndPeriodic
//===========================================================================
function Trig_HopesEndPeriodic_Func003Func007C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 2) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_HopesEndPeriodic_Func003Func019C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 2) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_HopesEndPeriodic_Func003Func020Func003C takes nothing returns boolean
    if ( not ( udg_hopes_end_clockwise == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_HopesEndPeriodic_Func003C takes nothing returns boolean
    if ( not ( GetUnitStateSwap(UNIT_STATE_MANA, gg_unit_H013_0011) >= 9999.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_HopesEndPeriodic_Actions takes nothing returns nothing
    call SetUnitLifePercentBJ(gg_unit_H013_0011, ( GetUnitLifePercent(gg_unit_H013_0011) - 0.50 ))
    if ( Trig_HopesEndPeriodic_Func003C() ) then
        call RemoveLocation(udg_hopes_end_pos[GetForLoopIndexA()])
        call SetUnitAnimation(gg_unit_H013_0011, "attack")
        call SetUnitManaPercentBJ(udg_Boss[1], 0.00)
        set udg_tempReal=45.00
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=4
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            set udg_hopes_end_pos[GetForLoopIndexA()]=PolarProjectionBJ(udg_emilisma_pos, 3500.00, udg_tempReal)
            set udg_tempReal=( udg_tempReal + 90.00 )
            set bj_forLoopAIndex=bj_forLoopAIndex + 1
        endloop
        set udg_tempReal=0.00
        if ( Trig_HopesEndPeriodic_Func003Func007C() ) then
            call PlaySoundOnUnitBJ(gg_snd_BansheeYesAttack2, 100, gg_unit_H013_0011)
        else
            call PlaySoundOnUnitBJ(gg_snd_BansheeYesAttack3, 100, gg_unit_H013_0011)
        endif
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=4
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            call AddLightningLoc("AFOD", udg_emilisma_pos, udg_hopes_end_pos[GetForLoopIndexA()])
            set udg_hopes_end_lightning[GetForLoopIndexA()]=GetLastCreatedLightningBJ()
            set bj_forLoopAIndex=bj_forLoopAIndex + 1
        endloop
        call StopSoundBJ(udg_hopes_end_sound, false)
        call PlaySoundAtPointBJ(gg_snd_beam_sound, 100, udg_emilisma_pos, 0)
        set udg_hopes_end_sound=GetLastPlayedSound()
        call TriggerSleepAction(0.50)
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=4
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            call DestroyLightningBJ(udg_hopes_end_lightning[GetForLoopIndexA()])
            call AddLightningLoc("AFOD", udg_emilisma_pos, udg_hopes_end_pos[GetForLoopIndexA()])
            set udg_hopes_end_lightning[GetForLoopIndexA()]=GetLastCreatedLightningBJ()
            set bj_forLoopAIndex=bj_forLoopAIndex + 1
        endloop
        call StopSoundBJ(udg_hopes_end_sound, false)
        call PlaySoundAtPointBJ(gg_snd_beam_sound, 100, udg_emilisma_pos, 0)
        set udg_hopes_end_sound=GetLastPlayedSound()
        call TriggerSleepAction(0.50)
        call SetUnitAnimation(gg_unit_H013_0011, "alive")
        if ( Trig_HopesEndPeriodic_Func003Func019C() ) then
            set udg_hopes_end_clockwise=true
        else
            set udg_hopes_end_clockwise=false
        endif
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=4
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            set udg_hopes_end_angle[GetForLoopIndexA()]=0.00
            call DestroyLightningBJ(udg_hopes_end_lightning[GetForLoopIndexA()])
            if ( Trig_HopesEndPeriodic_Func003Func020Func003C() ) then
                set udg_hopes_end_angle[GetForLoopIndexA()]=( AngleBetweenPoints(udg_emilisma_pos, udg_hopes_end_pos[GetForLoopIndexA()]) + 135.00 )
            else
                set udg_hopes_end_angle[GetForLoopIndexA()]=( AngleBetweenPoints(udg_emilisma_pos, udg_hopes_end_pos[GetForLoopIndexA()]) - 135.00 )
            endif
            set bj_forLoopAIndex=bj_forLoopAIndex + 1
        endloop
        call EnableTrigger(gg_trg_HopesEndMovePeriodic)
        call StartTimerBJ(udg_hopes_end_timer, false, 6.00)
        call StopSoundBJ(udg_hopes_end_sound, false)
        call PlaySoundAtPointBJ(gg_snd_beam_sound, 100, udg_emilisma_pos, 0)
        set udg_hopes_end_sound=GetLastPlayedSound()
    else
    endif
endfunction

//===========================================================================
function InitTrig_HopesEndPeriodic takes nothing returns nothing
    set gg_trg_HopesEndPeriodic=CreateTrigger()
    call DisableTrigger(gg_trg_HopesEndPeriodic)
    call TriggerRegisterTimerEventPeriodic(gg_trg_HopesEndPeriodic, 0.50)
    call TriggerAddAction(gg_trg_HopesEndPeriodic, function Trig_HopesEndPeriodic_Actions)
endfunction

//===========================================================================
// Trigger: HopesEndMovePeriodic
//===========================================================================
function Trig_HopesEndMovePeriodic_Func002Func001C takes nothing returns boolean
    if ( not ( udg_hopes_end_clockwise == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_HopesEndMovePeriodic_Func002Func008Func003Func001C takes nothing returns boolean
    if ( not ( IsUnitEnemy(GetEnumUnit(), Player(19)) == true ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( BlzIsUnitInvulnerable(GetEnumUnit()) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_HopesEndMovePeriodic_Func002Func008Func003A takes nothing returns nothing
    if ( Trig_HopesEndMovePeriodic_Func002Func008Func003Func001C() ) then
        call KillUnit(GetEnumUnit())
    else
    endif
endfunction

function Trig_HopesEndMovePeriodic_Actions takes nothing returns nothing
    set udg_tempReal=0.00
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=4
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        if ( Trig_HopesEndMovePeriodic_Func002Func001C() ) then
            set udg_tempReal=( AngleBetweenPoints(udg_emilisma_pos, udg_hopes_end_pos[GetForLoopIndexA()]) + 135.00 )
        else
            set udg_tempReal=( AngleBetweenPoints(udg_emilisma_pos, udg_hopes_end_pos[GetForLoopIndexA()]) - 135.00 )
        endif
        set udg_tempLoc=udg_hopes_end_pos[GetForLoopIndexA()]
        set udg_hopes_end_pos[GetForLoopIndexA()]=PolarProjectionBJ(udg_tempLoc, 80.00, udg_hopes_end_angle[GetForLoopIndexA()])
        call DestroyLightningBJ(udg_hopes_end_lightning[GetForLoopIndexA()])
        call AddLightningLoc("AFOD", udg_emilisma_pos, udg_hopes_end_pos[GetForLoopIndexA()])
        set udg_hopes_end_lightning[GetForLoopIndexA()]=GetLastCreatedLightningBJ()
        call RemoveLocation(udg_tempLoc)
        set bj_forLoopBIndex=1
        set bj_forLoopBIndexEnd=60
        loop
            exitwhen bj_forLoopBIndex > bj_forLoopBIndexEnd
            set udg_tempInt=( udg_tempInt + 40 )
            set udg_tempLoc=PolarProjectionBJ(udg_emilisma_pos, I2R(udg_tempInt), AngleBetweenPoints(udg_emilisma_pos, udg_hopes_end_pos[GetForLoopIndexA()]))
            call ForGroupBJ(GetUnitsInRangeOfLocAll(50.00, udg_tempLoc), function Trig_HopesEndMovePeriodic_Func002Func008Func003A)
            call RemoveLocation(udg_tempLoc)
            set bj_forLoopBIndex=bj_forLoopBIndex + 1
        endloop
        set udg_tempInt=0
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    set udg_tempReal=0.00
endfunction

//===========================================================================
function InitTrig_HopesEndMovePeriodic takes nothing returns nothing
    set gg_trg_HopesEndMovePeriodic=CreateTrigger()
    call DisableTrigger(gg_trg_HopesEndMovePeriodic)
    call TriggerRegisterTimerEventPeriodic(gg_trg_HopesEndMovePeriodic, 0.10)
    call TriggerAddAction(gg_trg_HopesEndMovePeriodic, function Trig_HopesEndMovePeriodic_Actions)
endfunction

