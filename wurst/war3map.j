//===========================================================================
// Trigger: OneManArmy
//===========================================================================
function Trig_OneManArmy_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A02O' ) ) then
        return false
    endif
    return true
endfunction

function Trig_OneManArmy_Func009Func001C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 100) <= 50 ) ) then
        return false
    endif
    return true
endfunction

function Trig_OneManArmy_Func009C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 100) <= 35 ) ) then
        return false
    endif
    return true
endfunction

function Trig_OneManArmy_Func019C takes nothing returns boolean
    if ( not ( udg_musicOn == 0 ) ) then
        return false
    endif
    if ( not ( udg_BossfightMainIsOn == 0 ) ) then
        return false
    endif
    if ( not ( GetRandomInt(1, 100) <= 50 ) ) then
        return false
    endif
    return true
endfunction

function Trig_OneManArmy_Actions takes nothing returns nothing
    set udg_TrueFormStrength=GetHeroStatBJ(bj_HEROSTAT_STR, gg_unit_E001_0061, false)
    set udg_TrueFormLvl=GetUnitAbilityLevelSwapped('A02O', GetTriggerUnit())
    set udg_morddigan_previous_dmg=BlzGetUnitBaseDamage(GetTriggerUnit(), 0)
    set udg_HERO_DAMAGE_DEF_ALL[GetConvertedPlayerId(GetOwningPlayer(gg_unit_E001_0061))]=( udg_HERO_DAMAGE_DEF_ALL[GetConvertedPlayerId(GetOwningPlayer(gg_unit_E001_0061))] + ( GetUnitAbilityLevelSwapped('A02O', GetTriggerUnit()) * 15 ) )
    call SetPlayerAbilityAvailableBJ(false, 'A02O', GetOwningPlayer(gg_unit_E001_0061))
    call DestroyEffectBJ(udg_OneManEff)
    call DestroyEffectBJ(udg_OneManEff_Copy)
    call DestroyEffectBJ(udg_OneManEff_Copy_2)
    if ( Trig_OneManArmy_Func009C() ) then
        if ( Trig_OneManArmy_Func009Func001C() ) then
            call PlaySoundOnUnitBJ(gg_snd_Legcom_econ_rare_01_rump3, 100.00, gg_unit_E001_0061)
        else
            call PlaySoundOnUnitBJ(gg_snd_Legcom_fastres_01_rump3, 100.00, gg_unit_E001_0061)
        endif
    else
        call PlaySoundOnUnitBJ(gg_snd_Vo_legion_commander_legcom_dem_laugh_06_mp3__AudioTrimmer_com_u, 100.00, gg_unit_E001_0061)
    endif
    call AddSpecialEffectLocBJ(GetUnitLoc(GetTriggerUnit()), "Objects\\Spawnmodels\\Other\\NeutralBuildingExplosion\\NeutralBuildingExplosion.mdl")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call AddSpecialEffectTargetUnitBJ("chest", GetTriggerUnit(), "Environment\\SmallBuildingFire\\SmallBuildingFire2.mdl")
    set udg_OneManEff=GetLastCreatedEffectBJ()
    call AddSpecialEffectTargetUnitBJ("head", GetTriggerUnit(), "Environment\\SmallBuildingFire\\SmallBuildingFire2.mdl")
    set udg_OneManEff_Copy=GetLastCreatedEffectBJ()
    call AddSpecialEffectTargetUnitBJ("weapon", GetTriggerUnit(), "Environment\\SmallBuildingFire\\SmallBuildingFire2.mdl")
    set udg_OneManEff_Copy_2=GetLastCreatedEffectBJ()
    call EnableTrigger(gg_trg_OneManPeriodic)
    if ( Trig_OneManArmy_Func019C() ) then
        call PlayThematicMusicBJ("MorddUlti.mp3")
        call SetMusicVolumeBJ(100.00)
        set udg_musicOn=1
        call StartTimerBJ(udg_MusicTimer, false, 67.70)
    else
    endif
endfunction

//===========================================================================
function InitTrig_OneManArmy takes nothing returns nothing
    set gg_trg_OneManArmy=CreateTrigger()
    call TriggerRegisterUnitEvent(gg_trg_OneManArmy, gg_unit_E001_0061, EVENT_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_OneManArmy, Condition(function Trig_OneManArmy_Conditions))
    call TriggerAddAction(gg_trg_OneManArmy, function Trig_OneManArmy_Actions)
endfunction

//===========================================================================
// Trigger: OneManPeriodic
//===========================================================================
function Trig_OneManPeriodic_Conditions takes nothing returns boolean
    if ( not ( UnitHasBuffBJ(gg_unit_E001_0061, 'B00R') == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_OneManPeriodic_Actions takes nothing returns nothing
    call SetPlayerAbilityAvailableBJ(true, 'A02O', GetOwningPlayer(gg_unit_E001_0061))
    call DestroyEffectBJ(udg_OneManEff)
    call DestroyEffectBJ(udg_OneManEff_Copy)
    call DestroyEffectBJ(udg_OneManEff_Copy_2)
    call ModifyHeroStat(bj_HEROSTAT_STR, gg_unit_E001_0061, bj_MODIFYMETHOD_SET, udg_TrueFormStrength)
    set udg_HERO_DAMAGE_DEF_ALL[GetConvertedPlayerId(GetOwningPlayer(gg_unit_E001_0061))]=( udg_HERO_DAMAGE_DEF_ALL[GetConvertedPlayerId(GetOwningPlayer(gg_unit_E001_0061))] - ( udg_TrueFormLvl * 15 ) )
    call DisableTrigger(GetTriggeringTrigger())
endfunction

//===========================================================================
function InitTrig_OneManPeriodic takes nothing returns nothing
    set gg_trg_OneManPeriodic=CreateTrigger()
    call DisableTrigger(gg_trg_OneManPeriodic)
    call TriggerRegisterTimerEventPeriodic(gg_trg_OneManPeriodic, 0.50)
    call TriggerAddCondition(gg_trg_OneManPeriodic, Condition(function Trig_OneManPeriodic_Conditions))
    call TriggerAddAction(gg_trg_OneManPeriodic, function Trig_OneManPeriodic_Actions)
endfunction

//===========================================================================
// Trigger: Duel
//===========================================================================
function Trig_Duel_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A02J' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Duel_Func001C takes nothing returns boolean
    if ( not ( UnitHasBuffBJ(GetTriggerUnit(), 'B00R') == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_Duel_Func033C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 100) > 50 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Duel_Actions takes nothing returns nothing
    if ( Trig_Duel_Func001C() ) then
        set udg_morddigan_previous_dmg=BlzGetUnitBaseDamage(GetTriggerUnit(), 0)
    else
    endif
    set udg_DuelT=GetSpellTargetUnit()
    if IsUnitType(udg_DuelT, UNIT_TYPE_GIANT) then
    call SetUnitPositionLoc(GetSpellTargetUnit(), PolarProjectionBJ(GetUnitLoc(GetTriggerUnit()), 100.00, GetUnitFacing(GetTriggerUnit())))
    call PlaySoundOnUnitBJ(gg_snd_soundBlades_of_Voth_Domosh_Duel_mp3, 75.00, gg_unit_E001_0061)
    set udg_DuelSound=GetLastPlayedSound()
    set udg_DuelC=GetTriggerUnit()
    call AddSpecialEffectLocBJ(PolarProjectionBJ(GetUnitLoc(GetTriggerUnit()), 60.00, GetUnitFacing(gg_unit_E001_0061)), "war3mapImported\\DuelFXFinal.mdx")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 1.50)
    call BlzSetSpecialEffectColorByPlayer(GetLastCreatedEffectBJ(), Player(16))
    call DestroyEffectBJ(udg_DuelEff)
    set udg_DuelEff=GetLastCreatedEffectBJ()
    call EnableTrigger(gg_trg_DuelC)
    call EnableTrigger(gg_trg_DuelT)
    call IssueTargetOrderBJ(GetSpellTargetUnit(), "attack", GetTriggerUnit())
    set udg_tempLoc=GetUnitLoc(GetTriggerUnit())
    set udg_tempLoc2=GetUnitLoc(GetSpellTargetUnit())
    call CreateNUnitsAtLoc(1, 'h00I', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc, bj_UNIT_FACING)
    call IssueTargetOrderBJ(GetLastCreatedUnit(), "slow", GetTriggerUnit())
    call UnitApplyTimedLifeBJ(2.00, 'BTLF', GetLastCreatedUnit())
    call CreateNUnitsAtLoc(1, 'h00I', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc, bj_UNIT_FACING)
    call IssueTargetOrderBJ(GetLastCreatedUnit(), "slow", GetSpellTargetUnit())
    call UnitApplyTimedLifeBJ(2.00, 'BTLF', GetLastCreatedUnit())
    call CreateNUnitsAtLocFacingLocBJ(1, 'h000', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc, udg_tempLoc)
    set udg_tempUnit=GetLastCreatedUnit()
    call IssueTargetOrderBJ(GetLastCreatedUnit(), "soulburn", udg_DuelC)
    call CreateNUnitsAtLocFacingLocBJ(1, 'h000', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc2, udg_tempLoc2)
    set udg_tempUnit2=GetLastCreatedUnit()
    call IssueTargetOrderBJ(GetLastCreatedUnit(), "soulburn", udg_DuelT)
    call IssueTargetOrderBJ(udg_DuelC, "attack", udg_DuelT)
    call RemoveLocation(udg_tempLoc)
    call RemoveLocation(udg_tempLoc2)
    if ( Trig_Duel_Func033C() ) then
        call PlaySoundOnUnitBJ(gg_snd_Legcom_duelhero_05_rump3, 100.00, gg_unit_E001_0061)
    else
        call PlaySoundOnUnitBJ(gg_snd_Legcom_duel_05_rump3, 100.00, gg_unit_E001_0061)
    endif
    call TriggerExecute(gg_trg_DuelEff)
    call TriggerSleepAction(0.20)
    call EnableTrigger(gg_trg_DuelTimer)
    call TriggerSleepAction(2.00)
    call RemoveUnit(udg_tempUnit)
    call RemoveUnit(udg_tempUnit2)
    else
    call IssueImmediateOrderBJ(GetTriggerUnit(), "stop")
    endif
endfunction

