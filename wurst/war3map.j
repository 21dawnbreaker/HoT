    if ( ( GetItemTypeId(GetManipulatedItem()) == 'I02W' ) ) then
        return true
    endif
    if ( ( GetItemTypeId(GetManipulatedItem()) == 'I00D' ) ) then
        return true
    endif
    if ( ( GetItemTypeId(GetManipulatedItem()) == 'I04F' ) ) then
        return true
