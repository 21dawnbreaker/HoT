    if ( not ( GetSpellAbilityId() == 'A0GG' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Satiety_Actions takes nothing returns nothing
    set udg_tempLoc2=GetUnitLoc(GetTriggerUnit())
    set udg_tempLoc=PolarProjectionBJ(GetUnitLoc(GetTriggerUnit()), 100.00, ( GetUnitFacing(GetTriggerUnit()) + 90.00 ))
    call CreateNUnitsAtLoc(1, 'h01R', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc, bj_UNIT_FACING)
    call UnitApplyTimedLifeBJ(1.00, 'BTLF', GetLastCreatedUnit())
    set udg_tempUnit=GetLastCreatedUnit()
    call CreateNUnitsAtLoc(1, 'n012', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc2, GetUnitFacing(GetTriggerUnit()))
    set udg_SatietyU=GetLastCreatedUnit()
    call SetUnitPathing(udg_SatietyU, false)
    set udg_KBA_Caster=udg_tempUnit
    set udg_KBA_TargetUnit=GetLastCreatedUnit()
    set udg_KBA_StartingPosition=GetUnitLoc(udg_tempUnit)
    set udg_KBA_Level=1
    set udg_KBA_Speed=20.00
    set udg_KBA_DistancePerLevel=200.00
    set udg_KBA_SpecialEffects[1]=""
    set udg_KBA_SpecialEffects[2]=""
