    if ( not ( UnitHasBuffBJ(udg_CBtarget, 'B00F') == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_CBdmg_Func006C takes nothing returns boolean
    if ( not ( IsUnitInGroup(udg_CBtarget, udg_not_knockbackable_UG) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_CBdmg_Actions takes nothing returns nothing
    set udg_CBi2=GetHeroStatBJ(bj_HEROSTAT_INT, udg_CBcaster, true)
    call UnitDamageTargetBJ(udg_CBcaster, udg_CBtarget, ( ( 100.00 * I2R(udg_CBlevel) ) + ( 5.00 * I2R(GetHeroStatBJ(bj_HEROSTAT_INT, udg_CBcaster, true)) ) ), ATTACK_TYPE_CHAOS, DAMAGE_TYPE_NORMAL)
    call AddSpecialEffectTargetUnitBJ("origin", udg_CBtarget, "Objects\\Spawnmodels\\Undead\\UDeathSmall\\UDeathSmall.mdl")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    if ( Trig_CBdmg_Func006C() ) then
        set udg_KBA_Caster=udg_CBcaster
        set udg_KBA_TargetUnit=udg_CBtarget
        set udg_KBA_Level=1
        set udg_KBA_StartingPosition=GetUnitLoc(udg_CBcaster)
        set udg_KBA_Speed=7.00
        set udg_KBA_DistancePerLevel=200.00
        set udg_KBA_SpecialEffects[1]="Abilities\\Spells\\Human\\FlakCannons\\FlakTarget.mdl"
        set udg_KBA_SpecialEffects[2]="Abilities\\Weapons\\AncientProtectorMissile\\AncientProtectorMissile.mdl"
        set udg_KBA_DestroyTrees=false
        call ConditionalTriggerExecute(gg_trg_Cast_A_Knockback)
    else
    endif
    call DisableTrigger(gg_trg_CBdmg)
endfunction

