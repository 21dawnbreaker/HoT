function Trig_DeathAndDecay_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A0GS' ) ) then
        return false
    endif
    return true
endfunction

function Trig_DeathAndDecay_Func003Func001C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 2) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_DeathAndDecay_Func003C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 2) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_DeathAndDecay_Actions takes nothing returns nothing
    call AddSpecialEffectTargetUnitBJ("overhead", GetSpellTargetUnit(), "Abilities\\Spells\\Other\\TalkToMe\\TalkToMe.mdl")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    if ( Trig_DeathAndDecay_Func003C() ) then
        call PlaySoundOnUnitBJ(gg_snd_NecromancerYesAttack3, 100, GetTriggerUnit())
    else
        if ( Trig_DeathAndDecay_Func003Func001C() ) then
            call PlaySoundOnUnitBJ(gg_snd_NecromancerPissed5, 100, GetTriggerUnit())
        else
            call PlaySoundOnUnitBJ(gg_snd_NecromancerPissed1, 100, GetTriggerUnit())
        endif
    endif
    set udg_CurseOfDecayT=GetSpellTargetUnit()
    call TriggerSleepAction(5.00)
    set udg_tempLoc=GetUnitLoc(udg_CurseOfDecayT)
    call CreateNUnitsAtLoc(1, 'h021', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc, bj_UNIT_FACING)
    call UnitApplyTimedLifeBJ(75.00, 'BTLF', GetLastCreatedUnit())
    call RemoveLocation(udg_tempLoc)
    set udg_CurseOfDecayT=null
endfunction

