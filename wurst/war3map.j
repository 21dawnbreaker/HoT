//===========================================================================
// Trigger: tL29 Copy
//===========================================================================
function Trig_tL29_Copy_Conditions takes nothing returns boolean
    if ( not ( IsUnitInGroup(GetTriggerUnit(), udg_TerrorFromTheDeepUG) == true ) ) then
        return false
    endif
    if ( not ( GetRandomInt(1, 100) <= 20 ) ) then
        return false
    endif
    return true
endfunction

function Trig_tL29_Copy_Func002001003001 takes nothing returns boolean
    return ( IsUnitEnemy(GetFilterUnit(), GetOwningPlayer(GetTriggerUnit())) == true )
endfunction

function Trig_tL29_Copy_Func002001003002 takes nothing returns boolean
    return ( IsUnitAliveBJ(GetFilterUnit()) == true )
endfunction

function Trig_tL29_Copy_Func002001003 takes nothing returns boolean
    return GetBooleanAnd((IsUnitEnemy(GetFilterUnit(), GetOwningPlayer(GetTriggerUnit())) == true), (IsUnitAliveBJ(GetFilterUnit()) == true)) // INLINED!!
endfunction

function Trig_tL29_Copy_Func002Func001C takes nothing returns boolean
    if ( not ( udg_TerrorFromTheDeepInt == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_tL29_Copy_Func002A takes nothing returns nothing
    if ( Trig_tL29_Copy_Func002Func001C() ) then
        set udg_TerrorFromTheDeepInt=1
        call RemoveLocation(udg_tempLoc)
        set udg_tempLoc=GetUnitLoc(GetEnumUnit())
        call CreateNUnitsAtLoc(1, 'n00J', GetOwningPlayer(GetTriggerUnit()), PolarProjectionBJ(udg_tempLoc, 250.00, GetRandomDirectionDeg()), bj_UNIT_FACING)
        call UnitApplyTimedLifeBJ(( 8.00 * I2R(GetUnitAbilityLevelSwapped('A0A7', GetTriggerUnit())) ), 'BTLF', GetLastCreatedUnit())
        call BlzSetUnitMaxHP(GetLastCreatedUnit(), ( 100 + ( BlzGetUnitMaxHP(GetTriggerUnit()) / 4 ) ))
        call BlzSetUnitBaseDamage(GetLastCreatedUnit(), ( BlzGetUnitBaseDamage(GetTriggerUnit(), 0) / 2 ), 0)
        call RemoveLocation(udg_tempLoc)
    else
    endif
endfunction

function Trig_tL29_Copy_Actions takes nothing returns nothing
    set udg_tempLoc=GetUnitLoc(GetTriggerUnit())
    call ForGroupBJ(GetUnitsInRangeOfLocMatching(900.00, udg_tempLoc, Condition(function Trig_tL29_Copy_Func002001003)), function Trig_tL29_Copy_Func002A)
    set udg_TerrorFromTheDeepInt=0
endfunction

//===========================================================================
function InitTrig_tL29_Copy takes nothing returns nothing
    set gg_trg_tL29_Copy=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_tL29_Copy, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_tL29_Copy, Condition(function Trig_tL29_Copy_Conditions))
    call TriggerAddAction(gg_trg_tL29_Copy, function Trig_tL29_Copy_Actions)
endfunction

