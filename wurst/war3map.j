            call UnitDamageTargetBJ(udg_PyroC, udg_PyroT, ( ( 200.00 * I2R(GetUnitAbilityLevelSwapped('A0DR', udg_PyroC)) ) + ( ( 4.00 * ( 1 * I2R(GetUnitAbilityLevelSwapped('A0DR', udg_PyroC)) ) ) * I2R(GetHeroStatBJ(bj_HEROSTAT_INT, udg_PyroC, true)) ) ), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_NORMAL)
            call UnitDamageTargetBJ(udg_PyroC, udg_PyroT, ( ( 200.00 * I2R(GetUnitAbilityLevelSwapped('A0DR', udg_PyroC)) ) + ( ( 4.00 * ( 1 * I2R(GetUnitAbilityLevelSwapped('A0DR', udg_PyroC)) ) ) * I2R(GetHeroStatBJ(bj_HEROSTAT_INT, udg_PyroC, true)) ) ), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_NORMAL)
