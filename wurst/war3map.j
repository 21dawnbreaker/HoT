//===========================================================================
// Trigger: ImpalerTimer
//===========================================================================
function Trig_ImpalerTimer_Func002Func001Func001Func003C takes nothing returns boolean
    if ( not ( IsUnitInGroup(GetEnumUnit(), udg_MinionsUG) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_ImpalerTimer_Func002Func001Func001C takes nothing returns boolean
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(gg_unit_U006_0283)) == true ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( BlzIsUnitInvulnerable(GetEnumUnit()) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_ImpalerTimer_Func002Func001A takes nothing returns nothing
    if ( Trig_ImpalerTimer_Func002Func001Func001C() ) then
        call AddSpecialEffectTargetUnitBJ("chest", GetEnumUnit(), "Objects\\Spawnmodels\\Orc\\Orcblood\\BattrollBlood.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        if ( Trig_ImpalerTimer_Func002Func001Func001Func003C() ) then
            call UnitDamageTargetBJ(gg_unit_U006_0283, GetEnumUnit(), ( GetUnitStateSwap(UNIT_STATE_MAX_LIFE, GetEnumUnit()) * 1.00 ), ATTACK_TYPE_MELEE, DAMAGE_TYPE_NORMAL)
            call SetUnitLifePercentBJ(gg_unit_U006_0283, ( GetUnitLifePercent(gg_unit_U006_0283) + 1.00 ))
        else
            call UnitDamageTargetBJ(gg_unit_U006_0283, GetEnumUnit(), ( GetUnitStateSwap(UNIT_STATE_MAX_LIFE, GetEnumUnit()) * 0.15 ), ATTACK_TYPE_MELEE, DAMAGE_TYPE_NORMAL)
        endif
    else
    endif
endfunction

function Trig_ImpalerTimer_Actions takes nothing returns nothing
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=8
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        call AddSpecialEffectLocBJ(udg_ImpalerDamage[GetForLoopIndexA()], "Abilities\\Spells\\Undead\\Impale\\ImpaleHitTarget.mdl")
        call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 2.00)
        call BlzSetSpecialEffectYaw(GetLastCreatedEffectBJ(), Deg2Rad(udg_ImpalerReal[GetForLoopIndexA()]))
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    set bj_forLoopBIndex=1
    set bj_forLoopBIndexEnd=8
    loop
        exitwhen bj_forLoopBIndex > bj_forLoopBIndexEnd
        call ForGroupBJ(GetUnitsInRangeOfLocAll(100.00, udg_ImpalerDamage[GetForLoopIndexB()]), function Trig_ImpalerTimer_Func002Func001A)
        call DestroyGroup(GetLastCreatedGroup())
        set bj_forLoopBIndex=bj_forLoopBIndex + 1
    endloop
endfunction

