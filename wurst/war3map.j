    if ( not ( GetOwningPlayer(GetSpellTargetUnit()) != Player(12) ) ) then
        return false
    endif
    if ( not ( GetOwningPlayer(GetSpellTargetUnit()) != Player(13) ) ) then
        return false
    endif
    if ( not ( GetOwningPlayer(GetSpellTargetUnit()) != Player(21) ) ) then
        return false
    endif
    return true
endfunction

function Trig_FalseProphet_Actions takes nothing returns nothing
    if ( Trig_FalseProphet_Func001C() ) then
        call IssueImmediateOrderBJ(GetTriggerUnit(), "stop")
    else
        set udg_FalseProphetT=GetSpellTargetUnit()
        set udg_FalseProphetGold=( GetRandomInt(20, 80) + R2I(( I2R(GetHeroStatBJ(bj_HEROSTAT_INT, GetTriggerUnit(), true)) * 0.20 )) )
        call CreateNUnitsAtLoc(1, 'h00L', GetOwningPlayer(GetTriggerUnit()), GetUnitLoc(GetTriggerUnit()), bj_UNIT_FACING)
        call IssueTargetOrderBJ(GetLastCreatedUnit(), "innerfire", gg_unit_H00E_0060)
        call UnitApplyTimedLifeBJ(1.00, 'BTLF', GetLastCreatedUnit())
        call SetUnitFacingToFaceUnitTimed(udg_FalseProphetT, gg_unit_H00E_0060, 0)
        call PauseUnitBJ(true, GetSpellTargetUnit())
        if ( Trig_FalseProphet_Func001Func008C() ) then
            call CreateTextTagUnitBJ("TRIGSTR_010", GetTriggerUnit(), 0, 10, 100, 100, 100, 0)
            call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
            call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 3.00)
            call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
            call TriggerSleepAction(4.50)
            if ( Trig_FalseProphet_Func001Func008Func008C() ) then
                call CreateTextTagUnitBJ("TRIGSTR_011", gg_unit_H00E_0060, 0, 10, 100, 100, 100, 0)
                call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
                call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 3.00)
                call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
                call TriggerSleepAction(3.00)
                if ( Trig_FalseProphet_Func001Func008Func008Func009C() ) then
                    call CreateTextTagUnitBJ("TRIGSTR_012", GetTriggerUnit(), 0, 10, 100, 100, 100, 0)
                    call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
                    call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 5.00)
                    call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
                    call TriggerSleepAction(1.00)
                    call DisableTrigger(gg_trg_FalseProphetBuffCheck)
                    call CreateTextTagUnitBJ(( "+ " + I2S(udg_FalseProphetGold) ), gg_unit_H00E_0060, 0, 10, 100, 100, 0.00, 0)
                    call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
                    call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 4.00)
                    call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
                    call AdjustPlayerStateBJ(udg_FalseProphetGold, GetOwningPlayer(gg_unit_H00E_0060), PLAYER_STATE_RESOURCE_GOLD)
                    call PlaySoundOnUnitBJ(gg_snd_GoldSoundEff1, 100, gg_unit_H00E_0060)
                else
                endif
            else
            endif
        else
            if ( Trig_FalseProphet_Func001Func008Func001C() ) then
                call CreateTextTagUnitBJ("TRIGSTR_005", gg_unit_H00E_0060, 0, 10, 100, 100, 100, 0)
                call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
                call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 3.00)
                call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
                call TriggerSleepAction(4.50)
                if ( Trig_FalseProphet_Func001Func008Func001Func013C() ) then
                    call CreateTextTagUnitBJ("TRIGSTR_008", gg_unit_H00E_0060, 0, 10, 100, 100, 100, 0)
                    call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
                    call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 3.00)
                    call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
                    call TriggerSleepAction(3.00)
                    if ( Trig_FalseProphet_Func001Func008Func001Func013Func009C() ) then
                        call CreateTextTagUnitBJ("TRIGSTR_009", gg_unit_H00E_0060, 0, 10, 100, 100, 100, 0)
                        call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
                        call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 5.00)
