    call TriggerRegisterPlayerEventLeave(gg_trg_Leave, Player(15))
    call TriggerRegisterPlayerEventLeave(gg_trg_Leave, Player(16))
    call TriggerRegisterPlayerEventLeave(gg_trg_Leave, Player(17))
    call TriggerRegisterPlayerEventLeave(gg_trg_Leave, Player(18))
    call TriggerRegisterPlayerEventLeave(gg_trg_Leave, Player(19))
    call TriggerRegisterPlayerEventLeave(gg_trg_Leave, Player(20))
    call TriggerRegisterPlayerEventLeave(gg_trg_Leave, Player(21))
    call TriggerRegisterPlayerEventLeave(gg_trg_Leave, Player(22))
    call TriggerRegisterPlayerEventLeave(gg_trg_Leave, Player(23))
