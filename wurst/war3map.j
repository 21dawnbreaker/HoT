//===========================================================================
// Trigger: Impaler
//===========================================================================
function Trig_Impaler_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A06W' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Impaler_Func019Func002C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 2) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Impaler_Func019C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 2) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Impaler_Func020C takes nothing returns boolean
    if ( not ( udg_DIFFICULTY == 3 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Impaler_Func025C takes nothing returns boolean
    if ( not ( IsUnitAliveBJ(gg_unit_U006_0283) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Impaler_Actions takes nothing returns nothing
    call PauseUnitBJ(true, GetTriggerUnit())
    call DisableTrigger(gg_trg_StrangulateTriggerDifficulty)
    set udg_tempLoc=PolarProjectionBJ(GetRectCenter(gg_rct_PlayableMapAreaLoc), GetRandomReal(0, 300.00), GetRandomDirectionDeg())
    call AddSpecialEffectLocBJ(udg_tempLoc, "Call of Dread Red.mdx")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call AddSpecialEffectTargetUnitBJ("chest", gg_unit_U006_0283, "Abilities\\Weapons\\AvengerMissile\\AvengerMissile.mdl")
    call SetUnitPositionLocFacingBJ(GetTriggerUnit(), udg_tempLoc, GetRandomDirectionDeg())
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call RemoveLocation(udg_tempLoc)
    call SetUnitAnimation(gg_unit_U006_0283, "slam")
    set udg_ImpalerInt=16
    set udg_ImpalerStartLoc=GetUnitLoc(GetTriggerUnit())
    set udg_ImpalerReal[GetForLoopIndexA()]=( udg_ImpalerReal[GetForLoopIndexA()] + 45.00 )
    set udg_ImpalerDistance=0.00
    set udg_ImpalerReal[9]=45.00
    call AddSpecialEffectLocBJ(udg_ImpalerStartLoc, "Call of Dread Red.mdx")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=8
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        set udg_ImpalerReal[GetForLoopIndexA()]=( 0.00 + ( udg_ImpalerReal[9] * I2R(GetForLoopIndexA()) ) )
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    if ( Trig_Impaler_Func019C() ) then
        call PlaySoundAtPointBJ(gg_snd_VarimathrasYesAttack3, 100, udg_ImpalerStartLoc, 0)
    else
        if ( Trig_Impaler_Func019Func002C() ) then
            call PlaySoundBJ(gg_snd_L06Balnazzar27)
        else
            call PlaySoundAtPointBJ(gg_snd_VarimathrasPissed6, 100, udg_ImpalerStartLoc, 0)
        endif
    endif
    if ( Trig_Impaler_Func020C() ) then
        call EnableTrigger(gg_trg_ImpalerPeriodicNightmare)
    else
        call EnableTrigger(gg_trg_ImpalerPeriodic)
    endif
    call TriggerSleepAction(1.90)
    call SetUnitAnimation(gg_unit_U006_0283, "ready")
    call TriggerSleepAction(1.00)
    call PauseUnitBJ(false, GetTriggerUnit())
    if ( Trig_Impaler_Func025C() ) then
        call EnableTrigger(gg_trg_StrangulateTriggerDifficulty)
    else
    endif
endfunction

