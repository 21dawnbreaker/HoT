    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_RandomImpalesPeriodic_Func014A takes nothing returns nothing
    if ( Trig_RandomImpalesPeriodic_Func014Func001C() ) then
        if ( Trig_RandomImpalesPeriodic_Func014Func001Func001C() ) then
            call UnitDamageTargetBJ(gg_unit_U006_0283, GetEnumUnit(), ( 3.00 * I2R(BlzGetUnitBaseDamage(gg_unit_U006_0283, 0)) ), ATTACK_TYPE_MELEE, DAMAGE_TYPE_NORMAL)
            call SetUnitLifePercentBJ(gg_unit_U006_0283, ( GetUnitLifePercent(gg_unit_U006_0283) + 5.00 ))
        else
            call UnitDamageTargetBJ(gg_unit_U006_0283, GetEnumUnit(), ( 0.10 * ( 3.00 * I2R(BlzGetUnitBaseDamage(gg_unit_U006_0283, 0)) ) ), ATTACK_TYPE_MELEE, DAMAGE_TYPE_NORMAL)
        endif
        call AddSpecialEffectTargetUnitBJ("chest", GetEnumUnit(), "Objects\\Spawnmodels\\Orc\\Orcblood\\BattrollBlood.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
    else
    endif
endfunction

function Trig_RandomImpalesPeriodic_Actions takes nothing returns nothing
    set udg_RandomImpalesInt=( udg_RandomImpalesInt + 1 )
    if ( Trig_RandomImpalesPeriodic_Func003C() ) then
        set udg_RandomImpalesInt=1
    else
    endif
    set udg_RandomImpaleLoc[udg_RandomImpalesInt]=PolarProjectionBJ(GetUnitLoc(GroupPickRandomUnit(GetUnitsInRectMatching(gg_rct_MainBossLoc, Condition(function Trig_RandomImpalesPeriodic_Func004002001001001002)))), GetRandomReal(0, 500.00), GetRandomDirectionDeg())
    call AddSpecialEffectLocBJ(udg_RandomImpaleLoc[udg_RandomImpalesInt], "Skill_Indicator_Circle.mdx")
    set udg_RandomImpaleEff1[udg_RandomImpalesInt]=GetLastCreatedEffectBJ()
    call TriggerSleepAction(1.50)
    call DestroyEffectBJ(udg_RandomImpaleEff1[udg_RandomImpalesInt])
    call AddSpecialEffectLocBJ(udg_RandomImpaleLoc[udg_RandomImpalesInt], "Abilities\\Spells\\Undead\\Impale\\ImpaleHitTarget.mdl")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 2.00)
    call BlzSetSpecialEffectYaw(GetLastCreatedEffectBJ(), Deg2Rad(GetRandomDirectionDeg()))
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call ForGroupBJ(GetUnitsInRangeOfLocAll(100.00, udg_RandomImpaleLoc[udg_RandomImpalesInt]), function Trig_RandomImpalesPeriodic_Func014A)
    call RemoveLocation(udg_RandomImpaleLoc[udg_RandomImpalesInt])
endfunction

