    else
    endif
endfunction

function Trig_Annihilation_Actions takes nothing returns nothing
    set udg_AnnihilationPos=GetSpellTargetLoc()
    call TriggerSleepAction(1.00)
    call AddSpecialEffectLocBJ(PolarProjectionBJ(udg_AnnihilationPos, 50.00, 270.00), "Voidfall Major.mdx")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 1.50)
    set udg_AnnihilationEff=GetLastCreatedEffectBJ()
    call TriggerSleepAction(1.00)
    call DestroyEffectBJ(udg_AnnihilationEff)
    call ForGroupBJ(GetUnitsInRangeOfLocAll(250.00, udg_AnnihilationPos), function Trig_Annihilation_Func008A)
    call TriggerSleepAction(1.00)
    call AddSpecialEffectLocBJ(PolarProjectionBJ(udg_AnnihilationPos, 50.00, 270.00), "Voidfall Major.mdx")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 1.50)
    set udg_AnnihilationEff=GetLastCreatedEffectBJ()
    call TriggerSleepAction(1.00)
    call DestroyEffectBJ(udg_AnnihilationEff)
    call ForGroupBJ(GetUnitsInRangeOfLocAll(250.00, udg_AnnihilationPos), function Trig_Annihilation_Func015A)
    call TriggerSleepAction(1.00)
    call AddSpecialEffectLocBJ(PolarProjectionBJ(udg_AnnihilationPos, 50.00, 270.00), "Voidfall Major.mdx")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 1.50)
    set udg_AnnihilationEff=GetLastCreatedEffectBJ()
