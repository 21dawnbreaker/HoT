function Trig_FrostExplosion_Conditions takes nothing returns boolean
    if ( not ( IsUnitInGroup(GetTriggerUnit(), udg_frozen_UG) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_FrostExplosion_Actions takes nothing returns nothing
    set udg_tempLoc=GetUnitLoc(GetTriggerUnit())
    set udg_tempZ=BlzGetLocalUnitZ(GetTriggerUnit())
    call AddSpecialEffectLocBJ(udg_tempLoc, "FrostOrb.mdx")
    call BlzSetSpecialEffectZ(GetLastCreatedEffectBJ(), ( udg_tempZ + 30.00 ))
    call RemoveUnit(GetTriggerUnit())
    call PlaySoundAtPointBJ(gg_snd_diablo2shatter2, 100, udg_tempLoc, udg_tempZ)
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call RemoveLocation(udg_tempLoc)
    set udg_tempZ=0.00
endfunction

