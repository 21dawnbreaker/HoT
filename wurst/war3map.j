//===========================================================================
// Trigger: Vanguard
//===========================================================================
function Trig_Vanguard_Conditions takes nothing returns boolean
    if ( not ( UnitHasBuffBJ(GetTriggerUnit(), 'B003') != true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Vanguard_Func001C takes nothing returns boolean
    if ( not ( IsUnitAliveBJ(GetTriggerUnit()) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Vanguard_Actions takes nothing returns nothing
    if ( Trig_Vanguard_Func001C() ) then
        call TriggerSleepAction(0.01)
        call AddSpecialEffectTargetUnitBJ("origin", GetTriggerUnit(), "Abilities\\Spells\\NightElf\\BattleRoar\\RoarCaster.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call SetUnitLifePercentBJ(GetTriggerUnit(), ( GetUnitLifePercent(GetTriggerUnit()) + 35.00 ))
        call SetUnitManaBJ(GetTriggerUnit(), ( GetUnitStateSwap(UNIT_STATE_MANA, GetTriggerUnit()) - 50.00 ))
        call CreateNUnitsAtLoc(1, 'h00F', Player(PLAYER_NEUTRAL_AGGRESSIVE), GetUnitLoc(GetTriggerUnit()), bj_UNIT_FACING)
        call UnitApplyTimedLifeBJ(1.00, 'BTLF', GetLastCreatedUnit())
        call IssueTargetOrderBJ(GetLastCreatedUnit(), "drunkenhaze", GetTriggerUnit())
    else
    endif
endfunction

//===========================================================================
function InitTrig_Vanguard takes nothing returns nothing
    set gg_trg_Vanguard=CreateTrigger()
    call TriggerRegisterUnitLifeEvent(gg_trg_Vanguard, gg_unit_H00A_0082, LESS_THAN_OR_EQUAL, ( I2R(BlzGetUnitMaxHP(gg_unit_H00A_0082)) * 0.50 ))
    call TriggerAddCondition(gg_trg_Vanguard, Condition(function Trig_Vanguard_Conditions))
    call TriggerAddAction(gg_trg_Vanguard, function Trig_Vanguard_Actions)
endfunction

