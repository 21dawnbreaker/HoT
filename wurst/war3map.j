    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( BlzIsUnitInvulnerable(GetEnumUnit()) == false ) ) then
        return false
    endif
    if ( not ( IsUnitInGroup(GetEnumUnit(), udg_ricardessa_damaged_UG) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_RicardessaMovePeriodic_Func005A takes nothing returns nothing
    if ( Trig_RicardessaMovePeriodic_Func005Func001C() ) then
        if ( Trig_RicardessaMovePeriodic_Func005Func001Func005C() ) then
            call UnitDamageTargetBJ(udg_ricardessa, GetEnumUnit(), ( I2R(udg_boss_attack_damage) * 40.00 ), ATTACK_TYPE_MELEE, DAMAGE_TYPE_NORMAL)
            call StopSoundBJ(udg_ricardessa_sound, false)
            call PlaySoundAtPointBJ(gg_snd_MetalHeavySliceFlesh2, 100, udg_tempLoc2, 0)
            set udg_ricardessa_sound=GetLastPlayedSound()
        else
            if ( Trig_RicardessaMovePeriodic_Func005Func001Func005Func001C() ) then
                call UnitDamageTargetBJ(udg_ricardessa, GetEnumUnit(), ( I2R(udg_boss_attack_damage) * 10.00 ), ATTACK_TYPE_MELEE, DAMAGE_TYPE_NORMAL)
                call PlaySoundAtPointBJ(gg_snd_MetalHeavySliceFlesh2, 100, udg_tempLoc2, 0)
            else
                call UnitDamageTargetBJ(udg_ricardessa, GetEnumUnit(), ( GetUnitStateSwap(UNIT_STATE_MAX_LIFE, GetEnumUnit()) * 0.25 ), ATTACK_TYPE_MELEE, DAMAGE_TYPE_NORMAL)
            endif
        endif
        call GroupAddUnitSimple(GetEnumUnit(), udg_ricardessa_damaged_UG)
        if ( Trig_RicardessaMovePeriodic_Func005Func001Func007C() ) then
            call CreateTextTagUnitBJ("TRIGSTR_8919", udg_ricardessa, 0, 10, 100, 100, 100, 0)
            call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
            call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 1.00)
            call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 60.00, GetUnitFacing(udg_ricardessa))
        else
        endif
    else
    endif
endfunction

function Trig_RicardessaMovePeriodic_Func006Func001C takes nothing returns boolean
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(udg_ricardessa)) == true ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( BlzIsUnitInvulnerable(GetEnumUnit()) == false ) ) then
        return false
    endif
    if ( not ( IsUnitInGroup(GetEnumUnit(), udg_ricardessa_damaged_coil_UG) == false ) ) then
        return false
    endif
    if ( not ( IsUnitInGroup(GetEnumUnit(), udg_HeroesGroup) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_RicardessaMovePeriodic_Func006A takes nothing returns nothing
    if ( Trig_RicardessaMovePeriodic_Func006Func001C() ) then
        call CreateNUnitsAtLoc(1, 'h028', GetOwningPlayer(udg_Boss[1]), udg_tempLoc, bj_UNIT_FACING)
        call UnitApplyTimedLifeBJ(2.00, 'BTLF', GetLastCreatedUnit())
        call UnitAddAbilityBJ('A0IL', GetLastCreatedUnit())
        call IssueTargetOrderBJ(GetLastCreatedUnit(), "deathcoil", GetEnumUnit())
        call GroupAddUnitSimple(GetEnumUnit(), udg_ricardessa_damaged_coil_UG)
    else
    endif
endfunction

function Trig_RicardessaMovePeriodic_Func008Func008C takes nothing returns boolean
    if ( not ( IsUnitAliveBJ(udg_ricardessa) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_RicardessaMovePeriodic_Func008C takes nothing returns boolean
    if ( not ( RectContainsLoc(gg_rct_BossfightInnerLoc, udg_tempLoc) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_RicardessaMovePeriodic_Actions takes nothing returns nothing
    if ( Trig_RicardessaMovePeriodic_Func001C() ) then
        set udg_tempLoc=PolarProjectionBJ(GetUnitLoc(udg_ricardessa), 9.00, GetUnitFacing(udg_ricardessa))
    else
        set udg_tempLoc=PolarProjectionBJ(GetUnitLoc(udg_ricardessa), 7.00, GetUnitFacing(udg_ricardessa))
    endif
    set udg_tempLoc2=PolarProjectionBJ(GetUnitLoc(udg_ricardessa), 80.00, GetUnitFacing(udg_ricardessa))
    call SetUnitPositionLoc(udg_ricardessa, udg_tempLoc)
    if ( Trig_RicardessaMovePeriodic_Func004C() ) then
        call AddSpecialEffectLocBJ(udg_tempLoc2, "Culling Cleave Green.mdx")
        call BlzSetSpecialEffectZ(GetLastCreatedEffectBJ(), ( GetUnitFlyHeight(udg_ricardessa) + 100.00 ))
        call BlzSetSpecialEffectYaw(GetLastCreatedEffectBJ(), Deg2Rad(GetUnitFacing(udg_ricardessa)))
        call BlzSetSpecialEffectRoll(GetLastCreatedEffectBJ(), Deg2Rad(GetRandomReal(0, 360.00)))
        call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 1.00)
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
    else
    endif
    call ForGroupBJ(GetUnitsInRangeOfLocAll(100.00, udg_tempLoc), function Trig_RicardessaMovePeriodic_Func005A)
    call ForGroupBJ(GetUnitsInRangeOfLocAll(1200.00, udg_tempLoc), function Trig_RicardessaMovePeriodic_Func006A)
    // Outside InnerBossLoc
    if ( Trig_RicardessaMovePeriodic_Func008C() ) then
        call GroupClear(udg_ricardessa_damaged_UG)
        call GroupClear(udg_ricardessa_damaged_coil_UG)
        call SetUnitPositionLoc(udg_ricardessa, GetRectCenter(gg_rct_ricardessaLoc))
        call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\Items\\RitualDagger\\RitualDaggerTarget.mdl")
        call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 2.00)
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=20
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            call DestroyEffectBJ(udg_ricardessa_line[GetForLoopIndexA()])
            set bj_forLoopAIndex=bj_forLoopAIndex + 1
        endloop
        if ( Trig_RicardessaMovePeriodic_Func008Func008C() ) then
            call EnableTrigger(gg_trg_RicardessaPreparePeriodic)
        else
        endif
        call DisableTrigger(GetTriggeringTrigger())
    else
    endif
    call RemoveLocation(udg_tempLoc)
    call RemoveLocation(udg_tempLoc2)
endfunction

