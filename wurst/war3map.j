    if ( Trig_tL22_Func001Func001C() ) then
        call PlaySoundOnUnitBJ(gg_snd_PossessionMissileLaunch1, 100, GetEnumUnit())
        call GroupAddUnitSimple(GetEnumUnit(), udg_SadismUG)
        call IncUnitAbilityLevelSwapped('A09X', GetEnumUnit())
        call UnitAddAbilityBJ('A09X', GetEnumUnit())
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=udg_HeroNumber
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
