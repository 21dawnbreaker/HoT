//===========================================================================
// Trigger: tL14 Copy
//===========================================================================
function Trig_tL14_Copy_Conditions takes nothing returns boolean
    if ( not ( IsUnitInGroup(GetTriggerUnit(), udg_CondemnUG) == true ) ) then
        return false
    endif
    if ( not ( GetRandomInt(1, 100) <= 10 ) ) then
        return false
    endif
    return true
endfunction

function Trig_tL14_Copy_Func005Func002C takes nothing returns boolean
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(GetTriggerUnit())) == true ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( GetEnumUnit() != GetTriggerUnit() ) ) then
        return false
    endif
    if ( not ( BlzIsUnitInvulnerable(GetEnumUnit()) == false ) ) then
        return false
    endif
    if ( not ( DistanceBetweenPoints(udg_tempLoc, udg_tempLoc7) < udg_NearestUDistance ) ) then
        return false
    endif
    return true
endfunction

function Trig_tL14_Copy_Func005A takes nothing returns nothing
    set udg_tempLoc7=GetUnitLoc(GetEnumUnit())
    if ( Trig_tL14_Copy_Func005Func002C() ) then
        set udg_NearestU=GetEnumUnit()
        set udg_NearestUDistance=DistanceBetweenPoints(udg_tempLoc, udg_tempLoc7)
        call RemoveLocation(udg_tempLoc7)
    else
    endif
endfunction

function Trig_tL14_Copy_Actions takes nothing returns nothing
    set udg_tempLoc=GetUnitLoc(GetTriggerUnit())
    set udg_NearestUDistance=999999.00
    call ForGroupBJ(GetUnitsInRangeOfLocAll(900.00, udg_tempLoc), function Trig_tL14_Copy_Func005A)
    //  
    call AddSpecialEffectTargetUnitBJ("overhead", udg_NearestU, "Abilities\\Spells\\Undead\\ReplenishMana\\ReplenishManaCasterOverhead.mdl")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call CreateNUnitsAtLoc(1, 'h000', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc, bj_UNIT_FACING)
    call UnitApplyTimedLifeBJ(1.00, 'BTLF', GetLastCreatedUnit())
    call IssueTargetOrderBJ(GetLastCreatedUnit(), "cripple", udg_NearestU)
    call UnitDamageTargetBJ(GetTriggerUnit(), udg_NearestU, ( 100.00 * I2R(GetUnitAbilityLevelSwapped('A09F', GetTriggerUnit())) ), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_NORMAL)
    set udg_NearestU=null
    call RemoveLocation(udg_tempLoc)
    call RemoveLocation(udg_tempLoc7)
endfunction

//===========================================================================
function InitTrig_tL14_Copy takes nothing returns nothing
    set gg_trg_tL14_Copy=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_tL14_Copy, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_tL14_Copy, Condition(function Trig_tL14_Copy_Conditions))
    call TriggerAddAction(gg_trg_tL14_Copy, function Trig_tL14_Copy_Actions)
endfunction

