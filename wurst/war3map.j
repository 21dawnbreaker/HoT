    if ( not ( GetDyingUnit() != GetEnumUnit() ) ) then
        return false
    endif
    if ( not ( IsUnitInGroup(GetEnumUnit(), udg_SadismUG) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_tL22_copy_Copy_Func002A takes nothing returns nothing
    if ( Trig_tL22_copy_Copy_Func002Func001C() ) then
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=udg_HeroNumber
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            if ( Trig_tL22_copy_Copy_Func002Func001Func001Func001C() ) then
                set udg_SadismInt[GetForLoopIndexA()]=( udg_SadismInt[GetForLoopIndexA()] + 10 )
                if ( Trig_tL22_copy_Copy_Func002Func001Func001Func001Func002C() ) then
                    set udg_SadismInt[GetForLoopIndexA()]=udg_SadismCap_Int[GetForLoopIndexA()]
                else
                endif
                call CreateTextTagUnitBJ(( "|cffff0000Sadism: " + ( I2S(udg_SadismInt[GetForLoopIndexA()]) + ( " / " + ( I2S(udg_SadismCap_Int[GetForLoopIndexA()]) + "|r" ) ) ) ), GetEnumUnit(), 0, 10, 100, 100, 100, 0)
                call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
                call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 3.00)
                call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
                call AddSpecialEffectTargetUnitBJ("chest", GetEnumUnit(), "Abilities\\Weapons\\VengeanceMissile\\VengeanceMissile.mdl")
                call DestroyEffectBJ(GetLastCreatedEffectBJ())
            else
            endif
            set bj_forLoopAIndex=bj_forLoopAIndex + 1
        endloop
    else
    endif
endfunction

