endfunction

function Trig_MutagenApplyEffect_Actions takes nothing returns nothing
    if ( Trig_MutagenApplyEffect_Func001C() ) then
        call UnitAddItemByIdSwapped('I03T', udg_MutagenHero)
        if ( Trig_MutagenApplyEffect_Func001Func002C() ) then
            set udg_tempLoc=PolarProjectionBJ(GetUnitLoc(udg_MutagenHero), 60.00, 0.00)
            call CreateTextTagLocBJ("TRIGSTR_8726", udg_tempLoc, 0, 10, 100, 100, 100, 0)
            call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
            call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 1.00)
            call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 60.00, 90.00)
            call RemoveLocation(udg_tempLoc)
            call UnitAddItemByIdSwapped('I03T', udg_MutagenHero)
        else
        endif
    else
    endif
    if ( Trig_MutagenApplyEffect_Func002C() ) then
        call SetPlayerStateBJ(GetOwningPlayer(udg_MutagenHero), PLAYER_STATE_RESOURCE_LUMBER, ( GetPlayerState(GetOwningPlayer(udg_MutagenHero), PLAYER_STATE_RESOURCE_LUMBER) + 1 ))
        call CreateTextTagUnitBJ("TRIGSTR_8669", udg_MutagenHero, 0, 10, 100, 100, 100, 0)
        call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
        call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 3.00)
        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 8.00, 135.00)
    else
    endif
    if ( Trig_MutagenApplyEffect_Func003C() ) then
        call SetHeroLevelBJ(udg_MutagenHero, ( GetHeroLevel(udg_MutagenHero) + 1 ), true)
    else
    endif
    if ( Trig_MutagenApplyEffect_Func004C() ) then
        call BlzSetUnitMaxHP(udg_MutagenHero, ( BlzGetUnitMaxHP(udg_MutagenHero) + 150 ))
        call SetUnitLifePercentBJ(udg_MutagenHero, 100)
    else
    endif
    if ( Trig_MutagenApplyEffect_Func005C() ) then
        call UnitAddItemByIdSwapped('I08U', udg_MutagenHero)
    else
    endif
    if ( Trig_MutagenApplyEffect_Func006C() ) then
        call DestroyTextTagBJ(udg_MutagenFloatingText)
        if ( Trig_MutagenApplyEffect_Func006Func002C() ) then
            call SetItemCharges(GetItemOfTypeFromUnitBJ(udg_MutagenSeller, 'I08S'), ( GetItemCharges(GetItemOfTypeFromUnitBJ(udg_MutagenSeller, 'I08S')) + udg_MutagenPrice ))
        else
            set udg_MutagenDefenseModifier[GetConvertedPlayerId(GetOwningPlayer(udg_MutagenHero))]=( udg_MutagenDefenseModifier[GetConvertedPlayerId(GetOwningPlayer(udg_MutagenHero))] + 0.03 )
            set udg_HERO_DAMAGE_DEF_ALL[GetConvertedPlayerId(GetOwningPlayer(udg_MutagenHero))]=( udg_HERO_DAMAGE_DEF_ALL[GetConvertedPlayerId(GetOwningPlayer(udg_MutagenHero))] + 3 )
        endif
        set udg_tempInt=R2I(( ( udg_MutagenDefenseModifier[GetConvertedPlayerId(GetOwningPlayer(udg_MutagenHero))] + 0.01 ) * 100.00 ))
        call CreateTextTagUnitBJ(( "Текущее сопротивление урону:  |cffff0000" + ( I2S(udg_tempInt) + "%|r из |cffff000040%|r" ) ), udg_MutagenHero, 0, 10, 100, 100, 100, 0)
        call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
        call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 2.00)
        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
        set udg_MutagenFloatingText=GetLastCreatedTextTag()
        set udg_tempInt=0
    else
    endif
    if ( Trig_MutagenApplyEffect_Func007C() ) then
        call DestroyTextTagBJ(udg_MutagenFloatingText)
        if ( Trig_MutagenApplyEffect_Func007Func002C() ) then
            call SetItemCharges(GetItemOfTypeFromUnitBJ(udg_MutagenSeller, 'I08S'), ( GetItemCharges(GetItemOfTypeFromUnitBJ(udg_MutagenSeller, 'I08S')) + udg_MutagenPrice ))
        else
            set udg_MutagenDamageModifier[GetConvertedPlayerId(GetOwningPlayer(udg_MutagenHero))]=( udg_MutagenDamageModifier[GetConvertedPlayerId(GetOwningPlayer(udg_MutagenHero))] + 0.06 )
            set udg_HERO_DAMAGE_BONUS_ALL[GetConvertedPlayerId(GetOwningPlayer(udg_MutagenHero))]=( udg_HERO_DAMAGE_BONUS_ALL[GetConvertedPlayerId(GetOwningPlayer(udg_MutagenHero))] + 6 )
        endif
        set udg_tempInt=R2I(( ( udg_MutagenDamageModifier[GetConvertedPlayerId(GetOwningPlayer(udg_MutagenHero))] + 0.01 ) * 100.00 ))
        call CreateTextTagUnitBJ(( "Текущий бонус к урону:  |cffff0000" + ( I2S(udg_tempInt) + "%|r из |cffff0000300%|r" ) ), udg_MutagenHero, 0, 10, 100, 100, 100, 0)
        call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
        call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 2.00)
        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
        set udg_MutagenFloatingText=GetLastCreatedTextTag()
        set udg_tempInt=0
    else
    endif
    if ( Trig_MutagenApplyEffect_Func008C() ) then
        set udg_tempLoc=GetUnitLoc(udg_MutagenSeller)
        call CreateNUnitsAtLoc(1, 'e008', GetOwningPlayer(udg_MutagenSeller), udg_tempLoc, bj_UNIT_FACING)
        call RemoveLocation(udg_tempLoc)
    else
    endif
    if ( Trig_MutagenApplyEffect_Func009C() ) then
        call DestroyTextTagBJ(udg_MutagenFloatingText)
        set udg_tempInt=GetRandomInt(1, 10)
        if ( Trig_MutagenApplyEffect_Func009Func003C() ) then
            if ( Trig_MutagenApplyEffect_Func009Func003Func001C() ) then
                call SetItemCharges(GetItemOfTypeFromUnitBJ(udg_MutagenSeller, 'I08S'), ( GetItemCharges(GetItemOfTypeFromUnitBJ(udg_MutagenSeller, 'I08S')) + 2 ))
                set udg_player_mutagens[GetConvertedPlayerId(GetEnumPlayer())]=( udg_player_mutagens[GetConvertedPlayerId(GetEnumPlayer())] + 1 )
            else
                call UnitAddItemByIdSwapped('I08S', udg_MutagenSeller)
                call SetItemCharges(GetItemOfTypeFromUnitBJ(udg_MutagenSeller, 'I08S'), ( GetItemCharges(GetItemOfTypeFromUnitBJ(udg_MutagenSeller, 'I08S')) + 1 ))
            endif
            if ( Trig_MutagenApplyEffect_Func009Func003Func007C() ) then
                call SetItemCharges(GetItemOfTypeFromUnitBJ(udg_MutagenSeller, 'I08S'), ( GetItemCharges(GetItemOfTypeFromUnitBJ(udg_MutagenSeller, 'I08S')) + 1 ))
                set udg_player_mutagens[GetConvertedPlayerId(GetEnumPlayer())]=( udg_player_mutagens[GetConvertedPlayerId(GetEnumPlayer())] + 1 )
                call CreateTextTagUnitBJ("TRIGSTR_8646", udg_MutagenHero, 0, 10, 100, 100, 100, 0)
                call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
                call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 2.00)
                call PlaySoundAtPointBJ(gg_snd_Victory_01, 100, GetUnitLoc(udg_MutagenHero), 0)
            else
                call CreateTextTagUnitBJ("TRIGSTR_8647", udg_MutagenHero, 0, 10, 100, 100, 100, 0)
                call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
                call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 2.00)
                call PlaySoundAtPointBJ(gg_snd_Rescue, 100, GetUnitLoc(udg_MutagenHero), 0)
            endif
        else
            call CreateTextTagUnitBJ("TRIGSTR_8648", udg_MutagenHero, 0, 10, 100, 100, 100, 0)
            call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
            call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 2.00)
            call PlaySoundAtPointBJ(gg_snd_BanishCaster, 100, GetUnitLoc(udg_MutagenHero), 0)
            set udg_player_mutagens[GetConvertedPlayerId(GetEnumPlayer())]=( udg_player_mutagens[GetConvertedPlayerId(GetEnumPlayer())] - 1 )
        endif
        set udg_MutagenFloatingText=GetLastCreatedTextTag()
        call TriggerExecute(gg_trg_Save_Profiles)
        set udg_tempInt=0
    else
    endif
endfunction

//===========================================================================
function InitTrig_MutagenApplyEffect takes nothing returns nothing
    set gg_trg_MutagenApplyEffect=CreateTrigger()
    call TriggerAddAction(gg_trg_MutagenApplyEffect, function Trig_MutagenApplyEffect_Actions)
endfunction

//===========================================================================
// Trigger: MutagenDropMiniboss
//===========================================================================
function Trig_MutagenDropMiniboss_Conditions takes nothing returns boolean
    if ( not ( IsUnitInGroup(GetTriggerUnit(), udg_MiniBossUG) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_MutagenDropMiniboss_Func003C takes nothing returns boolean
    if ( not ( udg_DIFFICULTY >= 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_MutagenDropMiniboss_Func004Func001A takes nothing returns nothing
    call CreateItemLoc('I08S', udg_tempLoc)
endfunction

function Trig_MutagenDropMiniboss_Func004C takes nothing returns boolean
    if ( not ( udg_DIFFICULTY == 3 ) ) then
        return false
    endif
    return true
endfunction

function Trig_MutagenDropMiniboss_Actions takes nothing returns nothing
    set udg_tempLoc=GetUnitLoc(GetTriggerUnit())
    call CreateItemLoc('I08S', udg_tempLoc)
    if ( Trig_MutagenDropMiniboss_Func003C() ) then
        call CreateItemLoc('I08S', udg_tempLoc)
    else
    endif
    if ( Trig_MutagenDropMiniboss_Func004C() ) then
        call ForForce(udg_PlayerGroup, function Trig_MutagenDropMiniboss_Func004Func001A)
    else
    endif
    call RemoveLocation(udg_tempLoc)
endfunction

//===========================================================================
function InitTrig_MutagenDropMiniboss takes nothing returns nothing
    set gg_trg_MutagenDropMiniboss=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_MutagenDropMiniboss, EVENT_PLAYER_UNIT_DEATH)
    call TriggerAddCondition(gg_trg_MutagenDropMiniboss, Condition(function Trig_MutagenDropMiniboss_Conditions))
    call TriggerAddAction(gg_trg_MutagenDropMiniboss, function Trig_MutagenDropMiniboss_Actions)
endfunction

//===========================================================================
// Trigger: MutagenAquiring
//===========================================================================
function Trig_MutagenAquiring_Conditions takes nothing returns boolean
    if ( not ( GetItemTypeId(GetManipulatedItem()) == 'I08S' ) ) then
        return false
    endif
    return true
endfunction

function Trig_MutagenAquiring_Func001Func001C takes nothing returns boolean
    if ( not ( GetOwningPlayer(GetTriggerUnit()) == GetEnumPlayer() ) ) then
        return false
    endif
    return true
endfunction

function Trig_MutagenAquiring_Func001A takes nothing returns nothing
    if ( Trig_MutagenAquiring_Func001Func001C() ) then
        set udg_player_mutagens[GetConvertedPlayerId(GetEnumPlayer())]=( udg_player_mutagens[GetConvertedPlayerId(GetEnumPlayer())] + 1 )
    else
    endif
endfunction

function Trig_MutagenAquiring_Actions takes nothing returns nothing
    call ForForce(udg_PlayerGroup, function Trig_MutagenAquiring_Func001A)
    call TriggerExecute(gg_trg_Save_Profiles)
endfunction

//===========================================================================
function InitTrig_MutagenAquiring takes nothing returns nothing
    set gg_trg_MutagenAquiring=CreateTrigger()
    call DisableTrigger(gg_trg_MutagenAquiring)
    call TriggerRegisterAnyUnitEventBJ(gg_trg_MutagenAquiring, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_MutagenAquiring, Condition(function Trig_MutagenAquiring_Conditions))
    call TriggerAddAction(gg_trg_MutagenAquiring, function Trig_MutagenAquiring_Actions)
endfunction

