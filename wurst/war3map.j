function Trig_ShoulderToShoulder_Func003Func002C takes nothing returns boolean
    if ( ( UnitHasBuffBJ(gg_unit_U005_0113, 'B01S') == false ) ) then
        return true
    endif
    if ( ( UnitHasBuffBJ(gg_unit_U006_0283, 'B01S') == false ) ) then
        return true
    endif
    return false
endfunction

function Trig_ShoulderToShoulder_Func003C takes nothing returns boolean
    if ( not ( DistanceBetweenPoints(udg_BossLoc, udg_BossLoc2) <= 300.00 ) ) then
        return false
    endif
    if ( not Trig_ShoulderToShoulder_Func003Func002C() ) then
        return false
    endif
    return true
endfunction

function Trig_ShoulderToShoulder_Func004C takes nothing returns boolean
    if ( not ( DistanceBetweenPoints(udg_BossLoc, udg_BossLoc2) > 300.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ShoulderToShoulder_Actions takes nothing returns nothing
    set udg_BossLoc=GetUnitLoc(gg_unit_U005_0113)
    set udg_BossLoc2=GetUnitLoc(gg_unit_U006_0283)
    if ( Trig_ShoulderToShoulder_Func003C() ) then
        call CreateNUnitsAtLoc(1, 'h000', GetOwningPlayer(gg_unit_U005_0113), udg_BossLoc, bj_UNIT_FACING)
        call UnitApplyTimedLifeBJ(1.00, 'BTLF', GetLastCreatedUnit())
        call IssueImmediateOrderBJ(GetLastCreatedUnit(), "roar")
        call CreateNUnitsAtLoc(1, 'h000', GetOwningPlayer(gg_unit_U005_0113), udg_BossLoc2, bj_UNIT_FACING)
        call UnitApplyTimedLifeBJ(1.00, 'BTLF', GetLastCreatedUnit())
        call IssueImmediateOrderBJ(GetLastCreatedUnit(), "roar")
    else
    endif
    if ( Trig_ShoulderToShoulder_Func004C() ) then
        call UnitRemoveBuffBJ('B01S', udg_Boss[1])
        call UnitRemoveBuffBJ('B01S', udg_Boss[2])
    else
    endif
    call RemoveLocation(udg_BossLoc)
    call RemoveLocation(udg_BossLoc2)
endfunction

