        return false
    endif
    return true
endfunction

function Trig_BlackenedScrollCast_Func002Func001C takes nothing returns boolean
    if ( not ( udg_has_scrolls == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_BlackenedScrollCast_Func002Func002Func002C takes nothing returns boolean
    if ( not ( GetItemTypeId(UnitItemInSlotBJ(udg_BlackenedScrollUnit, GetForLoopIndexA())) == 'I074' ) ) then
        return false
    endif
    return true
endfunction

function Trig_BlackenedScrollCast_Func002Func002C takes nothing returns boolean
    if ( not ( udg_has_scrolls == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_BlackenedScrollCast_Func003Func003Func001Func001C takes nothing returns boolean
    if ( not ( GetItemType(UnitItemInSlotBJ(udg_BlackenedScrollUnit, GetForLoopIndexA())) == ITEM_TYPE_UNKNOWN ) ) then
        return false
    endif
    if ( not ( GetItemCharges(UnitItemInSlotBJ(udg_BlackenedScrollUnit, GetForLoopIndexA())) >= 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_BlackenedScrollCast_Func003Func003Func001C takes nothing returns boolean
    if ( not ( udg_has_scrolls == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_BlackenedScrollCast_Func003Func006Func001Func001C takes nothing returns boolean
    if ( not ( GetItemType(UnitItemInSlotBJ(udg_BlackenedScrollUnit, GetForLoopIndexA())) == ITEM_TYPE_UNKNOWN ) ) then
        return false
    endif
    if ( not ( GetItemCharges(UnitItemInSlotBJ(udg_BlackenedScrollUnit, GetForLoopIndexA())) >= 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_BlackenedScrollCast_Func003Func006Func001C takes nothing returns boolean
    if ( not ( udg_has_scrolls == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_BlackenedScrollCast_Func003C takes nothing returns boolean
    if ( not ( udg_has_scrolls == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_BlackenedScrollCast_Func005Func006C takes nothing returns boolean
    if ( not ( GetItemCharges(udg_itemScroll) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_BlackenedScrollCast_Func005C takes nothing returns boolean
    if ( not ( udg_has_scrolls == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_BlackenedScrollCast_Actions takes nothing returns nothing
    // scroll search - useless scrolls
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=6
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        if ( Trig_BlackenedScrollCast_Func002Func001C() ) then
            set udg_BlackenedScrollUnit=udg_backpack_by_player[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]
            if ( Trig_BlackenedScrollCast_Func002Func001Func002C() ) then
                set udg_has_scrolls=true
                set udg_itemScroll=UnitItemInSlotBJ(udg_BlackenedScrollUnit, GetForLoopIndexA())
            else
            endif
        else
        endif
        if ( Trig_BlackenedScrollCast_Func002Func002C() ) then
            set udg_BlackenedScrollUnit=udg_hero_by_player[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]
            if ( Trig_BlackenedScrollCast_Func002Func002Func002C() ) then
                set udg_has_scrolls=true
                set udg_itemScroll=UnitItemInSlotBJ(udg_BlackenedScrollUnit, GetForLoopIndexA())
            else
            endif
        else
        endif
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    if ( Trig_BlackenedScrollCast_Func003C() ) then
        // scroll search - backpack
        set udg_BlackenedScrollUnit=udg_backpack_by_player[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=6
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            if ( Trig_BlackenedScrollCast_Func003Func003Func001C() ) then
                if ( Trig_BlackenedScrollCast_Func003Func003Func001Func001C() ) then
                    set udg_has_scrolls=true
                    set udg_itemScroll=UnitItemInSlotBJ(udg_BlackenedScrollUnit, GetForLoopIndexA())
                else
                endif
            else
            endif
            set bj_forLoopAIndex=bj_forLoopAIndex + 1
        endloop
        // scroll search - hero
        set udg_BlackenedScrollUnit=udg_hero_by_player[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=6
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            if ( Trig_BlackenedScrollCast_Func003Func006Func001C() ) then
                if ( Trig_BlackenedScrollCast_Func003Func006Func001Func001C() ) then
                    set udg_has_scrolls=true
                    set udg_itemScroll=UnitItemInSlotBJ(udg_BlackenedScrollUnit, GetForLoopIndexA())
                else
                endif
            else
            endif
            set bj_forLoopAIndex=bj_forLoopAIndex + 1
        endloop
    else
    endif
    // scrolls spending
    if ( Trig_BlackenedScrollCast_Func005C() ) then
        if ( Trig_BlackenedScrollCast_Func005Func006C() ) then
            call RemoveItem(udg_itemScroll)
        else
            call SetItemCharges(udg_itemScroll, ( GetItemCharges(udg_itemScroll) - 1 ))
        endif
    else
        call IssueImmediateOrderBJ(GetTriggerUnit(), "stop")
        call CreateTextTagUnitBJ("TRIGSTR_9981", GetTriggerUnit(), 0, 10, 100, 100, 100, 0)
        call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
        call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 3.00)
        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
    endif
    set udg_itemScroll=null
    set udg_has_scrolls=false
endfunction

//===========================================================================
function InitTrig_BlackenedScrollCast takes nothing returns nothing
    set gg_trg_BlackenedScrollCast=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_BlackenedScrollCast, EVENT_PLAYER_UNIT_SPELL_CAST)
    call TriggerAddCondition(gg_trg_BlackenedScrollCast, Condition(function Trig_BlackenedScrollCast_Conditions))
    call TriggerAddAction(gg_trg_BlackenedScrollCast, function Trig_BlackenedScrollCast_Actions)
endfunction

