    if ( Trig_SeaSpiritsDeath_Func003Func001C() ) then
        call AddSpecialEffectTargetUnitBJ("origin", GetEnumUnit(), "Abilities\\Spells\\Undead\\ReplenishMana\\SpiritTouchTarget.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        if ( Trig_SeaSpiritsDeath_Func003Func001Func003C() ) then
            call SetUnitManaPercentBJ(GetEnumUnit(), ( GetUnitManaPercent(GetEnumUnit()) + ( 0.00 + ( 5.00 * I2R(GetUnitAbilityLevelSwapped('A012', gg_unit_H001_0116)) ) ) ))
        else
            call SetUnitManaPercentBJ(GetEnumUnit(), ( GetUnitManaPercent(GetEnumUnit()) + ( 15.00 + ( 5.00 * I2R(GetUnitAbilityLevelSwapped('A012', gg_unit_H001_0116)) ) ) ))
        endif
    else
    endif
endfunction

