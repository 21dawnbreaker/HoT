    set gg_trg_ChestOpen=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_ChestOpen, EVENT_PLAYER_UNIT_SELL)
    call TriggerAddCondition(gg_trg_ChestOpen, Condition(function Trig_ChestOpen_Conditions))
    call TriggerAddAction(gg_trg_ChestOpen, function Trig_ChestOpen_Actions)
endfunction

//===========================================================================
// Trigger: ChestsTrapTimer
//===========================================================================
function Trig_ChestsTrapTimer_Func005A takes nothing returns nothing
    call UnitDamageTargetBJ(udg_ChestTrapU, GetEnumUnit(), ( GetUnitStateSwap(UNIT_STATE_MAX_LIFE, GetEnumUnit()) * 0.50 ), ATTACK_TYPE_MELEE, DAMAGE_TYPE_NORMAL)
endfunction

function Trig_ChestsTrapTimer_Actions takes nothing returns nothing
    set udg_tempLoc=GetUnitLoc(udg_ChestTrapU)
    set udg_tempZ=GetLocationZ(udg_tempLoc)
    call AddSpecialEffectLocBJ(udg_tempLoc, "Objects\\Spawnmodels\\Other\\NeutralBuildingExplosion\\NeutralBuildingExplosion.mdl")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call ForGroupBJ(GetUnitsInRangeOfLocAll(150.00, udg_tempLoc), function Trig_ChestsTrapTimer_Func005A)
    call DestroyGroup(GetLastCreatedGroup())
    set udg_tempZ=0.00
    call RemoveLocation(udg_tempLoc)
    call KillUnit(udg_ChestTrapU)
    set udg_ChestTrapInt=0
    set udg_ChestTrapU=null
endfunction

