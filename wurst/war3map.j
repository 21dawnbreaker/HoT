    call TriggerAddCondition(gg_trg_MagicAmpDrop, Condition(function Trig_MagicAmpDrop_Conditions))
    call TriggerAddAction(gg_trg_MagicAmpDrop, function Trig_MagicAmpDrop_Actions)
endfunction

