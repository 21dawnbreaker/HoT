//===========================================================================
// Trigger: RaiseDead
//===========================================================================
function Trig_RaiseDead_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A0E2' ) ) then
        return false
    endif
    return true
endfunction

function Trig_RaiseDead_Func001Func001C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 2) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_RaiseDead_Func001C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 3) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_RaiseDead_Actions takes nothing returns nothing
    if ( Trig_RaiseDead_Func001C() ) then
    else
        if ( Trig_RaiseDead_Func001Func001C() ) then
            call PlaySoundOnUnitBJ(gg_snd_HeroFemaleDeathKnightYes3, 100, GetTriggerUnit())
        else
            call PlaySoundOnUnitBJ(gg_snd_HeroFemaleDeathKnightYesAttack2, 100, GetTriggerUnit())
        endif
    endif
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=udg_RaiseDeadInt
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        set udg_tempLoc=PolarProjectionBJ(GetUnitLoc(GetTriggerUnit()), GetRandomReal(100.00, 250.00), GetRandomDirectionDeg())
        call CreateNUnitsAtLoc(1, 'u00B', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc, GetUnitFacing(GetTriggerUnit()))
        call UnitApplyTimedLifeBJ(60, 'BTLF', GetLastCreatedUnit())
        call AddSpecialEffectTargetUnitBJ("origin", GetLastCreatedUnit(), "Abilities\\Spells\\Undead\\AnimateDead\\AnimateDeadTarget.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call RemoveLocation(udg_tempLoc)
        call TriggerSleepAction(0.50)
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
endfunction

//===========================================================================
function InitTrig_RaiseDead takes nothing returns nothing
    set gg_trg_RaiseDead=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_RaiseDead, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_RaiseDead, Condition(function Trig_RaiseDead_Conditions))
    call TriggerAddAction(gg_trg_RaiseDead, function Trig_RaiseDead_Actions)
endfunction

//===========================================================================
// Trigger: MinibossesScaling
//===========================================================================
function Trig_MinibossesScaling_Func001C takes nothing returns boolean
    if ( ( GetUnitTypeId(GetSoldUnit()) == 'o02J' ) ) then
        return true
    endif
    if ( ( GetUnitTypeId(GetSoldUnit()) == 'o02H' ) ) then
        return true
    endif
    if ( ( GetUnitTypeId(GetSoldUnit()) == 'o02K' ) ) then
        return true
    endif
    if ( ( GetUnitTypeId(GetSoldUnit()) == 'o02L' ) ) then
        return true
    endif
    return false
endfunction

function Trig_MinibossesScaling_Conditions takes nothing returns boolean
    if ( not Trig_MinibossesScaling_Func001C() ) then
        return false
    endif
    return true
endfunction

function Trig_MinibossesScaling_Func003A takes nothing returns nothing
    call BlzSetUnitMaxHP(GetEnumUnit(), ( ( BlzGetUnitMaxHP(GetEnumUnit()) * 6 ) + ( R2I(( udg_difficultyReal * GetUnitStateSwap(UNIT_STATE_MAX_LIFE, GetEnumUnit()) )) * R2I(udg_RoomMultiboardCounting) ) ))
    call SetUnitLifeBJ(GetEnumUnit(), GetUnitStateSwap(UNIT_STATE_MAX_LIFE, GetEnumUnit()))
    set udg_tempReal=I2R(BlzGetUnitBaseDamage(GetEnumUnit(), 0))
    call BlzSetUnitBaseDamage(GetEnumUnit(), ( BlzGetUnitBaseDamage(GetEnumUnit(), 0) + ( R2I(( udg_tempReal * udg_difficultyReal )) * R2I(udg_RoomMultiboardCounting) ) ), 0)
    call BlzSetUnitBaseDamage(GetEnumUnit(), ( BlzGetUnitBaseDamage(GetEnumUnit(), 0) * 2 ), 0)
    set udg_tempReal=0.00
    call SetUnitManaPercentBJ(GetEnumUnit(), 0.00)
    call PlaySoundOnUnitBJ(gg_snd_RankAnimations_5, 100, GetEnumUnit())
    call DisplayTextToForce(GetPlayersAll(), ( GetUnitName(GetEnumUnit()) + " бросает вызов героям!" ))
endfunction

function Trig_MinibossesScaling_Actions takes nothing returns nothing
    call ForGroupBJ(udg_MiniBossUG, function Trig_MinibossesScaling_Func003A)
endfunction

//===========================================================================
function InitTrig_MinibossesScaling takes nothing returns nothing
    set gg_trg_MinibossesScaling=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_MinibossesScaling, EVENT_PLAYER_UNIT_SELL)
    call TriggerAddCondition(gg_trg_MinibossesScaling, Condition(function Trig_MinibossesScaling_Conditions))
    call TriggerAddAction(gg_trg_MinibossesScaling, function Trig_MinibossesScaling_Actions)
endfunction

