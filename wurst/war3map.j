    return true
endfunction

function Trig_Talents_Actions takes nothing returns nothing
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=udg_HeroNumber
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        if ( Trig_Talents_Func003Func001C() ) then
            set bj_forLoopBIndex=1
            set bj_forLoopBIndexEnd=50
            loop
                exitwhen bj_forLoopBIndex > bj_forLoopBIndexEnd
                call RemoveUnitFromStockBJ(udg_TalentUnitType[GetForLoopIndexB()], GetTriggerUnit())
                set bj_forLoopBIndex=bj_forLoopBIndex + 1
            endloop
            set udg_TalentsInt=GetRandomInt(1, 15)
            call AddUnitToStockBJ(udg_TalentUnitType[udg_TalentsInt], GetTriggerUnit(), 1, 1)
            set udg_TalentUT1[1]=udg_TalentUnitType[udg_TalentsInt]
            set udg_TalentsInt=GetRandomInt(1, 45)
            call AddUnitToStockBJ(udg_TalentUnitType[udg_TalentsInt], GetTriggerUnit(), 1, 1)
            set udg_TalentUT2=udg_TalentUnitType[udg_TalentsInt]
            set udg_TalentsInt=GetRandomInt(31, 45)
            call AddUnitToStockBJ(udg_TalentUnitType[udg_TalentsInt], GetTriggerUnit(), 1, 1)
            set udg_TalentUT1[3]=udg_TalentUnitType[udg_TalentsInt]
            set udg_TalentsInt=GetRandomInt(16, 30)
            call AddUnitToStockBJ(udg_TalentUnitType[udg_TalentsInt], GetTriggerUnit(), 1, 1)
            set udg_TalentUT1[2]=udg_TalentUnitType[udg_TalentsInt]
            if ( Trig_Talents_Func003Func001Func014C() ) then
                set udg_TalentsInt=GetRandomInt(1, 45)
                call AddUnitToStockBJ(udg_TalentUnitType[udg_TalentsInt], GetTriggerUnit(), 1, 1)
                set udg_TalentUT2=udg_TalentUnitType[udg_TalentsInt]
                if ( Trig_Talents_Func003Func001Func014Func004C() ) then
                    set udg_TalentsInt=GetRandomInt(1, 45)
                    call AddUnitToStockBJ(udg_TalentUnitType[udg_TalentsInt], GetTriggerUnit(), 1, 1)
                    set udg_TalentUT2=udg_TalentUnitType[udg_TalentsInt]
                    if ( Trig_Talents_Func003Func001Func014Func004Func004C() ) then
                        set udg_TalentsInt=GetRandomInt(1, 45)
                        call AddUnitToStockBJ(udg_TalentUnitType[udg_TalentsInt], GetTriggerUnit(), 1, 1)
                        set udg_TalentUT2=udg_TalentUnitType[udg_TalentsInt]
                        if ( Trig_Talents_Func003Func001Func014Func004Func004Func004C() ) then
                        else
                            set udg_TalentsInt=GetRandomInt(1, 45)
                            call AddUnitToStockBJ(udg_TalentUnitType[udg_TalentsInt], GetTriggerUnit(), 1, 1)
                            set udg_TalentUT2=udg_TalentUnitType[udg_TalentsInt]
                            if ( Trig_Talents_Func003Func001Func014Func004Func004Func004Func004C() ) then
                            else
                            endif
                        endif
                    else
                    endif
                else
                endif
            else
            endif
            set udg_TalentUT2=0
            set udg_TalentUT1[1]=0
            set udg_TalentUT1[2]=0
            set udg_TalentUT1[3]=0
        else
        endif
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
endfunction

