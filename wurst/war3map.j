//===========================================================================
// Trigger: JadAsKir good
//===========================================================================
function Trig_JadAsKir_good_Conditions takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetSoldUnit()) == 'o00O' ) ) then
        return false
    endif
    if ( not ( UnitHasItemOfTypeBJ(GetBuyingUnit(), 'I087') == true ) ) then
        return false
    endif
    if ( not ( UnitHasItemOfTypeBJ(GetBuyingUnit(), 'I01Y') == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_JadAsKir_good_Func008Func001C takes nothing returns boolean
    if ( not ( GetOwningPlayer(udg_KarmaU) == udg_Player[GetForLoopIndexA()] ) ) then
        return false
    endif
    if ( not ( IsUnitInGroup(udg_KarmaU, udg_HeroesGroup) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_JadAsKir_good_Actions takes nothing returns nothing
    call RemoveItem(GetItemOfTypeFromUnitBJ(GetBuyingUnit(), 'I087'))
    call RemoveItem(GetItemOfTypeFromUnitBJ(GetBuyingUnit(), 'I01Y'))
    call AddSpecialEffectTargetUnitBJ("origin", GetBuyingUnit(), "Abilities\\Spells\\Human\\ManaFlare\\ManaFlareBoltImpact.mdl")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call UnitAddItemByIdSwapped('I08B', GetBuyingUnit())
    set udg_tempInt=1
    set udg_KarmaU=GetBuyingUnit()
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=udg_HeroNumber
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        if ( Trig_JadAsKir_good_Func008Func001C() ) then
            set udg_Karma[GetForLoopIndexA()]=( udg_Karma[GetForLoopIndexA()] + 1 )
            call ConditionalTriggerExecute(gg_trg_KarmaSystem)
            call CreateTextTagUnitBJ("TRIGSTR_8363", GetBuyingUnit(), 0, 10, 100, 100, 100, 0)
            call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
            call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 3.00)
            call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 8.00, 135.00)
        else
        endif
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
endfunction

