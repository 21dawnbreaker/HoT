    call UnitRemoveAbilityBJ('A06F', gg_unit_O001_0069)
    call UnitRemoveAbilityBJ('A06G', gg_unit_O001_0069)
    set udg_HERO_DAMAGE_DEF_ALL[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]=( udg_HERO_DAMAGE_DEF_ALL[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))] - ( udg_bones_of_netherworld_lvl * 10 ) )
    set udg_HERO_DAMAGE_BONUS_ALL[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]=( udg_HERO_DAMAGE_BONUS_ALL[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))] - ( udg_bones_of_netherworld_lvl * 10 ) )
