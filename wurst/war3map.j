    call PlaySoundAtPointBJ(gg_snd_RvilbulkDeathPact, 100, udg_tempLoc, 0)
    call RemoveLocation(udg_tempLoc)
    call SetUnitLifeBJ(GetTriggerUnit(), ( GetUnitStateSwap(UNIT_STATE_LIFE, GetTriggerUnit()) + ( 0.50 * GetUnitStateSwap(UNIT_STATE_LIFE, GetSpellTargetUnit()) ) ))
    call SetUnitManaBJ(GetTriggerUnit(), ( GetUnitStateSwap(UNIT_STATE_MANA, GetTriggerUnit()) + ( 0.50 * GetUnitStateSwap(UNIT_STATE_LIFE, GetSpellTargetUnit()) ) ))
