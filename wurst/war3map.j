//===========================================================================
// Trigger: Lycantrophy
//===========================================================================
function Trig_Lycantrophy_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A09R' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Lycantrophy_Func007C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped('A09R', GetTriggerUnit()) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Lycantrophy_Func008C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped('A09R', GetTriggerUnit()) == 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Lycantrophy_Func009C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped('A09R', GetTriggerUnit()) == 3 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Lycantrophy_Func013C takes nothing returns boolean
    if ( not ( udg_BossfightMainIsOn == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Lycantrophy_Func035Func001C takes nothing returns boolean
    if ( not ( GetOwningPlayer(GetTriggerUnit()) == udg_Player[GetForLoopIndexA()] ) ) then
        return false
    endif
    return true
endfunction

function Trig_Lycantrophy_Actions takes nothing returns nothing
    call StartTimerBJ(udg_LycantrophyTimer, false, 60.00)
    set udg_tempLoc=GetUnitLoc(GetTriggerUnit())
    set udg_LycantrophyC=GetTriggerUnit()
    call SetUnitInvulnerable(udg_LycantrophyC, true)
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=6
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        set udg_LycantrophyIT[GetForLoopIndexA()]=GetItemTypeId(UnitItemInSlotBJ(GetTriggerUnit(), GetForLoopIndexA()))
        call UnitRemoveItemFromSlotSwapped(GetForLoopIndexA(), udg_LycantrophyC)
        set udg_LycantrophyI[GetForLoopIndexA()]=GetLastRemovedItem()
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    call ShowUnitHide(GetTriggerUnit())
    if ( Trig_Lycantrophy_Func007C() ) then
        call CreateNUnitsAtLoc(1, 'U001', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc, GetUnitFacing(GetTriggerUnit()))
    else
    endif
    if ( Trig_Lycantrophy_Func008C() ) then
        call CreateNUnitsAtLoc(1, 'U002', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc, GetUnitFacing(GetTriggerUnit()))
    else
    endif
    if ( Trig_Lycantrophy_Func009C() ) then
        call CreateNUnitsAtLoc(1, 'U003', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc, GetUnitFacing(GetTriggerUnit()))
    else
    endif
    set udg_LycantrophyC2=GetLastCreatedUnit()
    call GroupAddUnitSimple(GetLastCreatedUnit(), udg_Metamorphosis)
    call GroupAddUnitSimple(GetLastCreatedUnit(), udg_HeroesGroup)
    if ( Trig_Lycantrophy_Func013C() ) then
        call GroupAddUnitSimple(GetLastCreatedUnit(), udg_HeroesBossfightUG)
    else
    endif
    call SetHeroXP(udg_LycantrophyC2, GetHeroXP(udg_LycantrophyC), false)
    set bj_forLoopBIndex=1
    set bj_forLoopBIndexEnd=6
    loop
        exitwhen bj_forLoopBIndex > bj_forLoopBIndexEnd
        call UnitAddItemSwapped(udg_LycantrophyI[GetForLoopIndexB()], udg_LycantrophyC2)
        set bj_forLoopBIndex=bj_forLoopBIndex + 1
    endloop
    call SetUnitManaBJ(GetLastCreatedUnit(), ( GetUnitStateSwap(UNIT_STATE_MANA, GetTriggerUnit()) - ( 80.00 + ( 40.00 * I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) ) ) ))
    call BlzSetUnitMaxHP(GetLastCreatedUnit(), ( BlzGetUnitMaxHP(GetLastCreatedUnit()) + BlzGetUnitMaxHP(GetTriggerUnit()) ))
    call SetUnitLifePercentBJ(GetLastCreatedUnit(), 100)
    call ClearSelectionForPlayer(GetOwningPlayer(GetTriggerUnit()))
    call SelectUnitForPlayerSingle(GetLastCreatedUnit(), GetOwningPlayer(GetTriggerUnit()))
    call AddSpecialEffectTargetUnitBJ("chest", GetLastCreatedUnit(), "Abilities\\Weapons\\AvengerMissile\\AvengerMissile.mdl")
    call AddSpecialEffectTargetUnitBJ("head", GetLastCreatedUnit(), "Abilities\\Weapons\\AvengerMissile\\AvengerMissile.mdl")
    call AddSpecialEffectTargetUnitBJ("hand,left", GetLastCreatedUnit(), "Abilities\\Weapons\\AvengerMissile\\AvengerMissile.mdl")
    call AddSpecialEffectTargetUnitBJ("hand,right", GetLastCreatedUnit(), "Abilities\\Weapons\\AvengerMissile\\AvengerMissile.mdl")
    call AddSpecialEffectTargetUnitBJ("foot,left", GetLastCreatedUnit(), "Abilities\\Weapons\\AvengerMissile\\AvengerMissile.mdl")
    call AddSpecialEffectTargetUnitBJ("foot,right", GetLastCreatedUnit(), "Abilities\\Weapons\\AvengerMissile\\AvengerMissile.mdl")
    call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\Human\\Polymorph\\PolyMorphTarget.mdl")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 2.00)
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call AddSpecialEffectLocBJ(udg_tempLoc, "MagicCircle_Devil.mdx")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 1.50)
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call RemoveLocation(udg_tempLoc)
    call PlaySoundOnUnitBJ(gg_snd_Howl_mp3, 100, GetTriggerUnit())
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=udg_HeroNumber
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        if ( Trig_Lycantrophy_Func035Func001C() ) then
            call SetUnitOwner(udg_Backpack[GetForLoopIndexA()], Player(PLAYER_NEUTRAL_PASSIVE), false)
        else
        endif
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    call TriggerSleepAction(0.10)
    call PauseUnitBJ(true, GetTriggerUnit())
    call EnableTrigger(gg_trg_DeepWoundsPeriodic)
    call DisableTrigger(GetTriggeringTrigger())
endfunction

