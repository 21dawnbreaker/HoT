//===========================================================================
// Trigger: MutagenDealTextInit
//===========================================================================
function Trig_MutagenDealTextInit_Actions takes nothing returns nothing
    set udg_MutagenText[0]="Я уверена в своем продукте"
    set udg_MutagenText[1]="\"Колеса\"? Что это?"
    set udg_MutagenText[2]="Кажется, должно работать..."
    set udg_MutagenText[3]="Раньше я могла бы лишиться за это лицензии..."
    set udg_MutagenText[4]="Забавный результат. То есть... это и ожидалось"
    set udg_MutagenText[5]="Удивительно. Не думала, что вы еще будете способны дышать..."
    set udg_MutagenText[6]="Что и ожидалось"
    set udg_MutagenText[7]="Прошу проследовать в комнату осмотра"
    set udg_MutagenText[8]="Подержите этот подорожник на месте укола"
    set udg_MutagenText[9]="Это всего лишь царапина. Не стоит волноваться..."
    set udg_MutagenText_Named[0]="Не стоит благодарности... но и жаловаться потом тоже не нужно, "
    set udg_MutagenText_Named[1]="Не ожидала подобного интереса к науке от вас, "
    set udg_MutagenText_Named[2]="Уже больше не должно болеть. Возможно, кое-что атрофировалось, "
    set udg_MutagenText_Named[3]="Надеюсь, у вас крепкая печень, "
    call DisableTrigger(GetTriggeringTrigger())
endfunction

