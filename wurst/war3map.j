                call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
                call TriggerSleepAction(4.50)
                if ( Trig_FalseProphet_Func001Func008Func001Func006C() ) then
                    call CreateTextTagUnitBJ("TRIGSTR_001", gg_unit_H00E_0060, 0, 10, 100, 100, 100, 0)
                    call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
                    call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 3.00)
                    call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
                    call TriggerSleepAction(3.00)
                    if ( Trig_FalseProphet_Func001Func008Func001Func006Func009C() ) then
                        call CreateTextTagUnitBJ("TRIGSTR_003", gg_unit_H00E_0060, 0, 10, 100, 100, 100, 0)
                        call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
                        call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 5.00)
                        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
                        call TriggerSleepAction(1.00)
                        call DisableTrigger(gg_trg_FalseProphetBuffCheck)
                        call CreateTextTagUnitBJ(( "+ " + I2S(udg_FalseProphetGold) ), gg_unit_H00E_0060, 0, 10, 100, 100, 0.00, 0)
                        call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
                        call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 4.00)
                        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
                        call AdjustPlayerStateBJ(udg_FalseProphetGold, GetOwningPlayer(gg_unit_H00E_0060), PLAYER_STATE_RESOURCE_GOLD)
                        call PlaySoundOnUnitBJ(gg_snd_GoldSoundEff1, 100, gg_unit_H00E_0060)
                    else
                    endif
                else
                endif
            endif
        endif
        call TriggerSleepAction(1.00)
        call EnableTrigger(gg_trg_FalseProphetBuffCheck)
    endif
endfunction

