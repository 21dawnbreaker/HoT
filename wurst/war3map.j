//===========================================================================
function Trig_OrcishMight_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A06K' ) ) then
        return false
    endif
    return true
endfunction

function Trig_OrcishMight_Func001C takes nothing returns boolean
    if ( not ( UnitHasBuffBJ(GetSpellTargetUnit(), 'B01U') == true ) ) then
        return false
    endif
    return true
endfunction

