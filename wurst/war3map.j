//===========================================================================
// Trigger: Metamorphosis
//===========================================================================
function Trig_Metamorphosis_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A06D' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Metamorphosis_Func019C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Metamorphosis_Func020C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()) == 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Metamorphosis_Func021C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()) == 3 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Metamorphosis_Actions takes nothing returns nothing
    set udg_bones_of_netherworld_lvl=GetUnitAbilityLevelSwapped('A06D', GetTriggerUnit())
    set udg_HERO_DAMAGE_DEF_ALL[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]=( udg_HERO_DAMAGE_DEF_ALL[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))] + ( GetUnitAbilityLevelSwapped('A06D', GetTriggerUnit()) * 10 ) )
    set udg_HERO_DAMAGE_BONUS_ALL[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]=( udg_HERO_DAMAGE_BONUS_ALL[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))] + ( GetUnitAbilityLevelSwapped('A06D', GetTriggerUnit()) * 10 ) )
    set udg_tempLoc=GetUnitLoc(GetTriggerUnit())
    call AddSpecialEffectLocBJ(udg_tempLoc, "Call of Dread Green.mdx")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call RemoveLocation(udg_tempLoc)
    call AddSpecialEffectTargetUnitBJ("origin", GetTriggerUnit(), "Abilities\\Spells\\Items\\AIil\\AIilTarget.mdl")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call PlaySoundAtPointBJ(gg_snd_S03Guldan17, 100, GetUnitLoc(GetTriggerUnit()), 0)
    set udg_MetamorphSound=GetLastPlayedSound()
    call AddSpecialEffectTargetUnitBJ("chest", GetTriggerUnit(), "DemonicAdornment.mdx")
    set udg_MetamorphEff=GetLastCreatedEffectBJ()
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 1.75)
    call BlzSetSpecialEffectZ(GetLastCreatedEffectBJ(), ( BlzGetLocalSpecialEffectZ(GetLastCreatedEffectBJ()) + 30.00 ))
    call EnableTrigger(gg_trg_MetamorphPeriodic)
    if ( Trig_Metamorphosis_Func019C() ) then
        call UnitAddAbilityBJ('A06E', GetTriggerUnit())
    else
    endif
    if ( Trig_Metamorphosis_Func020C() ) then
        call UnitAddAbilityBJ('A06F', GetTriggerUnit())
    else
    endif
    if ( Trig_Metamorphosis_Func021C() ) then
        call UnitAddAbilityBJ('A06G', GetTriggerUnit())
    else
    endif
    call TriggerSleepAction(3.50)
    call StopSoundBJ(udg_MetamorphSound, false)
endfunction

//===========================================================================
function InitTrig_Metamorphosis takes nothing returns nothing
    set gg_trg_Metamorphosis=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Metamorphosis, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_Metamorphosis, Condition(function Trig_Metamorphosis_Conditions))
    call TriggerAddAction(gg_trg_Metamorphosis, function Trig_Metamorphosis_Actions)
endfunction

