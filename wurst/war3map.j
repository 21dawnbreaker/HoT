//===========================================================================
// Trigger: GiornosAidPeriodic
//===========================================================================
function Trig_GiornosAidPeriodic_Func001C takes nothing returns boolean
    if ( not ( IsUnitAliveBJ(gg_unit_U008_0255) == true ) ) then
        return false
    endif
    if ( not ( BlzIsUnitInvulnerable(gg_unit_H012_0027) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_GiornosAidPeriodic_Actions takes nothing returns nothing
    if ( Trig_GiornosAidPeriodic_Func001C() ) then
        set udg_giorno_loc=PolarProjectionBJ(GetUnitLoc(gg_unit_H012_0027), 350.00, GetRandomDirectionDeg())
        call CreateNUnitsAtLoc(1, 'U00L', GetOwningPlayer(gg_unit_H012_0027), udg_giorno_loc, bj_UNIT_FACING)
        call SetUnitColor(GetLastCreatedUnit(), PLAYER_COLOR_SNOW)
        call IssueTargetOrderBJ(GetLastCreatedUnit(), "unholyfrenzy", gg_unit_H012_0027)
        call SetUnitManaPercentBJ(GetLastCreatedUnit(), 100.00)
        call SetHeroLevelBJ(GetLastCreatedUnit(), GetUnitLevel(GroupPickRandomUnit(udg_HeroesGroup)), false)
        set udg_giorno=GetLastCreatedUnit()
        call AddSpecialEffectLocBJ(udg_giorno_loc, "Abilities\\Spells\\Items\\RitualDagger\\RitualDaggerTarget.mdl")
        call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 1.50)
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call TriggerSleepAction(1.50)
        call RemoveUnit(udg_giorno)
        call AddSpecialEffectLocBJ(udg_giorno_loc, "Abilities\\Spells\\Items\\RitualDagger\\RitualDaggerTarget.mdl")
        call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 1.50)
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call RemoveLocation(udg_giorno_loc)
    else
        call DisableTrigger(GetTriggeringTrigger())
    endif
endfunction

