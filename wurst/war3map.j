    call UnitRemoveAbilityBJ('A025', GetEnumUnit())
    call UnitRemoveAbilityBJ('A026', GetEnumUnit())
    call UnitRemoveAbilityBJ('A027', GetEnumUnit())
    call UnitRemoveAbilityBJ('A028', GetEnumUnit())
endfunction

function Trig_SacredGround_Actions takes nothing returns nothing
    set udg_SacredGround=GetSpellTargetLoc()
    call PlaySoundAtPointBJ(gg_snd_ResurrectTarget, 100, udg_SacredGround, 0)
    call AddSpecialEffectLocBJ(udg_SacredGround, "BlessedField.mdx")
    set udg_SacredGroundEff=GetLastCreatedEffectBJ()
    call EnableTrigger(gg_trg_SacredGroundPeriodic)
    call TriggerSleepAction(7.00)
    call DestroyEffectBJ(udg_SacredGroundEff)
    call TriggerSleepAction(5.00)
    call ForGroupBJ(udg_SacredGroundGroup, function Trig_SacredGround_Func011A)
    call GroupRemoveGroup(udg_SacredGroundGroup, udg_SacredGroundGroup)
    call DisableTrigger(gg_trg_SacredGroundPeriodic)
    call DestroyEffectBJ(udg_SacredGroundEff)
