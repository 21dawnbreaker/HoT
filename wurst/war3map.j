// Trigger: ShiadalPeriodic
//===========================================================================
function Trig_ShiadalPeriodic_Conditions takes nothing returns boolean
    if ( not ( udg_BossfightDialogueInt == 0 ) ) then
        return false
    endif
    if ( not ( udg_BossfightMainIsOn == 1 ) ) then
        return false
    endif
    if ( not ( udg_BossfightShiadal == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ShiadalPeriodic_Actions takes nothing returns nothing
    set udg_tempLoc=GetUnitLoc(GroupPickRandomUnit(udg_HeroesGroup))
    call IssuePointOrderLocBJ(gg_unit_E002_0526, "attack", udg_tempLoc)
    call RemoveLocation(udg_tempLoc)
endfunction

//===========================================================================
function InitTrig_ShiadalPeriodic takes nothing returns nothing
    set gg_trg_ShiadalPeriodic=CreateTrigger()
    call DisableTrigger(gg_trg_ShiadalPeriodic)
    call TriggerRegisterTimerEventPeriodic(gg_trg_ShiadalPeriodic, 3.00)
    call TriggerAddCondition(gg_trg_ShiadalPeriodic, Condition(function Trig_ShiadalPeriodic_Conditions))
    call TriggerAddAction(gg_trg_ShiadalPeriodic, function Trig_ShiadalPeriodic_Actions)
endfunction

//===========================================================================
// Trigger: ShiadalInit
//===========================================================================
function Trig_ShiadalInit_Func001A takes nothing returns nothing
    call SetCameraBoundsToRectForPlayerBJ(GetEnumPlayer(), gg_rct_MainBossLoc)
    call PanCameraToTimedLocForPlayer(GetEnumPlayer(), GetRectCenter(gg_rct_StartLoc), 0)
endfunction

function Trig_ShiadalInit_Func020C takes nothing returns boolean
    if ( not ( udg_DIFFICULTY == 3 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ShiadalInit_Func021C takes nothing returns boolean
    if ( not ( udg_DIFFICULTY >= 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ShiadalInit_Actions takes nothing returns nothing
    call ForForce(udg_PlayerGroup, function Trig_ShiadalInit_Func001A)
    set udg_BossPhase=1
    set udg_Boss[1]=gg_unit_E002_0526
    call GroupAddUnitSimple(gg_unit_E002_0526, udg_BossUG)
    call SetUnitPositionLocFacingBJ(gg_unit_E002_0526, GetRectCenter(gg_rct_BossfightBossLoc), 0.00)
    // BOSS STATS
    call BlzSetUnitMaxHP(gg_unit_E002_0526, ( BlzGetUnitMaxHP(gg_unit_E002_0526) + ( R2I(( udg_difficultyReal * GetUnitStateSwap(UNIT_STATE_MAX_LIFE, gg_unit_E002_0526) )) * R2I(udg_RoomMultiboardCounting) ) ))
    call BlzSetUnitMaxHP(udg_Boss[1], ( BlzGetUnitMaxHP(udg_Boss[1]) * 3 ))
    call SetUnitLifePercentBJ(udg_Boss[1], 100)
    set udg_tempReal=I2R(BlzGetUnitBaseDamage(gg_unit_E002_0526, 0))
    call BlzSetUnitBaseDamage(gg_unit_E002_0526, ( BlzGetUnitBaseDamage(gg_unit_E002_0526, 0) + ( R2I(( udg_tempReal * udg_difficultyReal )) * R2I(udg_RoomMultiboardCounting) ) ), 0)
    call BlzSetUnitBaseDamage(gg_unit_E002_0526, ( BlzGetUnitBaseDamage(gg_unit_E002_0526, 0) * 3 ), 0)
    set udg_tempReal=0.00
    call SetUnitManaPercentBJ(gg_unit_E002_0526, 0.00)
    call SetHeroLevelBJ(gg_unit_E002_0526, GetUnitLevel(GroupPickRandomUnit(udg_HeroesGroup)), false)
    // ---
    set udg_BossHP=GetUnitStateSwap(UNIT_STATE_LIFE, gg_unit_E002_0526)
    set udg_BossfightShiadal=1
    // ---
    if ( Trig_ShiadalInit_Func020C() ) then
    else
        call UnitRemoveAbilityBJ('A0IF', udg_Boss[1])
    endif
    if ( Trig_ShiadalInit_Func021C() ) then
    else
    endif
    call PauseUnitBJ(true, udg_Boss[1])
    call SetUnitInvulnerable(udg_Boss[1], true)
    call TriggerSleepAction(7.00)
    call PauseUnitBJ(false, udg_Boss[1])
    call SetUnitInvulnerable(udg_Boss[1], false)
    call EnableTrigger(gg_trg_ShiadalPeriodic)
    call TriggerExecute(gg_trg_Phase1_Shiadal)
endfunction

//===========================================================================
function InitTrig_ShiadalInit takes nothing returns nothing
    set gg_trg_ShiadalInit=CreateTrigger()
    call TriggerAddAction(gg_trg_ShiadalInit, function Trig_ShiadalInit_Actions)
endfunction

