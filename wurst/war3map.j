function Trig_Chain_of_Disturbance_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A045' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Chain_of_Disturbance_Func013Func001C takes nothing returns boolean
    if ( not ( IsUnitType(GetEnumUnit(), UNIT_TYPE_HERO) == true ) ) then
        return false
    endif
    if ( not ( IsUnitAlly(GetEnumUnit(), GetOwningPlayer(GetTriggerUnit())) == true ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Chain_of_Disturbance_Func013A takes nothing returns nothing
    if ( Trig_Chain_of_Disturbance_Func013Func001C() ) then
        call SetUnitLifePercentBJ(GetEnumUnit(), ( GetUnitLifePercent(GetEnumUnit()) + 10.00 ))
        call AddSpecialEffectTargetUnitBJ("origin", GetEnumUnit(), "Abilities\\Spells\\Undead\\VampiricAura\\VampiricAuraTarget.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
    else
    endif
endfunction

function Trig_Chain_of_Disturbance_Func021Func001Func006Func001C takes nothing returns boolean
    if ( not ( IsUnitType(GetEnumUnit(), UNIT_TYPE_HERO) == true ) ) then
        return false
    endif
    if ( not ( IsUnitAlly(GetEnumUnit(), GetOwningPlayer(GetTriggerUnit())) == true ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Chain_of_Disturbance_Func021Func001Func006A takes nothing returns nothing
    if ( Trig_Chain_of_Disturbance_Func021Func001Func006Func001C() ) then
        call SetUnitLifePercentBJ(GetEnumUnit(), ( GetUnitLifePercent(GetEnumUnit()) + 1 ))
    else
    endif
endfunction

function Trig_Chain_of_Disturbance_Func021Func001C takes nothing returns boolean
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(GetTriggerUnit())) == true ) ) then
        return false
    endif
    if ( not ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_STRUCTURE) == false ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( GetEnumUnit() != GetSpellTargetUnit() ) ) then
        return false
    endif
    return true
endfunction

function Trig_Chain_of_Disturbance_Func021A takes nothing returns nothing
    if ( Trig_Chain_of_Disturbance_Func021Func001C() ) then
        set udg_DisturbanceZ2=( BlzGetLocalUnitZ(GetEnumUnit()) + 50.00 )
        set udg_DisturbanceX2=GetLocationX(GetUnitLoc(GetEnumUnit()))
        set udg_DisturbanceY2=GetLocationY(GetUnitLoc(GetEnumUnit()))
        set udg_Disturbance=AddLightningEx("MBUR", true, udg_DisturbanceX2, udg_DisturbanceY2, udg_DisturbanceZ2, udg_DisturbanceX1, udg_DisturbanceY1, udg_DisturbanceZ1)
        call UnitDamageTargetBJ(GetTriggerUnit(), GetEnumUnit(), ( ( 70.00 * I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) ) + ( ( 0.50 * I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) ) * I2R(GetHeroStatBJ(bj_HEROSTAT_INT, GetTriggerUnit(), true)) ) ), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_MAGIC)
        call ForGroupBJ(GetUnitsInRangeOfLocAll(900.00, udg_DisturbancePrimaryPos), function Trig_Chain_of_Disturbance_Func021Func001Func006A)
        call TriggerSleepAction(0.10)
        call DestroyLightningBJ(udg_Disturbance)
    else
    endif
endfunction

function Trig_Chain_of_Disturbance_Actions takes nothing returns nothing
    set udg_DisturbancePrimaryPos=GetUnitLoc(GetSpellTargetUnit())
    set udg_DisturbanceZ1=( BlzGetLocalUnitZ(GetTriggerUnit()) + 50.00 )
    set udg_DisturbanceX1=GetLocationX(GetUnitLoc(GetTriggerUnit()))
    set udg_DisturbanceY1=GetLocationY(GetUnitLoc(GetTriggerUnit()))
    set udg_DisturbanceZ2=( BlzGetLocalUnitZ(GetSpellTargetUnit()) + 50.00 )
    set udg_DisturbanceX2=GetLocationX(udg_DisturbancePrimaryPos)
    set udg_DisturbanceY2=GetLocationY(udg_DisturbancePrimaryPos)
    set udg_Disturbance2=AddLightningEx("MBUR", true, udg_DisturbanceX2, udg_DisturbanceY2, udg_DisturbanceZ2, udg_DisturbanceX1, udg_DisturbanceY1, udg_DisturbanceZ1)
    call PlaySoundOnUnitBJ(gg_snd_ManaFlareStrike, 100, GetSpellTargetUnit())
    call UnitDamageTargetBJ(GetTriggerUnit(), GetSpellTargetUnit(), ( ( 35.00 * I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) ) + ( ( 0.25 * I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) ) * I2R(GetHeroStatBJ(bj_HEROSTAT_INT, GetTriggerUnit(), true)) ) ), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_MAGIC)
    call ForGroupBJ(GetUnitsInRangeOfLocAll(900.00, udg_DisturbancePrimaryPos), function Trig_Chain_of_Disturbance_Func013A)
    call RemoveLocation(udg_DisturbancePrimaryPos)
    call TriggerSleepAction(0.10)
    call DestroyLightningBJ(udg_Disturbance2)
    set udg_DisturbancePrimaryPos=GetUnitLoc(GetSpellTargetUnit())
    set udg_DisturbanceZ1=( BlzGetLocalUnitZ(GetSpellTargetUnit()) + 50.00 )
    set udg_DisturbanceX1=GetLocationX(udg_DisturbancePrimaryPos)
    set udg_DisturbanceY1=GetLocationY(udg_DisturbancePrimaryPos)
    call ForGroupBJ(GetUnitsInRangeOfLocAll(300.00, udg_DisturbancePrimaryPos), function Trig_Chain_of_Disturbance_Func021A)
    call RemoveLocation(udg_DisturbancePrimaryPos)
endfunction

