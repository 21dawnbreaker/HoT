//===========================================================================
// Trigger: ManaBurst
//===========================================================================
function Trig_ManaBurst_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A02A' ) ) then
        return false
    endif
    return true
endfunction

function Trig_ManaBurst_Func002Func001Func002C takes nothing returns boolean
    if ( not ( IsUnitInGroup(GetEnumUnit(), udg_not_knockbackable_UG) == false ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( BlzIsUnitInvulnerable(GetTriggerUnit()) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_ManaBurst_Func002Func001C takes nothing returns boolean
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(gg_unit_E001_0061)) == true ) ) then
        return false
    endif
    if ( not ( IsUnitType(GetEnumUnit(), UNIT_TYPE_STRUCTURE) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_ManaBurst_Func002A takes nothing returns nothing
    if ( Trig_ManaBurst_Func002Func001C() ) then
        call UnitDamageTargetBJ(GetTriggerUnit(), GetEnumUnit(), ( I2R(GetHeroStatBJ(bj_HEROSTAT_STR, GetTriggerUnit(), true)) * 2.00 ), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_MAGIC)
        if ( Trig_ManaBurst_Func002Func001Func002C() ) then
            set udg_KBA_Caster=GetTriggerUnit()
            set udg_KBA_TargetUnit=GetEnumUnit()
            set udg_KBA_Level=1
            set udg_KBA_StartingPosition=GetUnitLoc(GetTriggerUnit())
            set udg_KBA_Speed=5.00
            set udg_KBA_DistancePerLevel=250.00
            set udg_KBA_SpecialEffects[1]="Abilities\\Spells\\Human\\FlakCannons\\FlakTarget.mdl"
            set udg_KBA_SpecialEffects[2]="Abilities\\Weapons\\AncientProtectorMissile\\AncientProtectorMissile.mdl"
            set udg_KBA_DestroyTrees=false
            call ConditionalTriggerExecute(gg_trg_Cast_A_Knockback)
        else
        endif
    else
    endif
endfunction

function Trig_ManaBurst_Func004C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 100) <= 40 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ManaBurst_Func008Func001Func001Func001Func001C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()) == 5 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ManaBurst_Func008Func001Func001Func001C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()) == 4 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ManaBurst_Func008Func001Func001C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()) == 3 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ManaBurst_Func008Func001C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()) == 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ManaBurst_Func008C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ManaBurst_Actions takes nothing returns nothing
    set udg_tempLoc=GetUnitLoc(gg_unit_E001_0061)
    call ForGroupBJ(GetUnitsInRangeOfLocAll(250.00, udg_tempLoc), function Trig_ManaBurst_Func002A)
    call RemoveLocation(udg_tempLoc)
    if ( Trig_ManaBurst_Func004C() ) then
        call PlaySoundOnUnitBJ(gg_snd_Legcom_respawn_12_rump3, 100.00, gg_unit_E001_0061)
    else
    endif
    call EnableTrigger(gg_trg_ManaBurstPeriodic)
    if ( Trig_ManaBurst_Func008C() ) then
        call UnitAddAbilityBJ('A02D', GetTriggerUnit())
    else
        if ( Trig_ManaBurst_Func008Func001C() ) then
            call UnitAddAbilityBJ('A02B', GetTriggerUnit())
        else
            if ( Trig_ManaBurst_Func008Func001Func001C() ) then
                call UnitAddAbilityBJ('A02E', GetTriggerUnit())
            else
                if ( Trig_ManaBurst_Func008Func001Func001Func001C() ) then
                    call UnitAddAbilityBJ('A021', GetTriggerUnit())
                else
                    if ( Trig_ManaBurst_Func008Func001Func001Func001Func001C() ) then
                        call UnitAddAbilityBJ('A02F', GetTriggerUnit())
                    else
                    endif
                endif
            endif
        endif
    endif
endfunction

//===========================================================================
function InitTrig_ManaBurst takes nothing returns nothing
    set gg_trg_ManaBurst=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_ManaBurst, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_ManaBurst, Condition(function Trig_ManaBurst_Conditions))
    call TriggerAddAction(gg_trg_ManaBurst, function Trig_ManaBurst_Actions)
