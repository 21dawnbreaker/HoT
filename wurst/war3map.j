        return false
    endif
    return true
endfunction

function Trig_Despair_Func001Func002C takes nothing returns boolean
    if ( ( GetUnitAbilityLevelSwapped('A07Y', GetSpellTargetUnit()) > 1 ) ) then
        return true
    endif
    if ( ( GetUnitAbilityLevelSwapped('A07Z', GetSpellTargetUnit()) > 1 ) ) then
        return true
    endif
    if ( ( GetUnitRace(GetEnumUnit()) == RACE_DEMON ) ) then
        return true
    endif
    return false
endfunction

