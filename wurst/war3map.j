        return false
    endif
    if ( not ( udg_TrickShotInt == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_TrickShotDmg_Func011Func001C takes nothing returns boolean
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(gg_unit_H00P_0279)) == true ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_TrickShotDmg_Func011A takes nothing returns nothing
    if ( Trig_TrickShotDmg_Func011Func001C() ) then
        call CreateNUnitsAtLoc(1, 'h00W', GetOwningPlayer(gg_unit_H00P_0279), udg_tempLoc, bj_UNIT_FACING)
        call IssueTargetOrderBJ(GetLastCreatedUnit(), "thunderbolt", GetEnumUnit())
        call UnitApplyTimedLifeBJ(2.00, 'BTLF', GetLastCreatedUnit())
        call UnitDamageTargetBJ(gg_unit_H00P_0279, GetEnumUnit(), ( ( 90.00 * I2R(GetUnitAbilityLevelSwapped('A08V', gg_unit_H00P_0279)) ) + ( ( I2R(GetUnitAbilityLevelSwapped('A08V', gg_unit_H00P_0279)) * 0.50 ) * I2R(GetHeroStatBJ(bj_HEROSTAT_AGI, gg_unit_H00P_0279, true)) ) ), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_MAGIC)
    else
    endif
endfunction

function Trig_TrickShotDmg_Actions takes nothing returns nothing
    set udg_TrickShotInt=1
    call AddSpecialEffectTargetUnitBJ("chest", udg_TrickShotT, "ArcaneMissileComplete.mdx")
    set udg_TrickShotEff=GetLastCreatedEffectBJ()
    call TriggerSleepAction(2)
    set udg_TrickShotInt=0
    set udg_tempLoc=GetUnitLoc(udg_TrickShotT)
    set udg_TrickShotT=null
