//===========================================================================
// Trigger: Baron
//===========================================================================
function Trig_Baron_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A01J' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Baron_Func013Func001Func001C takes nothing returns boolean
    if ( not ( udg_BaronRoll <= 33 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Baron_Func013Func001C takes nothing returns boolean
    if ( not ( udg_BaronRoll > 33 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Baron_Func013C takes nothing returns boolean
    if ( not ( udg_BaronRoll > 77 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Baron_Func014Func001C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()) == 3 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Baron_Func014C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()) == 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Baron_Actions takes nothing returns nothing
    call DestroyEffectBJ(udg_BaronEff)
    call DestroyEffectBJ(udg_BaronEff2)
    call DestroyEffectBJ(udg_BaronEff3)
    call DestroyEffectBJ(udg_BaronEff4)
    call DestroyEffectBJ(udg_BaronEff5)
    call DestroyEffectBJ(udg_BaronEff6)
    call CreateNUnitsAtLoc(1, 'n00B', GetOwningPlayer(GetTriggerUnit()), udg_BaronPoint, GetUnitFacing(GetTriggerUnit()))
    set udg_LuaneFollower=GetLastCreatedUnit()
    call BlzSetUnitMaxHP(GetLastCreatedUnit(), ( BlzGetUnitMaxMana(GetTriggerUnit()) * 5 ))
    call UnitApplyTimedLifeBJ(240.00, 'BTLF', GetLastCreatedUnit())
    call BlzSetUnitBaseDamage(GetLastCreatedUnit(), ( ( GetHeroStatBJ(bj_HEROSTAT_INT, gg_unit_H00B_0036, true) * 2 ) * 1 ), 1)
    set udg_BaronRoll=GetRandomInt(1, 100)
    if ( Trig_Baron_Func013C() ) then
        call PlaySoundOnUnitBJ(gg_snd_HPitLordWhat2, 100, GetLastCreatedUnit())
    else
        if ( Trig_Baron_Func013Func001C() ) then
            call PlaySoundOnUnitBJ(gg_snd_HPitLordWhat3, 100, GetLastCreatedUnit())
        else
            if ( Trig_Baron_Func013Func001Func001C() ) then
                call PlaySoundOnUnitBJ(gg_snd_HPitLordYesAttack1, 100, GetLastCreatedUnit())
            else
            endif
        endif
    endif
    if ( Trig_Baron_Func014C() ) then
        call UnitAddAbilityBJ('A01K', GetLastCreatedUnit())
    else
        if ( Trig_Baron_Func014Func001C() ) then
            call UnitAddAbilityBJ('A01K', GetLastCreatedUnit())
            call UnitAddAbilityBJ('A01L', GetLastCreatedUnit())
        else
        endif
    endif
    set udg_Baron=GetLastCreatedUnit()
    call AddSpecialEffectLocBJ(GetUnitLoc(udg_Baron), "AnnihilationBlast.mdx")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 1.50)
    set udg_BaronEff=GetLastCreatedEffectBJ()
    call TriggerSleepAction(5.00)
    call DestroyEffectBJ(udg_BaronEff)
endfunction

//===========================================================================
function InitTrig_Baron takes nothing returns nothing
    set gg_trg_Baron=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Baron, EVENT_PLAYER_UNIT_SPELL_FINISH)
    call TriggerAddCondition(gg_trg_Baron, Condition(function Trig_Baron_Conditions))
    call TriggerAddAction(gg_trg_Baron, function Trig_Baron_Actions)
endfunction

