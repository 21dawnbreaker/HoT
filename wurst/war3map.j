    call RemoveItem(GetItemOfTypeFromUnitBJ(GetTriggerUnit(), 'I0A5'))
    call UnitAddItemByIdSwapped(ChooseRandomItemBJ(5), GetTriggerUnit())
    call AddSpecialEffectTargetUnitBJ("origin", GetTriggerUnit(), "Call of Dread Green.mdx")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
endfunction

