function InitTrig_LifeTap takes nothing returns nothing
    set gg_trg_LifeTap=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_LifeTap, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_LifeTap, Condition(function Trig_LifeTap_Conditions))
    call TriggerAddAction(gg_trg_LifeTap, function Trig_LifeTap_Actions)
endfunction

