    set gg_trg_JadAsKir_good=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_JadAsKir_good, EVENT_PLAYER_UNIT_SELL)
    call TriggerAddCondition(gg_trg_JadAsKir_good, Condition(function Trig_JadAsKir_good_Conditions))
