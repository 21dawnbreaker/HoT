//===========================================================================
// Trigger: WarShout
//===========================================================================
function Trig_WarShout_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A002' ) ) then
        return false
    endif
    return true
endfunction

function Trig_WarShout_Func002Func001C takes nothing returns boolean
    if ( not ( GetEnumUnit() != GetTriggerUnit() ) ) then
        return false
    endif
    if ( not ( IsUnitAlly(GetEnumUnit(), GetOwningPlayer(GetTriggerUnit())) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_WarShout_Func002A takes nothing returns nothing
    if ( Trig_WarShout_Func002Func001C() ) then
        call SetUnitManaBJ(GetEnumUnit(), ( GetUnitStateSwap(UNIT_STATE_MANA, GetEnumUnit()) + 20.00 ))
    else
    endif
endfunction

function Trig_WarShout_Func003Func001C takes nothing returns boolean
    if ( not ( IsUnitAlly(GetEnumUnit(), GetOwningPlayer(GetTriggerUnit())) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_WarShout_Func003A takes nothing returns nothing
    if ( Trig_WarShout_Func003Func001C() ) then
        call UnitRemoveBuffBJ('B00C', GetEnumUnit())
    else
    endif
endfunction

function Trig_WarShout_Func004C takes nothing returns boolean
    if ( not ( udg_musicOn == 0 ) ) then
        return false
    endif
    if ( not ( udg_BossfightMainIsOn == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_WarShout_Actions takes nothing returns nothing
    call PlaySoundOnUnitBJ(gg_snd_FarseerThrallWarcry1, 100, GetTriggerUnit())
    call ForGroupBJ(GetUnitsInRangeOfLocAll(1500.00, GetUnitLoc(GetTriggerUnit())), function Trig_WarShout_Func002A)
    call ForGroupBJ(GetUnitsInRangeOfLocAll(1500.00, GetUnitLoc(GetTriggerUnit())), function Trig_WarShout_Func003A)
    if ( Trig_WarShout_Func004C() ) then
        call PlayThematicMusicBJ("LergzanUlti.mp3")
        call SetMusicVolumeBJ(100.00)
        set udg_musicOn=1
        call StartTimerBJ(udg_MusicTimer, false, 41.10)
    else
    endif
endfunction

//===========================================================================
function InitTrig_WarShout takes nothing returns nothing
    set gg_trg_WarShout=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_WarShout, EVENT_PLAYER_UNIT_SPELL_CAST)
    call TriggerAddCondition(gg_trg_WarShout, Condition(function Trig_WarShout_Conditions))
    call TriggerAddAction(gg_trg_WarShout, function Trig_WarShout_Actions)
endfunction

