    set gg_trg_BossfightNataAraEnd=CreateTrigger()
    call TriggerRegisterUnitEvent(gg_trg_BossfightNataAraEnd, gg_unit_U006_0283, EVENT_UNIT_DEATH)
    call TriggerRegisterUnitEvent(gg_trg_BossfightNataAraEnd, gg_unit_U005_0113, EVENT_UNIT_DEATH)
