        call ForGroupBJ(udg_HeroesGroup, function Trig_GoldenConsulEffect_Func003Func001A)
        set udg_GoldenConsulStoriesAvaible[3]=0
    else
    endif
    if ( Trig_GoldenConsulEffect_Func004C() ) then
        call DoNothing()
        set udg_GoldenConsulStoriesAvaible[4]=0
    else
    endif
    // Remove stories
    if ( Trig_GoldenConsulEffect_Func006C() ) then
    else
        call RemoveUnitFromAllStock(udg_GoldenConsulEffect)
    endif
    set udg_GoldenConsulEffect=0
    call RemoveLocation(udg_tempLoc)
endfunction

