    call UnitDamageTargetBJ(udg_DamageEventSource, udg_DamageEventSource, udg_inevitable_end_per_player_real[GetConvertedPlayerId(GetOwningPlayer(udg_DamageEventSource))], ATTACK_TYPE_CHAOS, DAMAGE_TYPE_MAGIC)
