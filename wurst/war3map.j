//===========================================================================
// Trigger: EXAMPLE GUI Save
//
// NSL_SavePlayer (variable type=Player) is the player being saved
// > Enabled and don't turn Initially On
// > Do not add anything in the `Events` and `Conditions` blocks
// > When finished, set `NSL_EventExecutorSaveCompleted` to 1.0
//===========================================================================
function Trig_EXAMPLE_GUI_Save_Actions takes nothing returns nothing
    // Easy-life variable
    set udg_NSL_PlayerId=GetConvertedPlayerId(udg_NSL_SavePlayer)
    set udg_NSL_Hero=GroupPickRandomUnit(GetUnitsSelectedAll(udg_NSL_SavePlayer))
    // Saving random numbers
    call SaveIntegerBJ(12345, 1, udg_NSL_PlayerId, udg_NSL_GUIHashtable)
    call SaveIntegerBJ(98765, 2, udg_NSL_PlayerId, udg_NSL_GUIHashtable)
    call SaveIntegerBJ(- 1500, 3, udg_NSL_PlayerId, udg_NSL_GUIHashtable)
    // Convert Hero
    set udg_NSL_UnitType=GetUnitTypeId(udg_NSL_Hero)
    // Use this custom script to convert an unit-type to an integer for GUI integration
    set udg_NSL_ConvertedUnitType=udg_NSL_UnitType
    call SaveIntegerBJ(udg_NSL_ConvertedUnitType, 4, udg_NSL_PlayerId, udg_NSL_GUIHashtable)
    // Convert Items
    // Store values at index [ 5 to 10 ]
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=6
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        set udg_NSL_Item=UnitItemInSlotBJ(udg_NSL_Hero, GetForLoopIndexA())
        set udg_NSL_ItemType=GetItemTypeId(udg_NSL_Item)
        // Use this custom script to convert an item-type to an integer for GUI integration
        set udg_NSL_ConvertedItemType=udg_NSL_ItemType
        call SaveIntegerBJ(udg_NSL_ConvertedItemType, ( 4 + GetForLoopIndexA() ), udg_NSL_PlayerId, udg_NSL_GUIHashtable)
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    // Store values at index [ 11 to 16 ]
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=6
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        set udg_NSL_Item=UnitItemInSlotBJ(udg_NSL_Hero, GetForLoopIndexA())
        call SaveIntegerBJ(GetItemCharges(udg_NSL_Item), ( 10 + GetForLoopIndexA() ), udg_NSL_PlayerId, udg_NSL_GUIHashtable)
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    // When finished saving, set `NSL_EventExecutorSaveCompleted` to 1.0
    set udg_NSL_EventExecutorSaveCompleted=1.00
endfunction

//===========================================================================
function InitTrig_EXAMPLE_GUI_Save takes nothing returns nothing
    set gg_trg_EXAMPLE_GUI_Save=CreateTrigger()
    call DisableTrigger(gg_trg_EXAMPLE_GUI_Save)
    call TriggerAddAction(gg_trg_EXAMPLE_GUI_Save, function Trig_EXAMPLE_GUI_Save_Actions)
endfunction

