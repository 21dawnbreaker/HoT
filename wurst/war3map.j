    call RemoveLocation(udg_tempLoc)
    call TriggerSleepAction(1.00)
    call ForGroupBJ(udg_RunestoneMasterUG, function Trig_RunestoneMaster_Func005A)
    call TriggerSleepAction(4.00)
    call GroupRemoveGroup(udg_RunestoneMasterUG, udg_RunestoneMasterUG)
endfunction

