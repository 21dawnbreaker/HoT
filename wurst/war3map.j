    if ( not ( UnitHasBuffBJ(GetEnumUnit(), 'B00J') == true ) ) then
        return false
    endif
    if ( not ( GetUnitAbilityLevelSwapped('A082', GetEnumUnit()) < 7 ) ) then
        return false
    endif
    return true
endfunction

function Trig_IntimidatingShoutMove_Func001A takes nothing returns nothing
    if ( Trig_IntimidatingShoutMove_Func001Func001C() ) then
        set udg_tempLoc=GetUnitLoc(gg_unit_O00C_0065)
        set udg_tempLoc2=GetUnitLoc(GetEnumUnit())
        call IssuePointOrderLocBJ(GetEnumUnit(), "move", PolarProjectionBJ(GetUnitLoc(GetEnumUnit()), 256, AngleBetweenPoints(udg_tempLoc, udg_tempLoc2)))
        call RemoveLocation(udg_tempLoc)
        call RemoveLocation(udg_tempLoc2)
    else
        call UnitRemoveAbilityBJ('Abun', GetEnumUnit())
        call GroupRemoveUnitSimple(GetEnumUnit(), udg_IntimidatingShoutGroup)
    endif
endfunction

function Trig_IntimidatingShoutMove_Actions takes nothing returns nothing
    call ForGroupBJ(udg_IntimidatingShoutGroup, function Trig_IntimidatingShoutMove_Func001A)
