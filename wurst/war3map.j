//===========================================================================
// Trigger: SellRemoving
//===========================================================================
function Trig_SellRemoving_Func002C takes nothing returns boolean
    if ( ( GetItemTypeId(GetSoldItem()) == 'I01I' ) ) then
        return true
    endif
    if ( ( GetItemTypeId(GetSoldItem()) == 'I01K' ) ) then
        return true
    endif
    if ( ( GetItemTypeId(GetSoldItem()) == 'I01J' ) ) then
        return true
    endif
    return false
endfunction

function Trig_SellRemoving_Conditions takes nothing returns boolean
    if ( not Trig_SellRemoving_Func002C() ) then
        return false
    endif
    return true
endfunction

function Trig_SellRemoving_Func003C takes nothing returns boolean
    if ( not ( GetItemCharges(GetItemOfTypeFromUnitBJ(udg_IngotFareU, 'I01J')) == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_SellRemoving_Func004C takes nothing returns boolean
    if ( not ( GetItemCharges(GetItemOfTypeFromUnitBJ(udg_IngotFareU, 'I01I')) == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_SellRemoving_Func005C takes nothing returns boolean
    if ( not ( GetItemCharges(GetItemOfTypeFromUnitBJ(udg_IngotFareU, 'I01K')) == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_SellRemoving_Func006C takes nothing returns boolean
    if ( not ( GetItemCharges(GetItemOfTypeFromUnitBJ(udg_IngotFareU, 'I01L')) == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_SellRemoving_Actions takes nothing returns nothing
    call TriggerSleepAction(0.02)
    if ( Trig_SellRemoving_Func003C() ) then
        call RemoveItem(GetItemOfTypeFromUnitBJ(udg_IngotFareU, 'I01J'))
    else
    endif
    if ( Trig_SellRemoving_Func004C() ) then
        call RemoveItem(GetItemOfTypeFromUnitBJ(udg_IngotFareU, 'I01I'))
    else
    endif
    if ( Trig_SellRemoving_Func005C() ) then
        call RemoveItem(GetItemOfTypeFromUnitBJ(udg_IngotFareU, 'I01K'))
    else
    endif
    if ( Trig_SellRemoving_Func006C() ) then
        call RemoveItem(GetItemOfTypeFromUnitBJ(udg_IngotFareU, 'I01L'))
    else
    endif
endfunction

