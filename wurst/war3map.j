        else
        endif
        if ( Trig_SoundItemDropsByClass_Func002Func007C() ) then
            set udg_ItemDropSound=gg_snd_diablo2_largemetalweapon
        else
        endif
        call PlaySoundAtPointBJ(udg_ItemDropSound, 100, udg_chest_pos, udg_tempZ)
        set udg_ItemDropSound=GetLastPlayedSound()
        set udg_tempZ=0.00
    endif
endfunction

