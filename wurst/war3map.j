    call BlzSetSpecialEffectColorByPlayer(GetLastCreatedEffectBJ(), Player(4))
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call StopSoundBJ(udg_blade_of_justice_sound, false)
    call PlaySoundOnUnitBJ(gg_snd_Spell_PA_BladeofJustice_Cast_Revamp_03, 100, GetTriggerUnit())
    set udg_blade_of_justice_sound=GetLastPlayedSound()
    call UnitDamageTargetBJ(GetTriggerUnit(), GetSpellTargetUnit(), ( ( I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) * 0.50 ) * I2R(GetHeroStatBJ(bj_HEROSTAT_STR, GetTriggerUnit(), true)) ), ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL)
    call UnitDamageTargetBJ(GetTriggerUnit(), GetSpellTargetUnit(), ( 75.00 * I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) ), ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL)
    call SetUnitLifePercentBJ(GetTriggerUnit(), ( GetUnitLifePercent(GetTriggerUnit()) + ( I2R(GetUnitAbilityLevelSwapped('A04K', gg_unit_H00N_0277)) * 3.00 ) ))
