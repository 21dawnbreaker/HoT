        return false
    endif
    return true
endfunction

function Trig_ShiadalDamaged_Func002C takes nothing returns boolean
    if ( not ( udg_BossPhase >= 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ShiadalDamaged_Func003C takes nothing returns boolean
    if ( not ( udg_BossPhase >= 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ShiadalDamaged_Actions takes nothing returns nothing
    if ( Trig_ShiadalDamaged_Func001C() ) then
        call IssueImmediateOrderBJ(udg_DamageEventTarget, "waterelemental")
    else
    endif
    if ( Trig_ShiadalDamaged_Func002C() ) then
        call IssueImmediateOrderBJ(udg_DamageEventTarget, "summongrizzly")
    else
    endif
    if ( Trig_ShiadalDamaged_Func003C() ) then
        call IssueImmediateOrderBJ(udg_DamageEventTarget, "berserk")
    else
    endif
    call DisableTrigger(GetTriggeringTrigger())
    call TriggerSleepAction(GetRandomReal(1.00, 2.50))
