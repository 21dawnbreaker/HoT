    if ( not ( GetRandomInt(1, 2) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_BossDiesGeneralFunc_Func006C takes nothing returns boolean
    if ( not ( udg_tempUnit == gg_unit_E002_0526 ) ) then
        return false
    endif
    return true
endfunction

function Trig_BossDiesGeneralFunc_Func019Func001C takes nothing returns boolean
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(GroupPickRandomUnit(udg_HeroesGroup))) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_BossDiesGeneralFunc_Func019A takes nothing returns nothing
    if ( Trig_BossDiesGeneralFunc_Func019Func001C() ) then
        call KillUnit(GetEnumUnit())
    else
    endif
endfunction

function Trig_BossDiesGeneralFunc_Func032A takes nothing returns nothing
    call PauseUnitBJ(false, GetEnumUnit())
    call GroupRemoveUnitSimple(GetEnumUnit(), udg_HeroesBossfightUG)
endfunction

function Trig_BossDiesGeneralFunc_Func036C takes nothing returns boolean
    if ( not ( udg_DIFFICULTY == 3 ) ) then
        return false
    endif
    return true
endfunction

function Trig_BossDiesGeneralFunc_Actions takes nothing returns nothing
    // LOOT
    set udg_tempLoc=GetUnitLoc(udg_tempUnit)
    if ( Trig_BossDiesGeneralFunc_Func003C() ) then
        if ( Trig_BossDiesGeneralFunc_Func003Func002C() ) then
            call CreateItemLoc('I09M', udg_tempLoc)
        else
            call CreateItemLoc('I09S', udg_tempLoc)
        endif
    else
    endif
    if ( Trig_BossDiesGeneralFunc_Func004C() ) then
        call CreateItemLoc('I09N', udg_tempLoc)
    else
    endif
    if ( Trig_BossDiesGeneralFunc_Func005C() ) then
    else
    endif
    if ( Trig_BossDiesGeneralFunc_Func006C() ) then
        if ( Trig_BossDiesGeneralFunc_Func006Func001C() ) then
        else
        endif
    else
    endif
    // CHEST BONUS GOLD
    set udg_tempReal=GetRandomReal(8.00, 8.00)
    set udg_chest_pos=PolarProjectionBJ(GetUnitLoc(udg_tempUnit), 0.00, GetRandomDirectionDeg())
    set udg_ChestU=udg_tempUnit
    set udg_tempUnit=null
    call DisableTrigger(gg_trg_ChestOpen)
    call EnableTrigger(gg_trg_GoldDropChestPeriodic)
    // -
    call ConditionalTriggerExecute(gg_trg_ChestEpic)
    call StartTimerBJ(udg_ChestTimerGold, false, udg_tempReal)
    // LOOT
    call TriggerExecute(gg_trg_CheckPlayerFoodLimitFunc)
    call ForGroupBJ(GetUnitsInRectAll(gg_rct_BossfightInnerLoc), function Trig_BossDiesGeneralFunc_Func019A)
    call RemoveLocation(udg_tempLoc)
    call TriggerSleepAction(2.00)
    set udg_tempLoc=PolarProjectionBJ(GetRectCenter(gg_rct_BossfightInnerLoc), 300.00, GetRandomDirectionDeg())
    call TriggerExecute(gg_trg_HeroResFunc)
    call RemoveLocation(udg_tempLoc)
    call TriggerSleepAction(8.00)
    set udg_musicOn=0
    call CreateNUnitsAtLoc(1, 'n00E', Player(PLAYER_NEUTRAL_PASSIVE), GetRectCenter(gg_rct_StartLoc), bj_UNIT_FACING)
    call AddSpecialEffectTargetUnitBJ("origin", GetLastCreatedUnit(), "Abilities\\Spells\\Human\\MassTeleport\\MassTeleportTo.mdl")
    set udg_BossfightEndEff=GetLastCreatedEffectBJ()
    call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\Human\\MassTeleport\\MassTeleportTarget.mdl")
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call ForGroupBJ(GetUnitsInRectAll(GetPlayableMapRect()), function Trig_BossDiesGeneralFunc_Func032A)
    call TriggerSleepAction(1.50)
    call TriggerExecute(gg_trg_QuestCompleted)
    call TriggerExecute(gg_trg_QuestMutagenReward)
    if ( Trig_BossDiesGeneralFunc_Func036C() ) then
        call TriggerExecute(gg_trg_QuestMutagenReward)
        call TriggerExecute(gg_trg_QuestMutagenReward)
    else
    endif
endfunction

