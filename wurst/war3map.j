//===========================================================================
// Trigger: CircleOfIceCast
//===========================================================================
function Trig_CircleOfIceCast_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A018' ) ) then
        return false
    endif
    return true
endfunction

function Trig_CircleOfIceCast_Actions takes nothing returns nothing
    call PlaySoundOnUnitBJ(gg_snd_StormBoltLaunch, 100, GetTriggerUnit())
    set udg_tempReal=0.00
    set udg_tempLoc=GetSpellTargetLoc()
    set udg_tempZ=BlzGetLocalUnitZ(GetTriggerUnit())
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=16
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        set udg_tempReal=( udg_tempReal + 22.50 )
        set udg_tempLoc2=PolarProjectionBJ(udg_tempLoc, ( udg_CoI_distance_real - 50.00 ), udg_tempReal)
        call AddSpecialEffectLocBJ(udg_tempLoc2, "Ice Shard.mdx")
        call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 0.75)
        call BlzSetSpecialEffectYaw(GetLastCreatedEffectBJ(), Deg2Rad(GetRandomReal(0, 360.00)))
        call BlzSetSpecialEffectPitch(GetLastCreatedEffectBJ(), Deg2Rad(GetRandomReal(- 20.00, 20.00)))
        call BlzSetSpecialEffectZ(GetLastCreatedEffectBJ(), ( udg_tempZ - 50.00 ))
        set udg_CoI_eff[GetForLoopIndexA()]=GetLastCreatedEffectBJ()
        call RemoveLocation(udg_tempLoc2)
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    call RemoveLocation(udg_tempLoc)
    set udg_tempZ=0.00
endfunction

