    if ( not ( GetSpellAbilityId() == 'A04J' ) ) then
        return false
    endif
    return true
endfunction

function Trig_ShieldOfVengeance_Actions takes nothing returns nothing
    set udg_ShieldOfVengeanceHP=( GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()) * GetHeroStatBJ(bj_HEROSTAT_INT, GetTriggerUnit(), true) )
    set udg_ShieldOfVengeanceHP=( udg_ShieldOfVengeanceHP + ( 150 * GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()) ) )
    set udg_ShieldOfVengeanceT=GetSpellTargetUnit()
    set udg_BladeOfJusticeLvl=GetUnitAbilityLevelSwapped('A04K', GetTriggerUnit())
    call EnableTrigger(gg_trg_ShieldOfVengeanceHP)
    call EnableTrigger(gg_trg_ShieldOfVengeanceCheck)
endfunction

