function Trig_RetributionCheck_Conditions takes nothing returns boolean
    if ( not ( UnitHasBuffBJ(gg_unit_H00N_0277, 'B00X') == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_RetributionCheck_Actions takes nothing returns nothing
    set udg_BladeOfJusticeLvl2=( GetUnitAbilityLevelSwapped('A04K', gg_unit_H00N_0277) + GetUnitAbilityLevelSwapped('A04O', gg_unit_H00N_0277) )
    set udg_BladeOfJusticeLvl2=( udg_BladeOfJusticeLvl2 + GetUnitAbilityLevelSwapped('A04L', gg_unit_H00N_0277) )
    call UnitRemoveAbilityBJ('A021', gg_unit_H00N_0277)
    call UnitRemoveAbilityBJ('A02C', gg_unit_H00N_0277)
    call UnitRemoveAbilityBJ('A04P', gg_unit_H00N_0277)
    set udg_RetributionIsOn=0
    call UnitRemoveAbilityBJ('A04O', gg_unit_H00N_0277)
    call UnitRemoveAbilityBJ('A04L', gg_unit_H00N_0277)
    call SetPlayerAbilityAvailableBJ(true, 'A04K', GetOwningPlayer(gg_unit_H00N_0277))
    call DisableTrigger(GetTriggeringTrigger())
endfunction

