    set udg_tempLoc=GetUnitLoc(GetTriggerUnit())
    set udg_tempLoc2=GetUnitLoc(GetSpellTargetUnit())
    set udg_tempLoc3=PolarProjectionBJ(udg_tempLoc, 50.00, AngleBetweenPoints(udg_tempLoc, udg_tempLoc2))
    call CreateNUnitsAtLoc(1, 'h01Z', GetOwningPlayer(GetTriggerUnit()), udg_tempLoc3, GetRandomDirectionDeg())
    call UnitApplyTimedLifeBJ(90.00, 'BTLF', GetLastCreatedUnit())
    set udg_KBA_Caster=GetTriggerUnit()
