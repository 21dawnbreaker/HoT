function InitTrig_ThunderStrike takes nothing returns nothing
    set gg_trg_ThunderStrike=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_ThunderStrike, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_ThunderStrike, Condition(function Trig_ThunderStrike_Conditions))
    call TriggerAddAction(gg_trg_ThunderStrike, function Trig_ThunderStrike_Actions)
endfunction

