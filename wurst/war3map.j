function Trig_Slots_Func002C takes nothing returns boolean
    if ( ( GetItemType(GetManipulatedItem()) == ITEM_TYPE_PERMANENT ) ) then
        return true
    endif
    if ( ( GetItemType(GetManipulatedItem()) == ITEM_TYPE_CHARGED ) ) then
        return true
    endif
    if ( ( GetItemType(GetManipulatedItem()) == ITEM_TYPE_ARTIFACT ) ) then
        return true
    endif
    if ( ( GetItemType(GetManipulatedItem()) == ITEM_TYPE_PURCHASABLE ) ) then
        return true
    endif
    if ( ( GetItemType(GetManipulatedItem()) == ITEM_TYPE_CAMPAIGN ) ) then
        return true
    endif
    return false
endfunction

function Trig_Slots_Conditions takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetTriggerUnit()) != 'H004' ) ) then
        return false
    endif
    if ( not Trig_Slots_Func002C() ) then
        return false
    endif
    return true
endfunction

function Trig_Slots_Func006Func002Func001C takes nothing returns boolean
    if ( not ( GetItemType(GetManipulatedItem()) == GetItemType(UnitItemInSlotBJ(GetTriggerUnit(), GetForLoopIndexA())) ) ) then
