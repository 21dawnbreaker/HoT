function Trig_CarrionSwarmPeriodic_Func001Func001C takes nothing returns boolean
    if ( not ( RectContainsUnit(gg_rct_MainBossLoc, udg_CarrionSwarmU[GetForLoopIndexA()]) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_CarrionSwarmPeriodic_Func001Func002Func002C takes nothing returns boolean
    if ( not ( udg_CarrionSwarmEffInt[GetForLoopIndexA()] == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_CarrionSwarmPeriodic_Func001Func002Func005Func001Func001C takes nothing returns boolean
    if ( not ( IsUnitInGroup(GetEnumUnit(), udg_MinionsUG) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_CarrionSwarmPeriodic_Func001Func002Func005Func001C takes nothing returns boolean
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(gg_unit_U006_0283)) == true ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( BlzIsUnitInvulnerable(udg_RandomU) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_CarrionSwarmPeriodic_Func001Func002Func005A takes nothing returns nothing
    if ( Trig_CarrionSwarmPeriodic_Func001Func002Func005Func001C() ) then
        if ( Trig_CarrionSwarmPeriodic_Func001Func002Func005Func001Func001C() ) then
            call UnitDamageTargetBJ(gg_unit_U006_0283, GetEnumUnit(), ( 0.20 * I2R(BlzGetUnitBaseDamage(gg_unit_U006_0283, 0)) ), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_MAGIC)
        else
            call UnitDamageTargetBJ(gg_unit_U006_0283, GetEnumUnit(), ( 5.00 + ( I2R(udg_DIFFICULTY) * 2.50 ) ), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_NORMAL)
        endif
        call AddSpecialEffectTargetUnitBJ("chest", GetEnumUnit(), "Abilities\\Weapons\\ChimaeraAcidMissile\\ChimaeraAcidMissile.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
    else
    endif
endfunction

function Trig_CarrionSwarmPeriodic_Func001Func002C takes nothing returns boolean
    if ( not ( IsUnitAliveBJ(udg_CarrionSwarmU[GetForLoopIndexA()]) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_CarrionSwarmPeriodic_Actions takes nothing returns nothing
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=9
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        if ( Trig_CarrionSwarmPeriodic_Func001Func001C() ) then
            call KillUnit(udg_CarrionSwarmU[GetForLoopIndexA()])
        else
        endif
        if ( Trig_CarrionSwarmPeriodic_Func001Func002C() ) then
            set udg_CarrionSwarmEffInt[GetForLoopIndexA()]=0
            set udg_CarrionSwarmLoc[GetForLoopIndexA()]=PolarProjectionBJ(GetUnitLoc(udg_CarrionSwarmU[GetForLoopIndexA()]), ( 1.50 + ( 5.00 * I2R(udg_DIFFICULTY) ) ), udg_CarrionSwarmReal[GetForLoopIndexA()])
            call SetUnitPositionLoc(udg_CarrionSwarmU[GetForLoopIndexA()], udg_CarrionSwarmLoc[GetForLoopIndexA()])
            call ForGroupBJ(GetUnitsInRangeOfLocAll(150.00, udg_CarrionSwarmLoc[GetForLoopIndexA()]), function Trig_CarrionSwarmPeriodic_Func001Func002Func005A)
        else
            if ( Trig_CarrionSwarmPeriodic_Func001Func002Func002C() ) then
                call DestroyEffectBJ(udg_CarrionSwarmEff[GetForLoopIndexA()])
                set udg_CarrionSwarmEffInt[GetForLoopIndexA()]=1
            else
            endif
        endif
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    call RemoveLocation(udg_CarrionSwarmLoc[GetForLoopIndexA()])
endfunction

//===========================================================================
function InitTrig_CarrionSwarmPeriodic takes nothing returns nothing
    set gg_trg_CarrionSwarmPeriodic=CreateTrigger()
    call DisableTrigger(gg_trg_CarrionSwarmPeriodic)
    call TriggerRegisterTimerEventPeriodic(gg_trg_CarrionSwarmPeriodic, 0.04)
    call TriggerAddAction(gg_trg_CarrionSwarmPeriodic, function Trig_CarrionSwarmPeriodic_Actions)
endfunction

