        else
            call UnitDamageTargetBJ(udg_FireBombC, GetEnumUnit(), udg_tempReal, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_MAGIC)
        endif
        if ( Trig_FireBombSpread_Func007Func001Func002C() ) then
            set udg_FireBombCounterInt=( udg_FireBombCounterInt + 1 )
            call GroupAddUnitSimple(GetEnumUnit(), udg_FireBombSpreadUG)
            call CreateNUnitsAtLoc(1, 'h00J', GetOwningPlayer(udg_FireBombC), udg_tempLoc, bj_UNIT_FACING)
            call SetUnitAbilityLevelSwapped('A0DP', GetLastCreatedUnit(), GetUnitAbilityLevelSwapped('A0DO', udg_FireBombC))
            call IssueTargetOrderBJ(GetLastCreatedUnit(), "shadowstrike", GetEnumUnit())
            call UnitApplyTimedLifeBJ(2.00, 'BTLF', GetLastCreatedUnit())
