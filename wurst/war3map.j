//===========================================================================
// Trigger: DemoralizingShout
//===========================================================================
function Trig_DemoralizingShout_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'ANht' ) ) then
        return false
    endif
    return true
endfunction

function Trig_DemoralizingShout_Func001Func001Func001Func001C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 2) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_DemoralizingShout_Func001Func001Func001C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 100) <= ( 10 * GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()) ) ) ) then
        return false
    endif
    return true
endfunction

function Trig_DemoralizingShout_Func001Func001C takes nothing returns boolean
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(GetTriggerUnit())) == true ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_DemoralizingShout_Func001A takes nothing returns nothing
    if ( Trig_DemoralizingShout_Func001Func001C() ) then
        if ( Trig_DemoralizingShout_Func001Func001Func001C() ) then
            if ( Trig_DemoralizingShout_Func001Func001Func001Func001C() ) then
                set udg_tempLoc=PolarProjectionBJ(GetUnitLoc(GetEnumUnit()), 50.00, GetRandomDirectionDeg())
                call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\Other\\Stampede\\StampedeMissileDeath.mdl")
                call DestroyEffectBJ(GetLastCreatedEffectBJ())
                call CreateItemLoc('I03W', udg_tempLoc)
                call RemoveLocation(udg_tempLoc)
            else
                set udg_LargeGoldDropLoc=PolarProjectionBJ(GetUnitLoc(GetEnumUnit()), 80.00, GetRandomDirectionDeg())
                set udg_tempZ=GetLocationZ(udg_LargeGoldDropLoc)
                call PlaySoundAtPointBJ(gg_snd_GoldSoundEff2, 100, udg_LargeGoldDropLoc, udg_tempZ)
                set udg_tempZ=0.00
                call CreateItemLoc('I03S', udg_LargeGoldDropLoc)
                call RemoveLocation(udg_LargeGoldDropLoc)
            endif
        else
        endif
    else
    endif
endfunction

function Trig_DemoralizingShout_Func002Func001C takes nothing returns boolean
    if ( not ( IsUnitAlly(GetEnumUnit(), GetOwningPlayer(GetTriggerUnit())) == true ) ) then
