//===========================================================================
// Trigger: BladeOfRetribution
//===========================================================================
function Trig_BladeOfRetribution_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A04O' ) ) then
        return false
    endif
    return true
endfunction

function Trig_BladeOfRetribution_Actions takes nothing returns nothing
    set udg_BladeOfJusticeLvl2=GetUnitAbilityLevelSwapped('A04O', gg_unit_H00N_0277)
    set udg_tempLoc=GetUnitLoc(GetSpellTargetUnit())
    call StopSoundBJ(udg_blade_of_justice_sound, false)
    call PlaySoundOnUnitBJ(gg_snd_Spell_PA_BladeofJustice_Cast_Revamp_03, 100, GetTriggerUnit())
    set udg_blade_of_justice_sound=GetLastPlayedSound()
    call UnitDamageTargetBJ(GetTriggerUnit(), GetSpellTargetUnit(), ( ( I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) * 0.50 ) * I2R(GetHeroStatBJ(bj_HEROSTAT_STR, GetTriggerUnit(), true)) ), ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL)
    call UnitDamageTargetBJ(GetTriggerUnit(), GetSpellTargetUnit(), ( 75.00 * I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) ), ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL)
    call SetUnitLifePercentBJ(GetTriggerUnit(), ( GetUnitLifePercent(GetTriggerUnit()) + ( I2R(GetUnitAbilityLevelSwapped('A04O', gg_unit_H00N_0277)) * 3.00 ) ))
    call SetUnitLifePercentBJ(GetTriggerUnit(), ( GetUnitLifePercent(GetTriggerUnit()) + ( I2R(GetUnitAbilityLevelSwapped('A015', gg_unit_H00N_0277)) * 5.00 ) ))
    call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\Undead\\Impale\\ImpaleHitTarget.mdl")
    call BlzSetSpecialEffectColor(GetLastCreatedEffectBJ(), 255, 255, 0)
    call BlzSetSpecialEffectAlpha(GetLastCreatedEffectBJ(), 200)
    call BlzSetSpecialEffectColorByPlayer(GetLastCreatedEffectBJ(), Player(4))
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call RemoveLocation(udg_tempLoc)
endfunction

