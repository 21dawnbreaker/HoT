// Trigger: ChestOpen
//===========================================================================
function Trig_ChestOpen_Conditions takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetSoldUnit()) == 'o026' ) ) then
        return false
    endif
    return true
endfunction

function Trig_ChestOpen_Func006Func001C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 4) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ChestOpen_Func006Func006Func012C takes nothing returns boolean
    if ( ( GetRandomInt(1, 10) > 1 ) ) then
        return true
    endif
    if ( ( GetUnitTypeId(GetTriggerUnit()) == 'o028' ) ) then
        return true
    endif
    return false
endfunction

function Trig_ChestOpen_Func006Func006Func016C takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetTriggerUnit()) == 'o027' ) ) then
        return false
    endif
    return true
endfunction

function Trig_ChestOpen_Func006Func006Func017C takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetTriggerUnit()) == 'o029' ) ) then
        return false
    endif
    return true
endfunction

function Trig_ChestOpen_Func006Func006Func018C takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetTriggerUnit()) == 'o028' ) ) then
        return false
    endif
    return true
endfunction

function Trig_ChestOpen_Func006Func006C takes nothing returns boolean
    if ( not Trig_ChestOpen_Func006Func006Func012C() ) then
        return false
    endif
    return true
endfunction

function Trig_ChestOpen_Func006C takes nothing returns boolean
    if ( not ( udg_item_type_unit_owner != null ) ) then
        return false
    endif
    return true
endfunction

function Trig_ChestOpen_Actions takes nothing returns nothing
    call RemoveUnit(GetSoldUnit())
    set udg_ChestCounter=0
    set udg_item_type_to_check='I03R'
    set udg_tempInt=GetConvertedPlayerId(GetOwningPlayer(GetBuyingUnit()))
    call TriggerExecute(gg_trg_CheckIfPlayerHasItemTypeFunc)
    if ( Trig_ChestOpen_Func006C() ) then
        call SetItemCharges(GetItemOfTypeFromUnitBJ(udg_item_type_unit_owner, 'I03R'), ( GetItemCharges(GetItemOfTypeFromUnitBJ(udg_item_type_unit_owner, 'I03R')) - 1 ))
        call TriggerExecute(gg_trg_ZeroChargesRemoveFunc)
        set udg_tempLoc=GetUnitLoc(GetTriggerUnit())
        set udg_tempZ=0.00
        if ( Trig_ChestOpen_Func006Func006C() ) then
            // CHEST BONUS GOLD
            set udg_tempReal=GetRandomReal(0.00, 5.00)
            set udg_chest_pos=PolarProjectionBJ(GetUnitLoc(GetTriggerUnit()), 0.00, GetRandomDirectionDeg())
            set udg_ChestU=GetTriggerUnit()
            call PauseUnitBJ(true, GetTriggerUnit())
            call DisableTrigger(gg_trg_ChestOpen)
            call EnableTrigger(gg_trg_GoldDropChestPeriodic)
            // -
            call PlaySoundAtPointBJ(gg_snd_ChestOpen, 100, udg_tempLoc, udg_tempZ)
            set udg_tempZ=GetLocationZ(udg_tempLoc)
            if ( Trig_ChestOpen_Func006Func006Func016C() ) then
                call ConditionalTriggerExecute(gg_trg_ChestBase)
            else
            endif
            if ( Trig_ChestOpen_Func006Func006Func017C() ) then
                set udg_tempReal=( udg_tempReal + GetRandomReal(1.00, 2.50) )
                call ConditionalTriggerExecute(gg_trg_ChestRare)
            else
            endif
            if ( Trig_ChestOpen_Func006Func006Func018C() ) then
                set udg_tempReal=( udg_tempReal + GetRandomReal(2.00, 5.00) )
                call ConditionalTriggerExecute(gg_trg_ChestEpic)
            else
            endif
            call StartTimerBJ(udg_ChestTimerGold, false, udg_tempReal)
        else
            set udg_ChestTrapInt=1
            set udg_ChestTrapU=GetTriggerUnit()
            call PlaySoundAtPointBJ(gg_snd_DiabloTrapChestOpenSound, 100, udg_tempLoc, udg_tempZ)
            call StartTimerBJ(udg_ChestTimerTrap, false, 1.00)
        endif
    else
        if ( Trig_ChestOpen_Func006Func001C() ) then
            call CreateTextTagUnitBJ(( "Мне нужен |cffff0000ключ|r..." ), GetBuyingUnit(), 0, 10, 100, 100, 100, 0)
            call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
            call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 3.00)
            call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
        else
        endif
    endif
    call RemoveLocation(udg_tempLoc)
    set udg_tempZ=0.00
    set udg_item_type_to_check='ches'
    set udg_item_type_unit_owner=null
    set udg_tempInt=0
endfunction

