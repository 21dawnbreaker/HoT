//===========================================================================
function Trig_ArtifactRewardingGeneral_Conditions takes nothing returns boolean
    if ( not ( IsUnitInGroup(GetTriggerUnit(), udg_RoomEnemyUG) == true ) ) then
        return false
    endif
    if ( not ( udg_PathArtifact == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ArtifactRewardingGeneral_Func004Func006Func001Func001Func001C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 100) <= 50 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ArtifactRewardingGeneral_Func004Func006Func001Func001C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 100) <= 15 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ArtifactRewardingGeneral_Func004Func006Func001C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 100) <= 6 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ArtifactRewardingGeneral_Func004Func006C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 100) <= 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ArtifactRewardingGeneral_Func004C takes nothing returns boolean
    if ( not ( RectContainsUnit(udg_RoomReg[udg_RoomInt], GetTriggerUnit()) == true ) ) then
        return false
    endif
    if ( not ( CountUnitsInGroup(udg_RoomEnemyUG) == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ArtifactRewardingGeneral_Actions takes nothing returns nothing
    call GroupRemoveUnitSimple(GetTriggerUnit(), udg_RoomEnemyUG)
    if ( Trig_ArtifactRewardingGeneral_Func004C() ) then
        call TriggerExecute(gg_trg_RewardingGeneral)
        call ConditionalTriggerExecute(gg_trg_HeroResFunc)
        set udg_EncounterEndInt=1
        call ConditionalTriggerExecute(gg_trg_RewardingChestsRollFunc)
        set udg_tempLoc=GetRandomLocInRect(udg_RewardRoom[udg_RoomInt])
        if ( Trig_ArtifactRewardingGeneral_Func004Func006C() ) then
            call CreateItemLoc(ChooseRandomItemExBJ(5, ITEM_TYPE_ANY), udg_tempLoc)
        else
            if ( Trig_ArtifactRewardingGeneral_Func004Func006Func001C() ) then
                call CreateItemLoc(ChooseRandomItemExBJ(4, ITEM_TYPE_ANY), udg_tempLoc)
            else
                if ( Trig_ArtifactRewardingGeneral_Func004Func006Func001Func001C() ) then
                    call CreateItemLoc(ChooseRandomItemExBJ(3, ITEM_TYPE_ANY), udg_tempLoc)
                else
                    if ( Trig_ArtifactRewardingGeneral_Func004Func006Func001Func001Func001C() ) then
                        call CreateItemLoc(ChooseRandomItemExBJ(GetRandomInt(1, 2), ITEM_TYPE_ANY), udg_tempLoc)
                    else
                        call CreateItemLoc(ChooseRandomItemExBJ(2, ITEM_TYPE_ANY), udg_tempLoc)
                    endif
                endif
            endif
        endif
        call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\NightElf\\Blink\\BlinkTarget.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call TriggerExecute(gg_trg_SoundItemDropsByClass)
        call RemoveLocation(udg_tempLoc)
    else
    endif
endfunction

//===========================================================================
function InitTrig_ArtifactRewardingGeneral takes nothing returns nothing
    set gg_trg_ArtifactRewardingGeneral=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_ArtifactRewardingGeneral, EVENT_PLAYER_UNIT_DEATH)
    call TriggerRegisterAnyUnitEventBJ(gg_trg_ArtifactRewardingGeneral, EVENT_PLAYER_UNIT_CHANGE_OWNER)
    call TriggerAddCondition(gg_trg_ArtifactRewardingGeneral, Condition(function Trig_ArtifactRewardingGeneral_Conditions))
    call TriggerAddAction(gg_trg_ArtifactRewardingGeneral, function Trig_ArtifactRewardingGeneral_Actions)
endfunction

