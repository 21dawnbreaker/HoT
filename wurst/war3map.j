    set gg_trg_ObeliskSpawnUndead=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_ObeliskSpawnUndead, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_ObeliskSpawnUndead, Condition(function Trig_ObeliskSpawnUndead_Conditions))
    call TriggerAddAction(gg_trg_ObeliskSpawnUndead, function Trig_ObeliskSpawnUndead_Actions)
endfunction

