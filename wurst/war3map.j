function Trig_ExamineGiveHero_Actions takes nothing returns nothing
    set udg_tempLoc=GetRectCenter(gg_rct_BossfightInnerLoc)
    call RemoveUnit(udg_ExamineHero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])
    call CreateNUnitsAtLoc(1, GetUnitTypeId(GetSpellTargetUnit()), GetOwningPlayer(GetTriggerUnit()), udg_tempLoc, bj_UNIT_FACING)
    set udg_ExamineHero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]=GetLastCreatedUnit()
    call IssueTargetOrderBJ(GetLastCreatedUnit(), "move", GetTriggerUnit())
    call SetUnitVertexColorBJ(GetLastCreatedUnit(), 40.00, 40.00, 75.00, 50.00)
    call UnitAddAbilityBJ('Avul', GetLastCreatedUnit())
    call ClearSelectionForPlayer(GetOwningPlayer(GetTriggerUnit()))
    call SelectUnitForPlayerSingle(GetLastCreatedUnit(), GetOwningPlayer(GetTriggerUnit()))
    call RemoveLocation(udg_tempLoc)
endfunction

