function Trig_LastStand_Func002Func001C takes nothing returns boolean
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( IsUnitAlly(GetEnumUnit(), GetOwningPlayer(GetTriggerUnit())) == true ) ) then
        return false
    endif
    if ( not ( IsUnitType(GetEnumUnit(), UNIT_TYPE_STRUCTURE) != true ) ) then
        return false
    endif
    return true
endfunction

function Trig_LastStand_Func002A takes nothing returns nothing
    if ( Trig_LastStand_Func002Func001C() ) then
        call GroupAddUnitSimple(GetEnumUnit(), udg_LastStandUG)
        if ( Trig_LastStand_Func002Func001Func002C() ) then
            call UnitAddAbilityBJ('A04C', GetEnumUnit())
        else
            if ( Trig_LastStand_Func002Func001Func002Func001C() ) then
                call UnitAddAbilityBJ('A04D', GetEnumUnit())
            else
                if ( Trig_LastStand_Func002Func001Func002Func001Func002C() ) then
                    call UnitAddAbilityBJ('A04E', GetEnumUnit())
                else
                    if ( Trig_LastStand_Func002Func001Func002Func001Func002Func002C() ) then
                        call UnitAddAbilityBJ('A04F', GetEnumUnit())
                    else
                        if ( Trig_LastStand_Func002Func001Func002Func001Func002Func002Func002C() ) then
                            call UnitAddAbilityBJ('A04B', GetEnumUnit())
                        else
                        endif
                    endif
                endif
            endif
        endif
        call SetUnitLifeBJ(GetEnumUnit(), ( GetUnitStateSwap(UNIT_STATE_LIFE, GetEnumUnit()) + ( 250.00 * I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())) ) ))
    else
    endif
endfunction

function Trig_LastStand_Func005A takes nothing returns nothing
    call UnitRemoveAbilityBJ('A04C', GetEnumUnit())
    call UnitRemoveAbilityBJ('A04D', GetEnumUnit())
    call UnitRemoveAbilityBJ('A04E', GetEnumUnit())
    call UnitRemoveAbilityBJ('A04F', GetEnumUnit())
    call UnitRemoveAbilityBJ('A04B', GetEnumUnit())
endfunction

function Trig_LastStand_Actions takes nothing returns nothing
    call PlaySoundOnUnitBJ(gg_snd_HeroMountainKingYesAttack1, 100, GetTriggerUnit())
    call ForGroupBJ(GetUnitsInRangeOfLocAll(550.00, GetUnitLoc(GetTriggerUnit())), function Trig_LastStand_Func002A)
    call EnableTrigger(gg_trg_LastStandPeriodic)
    call TriggerSleepAction(21.00)
    call ForGroupBJ(udg_LastStandUG, function Trig_LastStand_Func005A)
    call GroupRemoveGroup(udg_LastStandUG, udg_LastStandUG)
    call DisableTrigger(gg_trg_LastStandPeriodic)
endfunction

