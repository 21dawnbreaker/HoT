    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( IsUnitAlly(GetEnumUnit(), Player(12)) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_CharityPeriodic_Func001A takes nothing returns nothing
    if ( Trig_CharityPeriodic_Func001Func001C() ) then
        if ( Trig_CharityPeriodic_Func001Func001Func001C() ) then
        else
