function Trig_DifficultyVoteEnd_Func015C takes nothing returns boolean
    if ( not ( udg_DIFFICULTY == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_DifficultyVoteEnd_Func016C takes nothing returns boolean
    if ( not ( udg_DIFFICULTY == 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_DifficultyVoteEnd_Func017C takes nothing returns boolean
    if ( not ( udg_DIFFICULTY == 3 ) ) then
        return false
    endif
    return true
endfunction

function Trig_DifficultyVoteEnd_Actions takes nothing returns nothing
    call ForForce(GetPlayersAll(), function Trig_DifficultyVoteEnd_Func001A)
    if ( Trig_DifficultyVoteEnd_Func002C() ) then
        set udg_DIFFICULTY=1
        call DisplayTextToForce(GetPlayersAll(), "TRIGSTR_7836")
        call PlaySoundBJ(gg_snd_ClanInvitation)
    else
    endif
    //  
    if ( Trig_DifficultyVoteEnd_Func004C() ) then
        set udg_DIFFICULTY=2
        call DisplayTextToForce(GetPlayersAll(), "TRIGSTR_7840")
        call PlaySoundBJ(gg_snd_ClanInvitation)
    else
    endif
    //  
    if ( Trig_DifficultyVoteEnd_Func006C() ) then
        set udg_DIFFICULTY=3
        call DisplayTextToForce(GetPlayersAll(), "TRIGSTR_7835")
        call PlaySoundBJ(gg_snd_RankAnimations_5)
        call SetSoundOffsetBJ(0.50, GetLastPlayedSound())
    else
    endif
    //  
    if ( Trig_DifficultyVoteEnd_Func008C() ) then
        set udg_DIFFICULTY=1
        call DisplayTextToForce(GetPlayersAll(), "TRIGSTR_7837")
        call PlaySoundBJ(gg_snd_ClanInvitation)
    else
    endif
    //  
    if ( Trig_DifficultyVoteEnd_Func010C() ) then
        set udg_DIFFICULTY=1
        call DisplayTextToForce(GetPlayersAll(), "TRIGSTR_7838")
        call PlaySoundBJ(gg_snd_ClanInvitation)
    else
    endif
    //  
    if ( Trig_DifficultyVoteEnd_Func012C() ) then
        set udg_DIFFICULTY=2
        call DisplayTextToForce(GetPlayersAll(), "TRIGSTR_7841")
        call PlaySoundBJ(gg_snd_ClanInvitation)
    else
    endif
    if ( Trig_DifficultyVoteEnd_Func013C() ) then
        set udg_difficultyString="|cffdcdc00Normal|r"
    else
        set udg_difficultyString="|cffff0000NIGHTMARE|r"
    endif
    // MODIFIER
    if ( Trig_DifficultyVoteEnd_Func015C() ) then
        set udg_difficultyReal=0.04
    else
    endif
    if ( Trig_DifficultyVoteEnd_Func016C() ) then
        set udg_difficultyReal=0.10
    else
    endif
    if ( Trig_DifficultyVoteEnd_Func017C() ) then
        set udg_difficultyReal=0.16
    else
    endif
    // MODIFIER
    call MultiboardSetTitleText(udg_Multiboard1, ( ( udg_difficultyString + " - |cffffffffRoom:|r " ) + I2S(R2I(udg_RoomMultiboardCounting)) ))
    call DisableTrigger(GetTriggeringTrigger())
endfunction

