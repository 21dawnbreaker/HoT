//===========================================================================
// Trigger: CheedGenerateRandomItems
//===========================================================================
function Trig_CheedGenerateRandomItems_Func013Func001Func002Func002C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 100) <= 15 ) ) then
        return false
    endif
    return true
endfunction

function Trig_CheedGenerateRandomItems_Func013Func001Func002C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 100) <= 8 ) ) then
        return false
    endif
    return true
endfunction

function Trig_CheedGenerateRandomItems_Func013Func001C takes nothing returns boolean
    if ( not ( GetRandomInt(1, 100) <= 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_CheedGenerateRandomItems_Actions takes nothing returns nothing
    // CLEANUP
    call RemoveItemFromStockBJ('I08S', udg_Cheed)
    call RemoveItemFromStockBJ('I091', udg_Cheed)
    call RemoveItemFromStockBJ('I01Y', udg_Cheed)
    call RemoveItemFromStockBJ('I01Z', udg_Cheed)
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=4
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        call RemoveItemFromStockBJ(udg_CheedLootToSell[GetForLoopIndexA()], udg_Cheed)
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    // GENERATE
    call AddItemToStockBJ('I08S', udg_Cheed, GetRandomInt(0, 3), 3)
    call AddItemToStockBJ('I091', udg_Cheed, 1, 1)
    call AddItemToStockBJ('I01Y', udg_Cheed, 1, 1)
    call AddItemToStockBJ('I01Z', udg_Cheed, 1, 1)
    set udg_tempInt=GetRandomInt(1, 100)
    set bj_forLoopAIndex=1
    set bj_forLoopAIndexEnd=4
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        if ( Trig_CheedGenerateRandomItems_Func013Func001C() ) then
            set udg_CheedLootToSell[GetForLoopIndexA()]=ChooseRandomItemBJ(5)
        else
            if ( Trig_CheedGenerateRandomItems_Func013Func001Func002C() ) then
                set udg_CheedLootToSell[GetForLoopIndexA()]=ChooseRandomItemBJ(4)
            else
                if ( Trig_CheedGenerateRandomItems_Func013Func001Func002Func002C() ) then
                    set udg_CheedLootToSell[GetForLoopIndexA()]=ChooseRandomItemBJ(3)
                else
                    set udg_CheedLootToSell[GetForLoopIndexA()]=ChooseRandomItemBJ(GetRandomInt(0, 1))
                endif
            endif
        endif
        call AddItemToStockBJ(udg_CheedLootToSell[GetForLoopIndexA()], udg_Cheed, 1, 1)
        set bj_forLoopAIndex=bj_forLoopAIndex + 1
    endloop
    set udg_tempInt=0
    set udg_Cheed=null
endfunction

//===========================================================================
function InitTrig_CheedGenerateRandomItems takes nothing returns nothing
    set gg_trg_CheedGenerateRandomItems=CreateTrigger()
    call TriggerAddAction(gg_trg_CheedGenerateRandomItems, function Trig_CheedGenerateRandomItems_Actions)
endfunction

//===========================================================================
// Trigger: BloodAltar
//===========================================================================
function Trig_BloodAltar_Conditions takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetSoldUnit()) == 'o02F' ) ) then
        return false
    endif
    return true
endfunction

function Trig_BloodAltar_Func002Func001Func016Func001C takes nothing returns boolean
    if ( not ( GetOwningPlayer(GetBuyingUnit()) == udg_Player[GetForLoopIndexA()] ) ) then
        return false
    endif
    return true
endfunction

function Trig_BloodAltar_Func002Func001C takes nothing returns boolean
    if ( not ( udg_tempInt == 0 ) ) then
        return false
    endif
    if ( not ( IsUnitType(GetEnumUnit(), UNIT_TYPE_HERO) == false ) ) then
        return false
    endif
    if ( not ( IsUnitType(GetEnumUnit(), UNIT_TYPE_MECHANICAL) == false ) ) then
        return false
    endif
    if ( not ( GetOwningPlayer(GetEnumUnit()) == GetOwningPlayer(GetBuyingUnit()) ) ) then
        return false
    endif
    return true
endfunction

function Trig_BloodAltar_Func002A takes nothing returns nothing
    if ( Trig_BloodAltar_Func002Func001C() ) then
        set udg_tempInt=1
        set udg_tempLoc2=GetUnitLoc(GetEnumUnit())
        call PlaySoundOnUnitBJ(gg_snd_DiabloShrineSound, 100, GetTriggerUnit())
        call AddSpecialEffectLocBJ(udg_tempLoc2, "Abilities\\Spells\\Items\\AIso\\AIsoTarget.mdl")
        call BlzSetSpecialEffectYaw(GetLastCreatedEffectBJ(), Deg2Rad(GetUnitFacing(GetEnumUnit())))
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\Undead\\DeathPact\\DeathPactCaster.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        call KillUnit(GetEnumUnit())
        call AddSpecialEffectLocBJ(udg_tempLoc, "Abilities\\Spells\\Items\\RitualDagger\\RitualDaggerTarget.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=udg_HeroNumber
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            if ( Trig_BloodAltar_Func002Func001Func016Func001C() ) then
                set udg_Karma[GetForLoopIndexA()]=( udg_Karma[GetForLoopIndexA()] - 1 )
            else
            endif
            set bj_forLoopAIndex=bj_forLoopAIndex + 1
        endloop
        set udg_KarmaU=GetBuyingUnit()
        call TriggerExecute(gg_trg_KarmaSystem)
        set udg_KarmaU=null
        set udg_tempZ=GetLocationZ(udg_tempLoc)
        // CHEST BONUS GOLD
        set udg_tempReal=GetRandomReal(0.00, 5.00)
        set udg_chest_pos=PolarProjectionBJ(GetUnitLoc(GetTriggerUnit()), 0.00, GetRandomDirectionDeg())
        set udg_ChestU=GetTriggerUnit()
        call RemoveLocation(udg_tempLoc)
        call PauseUnitBJ(true, GetTriggerUnit())
        call DisableTrigger(gg_trg_ChestOpen)
        call EnableTrigger(gg_trg_GoldDropChestPeriodic)
        // -
        set udg_tempReal=( udg_tempReal + GetRandomReal(2.00, 5.00) )
        call ConditionalTriggerExecute(gg_trg_ChestEpic)
        call StartTimerBJ(udg_ChestTimerGold, false, udg_tempReal)
        call CreateTextTagUnitBJ("TRIGSTR_505", GetTriggerUnit(), 0, 10, 100, 100, 100, 0)
        call SetTextTagPermanentBJ(GetLastCreatedTextTag(), false)
        call SetTextTagLifespanBJ(GetLastCreatedTextTag(), 3.00)
        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 32.00, 45.00)
        call PauseUnitBJ(true, GetTriggerUnit())
    else
    endif
endfunction

function Trig_BloodAltar_Actions takes nothing returns nothing
    set udg_tempLoc=GetUnitLoc(GetSellingUnit())
    call ForGroupBJ(GetUnitsInRangeOfLocAll(300.00, udg_tempLoc), function Trig_BloodAltar_Func002A)
    set udg_tempInt=0
    set udg_tempZ=0.00
    call RemoveLocation(udg_tempLoc)
    call RemoveLocation(udg_tempLoc2)
endfunction

//===========================================================================
function InitTrig_BloodAltar takes nothing returns nothing
    set gg_trg_BloodAltar=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_BloodAltar, EVENT_PLAYER_UNIT_SELL)
    call TriggerAddCondition(gg_trg_BloodAltar, Condition(function Trig_BloodAltar_Conditions))
    call TriggerAddAction(gg_trg_BloodAltar, function Trig_BloodAltar_Actions)
endfunction

