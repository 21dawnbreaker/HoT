        set udg_tempInt=( udg_tempInt + 1 )
        call GroupAddUnitSimple(GetEnumUnit(), udg_DefenseStaffUG)
        set udg_DefenseStaffUnit[udg_tempInt]=GetEnumUnit()
        set udg_tempLoc=GetUnitLoc(GetEnumUnit())
        call CreateNUnitsAtLoc(1, 'h01Q', GetOwningPlayer(GetEnumUnit()), udg_tempLoc, bj_UNIT_FACING)
        call UnitAddAbilityBJ('A0I8', GetLastCreatedUnit())
        call UnitApplyTimedLifeBJ(2.00, 'BTLF', GetLastCreatedUnit())
        call IssueTargetOrderBJ(GetLastCreatedUnit(), "innerfire", GetEnumUnit())
        call RemoveLocation(udg_tempLoc)
    else
    endif
