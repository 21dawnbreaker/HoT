function Trig_StashMoving_Actions takes nothing returns nothing
    if ( Trig_StashMoving_Func001C() ) then
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=udg_HeroNumber
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            set udg_tempLoc=GetRectCenter(udg_StashRegOrc[GetForLoopIndexA()])
            call SetUnitPositionLoc(udg_StashU[GetForLoopIndexA()], udg_tempLoc)
            call RemoveLocation(udg_tempLoc)
            set bj_forLoopAIndex=bj_forLoopAIndex + 1
        endloop
    else
    endif
    if ( Trig_StashMoving_Func002C() ) then
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=udg_HeroNumber
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            set udg_tempLoc=GetRectCenter(udg_StashRegNaluara[GetForLoopIndexA()])
            call SetUnitPositionLoc(udg_StashU[GetForLoopIndexA()], udg_tempLoc)
            call RemoveLocation(udg_tempLoc)
            set bj_forLoopAIndex=bj_forLoopAIndex + 1
        endloop
    else
    endif
    if ( Trig_StashMoving_Func003C() ) then
        set bj_forLoopAIndex=1
        set bj_forLoopAIndexEnd=udg_HeroNumber
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            set udg_tempLoc=GetRectCenter(udg_StashRegAlliance[GetForLoopIndexA()])
            call SetUnitPositionLoc(udg_StashU[GetForLoopIndexA()], udg_tempLoc)
            call RemoveLocation(udg_tempLoc)
            set bj_forLoopAIndex=bj_forLoopAIndex + 1
        endloop
    else
    endif
endfunction

