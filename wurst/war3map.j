//===========================================================================
// Trigger: GoldDropChestPeriodic
//
// expects chest_pos, chestU returns nothing
//===========================================================================
function Trig_GoldDropChestPeriodic_Func008Func001Func002C takes nothing returns boolean
    if ( not ( udg_tempInt2 > 70 ) ) then
        return false
    endif
    return true
endfunction

function Trig_GoldDropChestPeriodic_Func008Func001C takes nothing returns boolean
    if ( not ( udg_tempInt2 > 80 ) ) then
        return false
    endif
    return true
endfunction

function Trig_GoldDropChestPeriodic_Func008C takes nothing returns boolean
    if ( not ( udg_tempInt2 > 95 ) ) then
        return false
    endif
    return true
endfunction

function Trig_GoldDropChestPeriodic_Actions takes nothing returns nothing
    set udg_tempInt2=GetRandomInt(1, 100)
    set udg_tempLoc=PolarProjectionBJ(udg_chest_pos, GetRandomReal(0, 80.00), GetRandomDirectionDeg())
    set udg_tempZ=GetLocationZ(udg_chest_pos)
    call StopSoundBJ(udg_GoldDropSound, false)
    call PlaySoundAtPointBJ(gg_snd_GoldSoundEff1, 100, udg_chest_pos, udg_tempZ)
    set udg_GoldDropSound=GetLastPlayedSound()
    set udg_tempZ=0.00
    if ( Trig_GoldDropChestPeriodic_Func008C() ) then
        call CreateItemLoc('I03U', udg_tempLoc)
    else
        if ( Trig_GoldDropChestPeriodic_Func008Func001C() ) then
            call CreateItemLoc('I03T', udg_tempLoc)
        else
            if ( Trig_GoldDropChestPeriodic_Func008Func001Func002C() ) then
                call CreateItemLoc('I01X', udg_tempLoc)
            else
                call CreateItemLoc('I03S', udg_tempLoc)
            endif
        endif
    endif
    set udg_tempInt2=0
    call RemoveLocation(udg_tempLoc)
endfunction

//===========================================================================
function InitTrig_GoldDropChestPeriodic takes nothing returns nothing
    set gg_trg_GoldDropChestPeriodic=CreateTrigger()
    call DisableTrigger(gg_trg_GoldDropChestPeriodic)
    call TriggerRegisterTimerEventPeriodic(gg_trg_GoldDropChestPeriodic, 0.50)
    call TriggerAddAction(gg_trg_GoldDropChestPeriodic, function Trig_GoldDropChestPeriodic_Actions)
endfunction

//===========================================================================
// Trigger: ItemsDropChestPeriodic
//
// expects chest_pos, chestU returns nothing
//===========================================================================
function Trig_ItemsDropChestPeriodic_Func002C takes nothing returns boolean
    if ( not ( udg_ChestCounter != 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ItemsDropChestPeriodic_Actions takes nothing returns nothing
    set udg_tempLoc=PolarProjectionBJ(udg_chest_pos, GetRandomReal(0, 80.00), GetRandomDirectionDeg())
    if ( Trig_ItemsDropChestPeriodic_Func002C() ) then
        call CreateItemLoc(udg_LootItems[udg_ChestCounter], udg_tempLoc)
        set udg_ChestCounter=( udg_ChestCounter - 1 )
        call TriggerExecute(gg_trg_SoundItemDropsByClass)
    else
        call RemoveLocation(udg_chest_pos)
        call KillUnit(udg_ChestU)
        set udg_ChestU=null
        call EnableTrigger(gg_trg_ChestOpen)
        call DisableTrigger(GetTriggeringTrigger())
    endif
    call RemoveLocation(udg_tempLoc)
endfunction

//===========================================================================
function InitTrig_ItemsDropChestPeriodic takes nothing returns nothing
    set gg_trg_ItemsDropChestPeriodic=CreateTrigger()
    call DisableTrigger(gg_trg_ItemsDropChestPeriodic)
    call TriggerRegisterTimerEventPeriodic(gg_trg_ItemsDropChestPeriodic, 0.50)
    call TriggerAddAction(gg_trg_ItemsDropChestPeriodic, function Trig_ItemsDropChestPeriodic_Actions)
endfunction

