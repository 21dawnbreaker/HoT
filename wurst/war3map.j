    if ( not ( udg_DIFFICULTY >= 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Phase_1_NataAra_Func005C takes nothing returns boolean
    if ( not ( udg_DIFFICULTY == 3 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Phase_1_NataAra_Actions takes nothing returns nothing
    call DisplayTextToForce(GetPlayersAll(), "TRIGSTR_3805")
    call PlaySoundOnUnitBJ(gg_snd_GromYesAttack1, 100, gg_unit_U005_0113)
    set udg_BossfightDialogueInt=0
    if ( Trig_Phase_1_NataAra_Func004C() ) then
        call EnableTrigger(gg_trg_ThePursuitTriggerDifficulty)
        call EnableTrigger(gg_trg_WillOfTheNecropolisDifficulty)
    else
    endif
    if ( Trig_Phase_1_NataAra_Func005C() ) then
        call EnableTrigger(gg_trg_StrangulateTriggerDifficulty)
    else
    endif
    call DisableTrigger(GetTriggeringTrigger())
endfunction

