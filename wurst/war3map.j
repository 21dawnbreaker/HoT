    set udg_ChargeC=GetTriggerUnit()
    set udg_ChargeT=GetSpellTargetUnit()
    call SetUnitPathing(GetTriggerUnit(), false)
    call AddSpecialEffectTargetUnitBJ("origin", GetTriggerUnit(), "Valiant Charge.mdx")
    set udg_ChargeEff=GetLastCreatedEffectBJ()
    call EnableTrigger(gg_trg_ChargeMove)
endfunction

//===========================================================================
