//===========================================================================
function Trig_ImpalesTimerExpire_Func005Func001Func001C takes nothing returns boolean
    if ( not ( IsUnitInGroup(GetEnumUnit(), udg_MinionsUG) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_ImpalesTimerExpire_Func005Func001C takes nothing returns boolean
    if ( not ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(gg_unit_U006_0283)) == true ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not ( BlzIsUnitInvulnerable(GetEnumUnit()) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_ImpalesTimerExpire_Func005A takes nothing returns nothing
    if ( Trig_ImpalesTimerExpire_Func005Func001C() ) then
        if ( Trig_ImpalesTimerExpire_Func005Func001Func001C() ) then
            call UnitDamageTargetBJ(gg_unit_U006_0283, GetEnumUnit(), ( GetUnitStateSwap(UNIT_STATE_MAX_LIFE, GetEnumUnit()) * 1.00 ), ATTACK_TYPE_MELEE, DAMAGE_TYPE_NORMAL)
            call SetUnitLifePercentBJ(gg_unit_U006_0283, ( GetUnitLifePercent(gg_unit_U006_0283) + 1.00 ))
        else
            call UnitDamageTargetBJ(gg_unit_U006_0283, GetEnumUnit(), ( GetUnitStateSwap(UNIT_STATE_MAX_LIFE, GetEnumUnit()) * 0.15 ), ATTACK_TYPE_MELEE, DAMAGE_TYPE_NORMAL)
        endif
        call AddSpecialEffectTargetUnitBJ("chest", GetEnumUnit(), "Objects\\Spawnmodels\\Orc\\Orcblood\\BattrollBlood.mdl")
        call DestroyEffectBJ(GetLastCreatedEffectBJ())
    else
    endif
endfunction

function Trig_ImpalesTimerExpire_Actions takes nothing returns nothing
    call AddSpecialEffectLocBJ(udg_RandomImpaleLoc[udg_RandomImpalesInt], "Abilities\\Spells\\Undead\\Impale\\ImpaleHitTarget.mdl")
    call BlzSetSpecialEffectScale(GetLastCreatedEffectBJ(), 2.00)
    call BlzSetSpecialEffectYaw(GetLastCreatedEffectBJ(), Deg2Rad(GetRandomDirectionDeg()))
    call DestroyEffectBJ(GetLastCreatedEffectBJ())
    call ForGroupBJ(GetUnitsInRangeOfLocAll(100.00, udg_RandomImpaleLoc[udg_RandomImpalesInt]), function Trig_ImpalesTimerExpire_Func005A)
    call DestroyEffectBJ(udg_RandomImpaleEff1[udg_RandomImpalesInt])
    call RemoveLocation(udg_RandomImpaleLoc[udg_RandomImpalesInt])
endfunction

