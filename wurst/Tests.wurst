package Tests
import ClosureEvents

import ItemsCommon
import ItemsRunesAndGems
import ItemsRare
import ItemsEpic
import ItemsLegendary


init
    EventListener.add(EVENT_PLAYER_CHAT_FILTER) ->
        let msg = GetEventPlayerChatString()
        let _player = GetTriggerPlayer()
        let _hero = udg_hero_by_player[_player.getId() + 1]

        if msg == "-test4"
            CreateItem(CROWN_OF_ETHORIA_ITEM_ID, _hero.getX(), _hero.getY())
            
        if msg == "-test5"
            let _item = _hero.itemInSlot(0)
            print(_item.getName() + " - lvl: " + _item.getLevel().toString())
            print(_item.getItemtype() == ITEM_TYPE_POWERUP)

        if msg == "-legendary"
            CreateItem(ChooseRandomItem(5), _hero.getX(), _hero.getY())

        if msg == "-randitem"
            CreateItem(ChooseRandomItem(GetRandomInt(1, 7)), _hero.getX(), _hero.getY())

        if msg == "-gems"
            for gem in GEMS
                CreateItem(gem.itemId, _hero.getX(), _hero.getY())