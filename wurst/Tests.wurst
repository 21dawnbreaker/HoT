package Tests
import ClosureEvents

import ItemCreation
import AbilityAndBuffID


init
    EventListener.add(EVENT_PLAYER_CHAT_FILTER) ->
        let msg = GetEventPlayerChatString()
        let plyer = GetTriggerPlayer()

        if msg == "-test4"
            let u = udg_hero_by_player[plyer.getId() + 1]
            print(u.getProperName())
            CreateItem(EXCALIBUR_ITEM_ID, u.getX(), u.getY())
            CreateItem(EYE_OF_AVADRAAH_ITEM_ID, u.getX(), u.getY())
            CreateItem(GIFT_OF_LORD_OF_LIES_ITEM_ID, u.getX(), u.getY())
        if msg == "-legendary"
            let u = udg_hero_by_player[plyer.getId() + 1]
            CreateItem(ChooseRandomItem(5), u.getX(), u.getY())
        