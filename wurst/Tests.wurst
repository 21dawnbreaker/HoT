package Tests
import ClosureEvents

import ItemsCommon
import ItemsRunesAndGems
import ItemsRare
import ItemsEpic
import ItemsLegendary

import AbilityAndBuffID


init
    EventListener.add(EVENT_PLAYER_CHAT_FILTER) ->
        let msg = GetEventPlayerChatString()
        let plyer = GetTriggerPlayer()

        if msg == "-test4"
            let u = udg_hero_by_player[plyer.getId() + 1]
            print(u.getProperName())
            CreateItem(EMERALD_1_ITEM_ID, u.getX(), u.getY())
            CreateItem(SKULL_1_ITEM_ID, u.getX(), u.getY())
            CreateItem('I08S', u.getX(), u.getY())
        if msg == "-test5"
            for i = 1 to CountUnitsInGroup(udg_HeroesGroup)
                print(udg_Hero[i].getName() + " - " + udg_Karma[i].toString())
        